*.kofun text eol=lf

# Kofun source. GitHub's Linguist does not know this language yet, so these
# files currently count as nothing in the repository language statistics. See
# the Linguist submission requirements: a language needs a syntax-highlighting
# grammar and demonstrable use across many repositories before it is accepted.
*.kofun linguist-detectable=true

# The bootstrap C is compiler *output*, not hand-written source. Without these
# markers it dominates the language statistics and makes a language that emits
# machine code directly look like a C project.
bootstrap/stage1/compiler.c linguist-generated=true
bootstrap/stage2/compiler.c linguist-generated=true

# Driver scripts are plumbing, not the project's content.
bin/kofun linguist-generated=true
