#!/usr/bin/env sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
BUILD_DIR=${KOFUN_BUILD_DIR:-"$ROOT/build/bootstrap-stage1"}
SEED_C="$ROOT/bootstrap/stage1/compiler.c"
COMPILER="$BUILD_DIR/kofun-stage1"
NATIVE_BUILD_DIR=${KOFUN_NATIVE_BUILD_DIR:-"$ROOT/build/native-core"}
NATIVE_SEED_C="$ROOT/bootstrap/native/core_compiler.c"
NATIVE_COMPILER="$NATIVE_BUILD_DIR/kofun-native-core"
STAGE2_BUILD_DIR=${KOFUN_STAGE2_BUILD_DIR:-"$ROOT/build/stage2"}
STAGE2_SEED_C="$ROOT/bootstrap/stage2/compiler.c"
STAGE2_COMPILER="$STAGE2_BUILD_DIR/kofun-stage2"
C_ABI_BUILD_DIR=${KOFUN_C_ABI_BUILD_DIR:-"$ROOT/build/c-abi"}
C_ABI_SEED_C="$ROOT/bootstrap/c_abi/compiler.c"
C_ABI_COMPILER="$C_ABI_BUILD_DIR/kofun-c-abi"
CLI_BUILD_DIR=${KOFUN_CLI_BUILD_DIR:-"$ROOT/build/native-cli"}
CLI_SEED_C="$ROOT/framework/cli/compiler.c"
CLI_TEMPLATE="$ROOT/framework/cli/runtime_template.inc"
CLI_COMPILER="$CLI_BUILD_DIR/kofun-cli-compiler"
CC=${CC:-cc}

usage() {
    cat <<'EOF'
usage:
  kofun build INPUT.kofun [-o OUTPUT] [--emit-c OUTPUT.c]
              [--backend c --c-abi [--link-library FILE]...]
              [--framework cli]
              [--target x86_64-linux|aarch64-linux] [-g]
  kofun build [TARGET...] [FROST_OPTIONS]  # with ./kofun.toml
  kofun new DIRECTORY --template cli
  kofun run INPUT.kofun
  kofun check INPUT.kofun
  kofun test [PATH]
  kofun bootstrap
  kofun emit-c INPUT.kofun OUTPUT.c
  kofun --version
EOF
}

ensure_compiler() {
    mkdir -p "$BUILD_DIR"
    if [ ! -x "$COMPILER" ] || [ "$SEED_C" -nt "$COMPILER" ]; then
        "$CC" -std=c11 -O2 -Wall -Wextra -Werror \
            "$SEED_C" -lm -o "$COMPILER"
    fi
}

ensure_native_compiler() {
    mkdir -p "$NATIVE_BUILD_DIR"
    if [ ! -x "$NATIVE_COMPILER" ] ||
       [ "$NATIVE_SEED_C" -nt "$NATIVE_COMPILER" ]
    then
        "$CC" -std=c11 -O2 -Wall -Wextra -Werror \
            "$NATIVE_SEED_C" -o "$NATIVE_COMPILER"
    fi
}

ensure_stage2_compiler() {
    mkdir -p "$STAGE2_BUILD_DIR"
    if [ ! -x "$STAGE2_COMPILER" ] ||
       [ "$STAGE2_SEED_C" -nt "$STAGE2_COMPILER" ]
    then
        "$CC" -std=c11 -O2 -Wall -Wextra -Werror \
            "$STAGE2_SEED_C" -o "$STAGE2_COMPILER"
    fi
}

ensure_c_abi_compiler() {
    mkdir -p "$C_ABI_BUILD_DIR"
    if [ ! -x "$C_ABI_COMPILER" ] ||
       [ "$C_ABI_SEED_C" -nt "$C_ABI_COMPILER" ]
    then
        "$CC" -std=c11 -O2 -Wall -Wextra -Werror \
            "$C_ABI_SEED_C" -o "$C_ABI_COMPILER"
    fi
}

ensure_cli_compiler() {
    mkdir -p "$CLI_BUILD_DIR"
    if [ ! -x "$CLI_COMPILER" ] ||
       [ "$CLI_SEED_C" -nt "$CLI_COMPILER" ] ||
       [ "$CLI_TEMPLATE" -nt "$CLI_COMPILER" ]
    then
        "$CC" -std=c11 -O2 -Wall -Wextra -Werror \
            "$CLI_SEED_C" -o "$CLI_COMPILER"
    fi
}

resolve_frost() {
    if test -n "${KOFUN_FROST-}"; then
        test -x "$KOFUN_FROST" || {
            printf '%s\n' \
                "kofun: KOFUN_FROST is not executable: $KOFUN_FROST" >&2
            exit 2
        }
        printf '%s\n' "$KOFUN_FROST"
        return
    fi
    if command -v frost >/dev/null 2>&1; then
        command -v frost
        return
    fi
    printf '%s\n' \
        "kofun: kofun.toml requires the frost-build engine; set KOFUN_FROST or install frost" >&2
    exit 2
}

prepare_frost_workspace() {
    project_root=$1
    engine_root=$2
    manifest=$project_root/kofun.toml

    test ! -L "$project_root/.kofun" &&
        test ! -L "$engine_root" || {
        printf '%s\n' \
            "kofun: refusing a symlinked .kofun build directory" >&2
        exit 2
    }
    mkdir -p "$engine_root"
    if test ! -f "$engine_root/frost.toml" ||
       ! cmp -s "$manifest" "$engine_root/frost.toml"
    then
        temporary_manifest="$engine_root/frost.toml.tmp.$$"
        trap 'rm -f "$temporary_manifest"' 0 1 2 15
        cp "$manifest" "$temporary_manifest"
        mv "$temporary_manifest" "$engine_root/frost.toml"
        trap - 0 1 2 15
    fi

    for mirrored in \
        "$engine_root"/* \
        "$engine_root"/.[!.]* \
        "$engine_root"/..?*
    do
        test -e "$mirrored" || test -L "$mirrored" || continue
        name=${mirrored##*/}
        case $name in
            .|..|.frost|frost.toml) continue ;;
        esac
        if test -L "$mirrored"; then
            test -e "$mirrored" || rm -f "$mirrored"
        else
            printf '%s\n' \
                "kofun: unexpected generated workspace entry: $mirrored" >&2
            exit 2
        fi
    done

    for entry in \
        "$project_root"/* \
        "$project_root"/.[!.]* \
        "$project_root"/..?*
    do
        test -e "$entry" || test -L "$entry" || continue
        name=${entry##*/}
        case $name in
            .|..|.git|.frost|.kofun|frost.toml|kofun.toml) continue ;;
        esac
        mirrored=$engine_root/$name
        if test -L "$mirrored"; then
            test "$(readlink "$mirrored")" = "$entry" || {
                printf '%s\n' \
                    "kofun: stale project mirror: $mirrored" >&2
                exit 2
            }
        elif test -e "$mirrored"; then
            printf '%s\n' \
                "kofun: project mirror conflicts with: $mirrored" >&2
            exit 2
        else
            ln -s "$entry" "$mirrored"
        fi
    done
}

build_project() (
    project_root=$(pwd -P)
    manifest=$project_root/kofun.toml
    test -f "$manifest" || {
        printf '%s\n' \
            "kofun: project build requires ./kofun.toml" >&2
        exit 2
    }
    frost=$(resolve_frost)
    engine_root=$project_root/.kofun/frost-workspace
    prepare_frost_workspace "$project_root" "$engine_root"
    PATH="$ROOT/bin${PATH:+:$PATH}" \
        "$frost" -C "$engine_root" build "$@"
)

require_source() {
    case ${1-} in
        *.kofun) ;;
        *)
            printf '%s\n' "kofun: source must use the .kofun extension" >&2
            exit 2
            ;;
    esac
    test -f "$1" || {
        printf '%s\n' "kofun: source not found: $1" >&2
        exit 2
    }
}

emit_c() (
    require_source "$1"
    temporary="$2.tmp.$$.c"
    stage1_stdout="$2.stage1.stdout.$$"
    stage1_stderr="$2.stage1.stderr.$$"
    stage2_stdout="$2.stage2.stdout.$$"
    stage2_stderr="$2.stage2.stderr.$$"
    stage2_ir="$2.stage2.ir.$$"
    stage2_tokens="$2.stage2.tokens.$$"
    trap 'rm -f "$temporary" "$stage1_stdout" "$stage1_stderr" "$stage2_stdout" "$stage2_stderr" "$stage2_ir" "$stage2_tokens"' 0 1 2 15
    ensure_stage2_compiler
    set +e
    "$STAGE2_COMPILER" \
        "$1" "$temporary" "$stage2_ir" "$stage2_tokens" \
        >"$stage2_stdout" 2>"$stage2_stderr"
    stage2_status=$?
    set -e
    if test "$stage2_status" -ne 0; then
        rm -f "$temporary"
        ensure_compiler
        set +e
        "$COMPILER" "$1" "$temporary" \
            >"$stage1_stdout" 2>"$stage1_stderr"
        stage1_status=$?
        set -e
        if test "$stage1_status" -ne 0; then
            test ! -s "$stage2_stderr" || cat "$stage2_stderr" >&2
            test ! -s "$stage2_stdout" || cat "$stage2_stdout" >&2
            exit "$stage2_status"
        fi
    fi
    test -s "$temporary" || exit 1
    mv "$temporary" "$2"
    printf '%s\n' "$2"
)

emit_c_abi() (
    require_source "$1"
    ensure_c_abi_compiler
    temporary="$2.tmp.$$"
    trap 'rm -f "$temporary"' 0 1 2 15
    "$C_ABI_COMPILER" "$1" "$temporary"
    test -s "$temporary" || exit 1
    mv "$temporary" "$2"
)

build_file() (
    emit_c "$1" "$3" >/dev/null
    "$CC" -std=c11 -O2 -Wall -Wextra -Werror "$3" -o "$2"
)

canonical_link_library() (
    candidate=$1
    case $candidate in
        -*|*'
'*)
            printf '%s\n' \
                "kofun: --link-library must be a file path, not an option" >&2
            exit 2
            ;;
    esac
    test -f "$candidate" || {
        printf '%s\n' \
            "kofun: --link-library is not a regular file: $candidate" >&2
        exit 2
    }
    directory=$(dirname "$candidate")
    basename=$(basename "$candidate")
    canonical_directory=$(CDPATH= cd -P -- "$directory" && pwd)
    printf '%s/%s\n' "$canonical_directory" "$basename"
)

build_c_abi_file() (
    input=$1
    output=$2
    emitted=$3
    link_libraries=$4
    emit_c_abi "$input" "$emitted"
    set -f
    if test -n "$link_libraries"; then
        previous_ifs=$IFS
        IFS='
'
        set -- $link_libraries
        IFS=$previous_ifs
    else
        set --
    fi
    "$CC" -std=c11 -O2 -Wall -Wextra -Werror \
        "$emitted" "$@" -o "$output"
)

build_native_file() (
    ensure_native_compiler
    temporary="$2.tmp.$$"
    trap 'rm -f "$temporary"' 0 1 2 15
    if test "$4" = true; then
        "$NATIVE_COMPILER" "$1" "$3" -g "$temporary"
    else
        "$NATIVE_COMPILER" "$1" "$3" "$temporary"
    fi
    test -s "$temporary"
    chmod +x "$temporary"
    mv "$temporary" "$2"
)

build_cli_file() (
    ensure_cli_compiler
    temporary="$2.tmp.$$"
    trap 'rm -f "$temporary"' 0 1 2 15
    "$CLI_COMPILER" "$1" "$temporary"
    test -s "$temporary"
    chmod +x "$temporary"
    mv "$temporary" "$2"
)

new_cli_project() (
    project=$1
    case $project in
        ''|-*|*[!A-Za-z0-9_./-]*)
            printf '%s\n' \
                "kofun: CLI project path contains unsupported characters: $project" >&2
            exit 2
            ;;
    esac
    test ! -e "$project" && test ! -L "$project" || {
        printf '%s\n' "kofun: project path already exists: $project" >&2
        exit 2
    }
    project_name=${project##*/}
    case $project_name in
        ''|[!A-Za-z]*|*[!A-Za-z0-9_-]*)
            printf '%s\n' \
                "kofun: CLI project name must start with a letter and use letters, digits, '_' or '-'" >&2
            exit 2
            ;;
    esac
    type_name=$(printf '%s' "$project_name" | tr '-' '_')
    mkdir -p "$project/src"
    cat >"$project/src/main.kofun" <<EOF
cli $type_name {
    name "$project_name"
    version "0.1.0"
    about "A native Kofun CLI application"

    command greet {
        about "Greet a person"
        position NAME "Person to greet"
        option shout "--shout" bool "Uppercase the greeting"
        option prefix "--prefix" text "Greeting prefix" default "Hello"
        action greet
    }

    command status {
        about "Render a terminal-aware progress status"
        position LABEL "Status label"
        action status
    }
}
EOF
    cat >"$project/README.md" <<EOF
# $project_name

Build the Linux x86-64 static executable:

\`\`\`sh
kofun build src/main.kofun --framework cli -o build/$project_name
./build/$project_name --help
\`\`\`
EOF
    printf '%s\n' "$project"
)

case ${1-} in
    --version|-V|version)
        printf '%s\n' "Kofun Stage 1 0.3.0-seed"
        ;;
    bootstrap)
        test "$#" -eq 1 || { usage >&2; exit 2; }
        exec sh "$ROOT/bootstrap/stage1/check.sh"
        ;;
    new)
        test "$#" -eq 4 &&
            test "$3" = --template &&
            test "$4" = cli || {
            usage >&2
            exit 2
        }
        new_cli_project "$2"
        ;;
    emit-c)
        test "$#" -eq 3 || { usage >&2; exit 2; }
        emit_c "$2" "$3"
        ;;
    check)
        test "$#" -eq 2 || { usage >&2; exit 2; }
        require_source "$2"
        work=$(mktemp -d "${TMPDIR:-/tmp}/kofun-check.XXXXXX")
        trap 'rm -rf "$work"' 0 1 2 15
        set +e
        emit_c "$2" "$work/output.c" \
            >"$work/stage1.stdout" 2>"$work/stage1.stderr"
        stage1_status=$?
        set -e
        if test "$stage1_status" -eq 0; then
            printf '%s\n' "ok: $2"
            exit 0
        fi
        ensure_stage2_compiler
        set +e
        "$STAGE2_COMPILER" --check-ownership "$2" \
            >"$work/stage2.stdout" 2>"$work/stage2.stderr"
        stage2_status=$?
        set -e
        if test "$stage2_status" -ne 0; then
            if grep -q 'error\[E2S20\]' "$work/stage2.stdout"; then
                test ! -s "$work/stage1.stderr" ||
                    cat "$work/stage1.stderr" >&2
                test ! -s "$work/stage1.stdout" ||
                    cat "$work/stage1.stdout"
                exit "$stage1_status"
            fi
            test ! -s "$work/stage2.stderr" ||
                cat "$work/stage2.stderr" >&2
            test ! -s "$work/stage2.stdout" ||
                cat "$work/stage2.stdout" >&2
            exit "$stage2_status"
        fi
        printf '%s\n' \
            "ok: $2 (Stage 2 Copy/borrow ownership slice; codegen unavailable)"
        ;;
    build)
        shift
        case ${1-} in
            *.kofun) ;;
            *)
                if test -f ./kofun.toml; then
                    build_project "$@"
                    exit $?
                fi
                test "$#" -gt 0 || {
                    printf '%s\n' \
                        "kofun: build needs INPUT.kofun or ./kofun.toml" >&2
                    exit 2
                }
                ;;
        esac
        input=${1-}
        test "$#" -gt 0 && shift
        require_source "$input"
        output=${input%.kofun}
        emitted=
        backend=
        c_abi=false
        framework=
        link_libraries=
        target=
        debug=false
        while test "$#" -gt 0; do
            case "$1" in
                -o|--output)
                    test "$#" -ge 2 || { usage >&2; exit 2; }
                    output=$2
                    shift 2
                    ;;
                --emit-c)
                    test "$#" -ge 2 || { usage >&2; exit 2; }
                    emitted=$2
                    shift 2
                    ;;
                --backend)
                    test "$#" -ge 2 && test "$2" = c || {
                        printf '%s\n' "kofun: Stage 1 exposes only the C11 bootstrap backend" >&2
                        exit 2
                    }
                    backend=c
                    shift 2
                    ;;
                --c-abi)
                    c_abi=true
                    shift
                    ;;
                --framework)
                    test "$#" -ge 2 && test "$2" = cli || {
                        printf '%s\n' \
                            "kofun: supported application framework is cli" >&2
                        exit 2
                    }
                    framework=cli
                    shift 2
                    ;;
                --link-library)
                    test "$#" -ge 2 || { usage >&2; exit 2; }
                    link_library=$(canonical_link_library "$2")
                    if test -z "$link_libraries"; then
                        link_libraries=$link_library
                    else
                        link_libraries="$link_libraries
$link_library"
                    fi
                    shift 2
                    ;;
                --link-library=*)
                    printf '%s\n' \
                        "kofun: pass --link-library and its file path separately" >&2
                    exit 2
                    ;;
                --target)
                    test "$#" -ge 2 || { usage >&2; exit 2; }
                    target=$2
                    shift 2
                    ;;
                -g)
                    debug=true
                    shift
                    ;;
                *)
                    printf '%s\n' "kofun: unknown build option: $1" >&2
                    exit 2
                    ;;
            esac
        done
        if "$c_abi"; then
            test "$backend" = c || {
                printf '%s\n' \
                    "kofun: --c-abi requires explicit --backend c" >&2
                exit 2
            }
        elif test -n "$link_libraries"; then
            printf '%s\n' \
                "kofun: --link-library requires --backend c --c-abi" >&2
            exit 2
        fi
        if test -n "$framework"; then
            test -z "$backend" &&
                test -z "$target" &&
                test -z "$emitted" &&
                test "$debug" = false || {
                printf '%s\n' \
                    "kofun: --framework cli cannot be combined with backend, target, emit-c, or debug options" >&2
                exit 2
            }
            mkdir -p "$(dirname "$output")"
            build_cli_file "$input" "$output"
            printf '%s\n' "$output"
            exit 0
        fi
        if test -n "$target"; then
            test -z "$emitted" || {
                printf '%s\n' \
                    "kofun: --emit-c cannot be combined with --target" >&2
                exit 2
            }
            test -z "$backend" || {
                printf '%s\n' \
                    "kofun: --backend c cannot be combined with --target" >&2
                exit 2
            }
            if "$debug" && test "$target" != x86_64-linux; then
                printf '%s\n' \
                    "kofun: -g currently requires --target x86_64-linux" >&2
                exit 2
            fi
            mkdir -p "$(dirname "$output")"
            build_native_file "$input" "$output" "$target" "$debug"
            printf '%s\n' "$output"
            exit 0
        fi
        if "$debug"; then
            printf '%s\n' "kofun: -g requires --target x86_64-linux" >&2
            exit 2
        fi
        if test -z "$emitted"; then
            emitted="$BUILD_DIR/$(basename "${input%.kofun}").c"
        fi
        mkdir -p "$(dirname "$output")" "$(dirname "$emitted")"
        if "$c_abi"; then
            build_c_abi_file \
                "$input" "$output" "$emitted" "$link_libraries"
        else
            build_file "$input" "$output" "$emitted"
        fi
        printf '%s\n' "$output"
        ;;
    run)
        test "$#" -eq 2 || { usage >&2; exit 2; }
        require_source "$2"
        work=$(mktemp -d "${TMPDIR:-/tmp}/kofun-run.XXXXXX")
        trap 'rm -rf "$work"' 0 1 2 15
        build_file "$2" "$work/program" "$work/program.c"
        "$work/program"
        ;;
    test)
        test "$#" -le 2 || { usage >&2; exit 2; }
        root=${2-"$ROOT/bootstrap/fixtures"}
        if test -d "$root" &&
           test -f "$root/expectations.kofun" &&
           test -f "$ROOT/tests/conformance/run.sh"
        then
            exec sh "$ROOT/tests/conformance/run.sh" "$root"
        fi
        ensure_compiler
        work=$(mktemp -d "${TMPDIR:-/tmp}/kofun-test.XXXXXX")
        trap 'rm -rf "$work"' 0 1 2 15
        passed=0
        skipped=0
        failed=0
        if test -f "$root"; then
            files=$root
        else
            files=$(find "$root" -type f -name '*.kofun' \
                ! -name 'expectations.kofun' -print | LC_ALL=C sort)
        fi
        for source in $files; do
            stem=$(basename "${source%.kofun}")
            c_file="$work/$stem.c"
            binary="$work/$stem"
            if ! emit_c "$source" "$c_file" >/dev/null 2>&1; then
                printf '%s\n' "SKIP $source (outside Stage 1 Core)"
                skipped=$((skipped + 1))
                continue
            fi
            if ! "$CC" -std=c11 -O2 -Wall -Wextra -Werror "$c_file" -o "$binary"; then
                printf '%s\n' "FAIL $source"
                failed=$((failed + 1))
                continue
            fi
            set +e
            "$binary" >"$work/$stem.stdout" 2>"$work/$stem.stderr"
            status=$?
            set -e
            actual_stdout=$(cat "$work/$stem.stdout")
            actual_stderr=$(cat "$work/$stem.stderr")
            expected_status=$(sed -n 's/^# expect-exit: //p' "$source" | sed -n '1p')
            expected_stdout=$(sed -n \
                -e 's/^# expect: //p' \
                -e 's/^# expect-stdout: //p' "$source")
            expected_stderr=$(sed -n 's/^# expect-stderr: //p' "$source")
            if test -z "$expected_status"; then
                expected_status=0
            fi
            if test "$status" -ne "$expected_status"; then
                printf '%s\n' "FAIL $source (expected exit $expected_status, got $status)"
                failed=$((failed + 1))
                continue
            fi
            if test -n "$expected_stdout" && test "$actual_stdout" != "$expected_stdout"; then
                printf '%s\n' "FAIL $source (stdout mismatch)"
                failed=$((failed + 1))
                continue
            fi
            if test -n "$expected_stderr" && test "$actual_stderr" != "$expected_stderr"; then
                printf '%s\n' "FAIL $source (stderr mismatch)"
                failed=$((failed + 1))
                continue
            fi
            printf '%s\n' "PASS $source"
            passed=$((passed + 1))
        done
        total=$((passed + failed + skipped))
        executed=$((passed + failed))
        printf '%s\n' \
            "$passed passed; $failed failed; $skipped explicitly skipped" \
            "coverage: $executed/$total cases executed by Stage 1"
        test "$passed" -gt 0
        test "$failed" -eq 0
        ;;
    ""|-h|--help|help)
        usage
        ;;
    *)
        printf '%s\n' "kofun: unknown command: ${1-}" >&2
        usage >&2
        exit 2
        ;;
esac
