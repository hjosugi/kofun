{
  "grammars": [
    {
      "name": "kofun",
      "camelcase": "Kofun",
      "scope": "source.kofun",
      "path": ".",
      "file-types": [
        "kofun"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "locals": [
        "queries/locals.scm"
      ],
      "injection-regex": "^kofun$",
      "external-files": [
        "src/scanner.c"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT OR Apache-2.0",
    "description": "Kofun grammar for Tree-sitter",
    "authors": [
      {
        "name": "Kofun contributors"
      }
    ],
    "links": {
      "repository": "https://github.com/hjosugi/kofun"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
