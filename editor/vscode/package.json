{
  "name": "cofn-language-bootstrap",
  "displayName": "Cofn Language Bootstrap",
  "description": "Basic syntax highlighting and bracket support for the Cofn bootstrap language.",
  "version": "0.2.0",
  "publisher": "cofn-language-project",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "cofn",
        "aliases": ["Cofn", "cofn"],
        "extensions": [".cofn"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cofn",
        "scopeName": "source.cofn",
        "path": "./syntaxes/cofn.tmLanguage.json"
      }
    ]
  }
}
