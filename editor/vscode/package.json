{
  "name": "kofun-language-bootstrap",
  "displayName": "Kofun Language Bootstrap",
  "description": "Basic syntax highlighting and bracket support for the Kofun bootstrap language.",
  "version": "0.2.0",
  "publisher": "kofun-language-project",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kofun",
        "aliases": ["Kofun", "kofun"],
        "extensions": [".kf"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kofun",
        "scopeName": "source.kf",
        "path": "./syntaxes/kofun.tmLanguage.json"
      }
    ]
  }
}
