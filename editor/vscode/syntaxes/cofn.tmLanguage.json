{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Cofn",
  "scopeName": "source.cofn",
  "patterns": [
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#numbers"},
    {"include": "#keywords"},
    {"include": "#types"},
    {"include": "#functions"},
    {"include": "#operators"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {"name": "comment.line.number-sign.cofn", "match": "#.*$"}
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cofn",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {"name": "constant.character.escape.cofn", "match": "\\\\(?:[nrt\\\"\\\\]|u\\{[0-9A-Fa-f]+\\})"}
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {"name": "constant.numeric.float.cofn", "match": "\\b(?:[0-9][0-9_]*\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?|[0-9][0-9_]*[eE][+-]?[0-9_]+)\\b"},
        {"name": "constant.numeric.integer.cofn", "match": "\\b(?:0[xX][0-9A-Fa-f_]+|0[bB][01_]+|[0-9][0-9_]*)\\b"}
      ]
    },
    "keywords": {
      "patterns": [
        {"name": "keyword.control.cofn", "match": "\\b(?:if|else|for|while|in|return|break|continue)\\b"},
        {"name": "storage.type.function.cofn", "match": "\\b(?:fn|meta|law|monad)\\b"},
        {"name": "storage.modifier.cofn", "match": "\\b(?:let|mut|own|read|edit|take)\\b"},
        {"name": "constant.language.cofn", "match": "\\b(?:true|false|null)\\b"}
      ]
    },
    "types": {
      "patterns": [
        {"name": "support.type.cofn", "match": "\\b(?:Int|Float|Bool|Text|Void|Any|Resource|List|Tuple)\\b"},
        {"name": "entity.name.type.cofn", "match": "\\b[A-Z][A-Za-z0-9_]*\\b"}
      ]
    },
    "functions": {
      "patterns": [
        {"name": "entity.name.function.cofn", "match": "(?<=\\bfn\\s)[\\p{L}_][\\p{L}\\p{N}_]*"}
      ]
    },
    "operators": {
      "patterns": [
        {"name": "keyword.operator.cofn", "match": "\\|>|\\?\\?|//|\\*\\*|==|!=|<=|>=|&&|\\|\\||->|=>|\\.\\.|[-+*/%<>=!?]"}
      ]
    }
  }
}
