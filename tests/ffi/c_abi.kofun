# expect-stdout: hello from Kofun C ABI
# expect-stdout: 42
# expect-stdout: 36
# expect-stdout: 41
# expect-stdout: 2
# expect-stdout: 3

repr(C) struct Pair {
    left: I64,
    right: I64,
    tag: I64,
}

extern "C" fn puts(message: CStr) -> CInt
extern "C" fn rust_add(left: CInt, right: CInt) -> CInt
extern "C" fn rust_stack_sum(
    one: CLong,
    two: CLong,
    three: CLong,
    four: CLong,
    five: CLong,
    six: CLong,
    seven: CLong,
    eight: CLong,
) -> CLong
extern "C" fn rust_transform(value: Pair) -> Pair

fn main() {
    puts("hello from Kofun C ABI")
    let answer = rust_add(20, 22)
    let stack_answer = rust_stack_sum(1, 2, 3, 4, 5, 6, 7, 8)
    let transformed = rust_transform(Pair(40, 0, 0))
    print(answer)
    print(stack_answer)
    print(transformed.left)
    print(transformed.right)
    print(transformed.tag)
}
