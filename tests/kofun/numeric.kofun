# expect: numeric ok
fn main() {
    assert_eq(7 // 2, 3)
    assert_eq(-7 // 2, -4)
    assert_eq(7 % 2, 1)
    assert_eq(-7 % 2, 1)
    assert_eq(2 + 3 * 4 - 6, 8)
    assert_eq(abs(-42), 42)
    assert_eq(min([4, 2, 8]), 2)
    assert_eq(max([4, 2, 8]), 8)
    assert_eq(7 / 2, 3.5)
    print("numeric ok")
}
