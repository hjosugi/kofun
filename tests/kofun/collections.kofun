# expect: collections ok
fn main() {
    let values = [3, 1, 4, 1, 5]
    assert_eq(len(values), 5)
    assert_eq(sum(values), 14)
    assert_eq(sort(values), [1, 1, 3, 4, 5])
    assert_eq(reverse(values), [5, 1, 4, 1, 3])
    assert_eq(map(values, fn(value: Int) => value * 2), [6, 2, 8, 2, 10])
    assert_eq(filter(values, fn(value: Int) => value > 3), [4, 5])
    assert_eq(fold(values, 0, fn(total: Int, value: Int) => total + value), 14)
    assert_eq(concat([1, 2], [3, 4]), [1, 2, 3, 4])
    assert_eq(push([1, 2], 3), [1, 2, 3])
    assert(contains(values, 4))
    print("collections ok")
}
