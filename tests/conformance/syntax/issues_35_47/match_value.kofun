fn probe(value: Int) -> Int {
    print(value)
    return value
}

fn choose(value: Int) -> Int {
    return match value > 0 {
        true if value == 1 => {
            if true {
                match false {
                    true => {
                        99
                    },
                    false => {
                        40 + 2
                    },
                }
            } else {
                1 // 0
            }
        },
        true => {
            43
        },
        false => {
            -1
        },
    }
}

fn main() -> Int {
    let selected: Int = match probe(1) == 1 {
        false if 1 // 0 == 0 => {
            90
        },
        true if probe(2) == 0 => {
            91
        },
        true if probe(3) == 3 => {
            choose(1)
        },
        true => {
            1 // 0
        },
        false => {
            1 // 0
        },
    }
    print(selected)
    print(match false {
        true => {
            1 // 0
        },
        _ => {
            7
        },
    })
    let mut replacement: Int = 0
    replacement = match 2 < 3 {
        true => {
            9
        },
        false => {
            1 // 0
        },
    }
    print(replacement)
    return 0
}
