# Executable Int-Core projection of stdlib/regex/regex.kofun.
# Pattern codes: 3 `.`, 4 `*`, 5 `^`, 6 `$`; other digits are literals.
# Inputs contain literal digits only. A successful span is encoded as
# (start + 1) * 1000 + (end + 1); zero means no match and negative values are
# validation errors.

fn pow10(exponent: Int) -> Int {
    if exponent == 0 { return 1 }
    return 10 * pow10(exponent - 1)
}

fn quotient(value: Int, divisor: Int) -> Int {
    if value >= divisor * 1000 {
        return 1000 + quotient(value - divisor * 1000, divisor)
    }
    if value >= divisor * 100 {
        return 100 + quotient(value - divisor * 100, divisor)
    }
    if value >= divisor * 10 {
        return 10 + quotient(value - divisor * 10, divisor)
    }
    if value < divisor { return 0 }
    return 1 + quotient(value - divisor, divisor)
}

fn remainder(value: Int, divisor: Int) -> Int {
    if value >= divisor * 1000 {
        return remainder(value - divisor * 1000, divisor)
    }
    if value >= divisor * 100 {
        return remainder(value - divisor * 100, divisor)
    }
    if value >= divisor * 10 {
        return remainder(value - divisor * 10, divisor)
    }
    if value < divisor { return value }
    return remainder(value - divisor, divisor)
}

fn symbol_at(source: Int, length: Int, index: Int) -> Int {
    return remainder(
        quotient(source, pow10(length - index - 1)),
        10
    )
}

fn validate(pattern: Int, length: Int, index: Int) -> Int {
    if index == length { return 0 }
    if symbol_at(pattern, length, index) == 4 {
        return validate_star(pattern, length, index)
    }
    if symbol_at(pattern, length, index) == 5 {
        return validate_start(pattern, length, index)
    }
    if symbol_at(pattern, length, index) == 6 {
        return validate_end(pattern, length, index)
    }
    return validate(pattern, length, index + 1)
}

fn validate_star(pattern: Int, length: Int, index: Int) -> Int {
    if index == 0 { return 1 }
    if symbol_at(pattern, length, index - 1) == 4 { return 2 }
    if symbol_at(pattern, length, index - 1) == 5 { return 1 }
    if symbol_at(pattern, length, index - 1) == 6 { return 1 }
    return validate(pattern, length, index + 1)
}

fn validate_start(pattern: Int, length: Int, index: Int) -> Int {
    if index != 0 { return 3 }
    return validate(pattern, length, index + 1)
}

fn validate_end(pattern: Int, length: Int, index: Int) -> Int {
    if index + 1 != length { return 4 }
    return validate(pattern, length, index + 1)
}

fn atom_matches(pattern_symbol: Int, input_symbol: Int) -> Int {
    if pattern_symbol == 3 { return 1 }
    if pattern_symbol == input_symbol { return 1 }
    return 0
}

# Returns end + 1, reserving zero for failure. Staying on the same pattern atom
# after consuming one input symbol implements greedy `*` without mutual
# recursion.
fn match_here_end(
    pattern: Int,
    pattern_length: Int,
    pattern_index: Int,
    input: Int,
    input_length: Int,
    input_index: Int
) -> Int {
    if pattern_index == pattern_length { return input_index + 1 }
    if symbol_at(pattern, pattern_length, pattern_index) == 6 {
        return match_end_anchor(
            pattern_length, pattern_index, input_length, input_index
        )
    }
    if pattern_index + 1 < pattern_length {
        return match_piece_with_next(
            pattern,
            pattern_length,
            pattern_index,
            input,
            input_length,
            input_index
        )
    }
    return match_one(
        pattern,
        pattern_length,
        pattern_index,
        input,
        input_length,
        input_index
    )
}

fn match_end_anchor(
    pattern_length: Int,
    pattern_index: Int,
    input_length: Int,
    input_index: Int
) -> Int {
    if pattern_index + 1 != pattern_length { return 0 }
    if input_index == input_length { return input_index + 1 }
    return 0
}

fn match_piece_with_next(
    pattern: Int,
    pattern_length: Int,
    pattern_index: Int,
    input: Int,
    input_length: Int,
    input_index: Int
) -> Int {
    if symbol_at(pattern, pattern_length, pattern_index + 1) == 4 {
        return match_star(
            pattern,
            pattern_length,
            pattern_index,
            input,
            input_length,
            input_index
        )
    }
    return match_one(
        pattern,
        pattern_length,
        pattern_index,
        input,
        input_length,
        input_index
    )
}

fn match_star(
    pattern: Int,
    pattern_length: Int,
    pattern_index: Int,
    input: Int,
    input_length: Int,
    input_index: Int
) -> Int {
    if input_index == input_length {
        return match_here_end(
            pattern,
            pattern_length,
            pattern_index + 2,
            input,
            input_length,
            input_index
        )
    }
    if atom_matches(
        symbol_at(pattern, pattern_length, pattern_index),
        symbol_at(input, input_length, input_index)
    ) == 0 {
        return match_here_end(
            pattern,
            pattern_length,
            pattern_index + 2,
            input,
            input_length,
            input_index
        )
    }
    if match_here_end(
        pattern,
        pattern_length,
        pattern_index,
        input,
        input_length,
        input_index + 1
    ) != 0 {
        return match_here_end(
            pattern,
            pattern_length,
            pattern_index,
            input,
            input_length,
            input_index + 1
        )
    }
    return match_here_end(
        pattern,
        pattern_length,
        pattern_index + 2,
        input,
        input_length,
        input_index
    )
}

fn match_one(
    pattern: Int,
    pattern_length: Int,
    pattern_index: Int,
    input: Int,
    input_length: Int,
    input_index: Int
) -> Int {
    if input_index == input_length { return 0 }
    if atom_matches(
        symbol_at(pattern, pattern_length, pattern_index),
        symbol_at(input, input_length, input_index)
    ) == 0 {
        return 0
    }
    return match_here_end(
        pattern,
        pattern_length,
        pattern_index + 1,
        input,
        input_length,
        input_index + 1
    )
}

fn search_from(
    pattern: Int,
    pattern_length: Int,
    input: Int,
    input_length: Int,
    start: Int
) -> Int {
    if start > input_length { return 0 }
    if match_here_end(
        pattern, pattern_length, 0, input, input_length, start
    ) != 0 {
        return (start + 1) * 1000 + match_here_end(
            pattern, pattern_length, 0, input, input_length, start
        )
    }
    return search_from(pattern, pattern_length, input, input_length, start + 1)
}

fn find_span(pattern: Int, pattern_length: Int, input: Int, input_length: Int) -> Int {
    if validate(pattern, pattern_length, 0) != 0 {
        return 0 - validate(pattern, pattern_length, 0)
    }
    if pattern_length > 0 {
        return find_nonempty(pattern, pattern_length, input, input_length)
    }
    return search_from(pattern, pattern_length, input, input_length, 0)
}

fn find_nonempty(
    pattern: Int,
    pattern_length: Int,
    input: Int,
    input_length: Int
) -> Int {
    if symbol_at(pattern, pattern_length, 0) == 5 {
        return find_anchored(pattern, pattern_length, input, input_length)
    }
    return search_from(pattern, pattern_length, input, input_length, 0)
}

fn find_anchored(
    pattern: Int,
    pattern_length: Int,
    input: Int,
    input_length: Int
) -> Int {
    if match_here_end(
        pattern, pattern_length, 1, input, input_length, 0
    ) == 0 { return 0 }
    return 1000 + match_here_end(
        pattern, pattern_length, 1, input, input_length, 0
    )
}

fn is_match(pattern: Int, pattern_length: Int, input: Int, input_length: Int) -> Int {
    if find_span(pattern, pattern_length, input, input_length) > 0 { return 1 }
    return 0
}

fn main() {
    print(is_match(12, 2, 12, 2))
    print(is_match(12, 2, 11, 2))
    print(is_match(132, 3, 172, 3))
    print(is_match(142, 3, 1112, 4))
    print(is_match(142, 3, 2, 1))
    print(is_match(12, 2, 7127, 4))
    print(is_match(512, 3, 712, 3))
    print(is_match(126, 3, 712, 3))
    print(is_match(5126, 4, 12, 2))
    print(is_match(14, 2, 0, 0))

    print(find_span(12, 2, 7127, 4))
    print(find_span(14, 2, 1112, 4))

    print(find_span(412, 3, 12, 2))
    print(find_span(144, 3, 1, 1))
    print(find_span(152, 3, 12, 2))
    print(find_span(162, 3, 12, 2))
}
