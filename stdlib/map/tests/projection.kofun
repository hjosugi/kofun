# Executable Map semantics over fixture keys 1, 3, and 5.
# Presence and value travel as separate Int scalars, so stored zero remains
# distinct from absence. This is not IntMap's public representation or domain.

fn map_projection_contains(
    has1: Int,
    has3: Int,
    has5: Int,
    key: Int
) -> Int {
    if key == 1 { return has1 }
    if key == 3 { return has3 }
    if key == 5 { return has5 }
    return 0
}

# Outcomes: 0 = value, 1 = MapKeyMissing.
fn map_projection_get_outcome(
    has1: Int,
    has3: Int,
    has5: Int,
    key: Int
) -> Int {
    if map_projection_contains(has1, has3, has5, key) == 1 { return 0 }
    return 1
}

# The caller uses this only after map_projection_get_outcome returns value.
fn map_projection_get_value(
    value1: Int,
    value3: Int,
    value5: Int,
    key: Int
) -> Int {
    if key == 1 { return value1 }
    if key == 3 { return value3 }
    if key == 5 { return value5 }
    return 0
}

fn map_projection_insert_contains(
    current: Int,
    key: Int,
    inserted_key: Int
) -> Int {
    if key == inserted_key { return 1 }
    return current
}

fn map_projection_insert_value(
    current: Int,
    key: Int,
    inserted_key: Int,
    inserted_value: Int
) -> Int {
    if key == inserted_key { return inserted_value }
    return current
}

fn map_projection_remove_contains(
    current: Int,
    key: Int,
    removed_key: Int
) -> Int {
    if key == removed_key { return 0 }
    return current
}

fn map_projection_length(has1: Int, has3: Int, has5: Int) -> Int {
    return has1 + has3 + has5
}

fn map_projection_length_after_insert(
    has1: Int,
    has3: Int,
    has5: Int,
    inserted_key: Int
) -> Int {
    return map_projection_length(
        map_projection_insert_contains(has1, 1, inserted_key),
        map_projection_insert_contains(has3, 3, inserted_key),
        map_projection_insert_contains(has5, 5, inserted_key)
    )
}

fn map_projection_length_after_remove(
    has1: Int,
    has3: Int,
    has5: Int,
    removed_key: Int
) -> Int {
    return map_projection_length(
        map_projection_remove_contains(has1, 1, removed_key),
        map_projection_remove_contains(has3, 3, removed_key),
        map_projection_remove_contains(has5, 5, removed_key)
    )
}

fn map_projection_fold_5(has5: Int, value5: Int, output: Int) -> Int {
    if has5 == 0 { return output }
    return output * 100 + 50 + value5
}

fn map_projection_fold_3(
    has3: Int,
    value3: Int,
    has5: Int,
    value5: Int,
    output: Int
) -> Int {
    if has3 == 0 { return map_projection_fold_5(has5, value5, output) }
    return map_projection_fold_5(
        has5,
        value5,
        output * 100 + 30 + value3
    )
}

# Entry pairs are appended in ascending key order: 1, then 3, then 5.
fn map_projection_fold_entries(
    has1: Int,
    value1: Int,
    has3: Int,
    value3: Int,
    has5: Int,
    value5: Int
) -> Int {
    if has1 == 0 {
        return map_projection_fold_3(has3, value3, has5, value5, 0)
    }
    return map_projection_fold_3(
        has3,
        value3,
        has5,
        value5,
        10 + value1
    )
}

fn map_projection_filter_presence_min4(present: Int, value: Int) -> Int {
    if present == 0 { return 0 }
    if value < 4 { return 0 }
    return 1
}

fn map_projection_filter_fold_min4(
    has1: Int,
    value1: Int,
    has3: Int,
    value3: Int,
    has5: Int,
    value5: Int
) -> Int {
    return map_projection_fold_entries(
        map_projection_filter_presence_min4(has1, value1),
        value1,
        map_projection_filter_presence_min4(has3, value3),
        value3,
        map_projection_filter_presence_min4(has5, value5),
        value5
    )
}

fn map_projection_increment_fold(
    has1: Int,
    value1: Int,
    has3: Int,
    value3: Int,
    has5: Int,
    value5: Int
) -> Int {
    return map_projection_fold_entries(
        has1,
        value1 + 1,
        has3,
        value3 + 1,
        has5,
        value5 + 1
    )
}

fn main() {
    print(map_projection_contains(1, 1, 1, 3))
    print(map_projection_get_outcome(1, 1, 1, 3))
    print(map_projection_get_value(2, 4, 6, 3))
    print(map_projection_get_outcome(1, 1, 1, 4))
    print(map_projection_insert_value(4, 3, 3, 8))
    print(map_projection_length_after_insert(1, 0, 1, 3))
    print(map_projection_length_after_remove(1, 1, 1, 3))
    print(map_projection_length_after_remove(1, 1, 1, 4))
    print(map_projection_fold_entries(1, 2, 1, 4, 1, 6))
    print(map_projection_filter_fold_min4(1, 2, 1, 4, 1, 6))
    print(map_projection_increment_fold(1, 2, 1, 4, 1, 6))
    print(map_projection_fold_entries(1, 2, 1, 4, 1, 6))
}
