# Canonical Kofun implementation of the first direct native image writer.
#
# This module deliberately emits bytes, not assembly text and not C. The first
# target is a static Linux x86-64 ET_EXEC image with one RX load segment and one
# zero-filled RW load segment.

fn u16_le(value: Int) -> List[Int] {
    return [
        value % 256,
        (value // 256) % 256,
    ]
}

fn u32_le(value: Int) -> List[Int] {
    return [
        value % 256,
        (value // 256) % 256,
        (value // 65536) % 256,
        (value // 16777216) % 256,
    ]
}

fn u64_le(value: Int) -> List[Int] {
    return [
        value % 256,
        (value // 256) % 256,
        (value // 65536) % 256,
        (value // 16777216) % 256,
        (value // 4294967296) % 256,
        (value // 1099511627776) % 256,
        (value // 281474976710656) % 256,
        (value // 72057594037927936) % 256,
    ]
}

fn patch_u32_le(
    image: List[Int],
    field_offset: Int,
    value: Int,
) -> List[Int] {
    # Rebuilding the list makes fixup application deterministic and keeps the
    # canonical encoder independent of mutable byte-buffer semantics.
    if field_offset < 0 || field_offset + 4 > len(image) {
        return []
    }
    let encoded = u32_le(value)
    let mut patched = []
    for index in 0 .. len(image) {
        if index >= field_offset && index < field_offset + 4 {
            patched = concat(patched, [encoded[index - field_offset]])
        } else {
            patched = concat(patched, [image[index]])
        }
    }
    return patched
}

fn resolve_abs32_fixup(
    image: List[Int],
    field_offset: Int,
    image_base: Int,
    label_offset: Int,
    addend: Int,
) -> List[Int] {
    let resolved = image_base + label_offset + addend
    if resolved < 0 || resolved > 4294967295 {
        return []
    }
    return patch_u32_le(
        image,
        field_offset,
        resolved,
    )
}

fn resolve_rel32_fixup(
    image: List[Int],
    field_offset: Int,
    instruction_end: Int,
    label_offset: Int,
) -> List[Int] {
    let displacement = label_offset - instruction_end
    if displacement < -2147483648 || displacement > 2147483647 {
        return []
    }
    return patch_u32_le(
        image,
        field_offset,
        displacement,
    )
}

fn label_offset(
    label_ids: List[Int],
    label_offsets: List[Int],
    wanted: Int,
) -> Int {
    if len(label_ids) != len(label_offsets) {
        return -1
    }

    let mut found = -1
    for index in 0 .. len(label_ids) {
        if label_ids[index] == wanted {
            # Duplicate labels are invalid; traversal order must not choose.
            if found >= 0 {
                return -1
            }
            found = label_offsets[index]
        }
    }
    return found
}

fn resolve_rel32_fixups(
    code: List[Int],
    label_ids: List[Int],
    label_offsets: List[Int],
    fixup_offsets: List[Int],
    instruction_ends: List[Int],
    fixup_label_ids: List[Int],
) -> List[Int] {
    if len(label_ids) != len(label_offsets) ||
       len(fixup_offsets) != len(instruction_ends) ||
       len(fixup_offsets) != len(fixup_label_ids) {
        return []
    }

    let mut linked = code
    for index in 0 .. len(fixup_offsets) {
        let target = label_offset(
            label_ids,
            label_offsets,
            fixup_label_ids[index],
        )
        if target < 0 {
            return []
        }
        linked = resolve_rel32_fixup(
            linked,
            fixup_offsets[index],
            instruction_ends[index],
            target,
        )
        if len(linked) == 0 {
            return []
        }
    }
    return linked
}

fn pad_to(image: List[Int], size: Int) -> List[Int] {
    let mut padded = image
    while len(padded) < size {
        padded = concat(padded, [0])
    }
    return padded
}

fn elf_ident() -> List[Int] {
    return [
        127, 69, 76, 70, # ELF magic
        2,                # ELFCLASS64
        1,                # ELFDATA2LSB
        1,                # EV_CURRENT
        0,                # System V ABI
        0,                # ABI version
        0, 0, 0, 0, 0, 0, 0,
    ]
}

fn x64_mov_r32_imm32(opcode: Int, value: Int) -> List[Int] {
    # B8+rd id encodes mov r32, imm32 for the eight legacy registers.
    if opcode < 184 || opcode > 191 || value < 0 || value > 4294967295 {
        return []
    }
    return concat([opcode], u32_le(value))
}

fn x64_mov_eax_imm32(value: Int) -> List[Int] {
    return x64_mov_r32_imm32(184, value)
}

fn x64_mov_ecx_imm32(value: Int) -> List[Int] {
    return x64_mov_r32_imm32(185, value)
}

fn x64_mov_edi_imm32(value: Int) -> List[Int] {
    return x64_mov_r32_imm32(191, value)
}

fn x64_mov_esi_imm32(value: Int) -> List[Int] {
    return x64_mov_r32_imm32(190, value)
}

fn x64_mov_edx_imm32(value: Int) -> List[Int] {
    return x64_mov_r32_imm32(186, value)
}

fn x64_syscall() -> List[Int] {
    return [15, 5]
}

fn x64_add_eax_imm8(value: Int) -> List[Int] {
    if value < 0 || value > 127 {
        return []
    }
    return [131, 192, value]
}

fn x64_xor_edx_edx() -> List[Int] {
    return [49, 210]
}

fn x64_div_ecx() -> List[Int] {
    return [247, 241]
}

fn x64_add_al_imm8(value: Int) -> List[Int] {
    if value < 0 || value > 255 {
        return []
    }
    return [4, value]
}

fn x64_add_dl_imm8(value: Int) -> List[Int] {
    if value < 0 || value > 255 {
        return []
    }
    return [128, 194, value]
}

fn x64_store_al_abs32_placeholder() -> List[Int] {
    # 88 /r with SIB base=5 carries a zero placeholder for an absolute disp32.
    return [136, 4, 37, 0, 0, 0, 0]
}

fn x64_store_dl_abs32_placeholder() -> List[Int] {
    return [136, 20, 37, 0, 0, 0, 0]
}

fn x64_jmp_rel32_placeholder() -> List[Int] {
    return [233, 0, 0, 0, 0]
}

fn x64_call_rel32_placeholder() -> List[Int] {
    return [232, 0, 0, 0, 0]
}

fn x64_lea_rsi_rel32_placeholder() -> List[Int] {
    # 48 8D 35 disp32 loads a RIP-relative address into rsi.
    return [72, 141, 53, 0, 0, 0, 0]
}

fn x64_imul_eax_imm8(value: Int) -> List[Int] {
    if value < 0 || value > 127 {
        return []
    }
    return [107, 192, value]
}

fn x64_write_stdout(address: Int, length: Int) -> List[Int] {
    # Linux x86-64 write(1, address, length). The initial static-image format
    # keeps addresses and lengths within the imm32 range.
    if address < 0 || address > 4294967295 ||
       length < 0 || length > 4294967295 {
        return []
    }
    return concat(
        x64_mov_eax_imm32(1),
        concat(
            x64_mov_edi_imm32(1),
            concat(
                x64_mov_esi_imm32(address),
                concat(x64_mov_edx_imm32(length), x64_syscall()),
            ),
        ),
    )
}

fn x64_exit_text(status: Int) -> List[Int] {
    # Linux x86-64: exit(status) is syscall 60 with status in edi.
    if status < 0 || status > 255 {
        return []
    }
    return concat(
        x64_mov_eax_imm32(60),
        concat(x64_mov_edi_imm32(status), x64_syscall()),
    )
}

fn x64_core_answer_text() -> List[Int] {
    # Lower this Stage 1 arithmetic Core behavior:
    #
    #   fn main() {
    #       print((6 + 1) * 6)
    #   }
    #
    # _start calls main and exits with its result. main prints through a
    # RIP-relative message label. Both forward references are rel32 fixups.
    let main_label = 1
    let message_label = 2

    let mut code = x64_call_rel32_placeholder()
    let call_fixup_at = 1
    let call_end = len(code)
    code = concat(code, [137, 199]) # mov edi,eax
    code = concat(code, x64_mov_eax_imm32(60))
    code = concat(code, x64_syscall())

    let main_offset = len(code)
    code = concat(code, x64_mov_eax_imm32(6))
    code = concat(code, x64_add_eax_imm8(1))
    code = concat(code, x64_imul_eax_imm8(6))
    code = concat(code, [80]) # push rax: preserve the Core result
    code = concat(code, x64_mov_eax_imm32(1))
    code = concat(code, x64_mov_edi_imm32(1))

    let lea_offset = len(code)
    code = concat(code, x64_lea_rsi_rel32_placeholder())
    let lea_fixup_at = lea_offset + 3
    let lea_end = len(code)

    code = concat(code, x64_mov_edx_imm32(3))
    code = concat(code, x64_syscall())
    code = concat(code, [88, 195]) # pop rax; ret

    let message_offset = len(code)
    let linked = resolve_rel32_fixups(
        code,
        [main_label, message_label],
        [main_offset, message_offset],
        [call_fixup_at, lea_fixup_at],
        [call_end, lea_end],
        [main_label, message_label],
    )
    return concat(linked, [52, 50, 10]) # "42\n"
}

fn elf64_header_for_machine(entry: Int, machine: Int) -> List[Int] {
    return concat(
        elf_ident(),
        concat(
            u16_le(2),                 # ET_EXEC
            concat(
                u16_le(machine),
                concat(
                    u32_le(1),         # EV_CURRENT
                    concat(
                        u64_le(entry),
                        concat(
                            u64_le(64), # program-header offset
                            concat(
                                u64_le(0),
                                concat(
                                    u32_le(0),
                                    concat(
                                        u16_le(64),
                                        concat(
                                            u16_le(56),
                                            concat(
                                                u16_le(2),
                                                concat(
                                                    u16_le(0),
                                                    concat(u16_le(0), u16_le(0)),
                                                ),
                                            ),
                                        ),
                                    ),
                                ),
                            ),
                        ),
                    ),
                ),
            ),
        ),
    )
}

fn elf64_debug_header(
    entry: Int,
    section_header_offset: Int,
    section_count: Int,
    section_name_index: Int,
) -> List[Int] {
    # Debug images use the same executable/program-header layout as release
    # images, but opt in to an ELF section table at the end of the file.
    return concat(
        elf_ident(),
        concat(
            u16_le(2),                 # ET_EXEC
            concat(
                u16_le(62),            # EM_X86_64
                concat(
                    u32_le(1),         # EV_CURRENT
                    concat(
                        u64_le(entry),
                        concat(
                            u64_le(64), # program-header offset
                            concat(
                                u64_le(section_header_offset),
                                concat(
                                    u32_le(0),
                                    concat(
                                        u16_le(64),
                                        concat(
                                            u16_le(56),
                                            concat(
                                                u16_le(2),
                                                concat(
                                                    u16_le(64),
                                                    concat(
                                                        u16_le(section_count),
                                                        u16_le(section_name_index),
                                                    ),
                                                ),
                                            ),
                                        ),
                                    ),
                                ),
                            ),
                        ),
                    ),
                ),
            ),
        ),
    )
}

fn elf64_header(entry: Int) -> List[Int] {
    return elf64_header_for_machine(entry, 62) # EM_X86_64
}

fn elf64_load_segment(
    flags: Int,
    file_offset: Int,
    address: Int,
    file_size: Int,
    memory_size: Int,
) -> List[Int] {
    return concat(
        u32_le(1), # PT_LOAD
        concat(
            u32_le(flags),
            concat(
                u64_le(file_offset),
                concat(
                    u64_le(address),
                    concat(
                        u64_le(address),
                        concat(
                            u64_le(file_size),
                            concat(u64_le(memory_size), u64_le(4096)),
                        ),
                    ),
                ),
            ),
        ),
    )
}

fn elf64_section_header(
    name_offset: Int,
    section_type: Int,
    flags: Int,
    address: Int,
    file_offset: Int,
    size: Int,
    link: Int,
    info: Int,
    alignment: Int,
    entry_size: Int,
) -> List[Int] {
    return concat(
        u32_le(name_offset),
        concat(
            u32_le(section_type),
            concat(
                u64_le(flags),
                concat(
                    u64_le(address),
                    concat(
                        u64_le(file_offset),
                        concat(
                            u64_le(size),
                            concat(
                                u32_le(link),
                                concat(
                                    u32_le(info),
                                    concat(
                                        u64_le(alignment),
                                        u64_le(entry_size),
                                    ),
                                ),
                            ),
                        ),
                    ),
                ),
            ),
        ),
    )
}

fn align_offset(offset: Int, alignment: Int) -> Int {
    let remainder = offset % alignment
    if remainder == 0 {
        return offset
    }
    return offset + alignment - remainder
}

fn elf64_exit_image(status: Int) -> List[Int] {
    let base = 4194304
    let text_offset = 176
    let rw_address = base + 4096
    let text = x64_exit_text(status)
    let image_size = text_offset + len(text)
    let header = elf64_header(base + text_offset)
    let rx = elf64_load_segment(5, 0, base, image_size, image_size)
    let rw = elf64_load_segment(6, 4096, rw_address, 0, 4096)
    return concat(header, concat(rx, concat(rw, text)))
}

fn x64_print_sum_text(left: Int, right: Int) -> List[Int] {
    # This first lowering fixture intentionally covers non-negative two-digit
    # results. It computes the value at runtime, divides by ten, converts both
    # digits to ASCII, stores them in the RW segment, then writes the buffer.
    let arithmetic = concat(
        x64_mov_eax_imm32(left),
        concat(
            x64_add_eax_imm8(right),
            concat(
                x64_xor_edx_edx(),
                concat(
                    x64_mov_ecx_imm32(10),
                    concat(
                        x64_div_ecx(),
                        concat(
                            x64_add_al_imm8(48),
                            x64_add_dl_imm8(48),
                        ),
                    ),
                ),
            ),
        ),
    )
    let stores = concat(
        x64_store_al_abs32_placeholder(),
        x64_store_dl_abs32_placeholder(),
    )
    let raw = concat(
        arithmetic,
        concat(
            stores,
            concat(x64_write_stdout(0, 3), x64_exit_text(0)),
        ),
    )

    # Fixup fields are measured from the start of text. The data label is a
    # file/virtual offset because both PT_LOAD mappings share image_base.
    let image_base = 4194304
    let buffer_label = 4096
    let tens_fixed = resolve_abs32_fixup(raw, 25, image_base, buffer_label, 0)
    let ones_fixed = resolve_abs32_fixup(
        tens_fixed,
        32,
        image_base,
        buffer_label,
        1,
    )
    return resolve_abs32_fixup(
        ones_fixed,
        47,
        image_base,
        buffer_label,
        0,
    )
}

fn elf64_print_sum_image(left: Int, right: Int) -> List[Int] {
    let base = 4194304
    let text_offset = 176
    let data_offset = 4096
    let text = x64_print_sum_text(left, right)
    let rx_size = text_offset + len(text)
    let header = elf64_header(base + text_offset)
    let rx = elf64_load_segment(5, 0, base, rx_size, rx_size)
    let rw = elf64_load_segment(6, data_offset, base + data_offset, 3, 4096)
    let without_data = concat(header, concat(rx, concat(rw, text)))
    # The first two bytes are overwritten by generated code; newline is static.
    return concat(pad_to(without_data, data_offset), [0, 0, 10])
}

fn elf64_core_answer_image() -> List[Int] {
    let base = 4194304
    let text_offset = 176
    let rw_address = base + 4096
    let text = x64_core_answer_text()
    let image_size = text_offset + len(text)
    let header = elf64_header(base + text_offset)
    let rx = elf64_load_segment(5, 0, base, image_size, image_size)
    let rw = elf64_load_segment(6, 4096, rw_address, 0, 4096)
    return concat(header, concat(rx, concat(rw, text)))
}

fn dwarf_source_path() -> List[Int] {
    return [
        98, 111, 111, 116, 115, 116, 114, 97, 112, 47,
        110, 97, 116, 105, 118, 101, 47,
        102, 105, 120, 116, 117, 114, 101, 115, 47,
        99, 111, 114, 101, 95, 97, 110, 115, 119, 101, 114, 95,
        100, 101, 98, 117, 103, 46, 107, 111, 102, 117, 110,
    ]
}

fn dwarf_debug_abbrev() -> List[Int] {
    # DWARF v4 abbreviations:
    #   1: compile_unit with one or more children
    #   2: external subprogram with name, declaration, and address range
    return [
        1, 17, 1,
        37, 14, # DW_AT_producer, DW_FORM_strp
        19, 5,  # DW_AT_language, DW_FORM_data2
        3, 14,  # DW_AT_name, DW_FORM_strp
        16, 23, # DW_AT_stmt_list, DW_FORM_sec_offset
        17, 1,  # DW_AT_low_pc, DW_FORM_addr
        18, 7,  # DW_AT_high_pc, DW_FORM_data8
        0, 0,
        2, 46, 0,
        3, 14,  # DW_AT_name, DW_FORM_strp
        58, 11, # DW_AT_decl_file, DW_FORM_data1
        59, 11, # DW_AT_decl_line, DW_FORM_data1
        17, 1,  # DW_AT_low_pc, DW_FORM_addr
        18, 7,  # DW_AT_high_pc, DW_FORM_data8
        63, 25, # DW_AT_external, DW_FORM_flag_present
        0, 0,
        0,
    ]
}

fn dwarf_debug_strings() -> List[Int] {
    let producer = [
        75, 111, 102, 117, 110, 32,
        98, 111, 111, 116, 115, 116, 114, 97, 112, 32,
        110, 97, 116, 105, 118, 101, 32,
        101, 110, 99, 111, 100, 101, 114, 0,
    ]
    let source = concat(dwarf_source_path(), [0])
    return concat(producer, concat(source, [109, 97, 105, 110, 0]))
}

fn dwarf_debug_info() -> List[Int] {
    let producer_offset = 0
    let source_offset = 31
    let main_offset = 81
    let start_address = 4194480 # 0x4000b0
    let main_address = 4194494  # 0x4000be

    let mut body = u16_le(4) # DWARF v4
    body = concat(body, u32_le(0)) # abbreviation table offset
    body = concat(body, [8]) # address size
    body = concat(body, [1]) # compile_unit abbreviation
    body = concat(body, u32_le(producer_offset))
    body = concat(body, u16_le(32768)) # implementation-defined Kofun language
    body = concat(body, u32_le(source_offset))
    body = concat(body, u32_le(0)) # .debug_line offset
    body = concat(body, u64_le(start_address))
    body = concat(body, u64_le(52)) # complete executable text range

    body = concat(body, [2]) # subprogram abbreviation
    body = concat(body, u32_le(main_offset))
    body = concat(body, [1, 1]) # file 1, declaration line 1
    body = concat(body, u64_le(main_address))
    body = concat(body, u64_le(38)) # main through ret
    body = concat(body, [0]) # end compile_unit children
    return concat(u32_le(len(body)), body)
}

fn dwarf_line_row(pc_advance: Int) -> List[Int] {
    # Advance the address, advance one source line, then append a row.
    return [
        2, pc_advance, # DW_LNS_advance_pc
        3, 1,          # DW_LNS_advance_line
        1,             # DW_LNS_copy
    ]
}

fn dwarf_debug_line() -> List[Int] {
    let mut header = [
        1,   # minimum instruction length
        1,   # maximum operations per instruction
        1,   # default_is_stmt
        251, # line_base = -5
        14,  # line_range
        13,  # opcode_base
        0, 1, 1, 1, 1, 0, 0, 0, 1, 0, 0, 1,
        0,   # empty include-directory table
    ]
    header = concat(header, dwarf_source_path())
    header = concat(header, [0, 0, 0, 0, 0]) # file terminator and table end

    let mut program = [0, 9, 2] # extended DW_LNE_set_address
    program = concat(program, u64_le(4194494)) # main at 0x4000be
    program = concat(program, [3, 1, 1]) # line 2 at main entry
    program = concat(program, dwarf_line_row(5))  # line 3
    program = concat(program, dwarf_line_row(3))  # line 4
    program = concat(program, dwarf_line_row(3))  # line 5
    program = concat(program, dwarf_line_row(25)) # line 6
    program = concat(program, [2, 2, 0, 1, 1]) # end at 0x4000e4

    let body = concat(
        u16_le(4),
        concat(u32_le(len(header)), concat(header, program)),
    )
    return concat(u32_le(len(body)), body)
}

fn elf64_symbol(
    name_offset: Int,
    address: Int,
    size: Int,
) -> List[Int] {
    return concat(
        u32_le(name_offset),
        concat(
            [18, 0], # STB_GLOBAL | STT_FUNC, default visibility
            concat(
                u16_le(1), # .text
                concat(u64_le(address), u64_le(size)),
            ),
        ),
    )
}

fn elf64_debug_symbols() -> List[Int] {
    let empty = pad_to([], 24)
    let start = elf64_symbol(1, 4194480, 14)
    let main_symbol = elf64_symbol(8, 4194494, 38)
    return concat(empty, concat(start, main_symbol))
}

fn elf64_symbol_strings() -> List[Int] {
    return [
        0,
        95, 115, 116, 97, 114, 116, 0, # _start
        109, 97, 105, 110, 0,           # main
    ]
}

fn elf64_section_strings() -> List[Int] {
    return [
        0,
        46, 116, 101, 120, 116, 0,
        46, 114, 111, 100, 97, 116, 97, 0,
        46, 100, 101, 98, 117, 103, 95,
        97, 98, 98, 114, 101, 118, 0,
        46, 100, 101, 98, 117, 103, 95, 105, 110, 102, 111, 0,
        46, 100, 101, 98, 117, 103, 95, 108, 105, 110, 101, 0,
        46, 100, 101, 98, 117, 103, 95, 115, 116, 114, 0,
        46, 115, 121, 109, 116, 97, 98, 0,
        46, 115, 116, 114, 116, 97, 98, 0,
        46, 115, 104, 115, 116, 114, 116, 97, 98, 0,
    ]
}

fn elf64_core_answer_debug_image() -> List[Int] {
    # This is the opt-in `-g` image for the compact Core fixture. Machine code,
    # read-only data, and PT_LOAD descriptors are identical to the release
    # image. ELF section-table fields differ in the file header, and
    # non-allocating debug/string/symbol sections and section headers follow.
    let base = 4194304
    let text_offset = 176
    let text = x64_core_answer_text()
    let runtime_size = text_offset + len(text)

    let abbreviations = dwarf_debug_abbrev()
    let information = dwarf_debug_info()
    let lines = dwarf_debug_line()
    let debug_strings = dwarf_debug_strings()
    let symbols = elf64_debug_symbols()
    let symbol_strings = elf64_symbol_strings()
    let section_strings = elf64_section_strings()

    let abbreviations_offset = runtime_size
    let information_offset = abbreviations_offset + len(abbreviations)
    let lines_offset = information_offset + len(information)
    let debug_strings_offset = lines_offset + len(lines)
    let symbols_offset = align_offset(
        debug_strings_offset + len(debug_strings),
        8,
    )
    let symbol_strings_offset = symbols_offset + len(symbols)
    let section_strings_offset = symbol_strings_offset + len(symbol_strings)
    let section_headers_offset = align_offset(
        section_strings_offset + len(section_strings),
        8,
    )

    let header = elf64_debug_header(
        base + text_offset,
        section_headers_offset,
        10,
        9,
    )
    let rx = elf64_load_segment(5, 0, base, runtime_size, runtime_size)
    let rw = elf64_load_segment(6, 4096, base + 4096, 0, 4096)
    let mut image = concat(header, concat(rx, concat(rw, text)))
    image = concat(image, abbreviations)
    image = concat(image, information)
    image = concat(image, lines)
    image = concat(image, debug_strings)
    image = pad_to(image, symbols_offset)
    image = concat(image, symbols)
    image = concat(image, symbol_strings)
    image = concat(image, section_strings)
    image = pad_to(image, section_headers_offset)

    let mut sections = pad_to([], 64) # mandatory SHT_NULL entry
    sections = concat(sections, elf64_section_header(
        1, 1, 6, base + text_offset, text_offset, 52, 0, 0, 16, 0,
    ))
    sections = concat(sections, elf64_section_header(
        7, 1, 2, base + 228, 228, 3, 0, 0, 1, 0,
    ))
    sections = concat(sections, elf64_section_header(
        15, 1, 0, 0,
        abbreviations_offset, len(abbreviations), 0, 0, 1, 0,
    ))
    sections = concat(sections, elf64_section_header(
        29, 1, 0, 0,
        information_offset, len(information), 0, 0, 1, 0,
    ))
    sections = concat(sections, elf64_section_header(
        41, 1, 0, 0,
        lines_offset, len(lines), 0, 0, 1, 0,
    ))
    sections = concat(sections, elf64_section_header(
        53, 1, 48, 0,
        debug_strings_offset, len(debug_strings), 0, 0, 1, 1,
    ))
    sections = concat(sections, elf64_section_header(
        64, 2, 0, 0,
        symbols_offset, len(symbols), 8, 1, 8, 24,
    ))
    sections = concat(sections, elf64_section_header(
        72, 3, 0, 0,
        symbol_strings_offset, len(symbol_strings), 0, 0, 1, 0,
    ))
    sections = concat(sections, elf64_section_header(
        80, 3, 0, 0,
        section_strings_offset, len(section_strings), 0, 0, 1, 0,
    ))
    return concat(image, sections)
}

# Native Core v1 is a target-independent postfix stream. Every operation is a
# pair: [opcode, operand]. Literal uses its operand; binary operations require
# zero. Both x86-64 and AArch64 consume exactly this representation.
#
#   1 literal
#   2 add
#   3 multiply

fn native_core_valid(core: List[Int]) -> Bool {
    if len(core) == 0 || len(core) % 2 != 0 {
        return false
    }
    let mut depth = 0
    let mut values = []
    let mut index = 0
    while index < len(core) {
        let opcode = core[index]
        let operand = core[index + 1]
        if opcode == 1 {
            if operand < 0 || operand > 65535 {
                return false
            }
            depth = depth + 1
            values = concat(values, [operand])
        } else if opcode == 2 || opcode == 3 {
            if operand != 0 || depth < 2 {
                return false
            }
            let left = values[depth - 2]
            let right = values[depth - 1]
            let mut result = 0
            if opcode == 2 {
                if left > 65535 - right {
                    return false
                }
                result = left + right
            } else {
                if right != 0 && left > 65535 // right {
                    return false
                }
                result = left * right
            }
            let mut reduced = []
            for slot in 0 .. depth - 2 {
                reduced = concat(reduced, [values[slot]])
            }
            values = concat(reduced, [result])
            depth = depth - 1
        } else {
            return false
        }
        index = index + 2
    }
    return depth == 1 && values[0] >= 10 && values[0] <= 99
}

fn x64_native_core_text(core: List[Int]) -> List[Int] {
    if !native_core_valid(core) {
        return []
    }
    let mut text = []
    let mut index = 0
    while index < len(core) {
        let opcode = core[index]
        let operand = core[index + 1]
        if opcode == 1 {
            text = concat(text, x64_mov_eax_imm32(operand))
            text = concat(text, [80]) # push rax
        } else {
            text = concat(text, [89, 88]) # pop rcx; pop rax
            if opcode == 2 {
                text = concat(text, [1, 200]) # add eax, ecx
            } else {
                text = concat(text, [15, 175, 193]) # imul eax, ecx
            }
            text = concat(text, [80]) # push result
        }
        index = index + 2
    }
    text = concat(text, [88]) # pop rax

    # Native Core v1 accepts results 10..99. Convert the runtime result to two
    # digits in the shared RW page and preserve Stage 1 print semantics.
    text = concat(text, x64_xor_edx_edx())
    text = concat(text, x64_mov_ecx_imm32(10))
    text = concat(text, x64_div_ecx())
    text = concat(text, x64_add_al_imm8(48))
    text = concat(text, x64_add_dl_imm8(48))
    text = concat(text, [136, 4, 37, 0, 16, 64, 0])
    text = concat(text, [136, 20, 37, 1, 16, 64, 0])
    text = concat(text, x64_write_stdout(4198400, 3))
    return concat(text, x64_exit_text(0))
}

fn a64_instruction(word: Int) -> List[Int] {
    if word < 0 || word > 4294967295 {
        return []
    }
    return u32_le(word)
}

fn a64_movz_x(register: Int, value: Int) -> List[Int] {
    if register < 0 || register > 30 || value < 0 || value > 65535 {
        return []
    }
    return a64_instruction(3531603968 + value * 32 + register)
}

fn a64_movk_x_lsl16(register: Int, value: Int) -> List[Int] {
    if register < 0 || register > 30 || value < 0 || value > 65535 {
        return []
    }
    return a64_instruction(4070572032 + value * 32 + register)
}

fn a64_add_x(register: Int, left: Int, right: Int) -> List[Int] {
    if register < 0 || register > 30 ||
       left < 0 || left > 30 || right < 0 || right > 30 {
        return []
    }
    return a64_instruction(
        2332033024 + right * 65536 + left * 32 + register,
    )
}

fn a64_mul_x(register: Int, left: Int, right: Int) -> List[Int] {
    if register < 0 || register > 30 ||
       left < 0 || left > 30 || right < 0 || right > 30 {
        return []
    }
    return a64_instruction(
        2600500224 + right * 65536 + left * 32 + register,
    )
}

fn a64_add_x_imm12(register: Int, source: Int, value: Int) -> List[Int] {
    if register < 0 || register > 30 ||
       source < 0 || source > 30 || value < 0 || value > 4095 {
        return []
    }
    return a64_instruction(
        2432696320 + value * 1024 + source * 32 + register,
    )
}

fn a64_udiv_x(register: Int, left: Int, right: Int) -> List[Int] {
    if register < 0 || register > 30 ||
       left < 0 || left > 30 || right < 0 || right > 30 {
        return []
    }
    return a64_instruction(
        2596276224 + right * 65536 + left * 32 + register,
    )
}

fn a64_msub_x(
    register: Int,
    left: Int,
    right: Int,
    accumulator: Int,
) -> List[Int] {
    if register < 0 || register > 30 ||
       left < 0 || left > 30 ||
       right < 0 || right > 30 ||
       accumulator < 0 || accumulator > 30 {
        return []
    }
    return a64_instruction(
        2600501248 +
        right * 65536 +
        accumulator * 1024 +
        left * 32 +
        register,
    )
}

fn a64_strb_w_imm12(source: Int, address: Int, offset: Int) -> List[Int] {
    if source < 0 || source > 30 ||
       address < 0 || address > 30 ||
       offset < 0 || offset > 4095 {
        return []
    }
    return a64_instruction(
        956301312 + offset * 1024 + address * 32 + source,
    )
}

fn a64_svc_zero() -> List[Int] {
    return a64_instruction(3556769793)
}

fn a64_native_core_text(core: List[Int]) -> List[Int] {
    if !native_core_valid(core) {
        return []
    }

    # Postfix stack slots map to x0..x15. A binary operation overwrites its
    # left slot, making the same Core stream independent of target registers.
    let mut text = []
    let mut depth = 0
    let mut index = 0
    while index < len(core) {
        let opcode = core[index]
        let operand = core[index + 1]
        if opcode == 1 {
            if depth >= 16 {
                return []
            }
            text = concat(text, a64_movz_x(depth, operand))
            depth = depth + 1
        } else {
            let left = depth - 2
            let right = depth - 1
            if opcode == 2 {
                text = concat(text, a64_add_x(left, left, right))
            } else {
                text = concat(text, a64_mul_x(left, left, right))
            }
            depth = depth - 1
        }
        index = index + 2
    }

    # x0 is the runtime result. Convert 10..99 to two ASCII digits:
    # quotient=x4, remainder=x5, buffer=x1 at 0x401000.
    text = concat(text, a64_movz_x(3, 10))
    text = concat(text, a64_udiv_x(4, 0, 3))
    text = concat(text, a64_msub_x(5, 4, 3, 0))
    text = concat(text, a64_add_x_imm12(4, 4, 48))
    text = concat(text, a64_add_x_imm12(5, 5, 48))
    text = concat(text, a64_movz_x(1, 4096))
    text = concat(text, a64_movk_x_lsl16(1, 64))
    text = concat(text, a64_strb_w_imm12(4, 1, 0))
    text = concat(text, a64_strb_w_imm12(5, 1, 1))

    # Linux AArch64 write(1, buffer, 3), then exit(0).
    text = concat(text, a64_movz_x(0, 1))
    text = concat(text, a64_movz_x(2, 3))
    text = concat(text, a64_movz_x(8, 64))
    text = concat(text, a64_svc_zero())
    text = concat(text, a64_movz_x(0, 0))
    text = concat(text, a64_movz_x(8, 93))
    return concat(text, a64_svc_zero())
}

fn elf64_native_core_image(machine: Int, core: List[Int]) -> List[Int] {
    let base = 4194304
    let text_offset = 176
    let data_offset = 4096
    let mut text = []
    if machine == 62 {
        text = x64_native_core_text(core)
    } else if machine == 183 {
        text = a64_native_core_text(core)
    } else {
        return []
    }
    if len(text) == 0 {
        return []
    }
    let rx_size = text_offset + len(text)
    let header = elf64_header_for_machine(base + text_offset, machine)
    let rx = elf64_load_segment(5, 0, base, rx_size, rx_size)
    let rw = elf64_load_segment(6, data_offset, base + data_offset, 3, 4096)
    let without_data = concat(header, concat(rx, concat(rw, text)))
    return concat(pad_to(without_data, data_offset), [0, 0, 10])
}

fn native_core_answer() -> List[Int] {
    # Target-independent postfix for (6 + 1) * 6.
    return [1, 6, 1, 1, 2, 0, 1, 6, 3, 0]
}

fn main() {
    for byte in elf64_print_sum_image(40, 2) {
        print(byte)
    }
}
