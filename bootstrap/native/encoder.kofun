fn native_list_v1_allocation_size(length: Int) -> Int {
    # Immutable List v1: +0 Int64 length, +8 contiguous Int64 items.
    # Bound makes 8 + 8*length + 15 safe before 16-byte alignment.
    if length < 0 || length > 1152921504606846973 {
        return -1
    }
    return ((8 + 8 * length + 15) // 16) * 16
}

