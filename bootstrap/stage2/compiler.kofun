# Kofun Stage 2 semantic-front-end checkpoint.
#
# This compiler is intentionally written in the typed bootstrap subset already
# used by Stage 1: Int, Bool, Text, List[Text], control flow, direct calls, and
# file/text builtins.  Its first fixed-point projection is conservative:
# tokenize and parse a Kofun compilation unit, emit a stable textual IR, then
# reproduce the accepted Kofun source byte-for-byte. A statement/expression
# parser also lowers the integer Core to deterministic, checked C11.
#
# The exact source projection remains useful before this compiler can lower its
# own full source: any change made by the front end would make the second
# projection differ.

fn identifier_start(symbol: Text) -> Bool {
    return symbol == "_" || is_xid_start(symbol)
}

fn identifier_continue(symbol: Text) -> Bool {
    return symbol == "_" || is_xid_continue(symbol)
}

fn skip_trivia(source: Text, start: Int) -> Int {
    let symbols = chars(source)
    let mut cursor = start
    while cursor < len(symbols) {
        if is_space(symbols[cursor]) {
            cursor = cursor + 1
        } else if symbols[cursor] == "#" {
            while cursor < len(symbols) && symbols[cursor] != "\n" {
                cursor = cursor + 1
            }
        } else {
            return cursor
        }
    }
    return cursor
}

fn string_end(source: Text, start: Int) -> Int {
    let symbols = chars(source)
    let mut cursor = start + 1
    let mut escaped = false
    while cursor < len(symbols) {
        let symbol = symbols[cursor]
        if escaped {
            escaped = false
        } else if symbol == "\\" {
            escaped = true
        } else if symbol == "\"" {
            return cursor + 1
        } else if symbol == "\n" {
            return -1
        }
        cursor = cursor + 1
    }
    return -1
}

fn pair_token(token: Text) -> Bool {
    return token == "->" || token == "==" || token == "!=" ||
    token == "<=" || token == ">=" || token == "&&" ||
    token == "||" || token == "//" || token == ".." ||
    token == "**" || token == "??" || token == "|>" ||
    token == "=>"
}

fn token_end(source: Text, start: Int) -> Int {
    let symbols = chars(source)
    if start >= len(symbols) {
        return start
    }

    let first = symbols[start]
    if first == "\"" {
        return string_end(source, start)
    }

    let mut cursor = start + 1
    if identifier_start(first) {
        while cursor < len(symbols) && identifier_continue(symbols[cursor]) {
            cursor = cursor + 1
        }
        return cursor
    }

    if is_digit(first) {
        while cursor < len(symbols) &&
              (is_digit(symbols[cursor]) || symbols[cursor] == "_") {
            cursor = cursor + 1
        }
        return cursor
    }

    if cursor < len(symbols) {
        let pair = text_slice(source, start, cursor + 1)
        if pair_token(pair) {
            return cursor + 1
        }
    }
    return cursor
}

fn token_text(source: Text, start: Int) -> Text {
    let end = token_end(source, start)
    if end < 0 {
        return ""
    }
    return text_slice(source, start, end)
}

fn keyword(token: Text) -> Bool {
    return token == "fn" || token == "let" || token == "mut" ||
    token == "return" || token == "if" || token == "else" ||
    token == "while" || token == "for" || token == "in" ||
    token == "break" || token == "continue" || token == "true" ||
    token == "false" || token == "match" || token == "type"
}

fn token_kind(source: Text, start: Int) -> Text {
    let token = token_text(source, start)
    if len(token) == 0 {
        return "invalid"
    }
    let symbols = chars(token)
    if symbols[0] == "\"" {
        return "string"
    }
    if identifier_start(symbols[0]) {
        if keyword(token) {
            return "keyword"
        }
        return "identifier"
    }
    if is_digit(symbols[0]) {
        return "integer"
    }
    return "punctuation"
}

fn line_at(source: Text, target: Int) -> Int {
    let symbols = chars(source)
    let mut line = 1
    let mut cursor = 0
    while cursor < target && cursor < len(symbols) {
        if symbols[cursor] == "\n" {
            line = line + 1
        }
        cursor = cursor + 1
    }
    return line
}

fn lex(source: Text) -> Text {
    let unicode_error = validate_unicode_source(source)
    if len(unicode_error) > 0 {
        return unicode_error
    }
    let mut tape = "kofun-token-tape/v1\n"
    let mut cursor = skip_trivia(source, 0)
    while cursor < len(source) {
        let end = token_end(source, cursor)
        if end <= cursor {
            return "error[E2S01]: unterminated string at byte " +
            to_text(cursor)
        }
        tape = tape + token_kind(source, cursor) + "|" +
        to_text(cursor) + "|" + to_text(end) + "|" +
        to_text(line_at(source, cursor)) + "\n"
        cursor = skip_trivia(source, end)
    }
    return tape
}

# General Pattern syntax is preserved independently from executable match
# semantics. Results use a one-line state header followed by post-order node
# records so the bootstrap subset does not need tuples or mutable globals.

fn pattern_depth_limit() -> Int {
    return 32
}

fn pattern_node_limit() -> Int {
    return 256
}

fn pattern_line_field(value: Text, line_start: Int, wanted: Int) -> Text {
    let symbols = chars(value)
    let mut cursor = line_start
    let mut field = 0
    let mut field_start = line_start
    while cursor < len(symbols) && symbols[cursor] != "\n" {
        if symbols[cursor] == "|" {
            if field == wanted {
                return text_slice(value, field_start, cursor)
            }
            field = field + 1
            field_start = cursor + 1
        }
        cursor = cursor + 1
    }
    if field == wanted {
        return text_slice(value, field_start, cursor)
    }
    return ""
}

fn pattern_result_field(result: Text, wanted: Int) -> Text {
    return pattern_line_field(result, 0, wanted)
}

fn pattern_result_records(result: Text) -> Text {
    let symbols = chars(result)
    let mut cursor = 0
    while cursor < len(symbols) && symbols[cursor] != "\n" {
        cursor = cursor + 1
    }
    if cursor >= len(symbols) {
        return ""
    }
    return text_slice(result, cursor + 1, len(result))
}

fn pattern_result(
    end: Int,
    root: Int,
    next_id: Int,
    nodes: Int,
    errors: Int,
    fatal: Bool,
    kind: Text,
    limit_id: Int,
    records: Text
) -> Text {
    let mut fatal_text = "0"
    if fatal {
        fatal_text = "1"
    }
    return to_text(end) + "|" + to_text(root) + "|" +
    to_text(next_id) + "|" + to_text(nodes) + "|" +
    to_text(errors) + "|" + fatal_text + "|" + kind + "|" +
    to_text(limit_id) + "\n" + records
}

fn pattern_result_int(result: Text, field: Int) -> Int {
    return decimal_value(pattern_result_field(result, field))
}

fn pattern_error_result(
    start: Int,
    end: Int,
    reason: Text,
    next_id: Int,
    nodes: Int,
    errors: Int,
    limit_id: Int,
    fatal: Bool
) -> Text {
    if nodes >= pattern_node_limit() {
        return pattern_result(
            end, -1, next_id, nodes, errors, true, "ErrorPattern",
            limit_id, ""
        )
    }
    let id = next_id
    let records = "node|" + to_text(id) + "|ErrorPattern|" +
    to_text(start) + "|" + to_text(end) + "|" + reason + "\n" +
    "pattern-diagnostic|E2S58|" + reason + "|" +
    to_text(start) + "|" + to_text(end) + "\n"
    return pattern_result(
        end, id, next_id + 1, nodes + 1, errors + 1, fatal,
        "ErrorPattern", limit_id, records
    )
}

fn pattern_limit_result(
    source: Text,
    start: Int,
    next_id: Int,
    nodes: Int,
    errors: Int,
    limit_id: Int
) -> Text {
    let end = token_end(source, start)
    if limit_id >= 0 {
        return pattern_result(
            end, limit_id, next_id, nodes, errors, true,
            "ErrorPattern", limit_id, ""
        )
    }
    let id = next_id
    let records = "node|" + to_text(id) + "|ErrorPattern|" +
    to_text(start) + "|" + to_text(end) + "|node-limit\n" +
    "pattern-diagnostic|E2S58|node-limit|" + to_text(start) +
    "|" + to_text(end) + "\n"
    return pattern_result(
        end, id, next_id + 1, nodes, errors + 1, true,
        "ErrorPattern", id, records
    )
}

fn pattern_stop_token(source: Text, start: Int) -> Bool {
    let token = token_text(source, start)
    return start >= len(source) || token == "=>" || token == "," ||
    token == ")" || token == "}" || token == "if"
}

fn pattern_recovery_end(source: Text, start: Int) -> Int {
    let mut cursor = skip_trivia(source, start)
    let mut parens = 0
    let mut brackets = 0
    while cursor < len(source) {
        let token = token_text(source, cursor)
        if token == "=>" {
            return cursor
        }
        if token == "{" && parens == 0 && brackets == 0 {
            return cursor
        }
        if token == "}" && parens == 0 && brackets == 0 {
            return cursor
        }
        if token == "," && parens == 0 && brackets == 0 {
            return cursor
        }
        if token == "(" {
            parens = parens + 1
        } else if token == ")" {
            if parens == 0 {
                return cursor
            }
            parens = parens - 1
        } else if token == "[" {
            brackets = brackets + 1
        } else if token == "]" {
            if brackets == 0 {
                return cursor
            }
            brackets = brackets - 1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return cursor
}

fn parse_pattern_or_result(
    source: Text,
    start: Int,
    depth: Int,
    next_id: Int,
    nodes: Int,
    errors: Int,
    limit_id: Int
) -> Text {
    let cursor = skip_trivia(source, start)
    let token = token_text(source, cursor)
    if token == "|" || token == "||" {
        let mut reason = "leading-or"
        if token == "||" {
            reason = "doubled-or"
        }
        return pattern_error_result(
            cursor, token_end(source, cursor), reason, next_id, nodes,
            errors, limit_id, false
        )
    }

    let first = parse_pattern_atomic_result(
        source, cursor, depth, next_id, nodes, errors, limit_id
    )
    if pattern_result_field(first, 5) == "1" {
        return first
    }
    let mut separator = skip_trivia(
        source,
        pattern_result_int(first, 0)
    )
    if token_text(source, separator) == "||" {
        return pattern_error_result(
            cursor, token_end(source, separator), "doubled-or",
            next_id, nodes, errors, limit_id, false
        )
    }
    if token_text(source, separator) != "|" {
        if token_text(source, separator) == ".." {
            let recovered = pattern_recovery_end(
                source,
                token_end(source, separator)
            )
            return pattern_error_result(
                cursor, recovered, "unsupported-range-pattern",
                next_id, nodes, errors, limit_id, false
            )
        }
        return first
    }

    let mut records = pattern_result_records(first)
    let mut children = pattern_result_field(first, 1)
    let mut current_next = pattern_result_int(first, 2)
    let mut current_nodes = pattern_result_int(first, 3)
    let mut current_errors = pattern_result_int(first, 4)
    let mut current_limit = pattern_result_int(first, 7)
    let mut alternatives = 1
    let mut end = pattern_result_int(first, 0)
    while separator < len(source) && token_text(source, separator) == "|" {
        records = records + "separator|OrPattern|" + to_text(cursor) +
        "|" + to_text(alternatives - 1) + "|" + to_text(separator) +
        "|" + to_text(token_end(source, separator)) + "\n"
        let next = skip_trivia(source, token_end(source, separator))
        if token_text(source, next) == "|" ||
           token_text(source, next) == "||" {
            return pattern_error_result(
                cursor, token_end(source, next), "doubled-or",
                next_id, nodes, errors, limit_id, false
            )
        }
        if pattern_stop_token(source, next) {
            return pattern_error_result(
                cursor, token_end(source, separator), "trailing-or",
                next_id, nodes, errors, limit_id, false
            )
        }
        let alternative = parse_pattern_atomic_result(
            source, next, depth, current_next, current_nodes,
            current_errors, current_limit
        )
        if pattern_result_field(alternative, 5) == "1" {
            return alternative
        }
        records = records + pattern_result_records(alternative)
        children = children + "," + pattern_result_field(alternative, 1)
        current_next = pattern_result_int(alternative, 2)
        current_nodes = pattern_result_int(alternative, 3)
        current_errors = pattern_result_int(alternative, 4)
        current_limit = pattern_result_int(alternative, 7)
        alternatives = alternatives + 1
        end = pattern_result_int(alternative, 0)
        separator = skip_trivia(source, end)
    }
    if token_text(source, separator) == "||" {
        return pattern_error_result(
            cursor, token_end(source, separator), "doubled-or",
            next_id, nodes, errors, limit_id, false
        )
    }
    if token_text(source, separator) == ".." {
        let recovered = pattern_recovery_end(
            source,
            token_end(source, separator)
        )
        return pattern_error_result(
            cursor, recovered, "unsupported-range-pattern",
            next_id, nodes, errors, limit_id, false
        )
    }
    if current_nodes >= pattern_node_limit() {
        return pattern_limit_result(
            source, cursor, current_next, current_nodes,
            current_errors, current_limit
        )
    }
    let id = current_next
    records = records + "node|" + to_text(id) + "|OrPattern|" +
    to_text(cursor) + "|" + to_text(end) + "|" +
    to_text(alternatives) + "|" + children + "\n"
    return pattern_result(
        end, id, current_next + 1, current_nodes + 1,
        current_errors, false, "OrPattern", current_limit, records
    )
}

fn parse_pattern_atomic_result(
    source: Text,
    start: Int,
    depth: Int,
    next_id: Int,
    nodes: Int,
    errors: Int,
    limit_id: Int
) -> Text {
    let cursor = skip_trivia(source, start)
    if nodes >= pattern_node_limit() {
        return pattern_limit_result(
            source, cursor, next_id, nodes, errors, limit_id
        )
    }
    if depth > pattern_depth_limit() {
        return pattern_error_result(
            cursor, pattern_recovery_end(source, cursor), "depth-limit",
            next_id, nodes, errors, limit_id, false
        )
    }
    let token = token_text(source, cursor)
    if cursor >= len(source) || pattern_stop_token(source, cursor) ||
       token == "|" {
        return pattern_error_result(
            cursor, token_end(source, cursor), "missing-pattern",
            next_id, nodes, errors, limit_id, false
        )
    }
    let token_finish = token_end(source, cursor)
    if token == "{" {
        let close = balanced_end(source, cursor, "{", "}")
        let mut end = close
        if close < 0 {
            end = pattern_recovery_end(source, cursor)
        }
        return pattern_error_result(
            cursor, end, "unsupported-record-pattern", next_id, nodes,
            errors, limit_id, false
        )
    }
    if token == "[" || token == ".." {
        let mut reason = "unsupported-pattern-token"
        if token == ".." {
            reason = "unsupported-rest-pattern"
        }
        return pattern_error_result(
            cursor, pattern_recovery_end(source, token_finish), reason,
            next_id, nodes, errors, limit_id, false
        )
    }

    if token == "(" {
        let inner = parse_pattern_or_result(
            source, skip_trivia(source, token_finish), depth + 1,
            next_id, nodes, errors, limit_id
        )
        if pattern_result_field(inner, 5) == "1" {
            return inner
        }
        let close = skip_trivia(source, pattern_result_int(inner, 0))
        if token_text(source, close) != ")" {
            return pattern_error_result(
                cursor, pattern_recovery_end(source, close),
                "missing-closing-parenthesis", next_id, nodes,
                errors, limit_id, false
            )
        }
        let current_nodes = pattern_result_int(inner, 3)
        let current_next = pattern_result_int(inner, 2)
        let current_errors = pattern_result_int(inner, 4)
        let current_limit = pattern_result_int(inner, 7)
        if current_nodes >= pattern_node_limit() {
            return pattern_limit_result(
                source, cursor, current_next, current_nodes,
                current_errors, current_limit
            )
        }
        let end = token_end(source, close)
        let id = current_next
        let records = pattern_result_records(inner) + "node|" +
        to_text(id) + "|ParenthesizedPattern|" + to_text(cursor) +
        "|" + to_text(end) + "|" + to_text(cursor) + "|" +
        to_text(token_finish) + "|" + to_text(close) + "|" +
        to_text(end) + "|" + pattern_result_field(inner, 1) + "\n"
        return pattern_result(
            end, id, current_next + 1, current_nodes + 1,
            current_errors, false, "ParenthesizedPattern",
            current_limit, records
        )
    }

    if token == "_" {
        let records = "node|" + to_text(next_id) +
        "|WildcardPattern|" + to_text(cursor) + "|" +
        to_text(token_finish) + "\n"
        return pattern_result(
            token_finish, next_id, next_id + 1, nodes + 1, errors,
            false, "WildcardPattern", limit_id, records
        )
    }
    if token == "true" || token == "false" || token == "null" ||
       token_kind(source, cursor) == "integer" {
        let mut literal_kind = "Bool"
        if token == "null" {
            literal_kind = "Null"
        } else if token_kind(source, cursor) == "integer" {
            literal_kind = "Int"
        }
        let records = "node|" + to_text(next_id) +
        "|LiteralPattern|" + to_text(cursor) + "|" +
        to_text(token_finish) + "|" + literal_kind + "|" + token + "|" +
        to_text(cursor) + "|" + to_text(token_finish) + "\n"
        return pattern_result(
            token_finish, next_id, next_id + 1, nodes + 1, errors,
            false, "LiteralPattern", limit_id, records
        )
    }
    if token_kind(source, cursor) != "identifier" {
        return pattern_error_result(
            cursor, pattern_recovery_end(source, token_finish),
            "unsupported-pattern-token", next_id, nodes, errors,
            limit_id, false
        )
    }

    let after_name = skip_trivia(source, token_finish)
    if token_text(source, after_name) == "{" {
        let close = balanced_end(source, after_name, "{", "}")
        let mut end = close
        if close < 0 {
            end = pattern_recovery_end(source, after_name)
        }
        return pattern_error_result(
            cursor, end, "unsupported-record-pattern", next_id, nodes,
            errors, limit_id, false
        )
    }
    if token_text(source, after_name) != "(" {
        let records = "node|" + to_text(next_id) + "|NamePattern|" +
        to_text(cursor) + "|" + to_text(token_finish) + "|" + token +
        "|" + to_text(cursor) + "|" + to_text(token_finish) + "\n"
        return pattern_result(
            token_finish, next_id, next_id + 1, nodes + 1, errors,
            false, "NamePattern", limit_id, records
        )
    }

    let open = after_name
    let mut payload = skip_trivia(source, token_end(source, open))
    if token_text(source, payload) == ")" {
        return pattern_error_result(
            cursor, token_end(source, payload), "empty-constructor-payload",
            next_id, nodes, errors, limit_id, false
        )
    }
    let mut records = ""
    let mut children = ""
    let mut payload_count = 0
    let mut close = -1
    let mut current_next = next_id
    let mut current_nodes = nodes
    let mut current_errors = errors
    let mut current_limit = limit_id
    while payload < len(source) && close < 0 {
        let child = parse_pattern_or_result(
            source, payload, depth + 1, current_next, current_nodes,
            current_errors, current_limit
        )
        if pattern_result_field(child, 5) == "1" {
            return child
        }
        records = records + pattern_result_records(child)
        if payload_count > 0 {
            children = children + ","
        }
        children = children + pattern_result_field(child, 1)
        current_next = pattern_result_int(child, 2)
        current_nodes = pattern_result_int(child, 3)
        current_errors = pattern_result_int(child, 4)
        current_limit = pattern_result_int(child, 7)
        payload_count = payload_count + 1
        let separator = skip_trivia(
            source,
            pattern_result_int(child, 0)
        )
        if token_text(source, separator) == "," {
            records = records + "delimiter|ConstructorPattern|" +
            to_text(cursor) + "|payload-comma|" +
            to_text(payload_count - 1) + "|" + to_text(separator) +
            "|" + to_text(token_end(source, separator)) + "\n"
            payload = skip_trivia(source, token_end(source, separator))
            if token_text(source, payload) == ")" {
                close = payload
            }
        } else if token_text(source, separator) == ")" {
            close = separator
        } else {
            let mut recovered = pattern_recovery_end(source, separator)
            if token_text(source, recovered) == ")" {
                recovered = token_end(source, recovered)
            }
            let mut reason = "missing-comma"
            if pattern_stop_token(source, separator) {
                reason = "missing-closing-parenthesis"
            }
            return pattern_error_result(
                cursor, recovered, reason, next_id, nodes,
                errors, limit_id, false
            )
        }
    }
    if close < 0 {
        return pattern_error_result(
            cursor, pattern_recovery_end(source, payload),
            "missing-closing-parenthesis", next_id, nodes, errors,
            limit_id, false
        )
    }
    if current_nodes >= pattern_node_limit() {
        return pattern_limit_result(
            source, cursor, current_next, current_nodes,
            current_errors, current_limit
        )
    }
    let end = token_end(source, close)
    let id = current_next
    records = records + "node|" + to_text(id) +
    "|ConstructorPattern|" + to_text(cursor) + "|" + to_text(end) +
    "|" + token + "|" + to_text(cursor) + "|" +
    to_text(token_finish) + "|" + to_text(open) + "|" +
    to_text(token_end(source, open)) + "|" + to_text(close) + "|" +
    to_text(end) + "|" + to_text(payload_count) + "|" + children + "\n"
    return pattern_result(
        end, id, current_next + 1, current_nodes + 1,
        current_errors, false, "ConstructorPattern", current_limit,
        records
    )
}

fn pattern_match_open(source: Text, match_start: Int) -> Int {
    let mut cursor = skip_trivia(source, token_end(source, match_start))
    let mut parens = 0
    let mut brackets = 0
    while cursor < len(source) {
        let token = token_text(source, cursor)
        if token == "(" {
            parens = parens + 1
        } else if token == ")" {
            if parens > 0 {
                parens = parens - 1
            }
        } else if token == "[" {
            brackets = brackets + 1
        } else if token == "]" {
            if brackets > 0 {
                brackets = brackets - 1
            }
        } else if token == "{" && parens == 0 && brackets == 0 {
            return cursor
        } else if token == "}" && parens == 0 && brackets == 0 {
            return -1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return -1
}

fn pattern_arm_arrow(source: Text, start: Int, match_close: Int) -> Int {
    let mut cursor = skip_trivia(source, start)
    let mut parens = 0
    let mut brackets = 0
    while cursor < match_close {
        let token = token_text(source, cursor)
        if token == "=>" {
            return cursor
        }
        if token == "," && parens == 0 && brackets == 0 {
            return -1
        }
        if token == "(" {
            parens = parens + 1
        } else if token == ")" {
            if parens > 0 {
                parens = parens - 1
            }
        } else if token == "[" {
            brackets = brackets + 1
        } else if token == "]" {
            if brackets > 0 {
                brackets = brackets - 1
            }
        } else if token == "{" && parens == 0 && brackets == 0 {
            return -1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return -1
}

fn parse_pattern_trees(source: Text) -> Text {
    let mut tree = "kofun-pattern-tree/v1\n" +
    "limits|depth|32|nodes-per-compilation|256\n"
    let mut cursor = skip_trivia(source, 0)
    let mut match_id = 0
    let mut next_id = 0
    let mut nodes = 0
    let mut errors = 0
    let mut limit_id = -1
    let mut budget_exhausted = false
    while cursor < len(source) && !budget_exhausted {
        if token_text(source, cursor) == "match" {
            let open = pattern_match_open(source, cursor)
            let mut match_end = -1
            if open >= 0 {
                match_end = balanced_end(source, open, "{", "}")
            }
            if open >= 0 && match_end >= 0 {
                let close = match_end - 1
                let mut arms = ""
                let mut arm_cursor = skip_trivia(
                    source,
                    token_end(source, open)
                )
                let mut arm_id = 0
                while arm_cursor < close &&
                      token_text(source, arm_cursor) != "}" {
                    let checkpoint_next = next_id
                    let checkpoint_nodes = nodes
                    let checkpoint_errors = errors
                    let checkpoint_limit = limit_id
                    let mut pattern = parse_pattern_or_result(
                        source, arm_cursor, 1, next_id, nodes,
                        errors, limit_id
                    )
                    let after_pattern = skip_trivia(
                        source,
                        pattern_result_int(pattern, 0)
                    )
                    if pattern_result_field(pattern, 5) != "1" &&
                       pattern_result_field(pattern, 6) != "ErrorPattern" &&
                       token_text(source, after_pattern) != "=>" &&
                       token_text(source, after_pattern) != "if" {
                        let recovered = pattern_recovery_end(
                            source,
                            after_pattern
                        )
                        pattern = pattern_error_result(
                            arm_cursor,
                            recovered,
                            "unexpected-token-after-pattern",
                            checkpoint_next,
                            checkpoint_nodes,
                            checkpoint_errors,
                            checkpoint_limit,
                            false
                        )
                    }
                    next_id = pattern_result_int(pattern, 2)
                    nodes = pattern_result_int(pattern, 3)
                    errors = pattern_result_int(pattern, 4)
                    limit_id = pattern_result_int(pattern, 7)
                    arms = arms + pattern_result_records(pattern)
                    let arrow = pattern_arm_arrow(
                        source,
                        pattern_result_int(pattern, 0),
                        close
                    )
                    let mut arrow_end = -1
                    if arrow >= 0 {
                        arrow_end = token_end(source, arrow)
                    }
                    arms = arms + "arm|" + to_text(match_id) + "|" +
                    to_text(arm_id) + "|" + pattern_result_field(pattern, 1) +
                    "|" + to_text(arm_cursor) + "|" +
                    pattern_result_field(pattern, 0) + "|" +
                    to_text(arrow) + "|" + to_text(arrow_end) + "\n"
                    arm_id = arm_id + 1
                    if pattern_result_field(pattern, 5) == "1" &&
                       pattern_result_int(pattern, 7) >= 0 {
                        budget_exhausted = true
                        arm_cursor = close
                    } else if arrow < 0 {
                        let recovery = skip_trivia(
                            source,
                            pattern_result_int(pattern, 0)
                        )
                        if recovery < close &&
                           token_text(source, recovery) == "," {
                            arm_cursor = skip_trivia(
                                source,
                                token_end(source, recovery)
                            )
                        } else {
                            arm_cursor = close
                        }
                    } else {
                        let body = skip_trivia(
                            source,
                            token_end(source, arrow)
                        )
                        if body >= close || token_text(source, body) != "{" {
                            arm_cursor = pattern_recovery_end(source, body)
                        } else {
                            let body_end = balanced_end(
                                source,
                                body,
                                "{",
                                "}"
                            )
                            if body_end < 0 {
                                arm_cursor = close
                            } else {
                                arm_cursor = skip_trivia(source, body_end)
                            }
                        }
                        if arm_cursor < close &&
                           token_text(source, arm_cursor) == "," {
                            arm_cursor = skip_trivia(
                                source,
                                token_end(source, arm_cursor)
                            )
                        }
                    }
                }
                tree = tree + "match|" + to_text(match_id) + "|" +
                to_text(cursor) + "|" + to_text(open) + "|" +
                to_text(token_end(source, open)) + "|" + to_text(close) +
                "|" + to_text(token_end(source, close)) + "|" +
                to_text(arm_id) + "\n" + arms
                match_id = match_id + 1
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return tree + "match-count|" + to_text(match_id) + "\n"
}

fn pattern_find_from(value: Text, wanted: Text, start: Int) -> Int {
    if len(wanted) == 0 {
        return start
    }
    let mut cursor = start
    while cursor + len(wanted) <= len(value) {
        if text_slice(value, cursor, cursor + len(wanted)) == wanted {
            return cursor
        }
        cursor = cursor + 1
    }
    return -1
}

fn pattern_first_error(tree: Text) -> Text {
    let mut search = 0
    let mut best_record = -1
    let mut best_start = -1
    while search < len(tree) {
        let record = pattern_find_from(
            tree,
            "pattern-diagnostic|",
            search
        )
        if record < 0 {
            search = len(tree)
        } else {
            let start = decimal_value(pattern_line_field(tree, record, 3))
            if best_start < 0 || start < best_start {
                best_record = record
                best_start = start
            }
            search = record + 1
        }
    }
    if best_record < 0 {
        return ""
    }
    return "error[E2S58]: invalid pattern (" +
    pattern_line_field(tree, best_record, 2) +
    ") at bytes " + pattern_line_field(tree, best_record, 3) + ".." +
    pattern_line_field(tree, best_record, 4)
}

fn pattern_summary(source: Text, start: Int) -> Text {
    let parsed = parse_pattern_or_result(source, start, 1, 0, 0, 0, -1)
    return pattern_result_field(parsed, 6) + "|" +
    pattern_result_field(parsed, 0)
}

fn pattern_summary_kind(summary: Text) -> Text {
    return pattern_line_field(summary, 0, 0)
}

fn pattern_summary_end(summary: Text) -> Int {
    return decimal_value(pattern_line_field(summary, 0, 1))
}

fn validate_executable_patterns(source: Text) -> Text {
    let mut cursor = skip_trivia(source, 0)
    while cursor < len(source) {
        if token_text(source, cursor) == "match" {
            let open = pattern_match_open(source, cursor)
            let mut match_end = -1
            if open >= 0 {
                match_end = balanced_end(source, open, "{", "}")
            }
            if open >= 0 && match_end >= 0 {
                let close = match_end - 1
                let mut arm = skip_trivia(source, token_end(source, open))
                while arm < close && token_text(source, arm) != "}" {
                    let summary = pattern_summary(source, arm)
                    let kind = pattern_summary_kind(summary)
                    let executable = kind == "WildcardPattern" ||
                    kind == "NamePattern" ||
                    (kind == "LiteralPattern" &&
                     (token_text(source, arm) == "true" ||
                      token_text(source, arm) == "false"))
                    if !executable {
                        return "error[E2S24]: general pattern syntax is parsed " +
                        "but not executable in Stage 2 Core at byte " +
                        to_text(arm)
                    }
                    let arrow = pattern_arm_arrow(
                        source,
                        pattern_summary_end(summary),
                        close
                    )
                    if arrow < 0 {
                        arm = close
                    } else {
                        let body = skip_trivia(
                            source,
                            token_end(source, arrow)
                        )
                        if body >= close || token_text(source, body) != "{" {
                            arm = close
                        } else {
                            let body_end = balanced_end(
                                source,
                                body,
                                "{",
                                "}"
                            )
                            if body_end < 0 {
                                arm = close
                            } else {
                                arm = skip_trivia(source, body_end)
                                if arm < close &&
                                   token_text(source, arm) == "," {
                                    arm = skip_trivia(
                                        source,
                                        token_end(source, arm)
                                    )
                                }
                            }
                        }
                    }
                }
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return "ok"
}

fn balanced_end(source: Text, start: Int, open: Text, close: Text) -> Int {
    let mut cursor = start
    let mut depth = 0
    while cursor < len(source) {
        cursor = skip_trivia(source, cursor)
        if cursor >= len(source) {
            return -1
        }
        let token = token_text(source, cursor)
        let end = token_end(source, cursor)
        if len(token) == 0 || end <= cursor {
            return -1
        }
        if token == open {
            depth = depth + 1
        } else if token == close {
            depth = depth - 1
            if depth == 0 {
                return end
            }
        }
        cursor = end
    }
    return -1
}

fn basic_visibility_modifier(source: Text, start: Int) -> Bool {
    let token = token_text(source, start)
    return token == "pub" || token == "internal" || token == "private"
}

fn visibility_word(source: Text, start: Int) -> Bool {
    let token = token_text(source, start)
    return basic_visibility_modifier(source, start) ||
    token == "public" || token == "protected"
}

fn visibility_prefix_candidate(source: Text, start: Int) -> Bool {
    if visibility_word(source, start) {
        return true
    }
    if token_kind(source, start) != "identifier" {
        return false
    }
    let next = skip_trivia(source, token_end(source, start))
    return token_text(source, next) == "fn"
}

fn function_declaration_start(source: Text, start: Int) -> Int {
    if token_text(source, start) == "fn" {
        return start
    }
    if !basic_visibility_modifier(source, start) {
        return -1
    }
    let after_modifier = skip_trivia(source, token_end(source, start))
    if after_modifier < len(source) &&
       token_text(source, after_modifier) == "fn" {
        return after_modifier
    }
    return -1
}

fn visibility_level(source: Text, start: Int) -> Text {
    if token_text(source, start) == "pub" {
        return "public"
    }
    if token_text(source, start) == "internal" {
        return "internal"
    }
    return "private"
}

fn visibility_prefix_error(source: Text, start: Int) -> Text {
    let modifier = token_text(source, start)
    if modifier == "public" || modifier == "protected" {
        return "error[E2S34]: unsupported visibility modifier `" +
        modifier + "`; use `pub`, `internal`, or `private` at bytes " +
        to_text(start) + ".." + to_text(token_end(source, start))
    }
    if !basic_visibility_modifier(source, start) {
        let next = skip_trivia(source, token_end(source, start))
        if token_kind(source, start) == "identifier" &&
           next < len(source) && token_text(source, next) == "fn" {
            return "error[E2S33]: unknown visibility modifier `" +
            modifier + "`; expected `pub`, `internal`, or `private` at bytes " +
            to_text(start) + ".." + to_text(token_end(source, start))
        }
        return ""
    }

    let next = skip_trivia(source, token_end(source, start))
    if next < len(source) && token_text(source, next) == "fn" {
        return ""
    }
    if next < len(source) && basic_visibility_modifier(source, next) {
        let second = token_text(source, next)
        let mut kind = "conflicting"
        if modifier == second {
            kind = "repeated"
        }
        return "error[E2S33]: " + kind + " visibility modifiers `" +
        modifier + "` and `" + second + "` at bytes " +
        to_text(start) + ".." + to_text(token_end(source, next))
    }
    if modifier == "pub" && next < len(source) &&
       token_text(source, next) == "(" {
        let mut form_end = balanced_end(source, next, "(", ")")
        if form_end < 0 {
            form_end = token_end(source, next)
        }
        let form_name = skip_trivia(source, token_end(source, next))
        let name = token_text(source, form_name)
        let mut form_kind = "restricted"
        if name == "crate" || name == "super" || name == "in" {
            form_kind = "Rust-style"
        }
        return "error[E2S34]: " + form_kind +
        " `pub(...)` visibility is not supported in this frontend slice at bytes " +
        to_text(start) + ".." + to_text(form_end)
    }
    return "error[E2S33]: visibility modifier `" + modifier +
    "` must be followed by a top-level `fn` declaration at bytes " +
    to_text(start) + ".." + to_text(token_end(source, start))
}

fn local_visibility_error(
    source: Text,
    function_start: Int,
    function_close: Int
) -> Text {
    let open = parameter_open(source, function_start)
    if open < 0 {
        return ""
    }
    let mut cursor = balanced_end(source, open, "(", ")")
    while cursor >= 0 && cursor < function_close &&
          token_text(source, cursor) != "{" {
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    if cursor < 0 || cursor >= function_close {
        return ""
    }
    cursor = skip_trivia(source, token_end(source, cursor))
    while cursor < function_close {
        let token = token_text(source, cursor)
        let basic = basic_visibility_modifier(source, cursor)
        let alias = token == "public" || token == "protected"
        if basic || alias {
            let next = skip_trivia(source, token_end(source, cursor))
            let next_token = token_text(source, next)
            let declaration_like = next < function_close &&
            (next_token == "fn" || next_token == "let" ||
             next_token == "var" || next_token == "type" ||
             basic_visibility_modifier(source, next))
            if declaration_like {
                let mut code = "E2S33"
                if alias {
                    code = "E2S34"
                }
                return "error[" + code + "]: visibility modifier `" +
                token + "` is not supported in local scope at bytes " +
                to_text(cursor) + ".." + to_text(token_end(source, cursor))
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return ""
}

fn function_name(source: Text, start: Int) -> Text {
    let after_fn = skip_trivia(source, token_end(source, start))
    if after_fn >= len(source) || token_kind(source, after_fn) != "identifier" {
        return ""
    }
    return token_text(source, after_fn)
}

fn parameter_open(source: Text, start: Int) -> Int {
    let after_fn = skip_trivia(source, token_end(source, start))
    let after_name = skip_trivia(source, token_end(source, after_fn))
    if after_name >= len(source) || token_text(source, after_name) != "(" {
        return -1
    }
    return after_name
}

fn parameter_count(source: Text, start: Int) -> Int {
    let open = parameter_open(source, start)
    if open < 0 {
        return -1
    }
    let close = balanced_end(source, open, "(", ")")
    if close < 0 {
        return -1
    }

    let mut cursor = skip_trivia(source, token_end(source, open))
    if cursor >= close || token_text(source, cursor) == ")" {
        return 0
    }

    let mut count = 1
    let mut paren_depth = 0
    let mut bracket_depth = 0
    while cursor < close {
        let token = token_text(source, cursor)
        if token == "(" {
            paren_depth = paren_depth + 1
        } else if token == ")" {
            if paren_depth == 0 {
                return count
            }
            paren_depth = paren_depth - 1
        } else if token == "[" {
            bracket_depth = bracket_depth + 1
        } else if token == "]" {
            bracket_depth = bracket_depth - 1
        } else if token == "," && paren_depth == 0 && bracket_depth == 0 {
            count = count + 1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return count
}

fn function_end(source: Text, start: Int) -> Int {
    if token_text(source, start) != "fn" || len(function_name(source, start)) == 0 {
        return -1
    }

    let open = parameter_open(source, start)
    if open < 0 {
        return -1
    }
    let parameters_end = balanced_end(source, open, "(", ")")
    if parameters_end < 0 {
        return -1
    }

    let mut cursor = skip_trivia(source, parameters_end)
    if cursor < len(source) && token_text(source, cursor) == "->" {
        cursor = skip_trivia(source, token_end(source, cursor))
        let mut type_tokens = 0
        while cursor < len(source) && token_text(source, cursor) != "{" {
            if token_text(source, cursor) == "=" {
                return -1
            }
            type_tokens = type_tokens + 1
            cursor = skip_trivia(source, token_end(source, cursor))
        }
        if type_tokens == 0 {
            return -1
        }
    }

    if cursor >= len(source) || token_text(source, cursor) != "{" {
        return -1
    }
    return balanced_end(source, cursor, "{", "}")
}

fn type_name(source: Text, start: Int) -> Text {
    let name = skip_trivia(source, token_end(source, start))
    if name >= len(source) || token_kind(source, name) != "identifier" {
        return ""
    }
    return token_text(source, name)
}

fn type_declaration_end(source: Text, start: Int) -> Int {
    if token_text(source, start) != "type" || len(type_name(source, start)) == 0 {
        return -1
    }
    let name = skip_trivia(source, token_end(source, start))
    let equals = skip_trivia(source, token_end(source, name))
    if equals >= len(source) || token_text(source, equals) != "=" {
        return -1
    }
    let mut pipe = skip_trivia(source, token_end(source, equals))
    let mut constructors = 0
    let mut last_end = -1
    while pipe < len(source) && token_text(source, pipe) == "|" {
        let constructor = skip_trivia(source, token_end(source, pipe))
        if constructor >= len(source) ||
           token_kind(source, constructor) != "identifier" {
            return -1
        }
        constructors = constructors + 1
        if constructors > 64 {
            return -2
        }
        last_end = token_end(source, constructor)
        pipe = skip_trivia(source, last_end)
        if pipe < len(source) && token_text(source, pipe) == "(" {
            let payload_end = balanced_end(source, pipe, "(", ")")
            if payload_end < 0 {
                return -1
            }
            last_end = payload_end
            pipe = skip_trivia(source, payload_end)
        }
    }
    if constructors == 0 {
        return -1
    }
    if pipe < len(source) && token_text(source, pipe) != "fn" &&
       token_text(source, pipe) != "type" &&
       !visibility_prefix_candidate(source, pipe) {
        return -1
    }
    return last_end
}

fn top_level_end(source: Text, start: Int) -> Int {
    if token_text(source, start) == "type" {
        return type_declaration_end(source, start)
    }
    let function_start = function_declaration_start(source, start)
    if function_start < 0 {
        return -1
    }
    return function_end(source, function_start)
}

fn after_optional_module_header(source: Text, start: Int) -> Int {
    let mut cursor = skip_trivia(source, start)
    if token_text(source, cursor) != "module" {
        return cursor
    }
    cursor = skip_trivia(source, token_end(source, cursor))
    while cursor < len(source) && token_text(source, cursor) != "type" &&
          token_text(source, cursor) != "fn" &&
          !visibility_prefix_candidate(source, cursor) {
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return cursor
}

fn next_function_start(source: Text, start: Int) -> Int {
    let mut cursor = after_optional_module_header(source, start)
    while cursor < len(source) && token_text(source, cursor) == "type" {
        let end = type_declaration_end(source, cursor)
        if end <= cursor {
            return len(source)
        }
        cursor = skip_trivia(source, end)
    }
    let function_start = function_declaration_start(source, cursor)
    if function_start < 0 {
        return cursor
    }
    return function_start
}

fn enum_declaration_start(source: Text, wanted: Text) -> Int {
    let mut cursor = after_optional_module_header(source, 0)
    while cursor < len(source) {
        if token_text(source, cursor) == "type" &&
           type_name(source, cursor) == wanted {
            return cursor
        }
        let end = top_level_end(source, cursor)
        if end <= cursor {
            return -1
        }
        cursor = skip_trivia(source, end)
    }
    return -1
}

fn enum_constructor_count(source: Text, enum_type: Text) -> Int {
    let declaration = enum_declaration_start(source, enum_type)
    if declaration < 0 {
        return -1
    }
    let name = skip_trivia(source, token_end(source, declaration))
    let equals = skip_trivia(source, token_end(source, name))
    let mut pipe = skip_trivia(source, token_end(source, equals))
    let end = type_declaration_end(source, declaration)
    let mut count = 0
    while pipe < end && token_text(source, pipe) == "|" {
        let constructor = skip_trivia(source, token_end(source, pipe))
        count = count + 1
        pipe = skip_trivia(source, token_end(source, constructor))
    }
    return count
}

fn enum_constructor_index(
    source: Text,
    enum_type: Text,
    wanted: Text
) -> Int {
    let declaration = enum_declaration_start(source, enum_type)
    if declaration < 0 {
        return -1
    }
    let name = skip_trivia(source, token_end(source, declaration))
    let equals = skip_trivia(source, token_end(source, name))
    let mut pipe = skip_trivia(source, token_end(source, equals))
    let end = type_declaration_end(source, declaration)
    let mut tag = 0
    while pipe < end && token_text(source, pipe) == "|" {
        let constructor = skip_trivia(source, token_end(source, pipe))
        if token_text(source, constructor) == wanted {
            return tag
        }
        tag = tag + 1
        pipe = skip_trivia(source, token_end(source, constructor))
    }
    return -1
}

fn enum_constructor_owner(source: Text, wanted: Text) -> Text {
    let mut cursor = skip_trivia(source, 0)
    while cursor < len(source) {
        if token_text(source, cursor) == "type" {
            let enum_type = type_name(source, cursor)
            if enum_constructor_index(source, enum_type, wanted) >= 0 {
                return enum_type
            }
        }
        let end = top_level_end(source, cursor)
        if end <= cursor {
            return ""
        }
        cursor = skip_trivia(source, end)
    }
    return ""
}

fn enum_declaration_names(source: Text, constructors: Bool) -> Text {
    let mut names = "|"
    let mut cursor = skip_trivia(source, 0)
    while cursor < len(source) {
        if token_text(source, cursor) == "type" {
            if constructors {
                let type_cursor = skip_trivia(
                    source,
                    token_end(source, cursor)
                )
                let equals = skip_trivia(
                    source,
                    token_end(source, type_cursor)
                )
                let mut pipe = skip_trivia(
                    source,
                    token_end(source, equals)
                )
                let end = type_declaration_end(source, cursor)
                while pipe < end && token_text(source, pipe) == "|" {
                    let constructor = skip_trivia(
                        source,
                        token_end(source, pipe)
                    )
                    names = names + token_text(source, constructor) + "|"
                    pipe = skip_trivia(
                        source,
                        token_end(source, constructor)
                    )
                }
            } else {
                names = names + type_name(source, cursor) + "|"
            }
        }
        let end = top_level_end(source, cursor)
        if end <= cursor {
            return names
        }
        cursor = skip_trivia(source, end)
    }
    return names
}

fn enum_constructors_covered(
    source: Text,
    enum_type: Text,
    covered: Text
) -> Bool {
    let declaration = enum_declaration_start(source, enum_type)
    if declaration < 0 {
        return false
    }
    let name = skip_trivia(source, token_end(source, declaration))
    let equals = skip_trivia(source, token_end(source, name))
    let mut pipe = skip_trivia(source, token_end(source, equals))
    let end = type_declaration_end(source, declaration)
    while pipe < end && token_text(source, pipe) == "|" {
        let constructor = skip_trivia(source, token_end(source, pipe))
        let constructor_name = token_text(source, constructor)
        if !contains(covered, "|" + constructor_name + "|") {
            return false
        }
        pipe = skip_trivia(source, token_end(source, constructor))
    }
    return true
}

fn enum_missing_constructors(
    source: Text,
    enum_type: Text,
    covered: Text
) -> Text {
    let declaration = enum_declaration_start(source, enum_type)
    let name = skip_trivia(source, token_end(source, declaration))
    let equals = skip_trivia(source, token_end(source, name))
    let mut pipe = skip_trivia(source, token_end(source, equals))
    let end = type_declaration_end(source, declaration)
    let mut missing = ""
    while pipe < end && token_text(source, pipe) == "|" {
        let constructor = skip_trivia(source, token_end(source, pipe))
        let constructor_name = token_text(source, constructor)
        if !contains(covered, "|" + constructor_name + "|") {
            if len(missing) > 0 {
                missing = missing + ", "
            }
            missing = missing + "`" + constructor_name + "`"
        }
        pipe = skip_trivia(source, token_end(source, constructor))
    }
    return missing
}

fn reserved_type_name(name: Text) -> Bool {
    return name == "Int" || name == "Bool" || name == "Float" ||
    name == "Unit" || name == "Text" || name == "List" || name == "_"
}

fn parse_program(source: Text) -> Text {
    let mut ir = "kofun-stage2-ir/v1\nsource-bytes|" +
    to_text(len(source)) + "\n"
    let mut cursor = skip_trivia(source, 0)
    let mut functions = 0
    let mut types = 0
    let mut declared_types = "|"
    let mut declared_constructors = "|"
    while cursor < len(source) {
        let visibility_error = visibility_prefix_error(source, cursor)
        if len(visibility_error) > 0 {
            return visibility_error
        }
        if token_text(source, cursor) == "type" {
            let name = type_name(source, cursor)
            let end = type_declaration_end(source, cursor)
            if end == -2 {
                return "error[E2S31]: concrete enum constructor limit is 64 at byte " +
                to_text(cursor)
            }
            if len(name) == 0 || end < 0 {
                return "error[E2S31]: malformed concrete enum declaration at byte " +
                to_text(cursor)
            }
            if reserved_type_name(name) {
                return "error[E2S31]: concrete enum cannot shadow built-in type `" +
                name + "` at byte " + to_text(cursor)
            }
            types = types + 1
            if types > 32 {
                return "error[E2S31]: concrete enum limit is 32 types at byte " +
                to_text(cursor)
            }
            if contains(declared_types, "|" + name + "|") {
                return "error[E2S31]: duplicate concrete enum type `" + name +
                "` at byte " + to_text(cursor)
            }
            if contains(declared_constructors, "|" + name + "|") {
                return "error[E2S31]: concrete enum type `" + name +
                "` conflicts with a constructor at byte " + to_text(cursor)
            }
            declared_types = declared_types + name + "|"
            let count = enum_constructor_count(source, name)
            if count < 1 {
                return "error[E2S31]: concrete enum must declare a constructor at byte " +
                to_text(cursor)
            }
            if count > 64 {
                return "error[E2S31]: concrete enum constructor limit is 64 at byte " +
                to_text(cursor)
            }
            ir = ir + "type|" + name + "|" + to_text(count) + "|" +
            to_text(cursor) + "|" + to_text(end) + "\n"
            let name_cursor = skip_trivia(source, token_end(source, cursor))
            let equals = skip_trivia(source, token_end(source, name_cursor))
            let mut pipe = skip_trivia(source, token_end(source, equals))
            let mut tag = 0
            while pipe < end && token_text(source, pipe) == "|" {
                let constructor = skip_trivia(source, token_end(source, pipe))
                let constructor_name = token_text(source, constructor)
                if constructor_name == "_" {
                    return "error[E2S31]: `_` is reserved for enum catch-all patterns at byte " +
                    to_text(constructor)
                }
                if contains(
                    declared_constructors,
                    "|" + constructor_name + "|"
                ) {
                    return "error[E2S31]: duplicate concrete enum constructor `" +
                    constructor_name + "` at byte " + to_text(constructor)
                }
                if contains(declared_types, "|" + constructor_name + "|") {
                    return "error[E2S31]: concrete enum constructor `" +
                    constructor_name + "` conflicts with an enum type at byte " +
                    to_text(constructor)
                }
                declared_constructors = declared_constructors +
                constructor_name + "|"
                ir = ir + "constructor|" + constructor_name + "|" +
                name + "|" + to_text(tag) + "|" +
                to_text(constructor) + "|" +
                to_text(token_end(source, constructor)) + "\n"
                tag = tag + 1
                pipe = skip_trivia(source, token_end(source, constructor))
            }
            cursor = skip_trivia(source, end)
        } else if function_declaration_start(source, cursor) < 0 {
            return "error[E2S02]: expected top-level `fn` or `type` at byte " +
            to_text(cursor)
        } else {
            let declaration_start = cursor
            let function_start = function_declaration_start(
                source,
                declaration_start
            )
            let name = function_name(source, function_start)
            let arity = parameter_count(source, function_start)
            let end = function_end(source, function_start)
            if len(name) == 0 || arity < 0 || end < 0 {
                return "error[E2S03]: malformed function at byte " +
                to_text(function_start)
            }
            let local_error = local_visibility_error(
                source,
                function_start,
                end
            )
            if len(local_error) > 0 {
                return local_error
            }
            let explicit_visibility = declaration_start != function_start
            let mut origin = "implicit"
            let mut modifier_start = -1
            let mut modifier_end = -1
            if explicit_visibility {
                origin = "explicit"
                modifier_start = declaration_start
                modifier_end = token_end(source, declaration_start)
            }
            ir = ir + "function|" + name + "|" + to_text(arity) + "|" +
            to_text(function_start) + "|" + to_text(end) + "|" +
            visibility_level(source, declaration_start) + "|" + origin + "|" +
            to_text(modifier_start) + "|" + to_text(modifier_end) + "|" +
            to_text(declaration_start) + "|" + to_text(end) +
            "|file:0|symbol:" + to_text(functions) + "\n"
            functions = functions + 1
            cursor = skip_trivia(source, end)
        }
    }
    if functions == 0 {
        return "error[E2S04]: compilation unit has no functions"
    }
    ir = ir + "function-count|" + to_text(functions) + "\n"
    let patterns = parse_pattern_trees(source)
    let pattern_error = pattern_first_error(patterns)
    if len(pattern_error) > 0 {
        return pattern_error
    }
    return ir + patterns
}

fn copy_type(type_name: Text) -> Bool {
    return type_name == "Int" || type_name == "Float" ||
    type_name == "Bool" || type_name == "Unit"
}

fn return_move_at(
    source: Text,
    body_open: Int,
    body_end: Int,
    element_name: Text
) -> Int {
    let mut cursor = skip_trivia(source, token_end(source, body_open))
    while cursor < body_end {
        if token_text(source, cursor) == "return" {
            let return_line = line_at(source, cursor)
            let mut value_cursor = skip_trivia(
                source,
                token_end(source, cursor)
            )
            while value_cursor < body_end &&
                  line_at(source, value_cursor) == return_line {
                if token_text(source, value_cursor) == element_name {
                    return value_cursor
                }
                value_cursor = skip_trivia(
                    source,
                    token_end(source, value_cursor)
                )
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return -1
}

fn borrowed_collection_check(source: Text) -> Text {
    let mut function_cursor = next_function_start(source, 0)
    let mut recognized_loops = 0
    while function_cursor < len(source) {
        let parameters_open = parameter_open(source, function_cursor)
        if parameters_open < 0 {
            return "error[E2S03]: malformed function"
        }
        let parameters_end = balanced_end(
            source,
            parameters_open,
            "(",
            ")"
        )
        if parameters_end < 0 {
            return "error[E2S03]: malformed parameters"
        }

        let mut borrowed_name = ""
        let mut element_type = ""
        let mut borrowed_lists = 0
        let mut parameter_cursor = skip_trivia(
            source,
            token_end(source, parameters_open)
        )
        while parameter_cursor < parameters_end &&
              token_text(source, parameter_cursor) != ")" {
            if token_text(source, parameter_cursor) == "read" {
                let name_cursor = skip_trivia(
                    source,
                    token_end(source, parameter_cursor)
                )
                let colon_cursor = skip_trivia(
                    source,
                    token_end(source, name_cursor)
                )
                let list_cursor = skip_trivia(
                    source,
                    token_end(source, colon_cursor)
                )
                let bracket_cursor = skip_trivia(
                    source,
                    token_end(source, list_cursor)
                )
                let element_cursor = skip_trivia(
                    source,
                    token_end(source, bracket_cursor)
                )
                if token_kind(source, name_cursor) == "identifier" &&
                   token_text(source, colon_cursor) == ":" &&
                   token_text(source, list_cursor) == "List" &&
                   token_text(source, bracket_cursor) == "[" &&
                   token_kind(source, element_cursor) == "identifier" {
                    borrowed_lists = borrowed_lists + 1
                    if borrowed_lists > 1 {
                        return "error[E2S21]: ownership slice supports one borrowed List parameter per function"
                    }
                    borrowed_name = token_text(source, name_cursor)
                    element_type = token_text(source, element_cursor)
                }
            }
            parameter_cursor = skip_trivia(
                source,
                token_end(source, parameter_cursor)
            )
        }

        let function_end_cursor = function_end(source, function_cursor)
        let mut body_open = skip_trivia(source, parameters_end)
        while body_open < function_end_cursor &&
              token_text(source, body_open) != "{" {
            body_open = skip_trivia(source, token_end(source, body_open))
        }
        if function_end_cursor < 0 || body_open >= function_end_cursor {
            return "error[E2S03]: malformed function body"
        }

        let mut cursor = skip_trivia(source, token_end(source, body_open))
        while cursor < function_end_cursor {
            if token_text(source, cursor) == "for" {
                let element_cursor = skip_trivia(
                    source,
                    token_end(source, cursor)
                )
                let in_cursor = skip_trivia(
                    source,
                    token_end(source, element_cursor)
                )
                let collection_cursor = skip_trivia(
                    source,
                    token_end(source, in_cursor)
                )
                let loop_open = skip_trivia(
                    source,
                    token_end(source, collection_cursor)
                )
                if token_kind(source, element_cursor) == "identifier" &&
                   token_text(source, in_cursor) == "in" &&
                   token_kind(source, collection_cursor) == "identifier" &&
                   token_text(source, loop_open) == "{" {
                    let loop_end = balanced_end(source, loop_open, "{", "}")
                    if loop_end < 0 {
                        return "error[E2S03]: malformed for body"
                    }
                    if len(borrowed_name) > 0 &&
                       token_text(source, collection_cursor) == borrowed_name {
                        recognized_loops = recognized_loops + 1
                        let element_name = token_text(source, element_cursor)
                        let move_at = return_move_at(
                            source,
                            loop_open,
                            loop_end,
                            element_name
                        )
                        if move_at >= 0 && !copy_type(element_type) {
                            return "error[E007]: cannot move non-Copy element `" +
                            element_name + ": " + element_type +
                            "` out of borrowed collection `" + borrowed_name +
                            "` at line " + to_text(line_at(source, move_at)) +
                            "; return a Copy scalar or clone the element"
                        }
                    }
                }
            }
            cursor = skip_trivia(source, token_end(source, cursor))
        }
        function_cursor = next_function_start(source, function_end_cursor)
    }
    if recognized_loops == 0 {
        return "error[E2S20]: Stage 2 ownership slice requires `for element in read_list`"
    }
    return "ok"
}

fn primary_end(source: Text, start: Int) -> Int {
    let cursor = skip_trivia(source, start)
    if cursor >= len(source) {
        return -1
    }
    let kind = token_kind(source, cursor)
    if kind == "integer" {
        return token_end(source, cursor)
    }
    if kind == "identifier" {
        let open = skip_trivia(source, token_end(source, cursor))
        if open >= len(source) || token_text(source, open) != "(" {
            return token_end(source, cursor)
        }
        let mut argument = skip_trivia(source, token_end(source, open))
        if argument < len(source) && token_text(source, argument) == ")" {
            return token_end(source, argument)
        }
        while argument < len(source) {
            let argument_end = expression_end(source, argument)
            if argument_end < 0 {
                return -1
            }
            let separator = skip_trivia(source, argument_end)
            if separator < len(source) &&
               token_text(source, separator) == ")" {
                return token_end(source, separator)
            }
            if separator >= len(source) ||
               token_text(source, separator) != "," {
                return -1
            }
            argument = skip_trivia(source, token_end(source, separator))
        }
        return -1
    }
    if token_text(source, cursor) == "(" {
        let value_start = skip_trivia(source, token_end(source, cursor))
        let value_end = expression_end(source, value_start)
        if value_end < 0 {
            return -1
        }
        let close = skip_trivia(source, value_end)
        if close >= len(source) || token_text(source, close) != ")" {
            return -1
        }
        return token_end(source, close)
    }
    return -1
}

fn unary_end(source: Text, start: Int) -> Int {
    let cursor = skip_trivia(source, start)
    let token = token_text(source, cursor)
    if token == "+" || token == "-" {
        return unary_end(source, skip_trivia(source, token_end(source, cursor)))
    }
    return primary_end(source, cursor)
}

fn product_end(source: Text, start: Int) -> Int {
    let mut cursor = unary_end(source, start)
    if cursor < 0 {
        return -1
    }
    let mut operator_start = skip_trivia(source, cursor)
    while operator_start < len(source) &&
          (token_text(source, operator_start) == "*" ||
           token_text(source, operator_start) == "//" ||
           token_text(source, operator_start) == "%") {
        let right_start = skip_trivia(
            source,
            token_end(source, operator_start)
        )
        cursor = unary_end(source, right_start)
        if cursor < 0 {
            return -1
        }
        operator_start = skip_trivia(source, cursor)
    }
    return cursor
}

fn expression_end(source: Text, start: Int) -> Int {
    let mut cursor = product_end(source, start)
    if cursor < 0 {
        return -1
    }
    let mut operator_start = skip_trivia(source, cursor)
    while operator_start < len(source) &&
          (token_text(source, operator_start) == "+" ||
           token_text(source, operator_start) == "-") {
        let right_start = skip_trivia(
            source,
            token_end(source, operator_start)
        )
        cursor = product_end(source, right_start)
        if cursor < 0 {
            return -1
        }
        operator_start = skip_trivia(source, cursor)
    }
    return cursor
}

fn emit_primary(source: Text, hir: Text, start: Int, end: Int) -> Text {
    let cursor = skip_trivia(source, start)
    let kind = token_kind(source, cursor)
    if kind == "integer" {
        return "INT64_C(" +
        replace(text_slice(source, cursor, end), "_", "") + ")"
    }
    if kind == "identifier" {
        let name = token_text(source, cursor)
        let open = skip_trivia(source, token_end(source, cursor))
        if open >= end || token_text(source, open) != "(" {
            return "k_b" + hir_use_binding_id(hir, cursor)
        }
        let mut emitted = "kofun_fn_" + name + "("
        let mut argument = skip_trivia(source, token_end(source, open))
        let mut arguments = 0
        while argument < end && token_text(source, argument) != ")" {
            let argument_end = expression_end(source, argument)
            if arguments > 0 {
                emitted = emitted + ", "
            }
            emitted = emitted +
            emit_expression(source, hir, argument, argument_end)
            arguments = arguments + 1
            let separator = skip_trivia(source, argument_end)
            if separator < end && token_text(source, separator) == "," {
                argument = skip_trivia(source, token_end(source, separator))
            } else {
                argument = separator
            }
        }
        return emitted + ")"
    }
    if token_text(source, cursor) == "(" {
        let value_start = skip_trivia(source, token_end(source, cursor))
        let close = skip_trivia(source, expression_end(source, value_start))
        return "(" + emit_expression(source, hir, value_start, close) + ")"
    }
    return ""
}

fn emit_unary(source: Text, hir: Text, start: Int, end: Int) -> Text {
    let cursor = skip_trivia(source, start)
    let token = token_text(source, cursor)
    if token == "+" {
        let value_start = skip_trivia(source, token_end(source, cursor))
        return emit_unary(source, hir, value_start, end)
    }
    if token == "-" {
        let value_start = skip_trivia(source, token_end(source, cursor))
        return "kofun_neg(" + emit_unary(source, hir, value_start, end) + ")"
    }
    return emit_primary(source, hir, cursor, end)
}

fn emit_product(source: Text, hir: Text, start: Int, end: Int) -> Text {
    let mut cursor = unary_end(source, start)
    let mut emitted = emit_unary(source, hir, start, cursor)
    let mut operator_start = skip_trivia(source, cursor)
    while operator_start < end {
        let operator = token_text(source, operator_start)
        let right_start = skip_trivia(
            source,
            token_end(source, operator_start)
        )
        let right_end = unary_end(source, right_start)
        let right = emit_unary(source, hir, right_start, right_end)
        if operator == "*" {
            emitted = "kofun_mul(" + emitted + ", " + right + ")"
        } else if operator == "//" {
            emitted = "kofun_floor_div(" + emitted + ", " + right + ")"
        } else if operator == "%" {
            emitted = "kofun_floor_mod(" + emitted + ", " + right + ")"
        }
        cursor = right_end
        operator_start = skip_trivia(source, cursor)
    }
    return emitted
}

fn emit_expression(source: Text, hir: Text, start: Int, end: Int) -> Text {
    let mut cursor = product_end(source, start)
    let mut emitted = emit_product(source, hir, start, cursor)
    let mut operator_start = skip_trivia(source, cursor)
    while operator_start < end {
        let operator = token_text(source, operator_start)
        let right_start = skip_trivia(
            source,
            token_end(source, operator_start)
        )
        let right_end = product_end(source, right_start)
        let right = emit_product(source, hir, right_start, right_end)
        if operator == "+" {
            emitted = "kofun_add(" + emitted + ", " + right + ")"
        } else if operator == "-" {
            emitted = "kofun_sub(" + emitted + ", " + right + ")"
        }
        cursor = right_end
        operator_start = skip_trivia(source, cursor)
    }
    return emitted
}

fn function_arity(source: Text, wanted: Text) -> Int {
    let mut cursor = next_function_start(source, 0)
    let mut found = -1
    while cursor < len(source) {
        if function_name(source, cursor) == wanted {
            if found >= 0 {
                return -2
            }
            found = parameter_count(source, cursor)
        }
        cursor = next_function_start(source, function_end(source, cursor))
    }
    return found
}

fn call_arity(source: Text, open: Int) -> Int {
    let mut cursor = skip_trivia(source, token_end(source, open))
    if cursor < len(source) && token_text(source, cursor) == ")" {
        return 0
    }
    let mut arity = 0
    while cursor < len(source) {
        let mut argument_end = expression_end(source, cursor)
        if argument_end < 0 {
            # Text-literal arguments are single tokens outside the bounded
            # arithmetic expression grammar.
            argument_end = token_end(source, cursor)
        }
        arity = arity + 1
        let separator = skip_trivia(source, argument_end)
        if separator < len(source) && token_text(source, separator) == ")" {
            return arity
        }
        if separator >= len(source) || token_text(source, separator) != "," {
            return -1
        }
        cursor = skip_trivia(source, token_end(source, separator))
    }
    return -1
}

# The 16 host builtins of the frozen self-host profile (#618/#619), keyed by
# arity. `print` stays a statement-level special case. `len` is one name here;
# its Text/List[Text] overload is resolved by type, not arity. Builtin calls
# are known and arity-checked, but the bounded Int C11 slice cannot lower
# them yet, so accepted uses classify as unsupported lowering, never as an
# unknown-function source error.
fn builtin_arity(name: Text) -> Int {
    if name == "args" {
        return 0
    }
    if name == "chars" || name == "is_digit" || name == "is_space" ||
       name == "is_xid_continue" || name == "len" || name == "read_text" ||
       name == "trim" || name == "validate_unicode_source" {
        return 1
    }
    if name == "contains" || name == "find" || name == "starts_with" ||
       name == "write_text" {
        return 2
    }
    if name == "replace" || name == "text_slice" {
        return 3
    }
    return 0 - 1
}

# Parameter types of the profile builtins, `|`-separated in order.
# `len` accepts either Text or List (its only overload); every other
# signature is exact.
fn builtin_parameter_types(name: Text) -> Text {
    if name == "args" {
        return ""
    }
    if name == "chars" || name == "is_digit" || name == "is_space" ||
       name == "is_xid_continue" || name == "read_text" || name == "trim" ||
       name == "validate_unicode_source" {
        return "Text"
    }
    if name == "len" {
        return "TextOrList"
    }
    if name == "contains" || name == "find" || name == "starts_with" ||
       name == "write_text" {
        return "Text|Text"
    }
    if name == "replace" {
        return "Text|Text|Text"
    }
    if name == "text_slice" {
        return "Text|Int|Int"
    }
    return "none"
}

# Body `{` of the function declaration that contains `position`.
fn enclosing_function_open(source: Text, position: Int) -> Int {
    let mut cursor = next_function_start(source, 0)
    while cursor < len(source) {
        let close = function_end(source, cursor)
        if cursor <= position && position < close {
            let parameters = parameter_open(source, cursor)
            if parameters < 0 {
                return 0 - 1
            }
            let parameters_close = balanced_end(source, parameters, "(", ")")
            if parameters_close < 0 {
                return 0 - 1
            }
            let mut open = skip_trivia(source, parameters_close)
            while open < close && token_text(source, open) != "{" {
                open = skip_trivia(source, token_end(source, open))
            }
            if open < close {
                return open
            }
            return 0 - 1
        }
        cursor = next_function_start(source, close)
    }
    return 0 - 1
}

fn expected_parameter_head(parameters: Text) -> Text {
    let separator = find(parameters, "|")
    if separator < 0 {
        return parameters
    }
    return text_slice(parameters, 0, separator)
}

fn expected_parameter_tail(parameters: Text) -> Text {
    let separator = find(parameters, "|")
    if separator < 0 {
        return ""
    }
    return text_slice(parameters, separator + 1, len(parameters))
}

# Check one builtin call's argument types against its frozen signature.
# Arguments whose bounded type cannot be established (value-control
# initializers) are skipped rather than rejected. Returns an error string
# or empty text.
fn builtin_argument_check(
    source: Text,
    hir: Text,
    name: Text,
    call_name: Int,
    open: Int
) -> Text {
    let mut parameters = builtin_parameter_types(name)
    if parameters == "none" {
        return ""
    }
    let function_open = enclosing_function_open(source, call_name)
    if function_open < 0 {
        return ""
    }
    let mut argument = skip_trivia(source, token_end(source, open))
    let mut index = 1
    let mut checking = true
    while checking && argument < len(source) &&
          token_text(source, argument) != ")" && len(parameters) > 0 {
        let expected = expected_parameter_head(parameters)
        if !value_control(token_text(source, argument)) {
            let actual = initializer_type(
                source,
                hir,
                function_open,
                argument
            )
            let mut matches = actual == expected
            if expected == "TextOrList" {
                matches = actual == "Text" || actual == "List"
            }
            if !matches {
                return "error[E2S15]: builtin `" + name + "` expects " +
                expected + " for argument " + to_text(index) + ", got " +
                actual + " at byte " + to_text(argument)
            }
        }
        let mut argument_end = expression_end(source, argument)
        if argument_end < 0 {
            # Text-literal arguments are single tokens outside the bounded
            # arithmetic expression grammar.
            argument_end = token_end(source, argument)
        }
        let separator = skip_trivia(source, argument_end)
        if separator >= len(source) ||
           token_text(source, separator) != "," {
            checking = false
        } else {
            argument = skip_trivia(source, token_end(source, separator))
            parameters = expected_parameter_tail(parameters)
            index = index + 1
        }
    }
    return ""
}

fn newline_between(source: Text, start: Int, finish: Int) -> Bool {
    return contains(text_slice(source, start, finish), "\n")
}

# Bounded condition and return typing for the whole profile surface,
# ordered before the unsupported-lowering classification so the frozen
# self-host source is fully checked. Statement `if`/`while` conditions
# must not be confidently non-Bool (the E2S23 message shape is reused
# byte for byte for `if`); value returns must not confidently mismatch
# the declared result type. Match guards, value-position `if`, and
# value-control operands are skipped rather than guessed.
fn validate_core_types(source: Text, hir: Text) -> Text {
    let mut function_start = next_function_start(source, 0)
    while function_start < len(source) {
        let function_close = function_end(source, function_start)
        let name = function_name(source, function_start)
        let declared = function_return_type(source, name)
        let mut probe = function_start
        if function_start < function_close {
            probe = function_close - 1
        }
        let function_open = enclosing_function_open(source, probe)
        if function_open >= 0 {
            let mut previous_start = function_open
            let mut cursor = skip_trivia(
                source,
                token_end(source, function_open)
            )
            while cursor < function_close {
                let statement_context =
                    token_text(source, previous_start) == "{" ||
                    token_text(source, previous_start) == "}" ||
                    token_text(source, previous_start) == "else" ||
                    newline_between(
                        source,
                        token_end(source, previous_start),
                        cursor
                    )
                let keyword = token_text(source, cursor)
                if (keyword == "if" || keyword == "while") &&
                   statement_context {
                    let condition = skip_trivia(
                        source,
                        token_end(source, cursor)
                    )
                    if condition < function_close {
                        let condition_type = initializer_type(
                            source,
                            hir,
                            function_open,
                            condition
                        )
                        if condition_type == "Int" ||
                           condition_type == "Text" ||
                           condition_type == "List" {
                            if keyword == "if" {
                                return "error[E2S23]: if condition must be Bool or an Int comparison at byte " +
                                to_text(condition)
                            }
                            return "error[E2S23]: while condition must be Bool at byte " +
                            to_text(condition)
                        }
                    }
                }
                if keyword == "return" && statement_context &&
                   len(declared) > 0 && declared != "Void" {
                    let value = skip_trivia(
                        source,
                        token_end(source, cursor)
                    )
                    let bare =
                        value >= function_close ||
                        token_text(source, value) == "}" ||
                        newline_between(
                            source,
                            token_end(source, cursor),
                            value
                        )
                    if !bare && !value_control(token_text(source, value)) {
                        let value_type = initializer_type(
                            source,
                            hir,
                            function_open,
                            value
                        )
                        let known =
                            value_type == "Int" || value_type == "Bool" ||
                            value_type == "Text" || value_type == "List"
                        if known && value_type != declared {
                            return "error[E2S15]: Core function `" + name +
                            "` returns " + value_type + ", expected " +
                            declared + " at byte " + to_text(value)
                        }
                    }
                }
                previous_start = cursor
                cursor = skip_trivia(source, token_end(source, cursor))
            }
        }
        function_start = next_function_start(source, function_close)
    }
    return "ok"
}

fn validate_core_calls(source: Text, hir: Text) -> Text {
    let mut cursor = next_function_start(source, 0)
    let mut previous = ""
    while cursor < len(source) {
        if token_kind(source, cursor) == "identifier" {
            let name = token_text(source, cursor)
            let open = skip_trivia(source, token_end(source, cursor))
            if previous != "fn" && name != "print" &&
               open < len(source) && token_text(source, open) == "(" {
                let expected = function_arity(source, name)
                if expected == -2 {
                    return "error[E2S16]: duplicate Core function `" + name +
                    "` at byte " + to_text(cursor)
                }
                if expected < 0 {
                    let builtin_expected = builtin_arity(name)
                    if builtin_expected < 0 {
                        return "error[E2S16]: unknown Core function `" +
                        name + "` at byte " + to_text(cursor)
                    }
                    let builtin_actual = call_arity(source, open)
                    if builtin_actual != builtin_expected {
                        return "error[E2S17]: Core function `" + name +
                        "` expects " + to_text(builtin_expected) +
                        " arguments, got " + to_text(builtin_actual) +
                        " at byte " + to_text(cursor)
                    }
                    let argument_error = builtin_argument_check(
                        source,
                        hir,
                        name,
                        cursor,
                        open
                    )
                    if len(argument_error) > 0 {
                        return argument_error
                    }
                    return "error[E2S10]: unsupported Core builtin call `" +
                    name + "` at byte " + to_text(cursor)
                }
                let actual = call_arity(source, open)
                if actual != expected {
                    return "error[E2S17]: Core function `" + name +
                    "` expects " + to_text(expected) + " arguments, got " +
                    to_text(actual) + " at byte " + to_text(cursor)
                }
            }
        }
        previous = token_text(source, cursor)
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return "ok"
}

fn core_parameters(
    source: Text,
    hir: Text,
    function_start: Int
) -> Text {
    let parameters = parameter_open(source, function_start)
    if parameters < 0 {
        return "error[E2S15]: malformed Core parameter list"
    }
    let parameters_end = balanced_end(source, parameters, "(", ")")
    if parameters_end < 0 {
        return "error[E2S15]: malformed Core parameter list"
    }
    let mut cursor = skip_trivia(source, token_end(source, parameters))
    let mut emitted = ""
    let mut count = 0
    while cursor < parameters_end && token_text(source, cursor) != ")" {
        if token_kind(source, cursor) != "identifier" {
            return "error[E2S15]: expected Core parameter name at byte " +
            to_text(cursor)
        }
        let name = token_text(source, cursor)
        let colon = skip_trivia(source, token_end(source, cursor))
        let type_cursor = skip_trivia(source, token_end(source, colon))
        if colon >= parameters_end || token_text(source, colon) != ":" ||
           type_cursor >= parameters_end ||
           token_text(source, type_cursor) != "Int" {
            return "error[E2S15]: Core parameters must have type Int at byte " +
            to_text(cursor)
        }
        if count > 0 {
            emitted = emitted + ", "
        }
        emitted = emitted + "int64_t k_b" +
        hir_definition_id_at(hir, cursor)
        count = count + 1
        let separator = skip_trivia(source, token_end(source, type_cursor))
        if separator < parameters_end &&
           token_text(source, separator) == "," {
            cursor = skip_trivia(source, token_end(source, separator))
        } else {
            cursor = separator
        }
    }
    return emitted
}

fn comparison_operator(token: Text) -> Bool {
    return token == "==" || token == "!=" || token == "<" ||
    token == "<=" || token == ">" || token == ">="
}

fn condition_end(source: Text, start: Int) -> Int {
    let cursor = skip_trivia(source, start)
    let first = token_text(source, cursor)
    if first == "true" || first == "false" {
        return token_end(source, cursor)
    }
    let left_end = expression_end(source, cursor)
    if left_end < 0 {
        return -1
    }
    let operator_start = skip_trivia(source, left_end)
    if operator_start >= len(source) ||
       !comparison_operator(token_text(source, operator_start)) {
        return -1
    }
    let right_start = skip_trivia(
        source,
        token_end(source, operator_start)
    )
    return expression_end(source, right_start)
}

fn emit_condition_into(
    source: Text,
    hir: Text,
    start: Int,
    end: Int,
    target: Text,
    failure_result: Text,
    indent: Text
) -> Text {
    let cursor = skip_trivia(source, start)
    let first = token_text(source, cursor)
    if first == "true" || first == "false" {
        return indent + "bool " + target + " = " + first + ";\n"
    }
    let left_end = expression_end(source, cursor)
    let operator_start = skip_trivia(source, left_end)
    let right_start = skip_trivia(
        source,
        token_end(source, operator_start)
    )
    return indent + "int64_t kofun_condition_left = " +
    emit_expression(source, hir, cursor, left_end) + ";\n" +
    indent + "if (kofun_failed) return " + failure_result + ";\n" +
    indent + "int64_t kofun_condition_right = " +
    emit_expression(source, hir, right_start, end) + ";\n" +
    indent + "if (kofun_failed) return " + failure_result + ";\n" +
    indent + "bool " + target + " = kofun_condition_left " +
    token_text(source, operator_start) +
    " kofun_condition_right;\n"
}

fn value_if_branch_end(source: Text, start: Int) -> Int {
    return value_end(source, start)
}

fn value_if_end(source: Text, start: Int) -> Int {
    let condition_start = skip_trivia(source, token_end(source, start))
    let condition_close = condition_end(source, condition_start)
    let then_open = skip_trivia(source, condition_close)
    let then_start = skip_trivia(source, token_end(source, then_open))
    let then_end = value_if_branch_end(source, then_start)
    let then_close = skip_trivia(source, then_end)
    let else_keyword = skip_trivia(source, token_end(source, then_close))
    let else_open = skip_trivia(source, token_end(source, else_keyword))
    let else_start = skip_trivia(source, token_end(source, else_open))
    let else_end = value_if_branch_end(source, else_start)
    let else_close = skip_trivia(source, else_end)
    return token_end(source, else_close)
}

fn value_match_end(source: Text, start: Int) -> Int {
    let cursor = skip_trivia(source, start)
    let value_start = skip_trivia(source, token_end(source, cursor))
    let value_close = condition_end(source, value_start)
    if value_close < 0 {
        return -1
    }
    let arms_open = skip_trivia(source, value_close)
    if arms_open >= len(source) || token_text(source, arms_open) != "{" {
        return -1
    }
    return balanced_end(source, arms_open, "{", "}")
}

fn value_end(source: Text, start: Int) -> Int {
    let cursor = skip_trivia(source, start)
    let first = token_text(source, cursor)
    if first == "if" {
        return value_if_end(source, cursor)
    }
    if first == "match" {
        return value_match_end(source, cursor)
    }
    return expression_end(source, cursor)
}

fn validate_value_if(source: Text, start: Int) -> Text {
    let cursor = skip_trivia(source, start)
    if cursor >= len(source) || token_text(source, cursor) != "if" {
        return "error[E2S28]: expected value-position `if` at byte " +
        to_text(cursor)
    }
    let condition_start = skip_trivia(source, token_end(source, cursor))
    let condition_close = condition_end(source, condition_start)
    if condition_close < 0 {
        return "error[E2S23]: if condition must be Bool or an Int comparison at byte " +
        to_text(condition_start)
    }
    let then_open = skip_trivia(source, condition_close)
    if then_open >= len(source) || token_text(source, then_open) != "{" {
        return "error[E2S18]: expected `{` after if condition at byte " +
        to_text(then_open)
    }
    let then_start = skip_trivia(source, token_end(source, then_open))
    let mut then_end = -1
    if token_text(source, then_start) == "if" {
        let nested_result = validate_value_if(source, then_start)
        if starts_with(nested_result, "error[") {
            return nested_result
        }
        then_end = value_if_end(source, then_start)
    } else if token_text(source, then_start) == "match" {
        let nested_result = validate_value_match(source, then_start)
        if starts_with(nested_result, "error[") {
            return nested_result
        }
        then_end = value_match_end(source, then_start)
    } else {
        if token_text(source, then_start) == "print" {
            return "error[E2S28]: value-position if branch must produce Int, not Void at byte " +
            to_text(then_start)
        }
        then_end = expression_end(source, then_start)
        if then_end < 0 {
            return "error[E2S28]: value-position if branch must produce Int at byte " +
            to_text(then_start)
        }
    }
    let then_close = skip_trivia(source, then_end)
    if then_close >= len(source) || token_text(source, then_close) != "}" {
        return "error[E2S28]: value-position if branch must contain one final Int expression at byte " +
        to_text(then_close)
    }
    let else_keyword = skip_trivia(source, token_end(source, then_close))
    if else_keyword >= len(source) ||
       token_text(source, else_keyword) != "else" {
        return "error[E2S27]: value-position if requires `else` at byte " +
        to_text(else_keyword)
    }
    let else_open = skip_trivia(source, token_end(source, else_keyword))
    if else_open >= len(source) || token_text(source, else_open) != "{" {
        return "error[E2S18]: expected `{` after `else` at byte " +
        to_text(else_open)
    }
    let else_start = skip_trivia(source, token_end(source, else_open))
    let mut else_end = -1
    if token_text(source, else_start) == "if" {
        let nested_result = validate_value_if(source, else_start)
        if starts_with(nested_result, "error[") {
            return nested_result
        }
        else_end = value_if_end(source, else_start)
    } else if token_text(source, else_start) == "match" {
        let nested_result = validate_value_match(source, else_start)
        if starts_with(nested_result, "error[") {
            return nested_result
        }
        else_end = value_match_end(source, else_start)
    } else {
        if token_text(source, else_start) == "print" {
            return "error[E2S28]: value-position if branch must produce Int, not Void at byte " +
            to_text(else_start)
        }
        else_end = expression_end(source, else_start)
        if else_end < 0 {
            return "error[E2S28]: value-position if branch must produce Int at byte " +
            to_text(else_start)
        }
    }
    let else_close = skip_trivia(source, else_end)
    if else_close >= len(source) || token_text(source, else_close) != "}" {
        return "error[E2S28]: value-position if branch must contain one final Int expression at byte " +
        to_text(else_close)
    }
    return "ok"
}

fn validate_value_match(source: Text, start: Int) -> Text {
    let cursor = skip_trivia(source, start)
    if cursor >= len(source) || token_text(source, cursor) != "match" {
        return "error[E2S30]: expected value-position `match` at byte " +
        to_text(cursor)
    }
    let value_start = skip_trivia(source, token_end(source, cursor))
    let value_close = condition_end(source, value_start)
    if value_close < 0 {
        return "error[E2S24]: bounded match scrutinee must be Bool at byte " +
        to_text(value_start)
    }
    let arms_open = skip_trivia(source, value_close)
    if arms_open >= len(source) || token_text(source, arms_open) != "{" {
        return "error[E2S24]: expected `{` after match scrutinee at byte " +
        to_text(arms_open)
    }
    let mut arm_cursor = skip_trivia(source, token_end(source, arms_open))
    let mut covered_true = false
    let mut covered_false = false
    let mut seen_catchall = false
    while arm_cursor < len(source) && token_text(source, arm_cursor) != "}" {
        let pattern_start = arm_cursor
        let pattern_info = pattern_summary(source, pattern_start)
        let pattern_kind = pattern_summary_kind(pattern_info)
        let pattern = token_text(source, pattern_start)
        let pattern_true = pattern_kind == "LiteralPattern" &&
        pattern == "true"
        let pattern_false = pattern_kind == "LiteralPattern" &&
        pattern == "false"
        let pattern_catchall = pattern_kind == "WildcardPattern"
        if seen_catchall {
            return "error[E2S26]: pattern after catch-all is unreachable at byte " +
            to_text(pattern_start)
        }
        if pattern_true && covered_true {
            return "error[E2S26]: duplicate `true` pattern is unreachable at byte " +
            to_text(pattern_start)
        }
        if pattern_false && covered_false {
            return "error[E2S26]: duplicate `false` pattern is unreachable at byte " +
            to_text(pattern_start)
        }
        if pattern_catchall && covered_true && covered_false {
            return "error[E2S26]: catch-all pattern is unreachable at byte " +
            to_text(pattern_start)
        }
        if !pattern_true && !pattern_false && !pattern_catchall {
            return "error[E2S24]: bounded Bool pattern must be `true`, `false`, or `_` at byte " +
            to_text(pattern_start)
        }
        let after_pattern = skip_trivia(
            source,
            pattern_summary_end(pattern_info)
        )
        let mut guarded = false
        let mut arrow = after_pattern
        if arrow < len(source) && token_text(source, arrow) == "if" {
            guarded = true
            let guard_start = skip_trivia(source, token_end(source, arrow))
            let guard_end = condition_end(source, guard_start)
            if guard_end < 0 {
                return "error[E2S29]: match guard must be Bool or an Int comparison at byte " +
                to_text(guard_start)
            }
            arrow = skip_trivia(source, guard_end)
        }
        if arrow >= len(source) || token_text(source, arrow) != "=>" {
            return "error[E2S24]: expected `=>` after Bool pattern at byte " +
            to_text(arrow)
        }
        let arm_open = skip_trivia(source, token_end(source, arrow))
        if arm_open >= len(source) || token_text(source, arm_open) != "{" {
            return "error[E2S24]: bounded Bool match arm must use a block at byte " +
            to_text(arm_open)
        }
        let arm_start = skip_trivia(source, token_end(source, arm_open))
        let mut arm_end = -1
        if token_text(source, arm_start) == "if" {
            let arm_result = validate_value_if(source, arm_start)
            if starts_with(arm_result, "error[") {
                return arm_result
            }
            arm_end = value_if_end(source, arm_start)
        } else if token_text(source, arm_start) == "match" {
            let arm_result = validate_value_match(source, arm_start)
            if starts_with(arm_result, "error[") {
                return arm_result
            }
            arm_end = value_match_end(source, arm_start)
        } else {
            if token_text(source, arm_start) == "print" {
                return "error[E2S30]: value-position match arm must produce Int, not Void at byte " +
                to_text(arm_start)
            }
            arm_end = expression_end(source, arm_start)
            if arm_end < 0 {
                return "error[E2S30]: value-position match arm must produce Int at byte " +
                to_text(arm_start)
            }
        }
        let arm_close = skip_trivia(source, arm_end)
        if arm_close >= len(source) || token_text(source, arm_close) != "}" {
            return "error[E2S30]: value-position match arm must contain one final Int expression at byte " +
            to_text(arm_close)
        }
        if !guarded {
            if pattern_true {
                covered_true = true
            } else if pattern_false {
                covered_false = true
            } else {
                covered_true = true
                covered_false = true
                seen_catchall = true
            }
        }
        arm_cursor = skip_trivia(source, token_end(source, arm_close))
        if arm_cursor < len(source) && token_text(source, arm_cursor) == "," {
            arm_cursor = skip_trivia(source, token_end(source, arm_cursor))
        } else if arm_cursor >= len(source) ||
                  token_text(source, arm_cursor) != "}" {
            return "error[E2S24]: expected `,` between match arms at byte " +
            to_text(arm_cursor)
        }
    }
    if arm_cursor >= len(source) || token_text(source, arm_cursor) != "}" {
        return "error[E2S24]: missing `}` after match arms at byte " +
        to_text(arms_open)
    }
    if !covered_true && !covered_false {
        return "error[E2S25]: non-exhaustive Bool match; missing patterns `true`, `false` at byte " +
        to_text(cursor)
    }
    if !covered_true {
        return "error[E2S25]: non-exhaustive Bool match; missing pattern `true` at byte " +
        to_text(cursor)
    }
    if !covered_false {
        return "error[E2S25]: non-exhaustive Bool match; missing pattern `false` at byte " +
        to_text(cursor)
    }
    return "ok"
}

fn value_control(token: Text) -> Bool {
    return token == "if" || token == "match"
}

fn validate_value_control(source: Text, start: Int) -> Text {
    let cursor = skip_trivia(source, start)
    if token_text(source, cursor) == "if" {
        return validate_value_if(source, cursor)
    }
    return validate_value_match(source, cursor)
}

fn emit_value_into(
    source: Text,
    hir: Text,
    start: Int,
    end: Int,
    target: Text,
    failure_result: Text
) -> Text {
    let cursor = skip_trivia(source, start)
    if token_text(source, cursor) == "match" {
        return emit_value_match_into(
            source,
            hir,
            cursor,
            end,
            target,
            failure_result
        )
    }
    if token_text(source, cursor) != "if" {
        return "    " + target + " = " +
        emit_expression(source, hir, cursor, end) + ";\n" +
        "    if (kofun_failed) return " + failure_result + ";\n"
    }
    let condition_start = skip_trivia(source, token_end(source, cursor))
    let condition_close = condition_end(source, condition_start)
    let then_open = skip_trivia(source, condition_close)
    let then_start = skip_trivia(source, token_end(source, then_open))
    let then_end = value_if_branch_end(source, then_start)
    let then_close = skip_trivia(source, then_end)
    let else_keyword = skip_trivia(source, token_end(source, then_close))
    let else_open = skip_trivia(source, token_end(source, else_keyword))
    let else_start = skip_trivia(source, token_end(source, else_open))
    let else_end = value_if_branch_end(source, else_start)
    return "    {\n" +
    emit_condition_into(
        source,
        hir,
        condition_start,
        condition_close,
        "kofun_value_condition",
        failure_result,
        "        "
    ) +
    "        if (kofun_value_condition) {\n" +
    emit_value_into(
        source,
        hir,
        then_start,
        then_end,
        target,
        failure_result
    ) +
    "        } else {\n" +
    emit_value_into(
        source,
        hir,
        else_start,
        else_end,
        target,
        failure_result
    ) +
    "        }\n" +
    "    }\n"
}

fn emit_value_match_into(
    source: Text,
    hir: Text,
    start: Int,
    end: Int,
    target: Text,
    failure_result: Text
) -> Text {
    let cursor = skip_trivia(source, start)
    let value_start = skip_trivia(source, token_end(source, cursor))
    let value_close = condition_end(source, value_start)
    let arms_open = skip_trivia(source, value_close)
    let mut arm_cursor = skip_trivia(source, token_end(source, arms_open))
    let mut dispatch = ""
    while arm_cursor < end && token_text(source, arm_cursor) != "}" {
        let pattern_info = pattern_summary(source, arm_cursor)
        let pattern_kind = pattern_summary_kind(pattern_info)
        let pattern = token_text(source, arm_cursor)
        let pattern_true = pattern_kind == "LiteralPattern" &&
        pattern == "true"
        let pattern_false = pattern_kind == "LiteralPattern" &&
        pattern == "false"
        let mut arrow = skip_trivia(
            source,
            pattern_summary_end(pattern_info)
        )
        let mut guarded = false
        let mut guard_start = -1
        let mut guard_end = -1
        if arrow < end && token_text(source, arrow) == "if" {
            guarded = true
            guard_start = skip_trivia(source, token_end(source, arrow))
            guard_end = condition_end(source, guard_start)
            arrow = skip_trivia(source, guard_end)
        }
        let arm_open = skip_trivia(source, token_end(source, arrow))
        let arm_start = skip_trivia(source, token_end(source, arm_open))
        let arm_end = value_end(source, arm_start)
        let arm_close = skip_trivia(source, arm_end)
        let mut pattern_condition = "true"
        if pattern_true {
            pattern_condition = "kofun_match_value"
        } else if pattern_false {
            pattern_condition = "!kofun_match_value"
        }
        let arm_body = emit_value_into(
            source,
            hir,
            arm_start,
            arm_end,
            target,
            failure_result
        )
        if guarded {
            dispatch = dispatch +
            "        if (!kofun_match_selected && " +
            pattern_condition + ") {\n" +
            emit_condition_into(
                source,
                hir,
                guard_start,
                guard_end,
                "kofun_match_guard",
                failure_result,
                "            "
            ) +
            "            if (kofun_match_guard) {\n" +
            arm_body +
            "                kofun_match_selected = true;\n" +
            "            }\n" +
            "        }\n"
        } else {
            dispatch = dispatch +
            "        if (!kofun_match_selected && " +
            pattern_condition + ") {\n" +
            arm_body +
            "            kofun_match_selected = true;\n" +
            "        }\n"
        }
        arm_cursor = skip_trivia(source, token_end(source, arm_close))
        if arm_cursor < end && token_text(source, arm_cursor) == "," {
            arm_cursor = skip_trivia(source, token_end(source, arm_cursor))
        }
    }
    return "    {\n" +
    emit_condition_into(
        source,
        hir,
        value_start,
        value_close,
        "kofun_match_value",
        failure_result,
        "        "
    ) +
    "        (void)kofun_match_value;\n" +
    "        bool kofun_match_selected = false;\n" +
    dispatch +
    "    }\n"
}

fn core_body_open(
    source: Text,
    hir: Text,
    function_start: Int,
    is_main: Bool
) -> Int {
    let parameters = parameter_open(source, function_start)
    if parameters < 0 {
        return -1
    }
    let parameters_end = balanced_end(source, parameters, "(", ")")
    if parameters_end < 0 ||
       starts_with(core_parameters(source, hir, function_start), "error[") {
        return -1
    }
    let mut cursor = skip_trivia(source, parameters_end)
    if cursor < len(source) && token_text(source, cursor) == "->" {
        cursor = skip_trivia(source, token_end(source, cursor))
        if cursor >= len(source) || token_text(source, cursor) != "Int" {
            return -1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    } else if !is_main {
        return -1
    }
    if cursor >= len(source) || token_text(source, cursor) != "{" {
        return -1
    }
    return cursor
}

fn parent_block_open(
    source: Text,
    function_open: Int,
    child_open: Int
) -> Int {
    let mut cursor = function_open
    let mut parent = -1
    while cursor < child_open {
        if token_text(source, cursor) == "{" {
            let candidate_end = balanced_end(source, cursor, "{", "}")
            if candidate_end > child_open {
                parent = cursor
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return parent
}

fn scope_kind_for_open(
    source: Text,
    function_open: Int,
    wanted_open: Int
) -> Text {
    let mut cursor = function_open
    let mut previous = ""
    while cursor < wanted_open {
        if token_text(source, cursor) == "if" {
            let condition_start = skip_trivia(
                source,
                token_end(source, cursor)
            )
            let condition_close = condition_end(source, condition_start)
            if condition_close >= 0 &&
               skip_trivia(source, condition_close) == wanted_open {
                return "if-then"
            }
        }
        previous = token_text(source, cursor)
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    if previous == "else" {
        return "if-else"
    }
    if previous == "=>" {
        return "match-arm"
    }
    return "block"
}

fn enum_declaration_syntax_token(
    source: Text,
    function_open: Int,
    target: Int
) -> Bool {
    let mut cursor = skip_trivia(source, token_end(source, function_open))
    while cursor <= target {
        if token_text(source, cursor) == "let" {
            let mut name = skip_trivia(source, token_end(source, cursor))
            if token_text(source, name) == "mut" {
                name = skip_trivia(source, token_end(source, name))
            }
            if name == target {
                return true
            }
            let colon = skip_trivia(source, token_end(source, name))
            if token_text(source, colon) == ":" {
                let type_cursor = skip_trivia(
                    source,
                    token_end(source, colon)
                )
                if type_cursor == target {
                    return true
                }
                let equals = skip_trivia(
                    source,
                    token_end(source, type_cursor)
                )
                let initializer = skip_trivia(
                    source,
                    token_end(source, equals)
                )
                if initializer == target &&
                   token_text(source, equals) == "=" {
                    let enum_type = token_text(source, type_cursor)
                    if enum_constructor_count(source, enum_type) >= 0 {
                        return true
                    }
                }
            }
        }
        if token_text(source, cursor) == "for" {
            let name = skip_trivia(source, token_end(source, cursor))
            if name == target {
                return true
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return false
}

fn enum_initializer_constructor_token(
    source: Text,
    function_open: Int,
    target: Int
) -> Bool {
    let mut cursor = skip_trivia(source, token_end(source, function_open))
    while cursor <= target {
        if token_text(source, cursor) == "let" {
            let mut name = skip_trivia(source, token_end(source, cursor))
            if token_text(source, name) == "mut" {
                name = skip_trivia(source, token_end(source, name))
            }
            let colon = skip_trivia(source, token_end(source, name))
            if token_text(source, colon) == ":" {
                let type_cursor = skip_trivia(
                    source,
                    token_end(source, colon)
                )
                let equals = skip_trivia(
                    source,
                    token_end(source, type_cursor)
                )
                let initializer = skip_trivia(
                    source,
                    token_end(source, equals)
                )
                if initializer == target && token_text(source, equals) == "=" {
                    let enum_type = token_text(source, type_cursor)
                    let constructor = token_text(source, initializer)
                    return enum_constructor_count(source, enum_type) >= 0 &&
                    len(enum_constructor_owner(source, constructor)) > 0
                }
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return false
}

fn enum_match_pattern_token(
    source: Text,
    function_open: Int,
    target: Int
) -> Bool {
    let mut cursor = skip_trivia(source, token_end(source, function_open))
    while cursor < target {
        if token_text(source, cursor) == "match" {
            let arms_open = pattern_match_open(source, cursor)
            if arms_open >= 0 && arms_open < target &&
               token_text(source, arms_open) == "{" {
                let match_end = balanced_end(source, arms_open, "{", "}")
                let match_close = match_end - 1
                let mut arm_cursor = skip_trivia(
                    source,
                    token_end(source, arms_open)
                )
                while match_end >= 0 && arm_cursor <= target &&
                      arm_cursor < match_close &&
                      token_text(source, arm_cursor) != "}" {
                    let pattern = pattern_summary(source, arm_cursor)
                    let pattern_end = pattern_summary_end(pattern)
                    if target >= arm_cursor && target < pattern_end {
                        return true
                    }
                    let arrow = pattern_arm_arrow(
                        source,
                        pattern_end,
                        match_close
                    )
                    if arm_cursor <= target &&
                       arrow >= 0 &&
                       token_text(source, arrow) == "=>" {
                        let arm_open = skip_trivia(
                            source,
                            token_end(source, arrow)
                        )
                        let arm_end = balanced_end(
                            source,
                            arm_open,
                            "{",
                            "}"
                        )
                        if arm_end < 0 {
                            arm_cursor = target + 1
                        } else if arm_end <= target {
                            arm_cursor = skip_trivia(source, arm_end)
                            if token_text(source, arm_cursor) == "," {
                                arm_cursor = skip_trivia(
                                    source,
                                    token_end(source, arm_cursor)
                                )
                            }
                        } else {
                            arm_cursor = target + 1
                        }
                    } else {
                        arm_cursor = target + 1
                    }
                }
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return false
}

fn text_find_from(value: Text, wanted: Text, start: Int) -> Int {
    if len(wanted) == 0 {
        return start
    }
    let mut cursor = start
    while cursor + len(wanted) <= len(value) {
        if text_slice(value, cursor, cursor + len(wanted)) == wanted {
            return cursor
        }
        cursor = cursor + 1
    }
    return -1
}

fn decimal_value(value: Text) -> Int {
    let symbols = chars(value)
    let mut cursor = 0
    let mut sign = 1
    if len(symbols) > 0 && symbols[0] == "-" {
        sign = -1
        cursor = 1
    }
    let mut result = 0
    while cursor < len(symbols) {
        if !is_digit(symbols[cursor]) {
            return -1
        }
        result = result * 10 +
        text_find_from("0123456789", symbols[cursor], 0)
        cursor = cursor + 1
    }
    return result * sign
}

fn hir_record_start(
    hir: Text,
    kind: Text,
    start: Int
) -> Int {
    let found = text_find_from(hir, "\n" + kind + "|", start)
    if found < 0 {
        return -1
    }
    return found + 1
}

fn hir_field(hir: Text, line_start: Int, wanted: Int) -> Text {
    let symbols = chars(hir)
    let mut cursor = line_start
    let mut field = 0
    let mut field_start = line_start
    while cursor < len(symbols) {
        if symbols[cursor] == "|" || symbols[cursor] == "\n" {
            if field == wanted {
                return text_slice(hir, field_start, cursor)
            }
            if symbols[cursor] == "\n" {
                return ""
            }
            field = field + 1
            field_start = cursor + 1
        }
        cursor = cursor + 1
    }
    if field == wanted {
        return text_slice(hir, field_start, cursor)
    }
    return ""
}

fn hir_scope_id_for_open(hir: Text, open: Int) -> Text {
    let mut line = hir_record_start(hir, "scope", 0)
    while line >= 0 {
        if decimal_value(hir_field(hir, line, 4)) == open {
            return hir_field(hir, line, 1)
        }
        line = hir_record_start(hir, "scope", line + 1)
    }
    return ""
}

fn hir_scope_field(hir: Text, scope_id: Text, field: Int) -> Text {
    let mut line = hir_record_start(hir, "scope", 0)
    while line >= 0 {
        if hir_field(hir, line, 1) == scope_id {
            return hir_field(hir, line, field)
        }
        line = hir_record_start(hir, "scope", line + 1)
    }
    return ""
}

fn hir_binding_field(hir: Text, binding_id: Text, field: Int) -> Text {
    let mut line = hir_record_start(hir, "binding", 0)
    while line >= 0 {
        if hir_field(hir, line, 1) == binding_id {
            return hir_field(hir, line, field)
        }
        line = hir_record_start(hir, "binding", line + 1)
    }
    return ""
}

fn hir_same_scope_declaration(
    hir: Text,
    scope_id: Text,
    name: Text
) -> Text {
    let mut line = hir_record_start(hir, "binding", 0)
    while line >= 0 {
        if hir_field(hir, line, 2) == scope_id &&
           hir_field(hir, line, 3) == name {
            return hir_field(hir, line, 8)
        }
        line = hir_record_start(hir, "binding", line + 1)
    }
    return ""
}

fn hir_definition_id_at(hir: Text, declaration_start: Int) -> Text {
    let mut line = hir_record_start(hir, "binding", 0)
    while line >= 0 {
        if decimal_value(hir_field(hir, line, 8)) == declaration_start {
            return hir_field(hir, line, 1)
        }
        line = hir_record_start(hir, "binding", line + 1)
    }
    return ""
}

fn hir_use_binding_id(hir: Text, use_start: Int) -> Text {
    let mut line = hir_record_start(hir, "use", 0)
    while line >= 0 {
        if decimal_value(hir_field(hir, line, 1)) == use_start {
            return hir_field(hir, line, 4)
        }
        line = hir_record_start(hir, "use", line + 1)
    }
    return ""
}

fn hir_resolve_binding(
    hir: Text,
    current_scope: Text,
    use_start: Int,
    name: Text
) -> Text {
    let mut scope_id = current_scope
    while len(scope_id) > 0 && scope_id != "-1" {
        let mut resolved = ""
        let mut line = hir_record_start(hir, "binding", 0)
        while line >= 0 {
            if hir_field(hir, line, 2) == scope_id &&
               hir_field(hir, line, 3) == name &&
               decimal_value(hir_field(hir, line, 10)) <= use_start {
                resolved = hir_field(hir, line, 1)
            }
            line = hir_record_start(hir, "binding", line + 1)
        }
        if len(resolved) > 0 {
            return resolved
        }
        scope_id = hir_scope_field(hir, scope_id, 2)
    }
    return ""
}

fn hir_pending_declaration(
    hir: Text,
    current_scope: Text,
    use_start: Int,
    name: Text
) -> Text {
    let mut scope_id = current_scope
    while len(scope_id) > 0 && scope_id != "-1" {
        let mut line = hir_record_start(hir, "binding", 0)
        while line >= 0 {
            let declaration = decimal_value(hir_field(hir, line, 8))
            let visible = decimal_value(hir_field(hir, line, 10))
            if hir_field(hir, line, 2) == scope_id &&
               hir_field(hir, line, 3) == name &&
               declaration < use_start && use_start < visible {
                return to_text(declaration)
            }
            line = hir_record_start(hir, "binding", line + 1)
        }
        scope_id = hir_scope_field(hir, scope_id, 2)
    }
    return ""
}

fn hir_scope_root(hir: Text, start_scope: Text) -> Text {
    let mut scope_id = start_scope
    let mut parent = hir_scope_field(hir, scope_id, 2)
    while len(parent) > 0 && parent != "-1" {
        scope_id = parent
        parent = hir_scope_field(hir, scope_id, 2)
    }
    return scope_id
}

fn hir_any_declaration(
    hir: Text,
    current_scope: Text,
    use_start: Int,
    name: Text
) -> Text {
    let current_root = hir_scope_root(hir, current_scope)
    let mut line = hir_record_start(hir, "binding", 0)
    while line >= 0 {
        let binding_scope = hir_field(hir, line, 2)
        let declaration = decimal_value(hir_field(hir, line, 8))
        if hir_field(hir, line, 3) == name &&
           declaration < use_start &&
           hir_scope_root(hir, binding_scope) == current_root {
            return to_text(declaration)
        }
        line = hir_record_start(hir, "binding", line + 1)
    }
    return ""
}

fn scope_depth_for_open(
    source: Text,
    function_open: Int,
    wanted_open: Int
) -> Int {
    let mut cursor = function_open
    let mut depth = 0
    while cursor <= wanted_open {
        if token_text(source, cursor) == "{" {
            depth = depth + 1
            if cursor == wanted_open {
                return depth
            }
        } else if token_text(source, cursor) == "}" {
            depth = depth - 1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return -1
}

# Result types of the 16 profile builtins for `let` initializer typing.
# The scope-HIR type vocabulary stays the existing single tokens
# (Int/Bool/Text/List/Void); List[Text] element typing belongs to the
# selfhost-HIR emitter. Returns "" for a non-builtin name.
fn builtin_return_type(name: Text) -> Text {
    if name == "args" || name == "chars" {
        return "List"
    }
    if name == "contains" || name == "is_digit" || name == "is_space" ||
       name == "is_xid_continue" || name == "starts_with" {
        return "Bool"
    }
    if name == "find" || name == "len" {
        return "Int"
    }
    if name == "read_text" || name == "replace" || name == "text_slice" ||
       name == "trim" || name == "validate_unicode_source" {
        return "Text"
    }
    if name == "write_text" {
        return "Void"
    }
    return ""
}

# Declared result type of a user function: the token after `->`, `Void`
# when there is no arrow, empty when the function is not declared.
fn function_return_type(source: Text, wanted: Text) -> Text {
    let mut cursor = next_function_start(source, 0)
    while cursor < len(source) {
        if function_name(source, cursor) == wanted {
            let parameters = parameter_open(source, cursor)
            if parameters < 0 {
                return ""
            }
            let parameters_end = balanced_end(source, parameters, "(", ")")
            if parameters_end < 0 {
                return ""
            }
            let after = skip_trivia(source, parameters_end)
            if after < len(source) && token_text(source, after) == "->" {
                let type_cursor = skip_trivia(
                    source,
                    token_end(source, after)
                )
                if type_cursor < len(source) {
                    return token_text(source, type_cursor)
                }
                return ""
            }
            return "Void"
        }
        cursor = next_function_start(source, function_end(source, cursor))
    }
    return ""
}

# Bounded initializer typing for unannotated `let` bindings. Top-level
# comparison and boolean operators make the value Bool; otherwise the
# profile's operands are homogeneous, so the first primary decides:
# literals by token kind, calls by declared or builtin result type, names
# by their resolved binding, bare enum constructors by their owner. The
# conservative fallback is the historical Int default, never an error.
fn initializer_type(
    source: Text,
    hir: Text,
    function_open: Int,
    initializer: Int
) -> Text {
    let mut end = expression_end(source, initializer)
    if end < 0 {
        end = token_end(source, initializer)
    }
    # The operator scan covers the whole initializer line: it ends at the
    # first newline outside parentheses, not at the bounded arithmetic
    # expression end, so `1 < 2` and multi-line parenthesized calls are
    # both seen completely.
    let mut depth = 0
    let mut walk = initializer
    let mut previous_end = initializer
    let mut scanning = true
    while scanning && walk < len(source) {
        if depth == 0 &&
           contains(text_slice(source, previous_end, walk), "\n") {
            scanning = false
        } else if token_text(source, walk) == "{" {
            scanning = false
        } else {
            let walk_text = token_text(source, walk)
            if walk_text == "(" {
                depth = depth + 1
            } else if walk_text == ")" {
                depth = depth - 1
            } else if depth == 0 &&
                      (walk_text == "==" || walk_text == "!=" ||
                       walk_text == "<" || walk_text == "<=" ||
                       walk_text == ">" || walk_text == ">=" ||
                       walk_text == "&&" || walk_text == "||" ||
                       walk_text == "!") {
                return "Bool"
            }
            previous_end = token_end(source, walk)
            walk = skip_trivia(source, previous_end)
        }
    }
    let mut cursor = skip_trivia(source, initializer)
    while cursor < end &&
          (token_text(source, cursor) == "(" ||
           token_text(source, cursor) == "-" ||
           token_text(source, cursor) == "+") {
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    if cursor >= end {
        return "Int"
    }
    let kind = token_kind(source, cursor)
    if kind == "integer" {
        return "Int"
    }
    if kind == "string" {
        return "Text"
    }
    let cursor_text = token_text(source, cursor)
    if cursor_text == "true" || cursor_text == "false" {
        return "Bool"
    }
    if kind == "identifier" {
        # Call and index detection must not stop at the bounded expression
        # end: profile initializers may continue across lines, and `[`
        # follows the resolved primary directly.
        let open = skip_trivia(source, token_end(source, cursor))
        if open < len(source) && token_text(source, open) == "(" {
            let declared = function_return_type(source, cursor_text)
            if len(declared) > 0 {
                return declared
            }
            let builtin = builtin_return_type(cursor_text)
            if len(builtin) > 0 {
                return builtin
            }
            return "Int"
        }
        let scope_open = parent_block_open(source, function_open, cursor)
        let scope_id = hir_scope_id_for_open(hir, scope_open)
        let binding_id = hir_resolve_binding(
            hir,
            scope_id,
            cursor,
            cursor_text
        )
        if len(binding_id) > 0 {
            let binding_type = hir_binding_field(hir, binding_id, 5)
            if len(binding_type) > 0 {
                # Indexing the profile's List[Text] yields its Text element.
                if binding_type == "List" && open < len(source) &&
                   token_text(source, open) == "[" {
                    return "Text"
                }
                return binding_type
            }
            return "Int"
        }
        let owner = enum_constructor_owner(source, cursor_text)
        if len(owner) > 0 {
            return owner
        }
    }
    return "Int"
}

fn build_scope_hir_mode(
    source: Text,
    preserve_pattern_candidates: Bool
) -> Text {
    let mut hir = "kofun-scope-hir/v1\n"
    let mut next_scope_id = 0
    let mut next_binding_id = 0
    let mut function_start = next_function_start(source, 0)
    while function_start < len(source) {
        let function_close = function_end(source, function_start)
        let parameters = parameter_open(source, function_start)
        let parameters_close = balanced_end(source, parameters, "(", ")")
        let mut function_open = skip_trivia(source, parameters_close)
        while function_open < function_close &&
              token_text(source, function_open) != "{" {
            function_open = skip_trivia(
                source,
                token_end(source, function_open)
            )
        }
        let parameter_scope = next_scope_id
        next_scope_id = next_scope_id + 1
        let body_scope = next_scope_id
        next_scope_id = next_scope_id + 1
        let mut scope_count = 2
        hir = hir + "hir-function|" + to_text(function_start) + "|" +
        to_text(parameter_scope) + "|" + to_text(body_scope) + "\n" +
        "scope|" + to_text(parameter_scope) + "|-1|parameters|" +
        to_text(parameters) + "|" + to_text(parameters_close) + "|0\n" +
        "scope|" + to_text(body_scope) + "|" +
        to_text(parameter_scope) + "|function-body|" +
        to_text(function_open) + "|" + to_text(function_close) + "|1\n"

        let mut cursor = skip_trivia(
            source,
            token_end(source, function_open)
        )
        while cursor < function_close {
            if token_text(source, cursor) == "{" {
                let depth = scope_depth_for_open(
                    source,
                    function_open,
                    cursor
                )
                if depth > 32 {
                    return "error[E2S35]: lexical scope depth limit is 32 at byte " +
                    to_text(cursor)
                }
                scope_count = scope_count + 1
                if scope_count > 256 {
                    return "error[E2S35]: lexical scope limit is 256 per function at byte " +
                    to_text(cursor)
                }
                let parent_open = parent_block_open(
                    source,
                    function_open,
                    cursor
                )
                let parent_scope = hir_scope_id_for_open(hir, parent_open)
                let close = balanced_end(source, cursor, "{", "}")
                let scope_kind = scope_kind_for_open(
                    source,
                    function_open,
                    cursor
                )
                hir = hir + "scope|" + to_text(next_scope_id) + "|" +
                parent_scope + "|" + scope_kind + "|" +
                to_text(cursor) + "|" +
                to_text(close) + "|" + to_text(depth) + "\n"
                next_scope_id = next_scope_id + 1
            }
            cursor = skip_trivia(source, token_end(source, cursor))
        }

        let mut binding_count = 0
        let mut parameter_cursor = skip_trivia(
            source,
            token_end(source, parameters)
        )
        while parameter_cursor < parameters_close &&
              token_text(source, parameter_cursor) != ")" {
            let name = parameter_cursor
            let colon = skip_trivia(source, token_end(source, name))
            let type_cursor = skip_trivia(source, token_end(source, colon))
            let first_declaration = hir_same_scope_declaration(
                hir,
                to_text(parameter_scope),
                token_text(source, name)
            )
            if len(first_declaration) > 0 {
                return "error[E2S47]: duplicate binding `" +
                token_text(source, name) +
                "` in lexical scope at byte " + to_text(name) +
                "; first declaration at byte " + first_declaration
            }
            binding_count = binding_count + 1
            if binding_count > 256 {
                return "error[E2S35]: lexical binding limit is 256 per function at byte " +
                to_text(name)
            }
            hir = hir + "binding|" + to_text(next_binding_id) + "|" +
            to_text(parameter_scope) + "|" + token_text(source, name) +
            "|immutable|" + token_text(source, type_cursor) +
            "|copy|initialized|" + to_text(name) + "|" +
            to_text(token_end(source, name)) + "|" +
            to_text(token_end(source, name)) + "\n"
            next_binding_id = next_binding_id + 1
            let separator = skip_trivia(
                source,
                token_end(source, type_cursor)
            )
            if separator < parameters_close &&
               token_text(source, separator) == "," {
                parameter_cursor = skip_trivia(
                    source,
                    token_end(source, separator)
                )
            } else {
                parameter_cursor = separator
            }
        }

        cursor = skip_trivia(source, token_end(source, function_open))
        while cursor < function_close {
            if token_text(source, cursor) == "let" {
                let mut name = skip_trivia(source, token_end(source, cursor))
                let mut mutability = "immutable"
                if token_text(source, name) == "mut" {
                    mutability = "mutable"
                    name = skip_trivia(source, token_end(source, name))
                }
                let mut after_name = skip_trivia(
                    source,
                    token_end(source, name)
                )
                let mut binding_type = "Int"
                let mut annotated = false
                if token_text(source, after_name) == ":" {
                    annotated = true
                    let type_cursor = skip_trivia(
                        source,
                        token_end(source, after_name)
                    )
                    binding_type = token_text(source, type_cursor)
                    after_name = skip_trivia(
                        source,
                        token_end(source, type_cursor)
                    )
                }
                let initializer = skip_trivia(
                    source,
                    token_end(source, after_name)
                )
                let mut visible_start = value_end(source, initializer)
                if visible_start < 0 {
                    visible_start = token_end(source, initializer)
                }
                if !annotated &&
                   !value_control(token_text(source, initializer)) {
                    binding_type = initializer_type(
                        source,
                        hir,
                        function_open,
                        initializer
                    )
                }
                let scope_open = parent_block_open(
                    source,
                    function_open,
                    name
                )
                let scope_id = hir_scope_id_for_open(hir, scope_open)
                let first_declaration = hir_same_scope_declaration(
                    hir,
                    scope_id,
                    token_text(source, name)
                )
                if len(first_declaration) > 0 {
                    return "error[E2S47]: duplicate binding `" +
                    token_text(source, name) +
                    "` in lexical scope at byte " + to_text(name) +
                    "; first declaration at byte " + first_declaration
                }
                binding_count = binding_count + 1
                if binding_count > 256 {
                    return "error[E2S35]: lexical binding limit is 256 per function at byte " +
                    to_text(name)
                }
                let mut ownership = "copy"
                if binding_type == "Text" || binding_type == "List" {
                    ownership = "gc"
                }
                hir = hir + "binding|" + to_text(next_binding_id) + "|" +
                scope_id + "|" + token_text(source, name) + "|" +
                mutability + "|" + binding_type + "|" + ownership +
                "|initialized|" + to_text(name) + "|" +
                to_text(token_end(source, name)) + "|" +
                to_text(visible_start) + "\n"
                next_binding_id = next_binding_id + 1
            }
            if token_text(source, cursor) == "for" {
                let name = skip_trivia(source, token_end(source, cursor))
                let mut body_open = name
                while body_open < function_close &&
                      token_text(source, body_open) != "{" {
                    body_open = skip_trivia(
                        source,
                        token_end(source, body_open)
                    )
                }
                if name < function_close &&
                   body_open < function_close &&
                   token_kind(source, name) == "identifier" {
                    let scope_id = hir_scope_id_for_open(hir, body_open)
                    let first_declaration = hir_same_scope_declaration(
                        hir,
                        scope_id,
                        token_text(source, name)
                    )
                    if len(first_declaration) > 0 {
                        return "error[E2S47]: duplicate binding `" +
                        token_text(source, name) +
                        "` in lexical scope at byte " + to_text(name) +
                        "; first declaration at byte " + first_declaration
                    }
                    binding_count = binding_count + 1
                    if binding_count > 256 {
                        return "error[E2S35]: lexical binding limit is 256 per function at byte " +
                        to_text(name)
                    }
                    hir = hir + "binding|" + to_text(next_binding_id) + "|" +
                    scope_id + "|" + token_text(source, name) +
                    "|immutable|Int|copy|initialized|" + to_text(name) + "|" +
                    to_text(token_end(source, name)) + "|" +
                    to_text(token_end(source, name)) + "\n"
                    next_binding_id = next_binding_id + 1
                }
            }
            cursor = skip_trivia(source, token_end(source, cursor))
        }

        let mut use_count = 0
        let mut unresolved_assignment = false
        cursor = skip_trivia(source, token_end(source, function_open))
        while cursor < function_close {
            if token_kind(source, cursor) == "identifier" {
                let name = token_text(source, cursor)
                let declaration_token = enum_declaration_syntax_token(
                    source,
                    function_open,
                    cursor
                )
                let initializer_token = enum_initializer_constructor_token(
                    source,
                    function_open,
                    cursor
                )
                let pattern_token = enum_match_pattern_token(
                    source,
                    function_open,
                    cursor
                )
                if !declaration_token && !initializer_token &&
                   !pattern_token && name != "print" && name != "_" {
                    let scope_open = parent_block_open(
                        source,
                        function_open,
                        cursor
                    )
                    let scope_id = hir_scope_id_for_open(hir, scope_open)
                    let binding_id = hir_resolve_binding(
                        hir,
                        scope_id,
                        cursor,
                        name
                    )
                    let after = skip_trivia(
                        source,
                        token_end(source, cursor)
                    )
                    let mut role = "read"
                    if token_text(source, after) == "=" {
                        role = "assign"
                    }
                    if len(binding_id) > 0 {
                        use_count = use_count + 1
                        if use_count > 256 {
                            return "error[E2S35]: lexical use limit is 256 per function at byte " +
                            to_text(cursor)
                        }
                        hir = hir + "use|" + to_text(cursor) + "|" +
                        to_text(token_end(source, cursor)) + "|" +
                        scope_id + "|" + binding_id + "|" + role + "\n"
                    } else if role == "assign" {
                        use_count = use_count + 1
                        if use_count > 256 {
                            return "error[E2S35]: lexical use limit is 256 per function at byte " +
                            to_text(cursor)
                        }
                        hir = hir + "use|" + to_text(cursor) + "|" +
                        to_text(token_end(source, cursor)) + "|" +
                        scope_id + "|-1|assign\n"
                        unresolved_assignment = true
                    } else if preserve_pattern_candidates &&
                              token_text(source, after) != "(" {
                        use_count = use_count + 1
                        if use_count > 256 {
                            return "error[E2S35]: lexical use limit is 256 per function at byte " +
                            to_text(cursor)
                        }
                        hir = hir + "candidate-use|" + to_text(cursor) + "|" +
                        to_text(token_end(source, cursor)) + "|" +
                        scope_id + "|" + name + "|" + role + "\n"
                    } else if token_text(source, after) != "(" &&
                              !unresolved_assignment {
                        let pending = hir_pending_declaration(
                            hir,
                            scope_id,
                            cursor,
                            name
                        )
                        if len(pending) > 0 {
                            return "error[E2S35]: binding `" + name +
                            "` is not initialized at byte " + to_text(cursor) +
                            "; declaration at byte " + pending
                        }
                        let escaped = hir_any_declaration(
                            hir,
                            scope_id,
                            cursor,
                            name
                        )
                        if len(escaped) > 0 {
                            return "error[E2S35]: binding `" + name +
                            "` is outside its lexical scope at byte " +
                            to_text(cursor) + "; declaration at byte " + escaped
                        }
                        if len(enum_constructor_owner(source, name)) == 0 {
                            return "error[E2S35]: unknown lexical binding `" +
                            name + "` at byte " + to_text(cursor)
                        }
                    }
                }
            }
            cursor = skip_trivia(source, token_end(source, cursor))
        }
        function_start = next_function_start(source, function_close)
    }
    return hir
}

fn build_scope_hir(source: Text) -> Text {
    return build_scope_hir_mode(source, false)
}

fn validate_enum_uses(source: Text, hir: Text) -> Text {
    let constructor_names = enum_declaration_names(source, true)
    if len(constructor_names) <= 1 {
        return "ok"
    }
    let mut function_start = next_function_start(source, 0)
    while function_start < len(source) {
        let function_close = function_end(source, function_start)
        let parameters = parameter_open(source, function_start)
        let parameters_close = balanced_end(source, parameters, "(", ")")
        let mut function_open = skip_trivia(source, parameters_close)
        while function_open < function_close &&
              token_text(source, function_open) != "{" {
            function_open = skip_trivia(
                source,
                token_end(source, function_open)
            )
        }
        let mut related_identifiers = 0
        let mut cursor = skip_trivia(source, token_end(source, function_open))
        let mut previous = ""
        while cursor < function_close {
            if token_kind(source, cursor) == "identifier" {
                let name = token_text(source, cursor)
                let pattern_token = enum_match_pattern_token(
                    source,
                    function_open,
                    cursor
                )
                let initializer_token = enum_initializer_constructor_token(
                    source,
                    function_open,
                    cursor
                )
                let declaration_token = enum_declaration_syntax_token(
                    source,
                    function_open,
                    cursor
                )
                let binding_id = hir_use_binding_id(hir, cursor)
                let binding_type = hir_binding_field(hir, binding_id, 5)
                let binding_enum = len(binding_type) > 0 &&
                enum_constructor_count(source, binding_type) >= 0
                let constructor_named = contains(
                    constructor_names,
                    "|" + name + "|"
                )
                let related = pattern_token || initializer_token ||
                binding_enum ||
                (constructor_named && len(binding_id) == 0 &&
                 !declaration_token)
                if related {
                    related_identifiers = related_identifiers + 1
                    if related_identifiers > 256 {
                        return "error[E2S32]: enum-related identifier use limit is 256 per function at byte " +
                        to_text(cursor)
                    }
                    if !pattern_token && !initializer_token &&
                       !declaration_token {
                        if binding_enum {
                            let after = skip_trivia(
                                source,
                                token_end(source, cursor)
                            )
                            let match_scrutinee = previous == "match" &&
                            token_text(source, after) == "{"
                            if !match_scrutinee {
                                return "error[E2S32]: concrete enum binding `" +
                                name +
                                "` is match-only in this Core slice at byte " +
                                to_text(cursor)
                            }
                        } else if constructor_named &&
                                  len(binding_id) == 0 {
                            let after = skip_trivia(
                                source,
                                token_end(source, cursor)
                            )
                            let resolved_function_call =
                            token_text(source, after) == "(" &&
                            function_arity(source, name) >= 0
                            if !resolved_function_call {
                                let constructor_owner = enum_constructor_owner(
                                    source,
                                    name
                                )
                                if len(constructor_owner) > 0 {
                                    return "error[E2S32]: concrete enum constructor `" +
                                    name +
                                    "` is only valid in an explicitly typed enum initializer or match pattern at byte " +
                                    to_text(cursor)
                                }
                            }
                        }
                    }
                }
            }
            previous = token_text(source, cursor)
            cursor = skip_trivia(source, token_end(source, cursor))
        }
        function_start = next_function_start(source, function_close)
    }
    return "ok"
}

fn enum_match_end(source: Text, start: Int) -> Int {
    let value_start = skip_trivia(source, token_end(source, start))
    let arms_open = skip_trivia(source, token_end(source, value_start))
    if arms_open >= len(source) || token_text(source, arms_open) != "{" {
        return -1
    }
    return balanced_end(source, arms_open, "{", "}")
}

fn lower_enum_match(
    source: Text,
    hir: Text,
    match_start: Int,
    enum_type: Text,
    is_main: Bool,
    function_open: Int
) -> Text {
    let value_start = skip_trivia(source, token_end(source, match_start))
    let value_name = token_text(source, value_start)
    let arms_open = skip_trivia(source, token_end(source, value_start))
    if arms_open >= len(source) || token_text(source, arms_open) != "{" {
        return "error[E2S24]: expected `{` after enum match scrutinee at byte " +
        to_text(arms_open)
    }
    let mut arm_cursor = skip_trivia(source, token_end(source, arms_open))
    let mut covered = "|"
    let mut seen_catchall = false
    let mut dispatch = ""
    let mut failure_result = "0"
    if is_main {
        failure_result = "1"
    }
    while arm_cursor < len(source) && token_text(source, arm_cursor) != "}" {
        let pattern_start = arm_cursor
        let pattern_info = pattern_summary(source, pattern_start)
        let pattern_kind = pattern_summary_kind(pattern_info)
        let pattern = token_text(source, pattern_start)
        let catchall = pattern_kind == "WildcardPattern"
        if seen_catchall {
            return "error[E2S26]: pattern after catch-all is unreachable at byte " +
            to_text(pattern_start)
        }
        let mut tag = -1
        if catchall {
            if enum_constructors_covered(source, enum_type, covered) {
                return "error[E2S26]: catch-all pattern is unreachable at byte " +
                to_text(pattern_start)
            }
        } else {
            if pattern_kind != "NamePattern" {
                return "error[E2S32]: enum pattern must name a constructor or `_` at byte " +
                to_text(pattern_start)
            }
            tag = enum_constructor_index(source, enum_type, pattern)
            if tag < 0 {
                return "error[E2S32]: constructor `" + pattern +
                "` does not belong to enum `" + enum_type + "` at byte " +
                to_text(pattern_start)
            }
            if contains(covered, "|" + pattern + "|") {
                return "error[E2S26]: duplicate enum constructor pattern `" +
                pattern + "` is unreachable at byte " +
                to_text(pattern_start)
            }
        }
        let after_pattern = skip_trivia(
            source,
            pattern_summary_end(pattern_info)
        )
        let mut guarded = false
        let mut guard_start = -1
        let mut guard_end = -1
        let mut arrow = after_pattern
        if arrow < len(source) && token_text(source, arrow) == "if" {
            guarded = true
            guard_start = skip_trivia(source, token_end(source, arrow))
            guard_end = condition_end(source, guard_start)
            if guard_end < 0 {
                return "error[E2S29]: match guard must be Bool or an Int comparison at byte " +
                to_text(guard_start)
            }
            arrow = skip_trivia(source, guard_end)
        }
        if arrow >= len(source) || token_text(source, arrow) != "=>" {
            return "error[E2S24]: expected `=>` after enum pattern at byte " +
            to_text(arrow)
        }
        let arm_open = skip_trivia(source, token_end(source, arrow))
        if arm_open >= len(source) || token_text(source, arm_open) != "{" {
            return "error[E2S24]: bounded enum match arm must use a block at byte " +
            to_text(arm_open)
        }
        let arm_close = balanced_end(source, arm_open, "{", "}")
        if arm_close < 0 {
            return "error[E2S24]: missing `}` after enum match arm at byte " +
            to_text(arm_open)
        }
        let arm_body = lower_body(
            source,
            hir,
            arm_open,
            is_main,
            false,
            function_open
        )
        if starts_with(arm_body, "error[") {
            return arm_body
        }
        let mut pattern_condition = "true"
        if !catchall {
            pattern_condition = "kofun_match_value == INT64_C(" +
            to_text(tag) + ")"
        }
        if guarded {
            dispatch = dispatch +
            "        if (!kofun_match_selected && " +
            pattern_condition + ") {\n" +
            emit_condition_into(
                source,
                hir,
                guard_start,
                guard_end,
                "kofun_match_guard",
                failure_result,
                "            "
            ) +
            "            if (kofun_match_guard) {\n" +
            arm_body +
            "                kofun_match_selected = true;\n" +
            "            }\n" +
            "        }\n"
        } else {
            dispatch = dispatch +
            "        if (!kofun_match_selected && " +
            pattern_condition + ") {\n" +
            arm_body +
            "            kofun_match_selected = true;\n" +
            "        }\n"
            if catchall {
                seen_catchall = true
            } else {
                covered = covered + pattern + "|"
            }
        }
        arm_cursor = skip_trivia(source, arm_close)
        if arm_cursor < len(source) && token_text(source, arm_cursor) == "," {
            arm_cursor = skip_trivia(source, token_end(source, arm_cursor))
        } else if arm_cursor >= len(source) ||
                  token_text(source, arm_cursor) != "}" {
            return "error[E2S24]: expected `,` between enum match arms at byte " +
            to_text(arm_cursor)
        }
    }
    if arm_cursor >= len(source) || token_text(source, arm_cursor) != "}" {
        return "error[E2S24]: missing `}` after enum match arms at byte " +
        to_text(arms_open)
    }
    if !seen_catchall &&
       !enum_constructors_covered(source, enum_type, covered) {
        return "error[E2S25]: non-exhaustive enum `" + enum_type +
        "` match; missing constructors " +
        enum_missing_constructors(source, enum_type, covered) +
        " at byte " + to_text(match_start)
    }
    return "    {\n" +
    "        int64_t kofun_match_value = k_b" +
    hir_use_binding_id(hir, value_start) + ";\n" +
    "        (void)kofun_match_value;\n" +
    "        bool kofun_match_selected = false;\n" +
    dispatch +
    "    }\n"
}

fn lower_body(
    source: Text,
    hir: Text,
    open: Int,
    is_main: Bool,
    append_default: Bool,
    function_open: Int
) -> Text {
    let mut emitted = ""
    let mut cursor = skip_trivia(source, token_end(source, open))
    let mut returned = false
    let mut failure_result = "0"
    if is_main {
        failure_result = "1"
    }
    while cursor < len(source) && token_text(source, cursor) != "}" {
        if returned {
            return "error[E2S14]: statement follows `return` at byte " +
            to_text(cursor)
        }
        let statement = token_text(source, cursor)
        if statement == "let" {
            cursor = skip_trivia(source, token_end(source, cursor))
            let mut mutable = false
            if cursor < len(source) && token_text(source, cursor) == "mut" {
                mutable = true
                cursor = skip_trivia(source, token_end(source, cursor))
            }
            if cursor >= len(source) ||
               token_kind(source, cursor) != "identifier" {
                return "error[E2S11]: expected binding name at byte " +
                to_text(cursor)
            }
            let name = token_text(source, cursor)
            let binding_id = hir_definition_id_at(hir, cursor)
            let storage = "k_b" + binding_id
            cursor = skip_trivia(source, token_end(source, cursor))
            let mut binding_type = "Int"
            if cursor < len(source) && token_text(source, cursor) == ":" {
                cursor = skip_trivia(source, token_end(source, cursor))
                if cursor >= len(source) ||
                   token_kind(source, cursor) != "identifier" {
                    return "error[E2S11]: expected Core binding type at byte " +
                    to_text(cursor)
                }
                binding_type = token_text(source, cursor)
                if binding_type != "Int" &&
                   enum_constructor_count(source, binding_type) < 0 {
                    return "error[E2S32]: unknown concrete enum type `" +
                    binding_type + "` at byte " + to_text(cursor)
                }
                cursor = skip_trivia(source, token_end(source, cursor))
            }
            if cursor >= len(source) || token_text(source, cursor) != "=" {
                return "error[E2S11]: expected `=` at byte " + to_text(cursor)
            }
            let value_start = skip_trivia(source, token_end(source, cursor))
            if binding_type != "Int" {
                if mutable {
                    return "error[E2S32]: concrete enum bindings are immutable in this Core slice at byte " +
                    to_text(value_start)
                }
                if token_kind(source, value_start) != "identifier" {
                    return "error[E2S32]: concrete enum initializer must name a constructor at byte " +
                    to_text(value_start)
                }
                let constructor = token_text(source, value_start)
                let tag = enum_constructor_index(
                    source,
                    binding_type,
                    constructor
                )
                if tag < 0 {
                    return "error[E2S32]: constructor `" + constructor +
                    "` does not belong to enum `" + binding_type +
                    "` at byte " + to_text(value_start)
                }
                emitted = emitted + "    int64_t " + storage +
                " = INT64_C(" + to_text(tag) + ");\n"
                cursor = skip_trivia(source, token_end(source, value_start))
            } else if value_control(token_text(source, value_start)) {
                let value_check = validate_value_control(source, value_start)
                if starts_with(value_check, "error[") {
                    return value_check
                }
                let value_end = value_end(source, value_start)
                emitted = emitted + "    int64_t " + storage +
                " = INT64_C(0);\n" +
                emit_value_into(
                    source,
                    hir,
                    value_start,
                    value_end,
                    storage,
                    failure_result
                )
                cursor = skip_trivia(source, value_end)
            } else {
                let value_end = expression_end(source, value_start)
                if value_end < 0 {
                    return "error[E2S12]: invalid Int expression at byte " +
                    to_text(value_start)
                }
                emitted = emitted + "    int64_t " + storage + " = " +
                emit_expression(source, hir, value_start, value_end) + ";\n" +
                "    if (kofun_failed) return " + failure_result + ";\n"
                cursor = skip_trivia(source, value_end)
            }
        } else if statement == "print" {
            let call_open = skip_trivia(source, token_end(source, cursor))
            if call_open >= len(source) ||
               token_text(source, call_open) != "(" {
                return "error[E2S13]: expected `print(` at byte " +
                to_text(cursor)
            }
            let value_start = skip_trivia(source, token_end(source, call_open))
            if value_control(token_text(source, value_start)) {
                let value_check = validate_value_control(source, value_start)
                if starts_with(value_check, "error[") {
                    return value_check
                }
                let value_end = value_end(source, value_start)
                let call_close = skip_trivia(source, value_end)
                if call_close >= len(source) ||
                   token_text(source, call_close) != ")" {
                    return "error[E2S13]: expected `)` at byte " +
                    to_text(call_close)
                }
                emitted = emitted +
                "    {\n" +
                "        int64_t kofun_value = INT64_C(0);\n" +
                emit_value_into(
                    source,
                    hir,
                    value_start,
                    value_end,
                    "kofun_value",
                    failure_result
                ) +
                "        printf(\"%\" PRId64 \"\\n\", kofun_value);\n" +
                "    }\n"
                cursor = skip_trivia(source, token_end(source, call_close))
            } else {
                let value_end = expression_end(source, value_start)
                if value_end < 0 {
                    return "error[E2S12]: invalid Int expression at byte " +
                    to_text(value_start)
                }
                let call_close = skip_trivia(source, value_end)
                if call_close >= len(source) ||
                   token_text(source, call_close) != ")" {
                    return "error[E2S13]: expected `)` at byte " +
                    to_text(call_close)
                }
                emitted = emitted +
                "    {\n" +
                "        int64_t kofun_value = " +
                emit_expression(source, hir, value_start, value_end) + ";\n" +
                "        if (kofun_failed) return " + failure_result + ";\n" +
                "        printf(\"%\" PRId64 \"\\n\", kofun_value);\n" +
                "    }\n"
                cursor = skip_trivia(source, token_end(source, call_close))
            }
        } else if statement == "if" {
            let condition_start = skip_trivia(
                source,
                token_end(source, cursor)
            )
            let condition_close = condition_end(source, condition_start)
            if condition_close < 0 {
                return "error[E2S23]: if condition must be Bool or an Int comparison at byte " +
                to_text(condition_start)
            }
            let branch_open = skip_trivia(source, condition_close)
            if branch_open >= len(source) ||
               token_text(source, branch_open) != "{" {
                return "error[E2S18]: expected `{` after if condition at byte " +
                to_text(branch_open)
            }
            let branch_close = balanced_end(source, branch_open, "{", "}")
            if branch_close < 0 {
                return "error[E2S18]: missing `}` after if branch at byte " +
                to_text(branch_open)
            }
            let branch_body = lower_body(
                source,
                hir,
                branch_open,
                is_main,
                false,
                function_open
            )
            if starts_with(branch_body, "error[") {
                return branch_body
            }
            emitted = emitted +
            "    {\n" +
            emit_condition_into(
                source,
                hir,
                condition_start,
                condition_close,
                "kofun_condition",
                failure_result,
                "        "
            ) +
            "        if (kofun_condition) {\n" +
            branch_body +
            "        }"
            cursor = skip_trivia(source, branch_close)
            if cursor < len(source) && token_text(source, cursor) == "else" {
                let else_open = skip_trivia(
                    source,
                    token_end(source, cursor)
                )
                if else_open >= len(source) ||
                   token_text(source, else_open) != "{" {
                    return "error[E2S18]: expected `{` after `else` at byte " +
                    to_text(else_open)
                }
                let else_close = balanced_end(source, else_open, "{", "}")
                if else_close < 0 {
                    return "error[E2S18]: missing `}` after else branch at byte " +
                    to_text(else_open)
                }
                let else_body = lower_body(
                    source,
                    hir,
                    else_open,
                    is_main,
                    false,
                    function_open
                )
                if starts_with(else_body, "error[") {
                    return else_body
                }
                emitted = emitted + " else {\n" + else_body + "        }"
                cursor = skip_trivia(source, else_close)
            }
            emitted = emitted + "\n    }\n"
        } else if statement == "match" {
            let match_start = cursor
            let value_start = skip_trivia(
                source,
                token_end(source, cursor)
            )
            let direct_end = skip_trivia(
                source,
                token_end(source, value_start)
            )
            if token_kind(source, value_start) == "identifier" &&
               direct_end < len(source) &&
               token_text(source, direct_end) == "{" {
                let value_name = token_text(source, value_start)
                let enum_binding = hir_use_binding_id(hir, value_start)
                let enum_type = hir_binding_field(hir, enum_binding, 5)
                if len(enum_type) == 0 || enum_type == "Int" ||
                   enum_constructor_count(source, enum_type) < 0 {
                    return "error[E2S32]: enum match scrutinee `" +
                    value_name +
                    "` must be a preceding explicitly typed enum binding at byte " +
                    to_text(value_start)
                }
                let match_body = lower_enum_match(
                    source,
                    hir,
                    match_start,
                    enum_type,
                    is_main,
                    function_open
                )
                if starts_with(match_body, "error[") {
                    return match_body
                }
                emitted = emitted + match_body
                let match_end = enum_match_end(source, match_start)
                cursor = skip_trivia(source, match_end)
            } else {
            let value_end = condition_end(source, value_start)
            if value_end < 0 {
                return "error[E2S24]: bounded match scrutinee must be Bool at byte " +
                to_text(value_start)
            }
            let arms_open = skip_trivia(source, value_end)
            if arms_open >= len(source) ||
               token_text(source, arms_open) != "{" {
                return "error[E2S24]: expected `{` after match scrutinee at byte " +
                to_text(arms_open)
            }
            let mut arm_cursor = skip_trivia(
                source,
                token_end(source, arms_open)
            )
            let mut covered_true = false
            let mut covered_false = false
            let mut seen_catchall = false
            let mut dispatch = ""
            while arm_cursor < len(source) &&
                  token_text(source, arm_cursor) != "}" {
                let pattern_start = arm_cursor
                let pattern_info = pattern_summary(source, pattern_start)
                let pattern_kind = pattern_summary_kind(pattern_info)
                let pattern = token_text(source, pattern_start)
                let pattern_true = pattern_kind == "LiteralPattern" &&
                pattern == "true"
                let pattern_false = pattern_kind == "LiteralPattern" &&
                pattern == "false"
                let pattern_catchall = pattern_kind == "WildcardPattern"
                if seen_catchall {
                    return "error[E2S26]: pattern after catch-all is unreachable at byte " +
                    to_text(pattern_start)
                }
                if pattern_true && covered_true {
                    return "error[E2S26]: duplicate `true` pattern is unreachable at byte " +
                    to_text(pattern_start)
                }
                if pattern_false && covered_false {
                    return "error[E2S26]: duplicate `false` pattern is unreachable at byte " +
                    to_text(pattern_start)
                }
                if pattern_catchall && covered_true && covered_false {
                    return "error[E2S26]: catch-all pattern is unreachable at byte " +
                    to_text(pattern_start)
                }
                if !pattern_true && !pattern_false && !pattern_catchall {
                    return "error[E2S24]: bounded Bool pattern must be `true`, `false`, or `_` at byte " +
                    to_text(pattern_start)
                }
                let after_pattern = skip_trivia(
                    source,
                    pattern_summary_end(pattern_info)
                )
                let mut guarded = false
                let mut guard_start = -1
                let mut guard_end = -1
                let mut arrow = after_pattern
                if arrow < len(source) &&
                   token_text(source, arrow) == "if" {
                    guarded = true
                    guard_start = skip_trivia(
                        source,
                        token_end(source, arrow)
                    )
                    guard_end = condition_end(source, guard_start)
                    if guard_end < 0 {
                        return "error[E2S29]: match guard must be Bool or an Int comparison at byte " +
                        to_text(guard_start)
                    }
                    arrow = skip_trivia(source, guard_end)
                }
                if arrow >= len(source) ||
                   token_text(source, arrow) != "=>" {
                    return "error[E2S24]: expected `=>` after Bool pattern at byte " +
                    to_text(arrow)
                }
                let arm_open = skip_trivia(
                    source,
                    token_end(source, arrow)
                )
                if arm_open >= len(source) ||
                   token_text(source, arm_open) != "{" {
                    return "error[E2S24]: bounded Bool match arm must use a block at byte " +
                    to_text(arm_open)
                }
                let arm_close = balanced_end(source, arm_open, "{", "}")
                if arm_close < 0 {
                    return "error[E2S24]: missing `}` after match arm at byte " +
                    to_text(arm_open)
                }
                let arm_body = lower_body(
                    source,
                    hir,
                    arm_open,
                    is_main,
                    false,
                    function_open
                )
                if starts_with(arm_body, "error[") {
                    return arm_body
                }

                let mut pattern_condition = "true"
                if pattern_true {
                    pattern_condition = "kofun_match_value"
                } else if pattern_false {
                    pattern_condition = "!kofun_match_value"
                }
                if guarded {
                    dispatch = dispatch +
                    "        if (!kofun_match_selected && " +
                    pattern_condition + ") {\n" +
                    emit_condition_into(
                        source,
                        hir,
                        guard_start,
                        guard_end,
                        "kofun_match_guard",
                        failure_result,
                        "            "
                    ) +
                    "            if (kofun_match_guard) {\n" +
                    arm_body +
                    "                kofun_match_selected = true;\n" +
                    "            }\n" +
                    "        }\n"
                } else {
                    dispatch = dispatch +
                    "        if (!kofun_match_selected && " +
                    pattern_condition + ") {\n" +
                    arm_body +
                    "            kofun_match_selected = true;\n" +
                    "        }\n"
                    if pattern_true {
                        covered_true = true
                    } else if pattern_false {
                        covered_false = true
                    } else {
                        covered_true = true
                        covered_false = true
                        seen_catchall = true
                    }
                }
                arm_cursor = skip_trivia(source, arm_close)
                if arm_cursor < len(source) &&
                   token_text(source, arm_cursor) == "," {
                    arm_cursor = skip_trivia(
                        source,
                        token_end(source, arm_cursor)
                    )
                } else if arm_cursor >= len(source) ||
                          token_text(source, arm_cursor) != "}" {
                    return "error[E2S24]: expected `,` between match arms at byte " +
                    to_text(arm_cursor)
                }
            }
            if arm_cursor >= len(source) ||
               token_text(source, arm_cursor) != "}" {
                return "error[E2S24]: missing `}` after match arms at byte " +
                to_text(arms_open)
            }
            if !covered_true && !covered_false {
                return "error[E2S25]: non-exhaustive Bool match; missing patterns `true`, `false` at byte " +
                to_text(match_start)
            }
            if !covered_true {
                return "error[E2S25]: non-exhaustive Bool match; missing pattern `true` at byte " +
                to_text(match_start)
            }
            if !covered_false {
                return "error[E2S25]: non-exhaustive Bool match; missing pattern `false` at byte " +
                to_text(match_start)
            }
            emitted = emitted +
            "    {\n" +
            emit_condition_into(
                source,
                hir,
                value_start,
                value_end,
                "kofun_match_value",
                failure_result,
                "        "
            ) +
            "        (void)kofun_match_value;\n" +
            "        bool kofun_match_selected = false;\n" +
            dispatch +
            "    }\n"
            cursor = skip_trivia(source, token_end(source, arm_cursor))
            }
        } else if statement == "return" {
            let value_start = skip_trivia(source, token_end(source, cursor))
            if value_start < len(source) &&
               token_text(source, value_start) == "}" {
                emitted = emitted + "    return 0;\n"
                cursor = value_start
            } else if value_control(token_text(source, value_start)) {
                let value_check = validate_value_control(source, value_start)
                if starts_with(value_check, "error[") {
                    return value_check
                }
                let value_end = value_end(source, value_start)
                emitted = emitted +
                "    {\n" +
                "        int64_t kofun_result = INT64_C(0);\n" +
                emit_value_into(
                    source,
                    hir,
                    value_start,
                    value_end,
                    "kofun_result",
                    failure_result
                )
                if is_main {
                    emitted = emitted +
                    "        return (int)kofun_result;\n"
                } else {
                    emitted = emitted + "        return kofun_result;\n"
                }
                emitted = emitted + "    }\n"
                cursor = skip_trivia(source, value_end)
            } else {
                let value_end = expression_end(source, value_start)
                if value_end < 0 {
                    return "error[E2S12]: invalid return expression at byte " +
                    to_text(value_start)
                }
                emitted = emitted +
                "    {\n" +
                "        int64_t kofun_result = " +
                emit_expression(source, hir, value_start, value_end) + ";\n" +
                "        if (kofun_failed) return " + failure_result + ";\n"
                if is_main {
                    emitted = emitted +
                    "        return (int)kofun_result;\n"
                } else {
                    emitted = emitted + "        return kofun_result;\n"
                }
                emitted = emitted +
                "    }\n"
                cursor = skip_trivia(source, value_end)
            }
            returned = true
        } else if token_kind(source, cursor) == "identifier" {
            let assignment_start = cursor
            let name = token_text(source, cursor)
            let equals = skip_trivia(source, token_end(source, cursor))
            if equals < len(source) && token_text(source, equals) == "=" {
                let binding_id = hir_use_binding_id(hir, assignment_start)
                if binding_id == "-1" || len(binding_id) == 0 {
                    return "error[E2S22]: unknown assignment target `" + name +
                    "` at byte " + to_text(assignment_start) +
                    "; declare it before assignment"
                }
                let mutability = hir_binding_field(hir, binding_id, 4)
                if mutability != "mutable" {
                    return "error[E2S22]: cannot assign to immutable binding `" +
                    name + "` at byte " + to_text(assignment_start) +
                    "; declare it with `let mut`"
                }
                let value_start = skip_trivia(source, token_end(source, equals))
                if value_control(token_text(source, value_start)) {
                    let value_check = validate_value_control(source, value_start)
                    if starts_with(value_check, "error[") {
                        return value_check
                    }
                    let value_end = value_end(source, value_start)
                    emitted = emitted +
                    "    {\n" +
                    "        int64_t kofun_replacement = INT64_C(0);\n" +
                    emit_value_into(
                        source,
                        hir,
                        value_start,
                        value_end,
                        "kofun_replacement",
                        failure_result
                    ) +
                    "        k_b" + binding_id + " = kofun_replacement;\n" +
                    "    }\n"
                    cursor = skip_trivia(source, value_end)
                } else {
                    let value_end = expression_end(source, value_start)
                    if value_end < 0 {
                        return "error[E2S12]: invalid Int expression at byte " +
                        to_text(value_start)
                    }
                    emitted = emitted +
                    "    {\n" +
                    "        int64_t kofun_replacement = " +
                    emit_expression(source, hir, value_start, value_end) + ";\n" +
                    "        if (kofun_failed) return " + failure_result + ";\n" +
                    "        k_b" + binding_id + " = kofun_replacement;\n" +
                    "    }\n"
                    cursor = skip_trivia(source, value_end)
                }
            } else {
                let value_end = expression_end(source, cursor)
                if value_end < 0 {
                    return "error[E2S12]: invalid expression statement at byte " +
                    to_text(cursor)
                }
                emitted = emitted + "    (void)" +
                emit_expression(source, hir, cursor, value_end) + ";\n" +
                "    if (kofun_failed) return " + failure_result + ";\n"
                cursor = skip_trivia(source, value_end)
            }
        } else {
            return "error[E2S10]: unsupported Core statement at byte " +
            to_text(cursor)
        }
    }
    if cursor >= len(source) || token_text(source, cursor) != "}" {
        return "error[E2S03]: missing function close"
    }
    if !returned && append_default {
        if !is_main {
            return "error[E2S19]: Core function may complete without returning Int at byte " +
            to_text(open)
        }
        emitted = emitted + "    return 0;\n"
    }
    return emitted
}

fn lower_c(source: Text, hir: Text) -> Text {
    let enum_use_check = validate_enum_uses(source, hir)
    if starts_with(enum_use_check, "error[") {
        return enum_use_check
    }
    let type_check = validate_core_types(source, hir)
    if starts_with(type_check, "error[") {
        return type_check
    }
    let call_check = validate_core_calls(source, hir)
    if starts_with(call_check, "error[") {
        return call_check
    }
    let mut prototypes = ""
    let mut bodies = ""
    let mut cursor = next_function_start(source, 0)
    let mut main_count = 0
    while cursor < len(source) {
        let name = function_name(source, cursor)
        if function_arity(source, name) == -2 {
            return "error[E2S16]: duplicate Core function `" + name +
            "` at byte " + to_text(cursor)
        }
        let is_main = name == "main"
        let arity = parameter_count(source, cursor)
        let parameters = core_parameters(source, hir, cursor)
        if starts_with(parameters, "error[") {
            return parameters
        }
        let mut c_parameters = parameters
        if len(c_parameters) == 0 {
            c_parameters = "void"
        }
        if is_main {
            main_count = main_count + 1
            if arity != 0 {
                return "error[E2S15]: Core main must have zero parameters"
            }
        } else {
            prototypes = prototypes + "static int64_t kofun_fn_" + name +
            "(" + c_parameters + ");\n"
        }
        let open = core_body_open(source, hir, cursor, is_main)
        if open < 0 {
            return "error[E2S15]: Core function `" + name +
            "` requires Int parameters and an Int return"
        }
        let body = lower_body(source, hir, open, is_main, true, open)
        if starts_with(body, "error[") {
            return body
        }
        if is_main {
            bodies = bodies + "int main(void) {\n" +
            "    (void)kofun_failed;\n" +
            "    (void)kofun_add;\n" +
            "    (void)kofun_sub;\n" +
            "    (void)kofun_mul;\n" +
            "    (void)kofun_neg;\n" +
            "    (void)kofun_floor_div;\n" +
            "    (void)kofun_floor_mod;\n" +
            body + "}\n"
        } else {
            bodies = bodies + "static int64_t kofun_fn_" + name +
            "(" + c_parameters + ") {\n" + body + "}\n"
        }
        cursor = next_function_start(source, function_end(source, cursor))
    }
    if main_count != 1 {
        return "error[E2S15]: C11 Core requires exactly one `fn main()`"
    }
    return "/* Generated by the Kofun-written Stage 2 Core lowerer. */\n" +
    "#include <inttypes.h>\n" +
    "#include <stdbool.h>\n" +
    "#include <stdint.h>\n" +
    "#include <stdio.h>\n\n" +
    "static bool kofun_failed;\n" +
    "static inline void kofun_error(const char *message) {\n" +
    "    if (!kofun_failed) { fputs(message, stderr); fputc('\\n', stderr); }\n" +
    "    kofun_failed = true;\n" +
    "}\n" +
    "static inline int64_t kofun_add(int64_t a, int64_t b) {\n" +
    "    int64_t r; if (__builtin_add_overflow(a, b, &r)) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `+`\"); return 0;\n" +
    "    } return r;\n" +
    "}\n" +
    "static inline int64_t kofun_sub(int64_t a, int64_t b) {\n" +
    "    int64_t r; if (__builtin_sub_overflow(a, b, &r)) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `-`\"); return 0;\n" +
    "    } return r;\n" +
    "}\n" +
    "static inline int64_t kofun_mul(int64_t a, int64_t b) {\n" +
    "    int64_t r; if (__builtin_mul_overflow(a, b, &r)) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `*`\"); return 0;\n" +
    "    } return r;\n" +
    "}\n" +
    "static inline int64_t kofun_neg(int64_t value) {\n" +
    "    if (value == INT64_MIN) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in unary operator `-`\"); return 0;\n" +
    "    } return -value;\n" +
    "}\n" +
    "static inline int64_t kofun_floor_div(int64_t a, int64_t b) {\n" +
    "    if (b == 0) {\n" +
    "        kofun_error(\"error[R010]: operator `//` failed: division by zero\"); return 0;\n" +
    "    }\n" +
    "    if (a == INT64_MIN && b == -1) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `//`\"); return 0;\n" +
    "    }\n" +
    "    int64_t q = a / b; int64_t r = a % b;\n" +
    "    if (r != 0 && ((r < 0) != (b < 0))) { --q; }\n" +
    "    return q;\n" +
    "}\n" +
    "static inline int64_t kofun_floor_mod(int64_t a, int64_t b) {\n" +
    "    if (b == 0) {\n" +
    "        kofun_error(\"error[R010]: operator `%` failed: division by zero\"); return 0;\n" +
    "    }\n" +
    "    if (a == INT64_MIN && b == -1) return 0;\n" +
    "    int64_t r = a % b;\n" +
    "    if (r != 0 && ((r < 0) != (b < 0))) { r += b; }\n" +
    "    return r;\n" +
    "}\n\n" + prototypes + "\n" + bodies
}

fn emit_kofun(source: Text, ir: Text) -> Text {
    if starts_with(ir, "error[") {
        return ""
    }
    return source
}

fn unsupported_lowering_error(diagnostic: Text) -> Bool {
    return starts_with(
        diagnostic,
        "error[E2S10]: unsupported Core statement"
    ) || starts_with(
        diagnostic,
        "error[E2S10]: unsupported Core builtin call "
    ) || starts_with(
        diagnostic,
        "error[E2S24]: general pattern syntax is parsed "
    )
}

fn compile_file(
    input_path: Text,
    output_path: Text,
    ir_path: Text,
    tokens_path: Text
) -> Int {
    let source = read_text(input_path)
    let tokens = lex(source)
    if starts_with(tokens, "error[") {
        print(tokens)
        return 1
    }
    let ir = parse_program(source)
    if starts_with(ir, "error[") {
        print(ir)
        return 1
    }
    write_text(tokens_path, tokens)
    write_text(ir_path, ir)
    if ends_with(output_path, ".c") {
        let pattern_check = validate_executable_patterns(source)
        if starts_with(pattern_check, "error[") {
            print(pattern_check)
            if unsupported_lowering_error(pattern_check) {
                return 3
            }
            return 1
        }
        let hir = build_scope_hir(source)
        if starts_with(hir, "error[") {
            print(hir)
            let ownership = borrowed_collection_check(source)
            if ownership == "ok" {
                return 3
            }
            return 1
        }
        let c_source = lower_c(source, hir)
        if starts_with(c_source, "error[") {
            print(c_source)
            if unsupported_lowering_error(c_source) {
                return 3
            }
            return 1
        }
        write_text(ir_path, ir + hir)
        write_text(output_path, c_source)
    } else {
        write_text(output_path, emit_kofun(source, ir))
    }
    print(output_path)
    return 0
}

fn parse_patterns_file(input_path: Text, output_path: Text) -> Bool {
    let source = read_text(input_path)
    let tokens = lex(source)
    if starts_with(tokens, "error[") {
        print(tokens)
        return false
    }
    let tree = parse_pattern_trees(source)
    write_text(output_path, tree)
    let pattern_error = pattern_first_error(tree)
    if len(pattern_error) > 0 {
        print(pattern_error)
        return false
    }
    return true
}

fn emit_scope_hir_file(input_path: Text, output_path: Text) -> Bool {
    if input_path == output_path {
        print("error[E2S35]: scope-HIR input and output must be distinct")
        return false
    }
    let source = read_text(input_path)
    let tokens = lex(source)
    if starts_with(tokens, "error[") {
        print(tokens)
        return false
    }
    let tree = parse_pattern_trees(source)
    let pattern_error = pattern_first_error(tree)
    if len(pattern_error) > 0 {
        print(pattern_error)
        return false
    }
    let hir = build_scope_hir_mode(source, true)
    if starts_with(hir, "error[") {
        print(hir)
        return false
    }
    write_text(output_path, hir)
    return true
}

fn check_ownership_file(input_path: Text) -> Bool {
    let source = read_text(input_path)
    let tokens = lex(source)
    if starts_with(tokens, "error[") {
        print(tokens)
        return false
    }
    let ir = parse_program(source)
    if starts_with(ir, "error[") {
        print(ir)
        return false
    }
    let result = borrowed_collection_check(source)
    if starts_with(result, "error[") {
        print(result)
        return false
    }
    return true
}

# kofun.selfhost-hir/v1 emitter (bootstrap/selfhost/hir-v1.md).
#
# One typed pre-order walk over the frozen profile surface produces the
# complete document: deduplicated type table, scope tree, symbols,
# bindings, and per-function node records. Any construct outside the
# profile rejects the whole document with diagnostics plus explicit
# `unsupported` records; a partial typed document is never written.
#
# The bootstrap subset has no tuples or mutable globals, so every pass
# returns one Text: a `|`-separated header line followed by record lines.
# Internal errors are a single `error|CODE|AT|MESSAGE` line; `AT` is -1
# when the diagnostic carries no byte position. Expressions parse into
# local `xnode` records first, then a second walk renumbers them into the
# document's pre-order node ids, exactly like the audited seed's
# parse-then-emit split.

fn selfhost_field(result: Text, wanted: Int) -> Text {
    return pattern_line_field(result, 0, wanted)
}

fn selfhost_field_int(result: Text, wanted: Int) -> Int {
    return decimal_value(selfhost_field(result, wanted))
}

fn selfhost_records(result: Text) -> Text {
    return pattern_result_records(result)
}

fn selfhost_error(code: Text, at: Int, message: Text) -> Text {
    return "error|" + code + "|" + to_text(at) + "|" + message
}

fn selfhost_failed(result: Text) -> Bool {
    return starts_with(result, "error|")
}

# hir-v1 record escaping: `\` -> `\\`, `|` -> `\p`, newline -> `\n`.
fn selfhost_escape(value: Text) -> Text {
    let symbols = chars(value)
    let mut escaped = ""
    let mut cursor = 0
    while cursor < len(symbols) {
        let symbol = symbols[cursor]
        if symbol == "\\" {
            escaped = escaped + "\\\\"
        } else if symbol == "|" {
            escaped = escaped + "\\p"
        } else if symbol == "\n" {
            escaped = escaped + "\\n"
        } else {
            escaped = escaped + symbol
        }
        cursor = cursor + 1
    }
    return escaped
}

# Surface names Int/Bool/Text/Void/List map onto the closed universe.
fn selfhost_scalar_key(surface: Text) -> Text {
    if surface == "Int" {
        return "int"
    }
    if surface == "Bool" {
        return "bool"
    }
    if surface == "Text" {
        return "text"
    }
    if surface == "Void" {
        return "void"
    }
    if surface == "List" {
        return "list-text"
    }
    return ""
}

fn selfhost_line_count(records: Text) -> Int {
    let symbols = chars(records)
    let mut cursor = 0
    let mut count = 0
    while cursor < len(symbols) {
        if symbols[cursor] == "\n" {
            count = count + 1
        }
        cursor = cursor + 1
    }
    return count
}

# The deduplicated type table is kept as its emitted `type|ID|KEY` record
# lines. Keys of function types contain `|`, so the key of a line is the
# remainder after its second separator.
fn selfhost_type_lookup(types: Text, key: Text) -> Int {
    let symbols = chars(types)
    let mut line = 0
    while line < len(symbols) {
        let mut cursor = line
        let mut bars = 0
        while cursor < len(symbols) && symbols[cursor] != "\n" && bars < 2 {
            if symbols[cursor] == "|" {
                bars = bars + 1
            }
            cursor = cursor + 1
        }
        let mut line_end = cursor
        while line_end < len(symbols) && symbols[line_end] != "\n" {
            line_end = line_end + 1
        }
        if bars == 2 && text_slice(types, cursor, line_end) == key {
            return decimal_value(pattern_line_field(types, line, 1))
        }
        line = line_end + 1
    }
    return -1
}

# Intern one type key, appending a new `type` record on first use. The
# result is the updated table or an internal error line; the id of the
# interned key is recovered with selfhost_type_lookup.
fn selfhost_type_require(types: Text, key: Text) -> Text {
    if selfhost_type_lookup(types, key) >= 0 {
        return types
    }
    let count = selfhost_line_count(types)
    if count >= 64 {
        return selfhost_error("E2S35", -1, "selfhost-HIR type limit is 64")
    }
    return types + "type|" + to_text(count) + "|" + key + "\n"
}

# Intern the scalar type named by a profile surface spelling.
fn selfhost_scalar_require(types: Text, surface: Text) -> Text {
    let key = selfhost_scalar_key(surface)
    if len(key) == 0 {
        return selfhost_error(
            "E2S15",
            -1,
            "type is outside the frozen profile"
        )
    }
    return selfhost_type_require(types, key)
}

fn selfhost_scalar_id(types: Text, surface: Text) -> Int {
    return selfhost_type_lookup(types, selfhost_scalar_key(surface))
}

# Intern a function type `fn|RESULT|PARAM*` from surface spellings; the
# parameters arrive `|`-separated as in the signature table. The result
# packs `TYPES` after a first `TYPEID` header line.
fn selfhost_fn_type_require(
    types: Text,
    result_surface: Text,
    parameters: Text
) -> Text {
    let mut table = selfhost_scalar_require(types, result_surface)
    if selfhost_failed(table) {
        return table
    }
    let mut key = "fn|" + to_text(selfhost_scalar_id(table, result_surface))
    let mut remaining = parameters
    while len(remaining) > 0 {
        let surface = expected_parameter_head(remaining)
        table = selfhost_scalar_require(table, surface)
        if selfhost_failed(table) {
            return table
        }
        key = key + "|" + to_text(selfhost_scalar_id(table, surface))
        remaining = expected_parameter_tail(remaining)
    }
    table = selfhost_type_require(table, key)
    if selfhost_failed(table) {
        return table
    }
    return to_text(selfhost_type_lookup(table, key)) + "\n" + table
}

# The declared-function signature table is one `fun|NAME|RESULT|ARITY|P*`
# line per function in source order; a function's symbol id is its index.

fn selfhost_function_count(functions: Text) -> Int {
    return selfhost_line_count(functions)
}

fn selfhost_function_line_at(functions: Text, index: Int) -> Int {
    let symbols = chars(functions)
    let mut line = 0
    let mut remaining = index
    while line < len(symbols) {
        if remaining == 0 {
            return line
        }
        while line < len(symbols) && symbols[line] != "\n" {
            line = line + 1
        }
        line = line + 1
        remaining = remaining - 1
    }
    return -1
}

fn selfhost_function_index(functions: Text, name: Text) -> Int {
    let count = selfhost_function_count(functions)
    let mut index = 0
    while index < count {
        let line = selfhost_function_line_at(functions, index)
        if pattern_line_field(functions, line, 1) == name {
            return index
        }
        index = index + 1
    }
    return -1
}

# The `|`-separated parameter tail of one signature line: the text after
# its fourth separator, empty for a zero-arity function.
fn selfhost_function_parameters(functions: Text, line: Int) -> Text {
    let symbols = chars(functions)
    let mut cursor = line
    let mut bars = 0
    while cursor < len(symbols) && symbols[cursor] != "\n" && bars < 4 {
        if symbols[cursor] == "|" {
            bars = bars + 1
        }
        cursor = cursor + 1
    }
    if bars < 4 {
        return ""
    }
    let mut line_end = cursor
    while line_end < len(symbols) && symbols[line_end] != "\n" {
        line_end = line_end + 1
    }
    return text_slice(functions, cursor, line_end)
}

# Parse one declaration's signature into a table line (no newline), or an
# internal error. Mirrors the audited seed byte for byte, including the
# `List` annotation walk that stays inside the parameter list.
fn selfhost_signature(source: Text, functions: Text, start: Int) -> Text {
    if selfhost_function_count(functions) >= 64 {
        return selfhost_error("E2S16", start, "function limit is 64")
    }
    let name = function_name(source, start)
    if selfhost_function_index(functions, name) >= 0 {
        return selfhost_error("E2S16", start, "duplicate Core function")
    }
    let parameters = parameter_open(source, start)
    let mut parameters_close = -1
    if parameters >= 0 {
        parameters_close = balanced_end(source, parameters, "(", ")")
    }
    if parameters < 0 || parameters_close < 0 {
        return selfhost_error("E2S15", start, "malformed parameter list")
    }
    let mut arity = 0
    let mut parameter_types = ""
    let mut cursor = skip_trivia(source, token_end(source, parameters))
    while cursor < parameters_close && token_text(source, cursor) != ")" {
        if arity >= 8 {
            return selfhost_error("E2S17", cursor, "parameter limit is 8")
        }
        let colon = skip_trivia(source, token_end(source, cursor))
        let type_at = skip_trivia(source, token_end(source, colon))
        if colon >= parameters_close || token_text(source, colon) != ":" {
            return selfhost_error(
                "E2S15",
                cursor,
                "parameter needs `: TYPE`"
            )
        }
        let parameter_type = token_text(source, type_at)
        parameter_types = parameter_types + "|" + parameter_type
        cursor = skip_trivia(source, token_end(source, type_at))
        if parameter_type == "List" {
            cursor = skip_trivia(source, token_end(source, cursor))
            cursor = skip_trivia(source, token_end(source, cursor))
        }
        arity = arity + 1
        if cursor < parameters_close && token_text(source, cursor) == "," {
            cursor = skip_trivia(source, token_end(source, cursor))
        }
    }
    let mut result = "Void"
    let after = skip_trivia(source, parameters_close)
    if after < len(source) && token_text(source, after) == "->" {
        let result_at = skip_trivia(source, token_end(source, after))
        result = token_text(source, result_at)
    }
    return "fun|" + name + "|" + result + "|" + to_text(arity) +
    parameter_types
}

# Collect every declared signature in source order. The walk stops at a
# declaration whose body never closes; its body parse reports the exact
# brace diagnostic later.
fn selfhost_signatures(source: Text) -> Text {
    let mut functions = ""
    let mut function_start = next_function_start(source, 0)
    let mut scanning = function_start < len(source)
    while scanning {
        let line = selfhost_signature(source, functions, function_start)
        if selfhost_failed(line) {
            return line
        }
        functions = functions + line + "\n"
        let close = function_end(source, function_start)
        if close < 0 {
            scanning = false
        } else {
            function_start = next_function_start(source, close)
            scanning = function_start < len(source)
        }
    }
    return "ok\n" + functions
}

# The 16 builtin signatures in their frozen slot order, `NAME|RESULT|P*`.
fn selfhost_builtin_signature(slot: Int) -> Text {
    if slot == 0 {
        return "args|List"
    }
    if slot == 1 {
        return "chars|List|Text"
    }
    if slot == 2 {
        return "contains|Bool|Text|Text"
    }
    if slot == 3 {
        return "find|Int|Text|Text"
    }
    if slot == 4 {
        return "is_digit|Bool|Text"
    }
    if slot == 5 {
        return "is_space|Bool|Text"
    }
    if slot == 6 {
        return "is_xid_continue|Bool|Text"
    }
    if slot == 7 {
        return "len|Int|Text"
    }
    if slot == 8 {
        return "print|Void|Text"
    }
    if slot == 9 {
        return "read_text|Text|Text"
    }
    if slot == 10 {
        return "replace|Text|Text|Text|Text"
    }
    if slot == 11 {
        return "starts_with|Bool|Text|Text"
    }
    if slot == 12 {
        return "text_slice|Text|Text|Int|Int"
    }
    if slot == 13 {
        return "trim|Text|Text"
    }
    if slot == 14 {
        return "validate_unicode_source|Text|Text"
    }
    if slot == 15 {
        return "write_text|Void|Text|Text"
    }
    return ""
}

fn selfhost_builtin_slot(name: Text) -> Int {
    let mut slot = 0
    while slot < 16 {
        let signature = selfhost_builtin_signature(slot)
        if pattern_line_field(signature, 0, 0) == name {
            return slot
        }
        slot = slot + 1
    }
    return -1
}

# The tail after `NAME|` of one builtin signature: `RESULT|P*`.
fn selfhost_builtin_tail(slot: Int) -> Text {
    return expected_parameter_tail(selfhost_builtin_signature(slot))
}

# Register the type table plus the symbol and module-binding records for
# declared functions, the 16 builtins, and the `len` List[Text] overload,
# in the exact seed order. Packs `ok` and then type, symbol, and binding
# record lines; the caller separates them by tag.
fn selfhost_register(source: Text, functions: Text) -> Text {
    let mut types = ""
    let mut symbols = ""
    let mut bindings = ""
    let count = selfhost_function_count(functions)
    let mut function_start = next_function_start(source, 0)
    let mut index = 0
    while index < count {
        let name_at = skip_trivia(
            source,
            token_end(source, function_start)
        )
        let name_end = token_end(source, name_at)
        let line = selfhost_function_line_at(functions, index)
        let required = selfhost_fn_type_require(
            types,
            pattern_line_field(functions, line, 2),
            selfhost_function_parameters(functions, line)
        )
        if selfhost_failed(required) {
            return required
        }
        let fn_type = selfhost_field_int(required, 0)
        types = selfhost_records(required)
        let name = pattern_line_field(functions, line, 1)
        symbols = symbols + "symbol|" + to_text(index) + "|function|" +
        name + "|" + to_text(fn_type) + "|" + to_text(name_at) + "|" +
        to_text(name_end) + "\n"
        bindings = bindings + "binding|" + to_text(index) + "|0|" +
        to_text(index) + "|" + name + "|imm|" + to_text(name_at) + "|" +
        to_text(name_end) + "\n"
        let close = function_end(source, function_start)
        if close >= 0 {
            function_start = next_function_start(source, close)
        } else {
            index = count
        }
        index = index + 1
    }
    let mut slot = 0
    while slot < 16 {
        let tail = selfhost_builtin_tail(slot)
        let required = selfhost_fn_type_require(
            types,
            expected_parameter_head(tail),
            expected_parameter_tail(tail)
        )
        if selfhost_failed(required) {
            return required
        }
        types = selfhost_records(required)
        symbols = symbols + "symbol|" + to_text(count + slot) +
        "|builtin|" +
        pattern_line_field(selfhost_builtin_signature(slot), 0, 0) + "|" +
        selfhost_field(required, 0) + "|0|0\n"
        slot = slot + 1
    }
    let required = selfhost_fn_type_require(types, "Int", "List")
    if selfhost_failed(required) {
        return required
    }
    types = selfhost_records(required)
    symbols = symbols + "symbol|" + to_text(count + 16) + "|builtin|len|" +
    selfhost_field(required, 0) + "|0|0\n"
    return "ok\n" + types + symbols + bindings
}

# The lexical environment is one `env|NAME|TYPE|BINDINGID|MUT` line per
# live binding; resolution picks the innermost (last) declaration.

fn selfhost_resolve(env: Text, name: Text) -> Int {
    let symbols = chars(env)
    let mut line = 0
    let mut resolved = -1
    while line < len(symbols) {
        if pattern_line_field(env, line, 1) == name {
            resolved = line
        }
        while line < len(symbols) && symbols[line] != "\n" {
            line = line + 1
        }
        line = line + 1
    }
    return resolved
}

fn selfhost_env_count(env: Text) -> Int {
    return selfhost_line_count(env)
}

# Parsed expressions are `xnode|ID|KIND|START|END|TYPE|...` lines with
# document-local ids; the second walk renumbers them in pre-order.

fn selfhost_tree_line(tree: Text, id: Int) -> Int {
    let symbols = chars(tree)
    let wanted = to_text(id)
    let mut line = 0
    while line < len(symbols) {
        if pattern_line_field(tree, line, 1) == wanted {
            return line
        }
        while line < len(symbols) && symbols[line] != "\n" {
            line = line + 1
        }
        line = line + 1
    }
    return -1
}

fn selfhost_tree_field(tree: Text, id: Int, field: Int) -> Text {
    let line = selfhost_tree_line(tree, id)
    if line < 0 {
        return ""
    }
    return pattern_line_field(tree, line, field)
}

fn selfhost_tree_int(tree: Text, id: Int, field: Int) -> Int {
    return decimal_value(selfhost_tree_field(tree, id, field))
}

# Expression results pack `END|ROOT|NEXT|TYPE` over the xnode records.
fn selfhost_expression_result(
    end: Int,
    root: Int,
    next: Int,
    value_type: Text,
    records: Text
) -> Text {
    return to_text(end) + "|" + to_text(root) + "|" + to_text(next) +
    "|" + value_type + "\n" + records
}

fn selfhost_operator_level(level: Int, token: Text) -> Bool {
    if level == 0 {
        return token == "||"
    }
    if level == 1 {
        return token == "&&"
    }
    if level == 2 {
        return token == "==" || token == "!=" || token == "<=" ||
        token == ">=" || token == "<" || token == ">"
    }
    if level == 3 {
        return token == "+" || token == "-"
    }
    return token == "*" || token == "//" || token == "/" || token == "%"
}

# Resolve and type one call expression; `at` is the callee name token.
# Declared functions win over builtins; `len` picks its overload from the
# first argument; every arity and argument type is checked here so a
# rejected document never carries typed nodes.
fn selfhost_parse_call(
    source: Text,
    functions: Text,
    env: Text,
    at: Int,
    next: Int
) -> Text {
    let name = token_text(source, at)
    let open = skip_trivia(source, token_end(source, at))
    let mut cursor = skip_trivia(source, token_end(source, open))
    let mut argument_count = 0
    let mut argument_ids = ""
    let mut argument_starts = ""
    let mut argument_types = ""
    let mut records = ""
    let mut local_next = next
    while cursor < len(source) && token_text(source, cursor) != ")" {
        if argument_count >= 8 {
            return selfhost_error(
                "E2S17",
                at,
                "call has too many arguments"
            )
        }
        let argument = selfhost_parse_expression(
            source,
            functions,
            env,
            cursor,
            local_next
        )
        if selfhost_failed(argument) {
            return argument
        }
        cursor = selfhost_field_int(argument, 0)
        let root = selfhost_field_int(argument, 1)
        local_next = selfhost_field_int(argument, 2)
        records = records + selfhost_records(argument)
        argument_ids = argument_ids + "|" + to_text(root)
        argument_starts = argument_starts + "|" +
        selfhost_tree_field(records, root, 3)
        if argument_count > 0 {
            argument_types = argument_types + "|"
        }
        argument_types = argument_types + selfhost_field(argument, 3)
        argument_count = argument_count + 1
        if cursor < len(source) && token_text(source, cursor) == "," {
            cursor = skip_trivia(source, token_end(source, cursor))
        }
    }
    if cursor >= len(source) {
        return selfhost_error("E2S12", at, "expected `)`")
    }
    let call_end = token_end(source, cursor)
    let after = skip_trivia(source, call_end)
    let mut symbol = -1
    let mut result_type = ""
    let declared = selfhost_function_index(functions, name)
    if declared >= 0 {
        let line = selfhost_function_line_at(functions, declared)
        if argument_count !=
           decimal_value(pattern_line_field(functions, line, 3)) {
            return selfhost_error("E2S17", at, "wrong call arity")
        }
        let mut expected = selfhost_function_parameters(functions, line)
        let mut index = 0
        while index < argument_count {
            if pattern_line_field(argument_types, 0, index) !=
               expected_parameter_head(expected) {
                return selfhost_error(
                    "E2S15",
                    decimal_value(
                        pattern_line_field("x" + argument_starts, 0, index + 1)
                    ),
                    "call argument type mismatch"
                )
            }
            expected = expected_parameter_tail(expected)
            index = index + 1
        }
        symbol = declared
        result_type = pattern_line_field(functions, line, 2)
    } else {
        let mut arity = builtin_arity(name)
        if name == "print" {
            arity = 1
        }
        if arity < 0 {
            return selfhost_error("E2S16", at, "unknown function")
        }
        if argument_count != arity {
            return selfhost_error("E2S17", at, "wrong builtin arity")
        }
        result_type = "Void"
        if name != "print" {
            result_type = builtin_return_type(name)
        }
        let count = selfhost_function_count(functions)
        if name == "len" {
            let argument_type = pattern_line_field(argument_types, 0, 0)
            if argument_type != "Text" && argument_type != "List" {
                return selfhost_error(
                    "E2S15",
                    decimal_value(
                        pattern_line_field("x" + argument_starts, 0, 1)
                    ),
                    "len expects Text or List[Text]"
                )
            }
            symbol = count + 7
            if argument_type == "List" {
                symbol = count + 16
            }
        } else if name == "print" {
            if pattern_line_field(argument_types, 0, 0) != "Text" {
                return selfhost_error(
                    "E2S15",
                    decimal_value(
                        pattern_line_field("x" + argument_starts, 0, 1)
                    ),
                    "print expects Text in the profile"
                )
            }
            symbol = count + 8
        } else {
            let mut expected = builtin_parameter_types(name)
            let mut index = 0
            while index < argument_count {
                if pattern_line_field(argument_types, 0, index) !=
                   expected_parameter_head(expected) {
                    return selfhost_error(
                        "E2S15",
                        decimal_value(
                            pattern_line_field(
                                "x" + argument_starts,
                                0,
                                index + 1
                            )
                        ),
                        "builtin argument type mismatch"
                    )
                }
                expected = expected_parameter_tail(expected)
                index = index + 1
            }
            symbol = count + selfhost_builtin_slot(name)
        }
    }
    let call_record = "xnode|" + to_text(local_next) + "|call|" +
    to_text(at) + "|" + to_text(call_end) + "|" + result_type + "|" +
    to_text(symbol) + argument_ids + "\n"
    return selfhost_expression_result(
        after,
        local_next,
        local_next + 1,
        result_type,
        records + call_record
    )
}

fn selfhost_parse_primary(
    source: Text,
    functions: Text,
    env: Text,
    cursor: Int,
    next: Int
) -> Text {
    let at = cursor
    if at >= len(source) {
        return selfhost_error("E2S12", at, "expected expression")
    }
    let kind = token_kind(source, at)
    let end = token_end(source, at)
    if kind == "integer" {
        return selfhost_expression_result(
            skip_trivia(source, end),
            next,
            next + 1,
            "Int",
            "xnode|" + to_text(next) + "|literal-int|" + to_text(at) +
            "|" + to_text(end) + "|Int\n"
        )
    }
    if kind == "string" {
        return selfhost_expression_result(
            skip_trivia(source, end),
            next,
            next + 1,
            "Text",
            "xnode|" + to_text(next) + "|literal-text|" + to_text(at) +
            "|" + to_text(end) + "|Text\n"
        )
    }
    let token = token_text(source, at)
    if token == "true" || token == "false" {
        return selfhost_expression_result(
            skip_trivia(source, end),
            next,
            next + 1,
            "Bool",
            "xnode|" + to_text(next) + "|literal-bool|" + to_text(at) +
            "|" + to_text(end) + "|Bool\n"
        )
    }
    if token == "(" {
        let inner = selfhost_parse_expression(
            source,
            functions,
            env,
            skip_trivia(source, end),
            next
        )
        if selfhost_failed(inner) {
            return inner
        }
        let close = selfhost_field_int(inner, 0)
        if close >= len(source) || token_text(source, close) != ")" {
            return selfhost_error("E2S12", close, "expected `)`")
        }
        return selfhost_expression_result(
            skip_trivia(source, token_end(source, close)),
            selfhost_field_int(inner, 1),
            selfhost_field_int(inner, 2),
            selfhost_field(inner, 3),
            selfhost_records(inner)
        )
    }
    if kind == "identifier" {
        let after = skip_trivia(source, end)
        if after < len(source) && token_text(source, after) == "(" {
            return selfhost_parse_call(source, functions, env, at, next)
        }
        let resolved = selfhost_resolve(env, token)
        if resolved < 0 {
            return selfhost_error("E2S35", at, "unknown lexical binding")
        }
        return selfhost_expression_result(
            after,
            next,
            next + 1,
            pattern_line_field(env, resolved, 2),
            "xnode|" + to_text(next) + "|name|" + to_text(at) + "|" +
            to_text(end) + "|" + pattern_line_field(env, resolved, 2) +
            "|" + pattern_line_field(env, resolved, 3) + "\n"
        )
    }
    return selfhost_error("E2S12", at, "expected expression")
}

fn selfhost_parse_postfix(
    source: Text,
    functions: Text,
    env: Text,
    cursor: Int,
    next: Int
) -> Text {
    let mut result = selfhost_parse_primary(
        source,
        functions,
        env,
        cursor,
        next
    )
    if selfhost_failed(result) {
        return result
    }
    let mut walk = selfhost_field_int(result, 0)
    while walk < len(source) && token_text(source, walk) == "[" {
        if selfhost_field(result, 3) != "List" {
            return selfhost_error(
                "E2S15",
                walk,
                "only List[Text] can be indexed"
            )
        }
        let index = selfhost_parse_expression(
            source,
            functions,
            env,
            skip_trivia(source, token_end(source, walk)),
            selfhost_field_int(result, 2)
        )
        if selfhost_failed(index) {
            return index
        }
        let index_root = selfhost_field_int(index, 1)
        if selfhost_field(index, 3) != "Int" {
            return selfhost_error(
                "E2S15",
                selfhost_tree_int(selfhost_records(index), index_root, 3),
                "index must be Int"
            )
        }
        let close_at = selfhost_field_int(index, 0)
        if close_at >= len(source) || token_text(source, close_at) != "]" {
            return selfhost_error("E2S12", close_at, "expected `]`")
        }
        let close = token_end(source, close_at)
        let records = selfhost_records(result) + selfhost_records(index)
        let base_root = selfhost_field_int(result, 1)
        let id = selfhost_field_int(index, 2)
        result = selfhost_expression_result(
            skip_trivia(source, close),
            id,
            id + 1,
            "Text",
            records + "xnode|" + to_text(id) + "|index|" +
            selfhost_tree_field(records, base_root, 3) + "|" +
            to_text(close) + "|Text|" + to_text(base_root) + "|" +
            to_text(index_root) + "\n"
        )
        walk = selfhost_field_int(result, 0)
    }
    return result
}

fn selfhost_parse_unary(
    source: Text,
    functions: Text,
    env: Text,
    cursor: Int,
    next: Int
) -> Text {
    let at = cursor
    if at < len(source) &&
       (token_text(source, at) == "!" || token_text(source, at) == "-") {
        let negation = token_text(source, at) == "!"
        let operand = selfhost_parse_unary(
            source,
            functions,
            env,
            skip_trivia(source, token_end(source, at)),
            next
        )
        if selfhost_failed(operand) {
            return operand
        }
        let root = selfhost_field_int(operand, 1)
        let records = selfhost_records(operand)
        if negation && selfhost_field(operand, 3) != "Bool" {
            return selfhost_error(
                "E2S15",
                selfhost_tree_int(records, root, 3),
                "`!` expects Bool"
            )
        }
        if !negation && selfhost_field(operand, 3) != "Int" {
            return selfhost_error(
                "E2S15",
                selfhost_tree_int(records, root, 3),
                "unary `-` expects Int"
            )
        }
        let mut result_type = "Int"
        let mut operator = "-"
        if negation {
            result_type = "Bool"
            operator = "!"
        }
        let id = selfhost_field_int(operand, 2)
        return selfhost_expression_result(
            selfhost_field_int(operand, 0),
            id,
            id + 1,
            result_type,
            records + "xnode|" + to_text(id) + "|unary|" + to_text(at) +
            "|" + selfhost_tree_field(records, root, 4) + "|" +
            result_type + "|" + operator + "|" + to_text(root) + "\n"
        )
    }
    return selfhost_parse_postfix(source, functions, env, cursor, next)
}

# Levels: 0 `||`; 1 `&&`; 2 comparisons; 3 `+ -`; 4 `* / // %`.
fn selfhost_parse_binary(
    source: Text,
    functions: Text,
    env: Text,
    cursor: Int,
    next: Int,
    level: Int
) -> Text {
    if level > 4 {
        return selfhost_parse_unary(source, functions, env, cursor, next)
    }
    let mut result = selfhost_parse_binary(
        source,
        functions,
        env,
        cursor,
        next,
        level + 1
    )
    if selfhost_failed(result) {
        return result
    }
    let mut walk = selfhost_field_int(result, 0)
    while walk < len(source) &&
          selfhost_operator_level(level, token_text(source, walk)) {
        let operator_at = walk
        let operator = token_text(source, walk)
        let right = selfhost_parse_binary(
            source,
            functions,
            env,
            skip_trivia(source, token_end(source, walk)),
            selfhost_field_int(result, 2),
            level + 1
        )
        if selfhost_failed(right) {
            return right
        }
        let left_type = selfhost_field(result, 3)
        let right_type = selfhost_field(right, 3)
        let mut result_type = ""
        if level <= 1 {
            if left_type != "Bool" || right_type != "Bool" {
                return selfhost_error(
                    "E2S15",
                    operator_at,
                    "logical operands must be Bool"
                )
            }
            result_type = "Bool"
        } else if level == 2 {
            if left_type != right_type || left_type == "List" ||
               left_type == "Void" {
                return selfhost_error(
                    "E2S15",
                    operator_at,
                    "comparison operands must share a scalar type"
                )
            }
            result_type = "Bool"
        } else if level == 3 && operator == "+" && left_type == "Text" {
            if right_type != "Text" {
                return selfhost_error(
                    "E2S15",
                    operator_at,
                    "Text `+` expects Text"
                )
            }
            result_type = "Text"
        } else {
            if left_type != "Int" || right_type != "Int" {
                return selfhost_error(
                    "E2S15",
                    operator_at,
                    "arithmetic operands must be Int"
                )
            }
            result_type = "Int"
        }
        let records = selfhost_records(result) + selfhost_records(right)
        let left_root = selfhost_field_int(result, 1)
        let right_root = selfhost_field_int(right, 1)
        let id = selfhost_field_int(right, 2)
        result = selfhost_expression_result(
            selfhost_field_int(right, 0),
            id,
            id + 1,
            result_type,
            records + "xnode|" + to_text(id) + "|binary|" +
            selfhost_tree_field(records, left_root, 3) + "|" +
            selfhost_tree_field(records, right_root, 4) + "|" +
            result_type + "|" + selfhost_escape(operator) + "|" +
            to_text(left_root) + "|" + to_text(right_root) + "\n"
        )
        walk = selfhost_field_int(result, 0)
    }
    return result
}

fn selfhost_parse_expression(
    source: Text,
    functions: Text,
    env: Text,
    cursor: Int,
    next: Int
) -> Text {
    return selfhost_parse_binary(source, functions, env, cursor, next, 0)
}

# The second expression walk: renumber one parsed tree into pre-order
# document node records, parent before children.

fn selfhost_ownership(value_type: Text) -> Text {
    if value_type == "Text" || value_type == "List" {
        return "read"
    }
    return "copy"
}

# Decode source string escapes, then re-escape for the record format.
fn selfhost_text_literal_field(source: Text, start: Int, end: Int) -> Text {
    let symbols = chars(source)
    let mut decoded = ""
    let mut cursor = start + 1
    while cursor + 1 < end {
        let symbol = symbols[cursor]
        if symbol == "\\" {
            let following = symbols[cursor + 1]
            if following == "n" {
                decoded = decoded + "\n"
            } else {
                decoded = decoded + following
            }
            cursor = cursor + 2
        } else {
            decoded = decoded + symbol
            cursor = cursor + 1
        }
    }
    return selfhost_escape(decoded)
}

# Emit the xnode `id` as document node `node`; returns `NEXT` over the
# emitted records. Child ids follow their parent, in field order.
fn selfhost_emit_expression(
    source: Text,
    types: Text,
    tree: Text,
    id: Int,
    node: Int
) -> Text {
    let line = selfhost_tree_line(tree, id)
    let kind = pattern_line_field(tree, line, 2)
    let start = pattern_line_field(tree, line, 3)
    let end = pattern_line_field(tree, line, 4)
    let value_type = pattern_line_field(tree, line, 5)
    let type_id = selfhost_scalar_id(types, value_type)
    let mut fields = ""
    let mut children = ""
    let mut next = node + 1
    if kind == "literal-int" || kind == "literal-bool" {
        fields = text_slice(
            source,
            decimal_value(start),
            decimal_value(end)
        )
    } else if kind == "literal-text" {
        fields = selfhost_text_literal_field(
            source,
            decimal_value(start),
            decimal_value(end)
        )
    } else if kind == "name" {
        fields = pattern_line_field(tree, line, 6)
    } else if kind == "call" {
        fields = pattern_line_field(tree, line, 6)
        let mut argument_field = 7
        while len(pattern_line_field(tree, line, argument_field)) > 0 {
            let argument = decimal_value(
                pattern_line_field(tree, line, argument_field)
            )
            fields = fields + "|" + to_text(next)
            let emitted = selfhost_emit_expression(
                source,
                types,
                tree,
                argument,
                next
            )
            next = selfhost_field_int(emitted, 0)
            children = children + selfhost_records(emitted)
            argument_field = argument_field + 1
        }
    } else if kind == "unary" {
        let operand = decimal_value(pattern_line_field(tree, line, 7))
        fields = pattern_line_field(tree, line, 6) + "|" + to_text(next)
        let emitted = selfhost_emit_expression(
            source,
            types,
            tree,
            operand,
            next
        )
        next = selfhost_field_int(emitted, 0)
        children = selfhost_records(emitted)
    } else if kind == "binary" {
        let left = decimal_value(pattern_line_field(tree, line, 7))
        let right = decimal_value(pattern_line_field(tree, line, 8))
        let left_id = next
        let left_emitted = selfhost_emit_expression(
            source,
            types,
            tree,
            left,
            next
        )
        next = selfhost_field_int(left_emitted, 0)
        let right_id = next
        let right_emitted = selfhost_emit_expression(
            source,
            types,
            tree,
            right,
            next
        )
        next = selfhost_field_int(right_emitted, 0)
        fields = pattern_line_field(tree, line, 6) + "|" +
        to_text(left_id) + "|" + to_text(right_id)
        children = selfhost_records(left_emitted) +
        selfhost_records(right_emitted)
    } else {
        let left = decimal_value(pattern_line_field(tree, line, 6))
        let right = decimal_value(pattern_line_field(tree, line, 7))
        let left_id = next
        let left_emitted = selfhost_emit_expression(
            source,
            types,
            tree,
            left,
            next
        )
        next = selfhost_field_int(left_emitted, 0)
        let right_id = next
        let right_emitted = selfhost_emit_expression(
            source,
            types,
            tree,
            right,
            next
        )
        next = selfhost_field_int(right_emitted, 0)
        fields = to_text(left_id) + "|" + to_text(right_id)
        children = selfhost_records(left_emitted) +
        selfhost_records(right_emitted)
    }
    return to_text(next) + "\n" + "node|" + to_text(node) + "|" + kind +
    "|" + start + "|" + end + "|" + to_text(type_id) + "|" +
    selfhost_ownership(value_type) + "|" + fields + "\n" + children
}

# Statement results pack `END|NODE|SCOPE|SYMBOL|BINDING|STMTID` and then
# `ENVNAME|ENVTYPE|ENVBINDING|ENVMUT` when the statement declared a local,
# over the statement's scope, symbol, binding, and node records.

fn selfhost_counters(
    node: Int,
    scope: Int,
    symbol: Int,
    binding: Int
) -> Text {
    return to_text(node) + "|" + to_text(scope) + "|" + to_text(symbol) +
    "|" + to_text(binding)
}

fn selfhost_counter(counters: Text, wanted: Int) -> Int {
    return decimal_value(pattern_line_field(counters, 0, wanted))
}

fn selfhost_statement_result(
    end: Int,
    counters: Text,
    statement: Int,
    declared_env: Text,
    records: Text
) -> Text {
    let mut env_fields = "|||"
    if len(declared_env) > 0 {
        env_fields = declared_env
    }
    return to_text(end) + "|" + counters + "|" + to_text(statement) +
    "|" + env_fields + "\n" + records
}

# One symbol plus binding record pair; `ids` packs `SYMBOL|BINDING` and
# `span` packs `START|END` of the declared name.
fn selfhost_bind_records(
    types: Text,
    ids: Text,
    scope: Int,
    name: Text,
    surface: Text,
    mutability: Text,
    kind: Text,
    span: Text
) -> Text {
    return "symbol|" + pattern_line_field(ids, 0, 0) + "|" + kind + "|" +
    name + "|" + to_text(selfhost_scalar_id(types, surface)) + "|" +
    span + "\n" + "binding|" + pattern_line_field(ids, 0, 1) + "|" +
    to_text(scope) + "|" + pattern_line_field(ids, 0, 0) + "|" + name +
    "|" + mutability + "|" + span + "\n"
}

fn selfhost_let_statement(
    source: Text,
    functions: Text,
    types: Text,
    env: Text,
    cursor: Int,
    counters: Text,
    scope_context: Text
) -> Text {
    let at = cursor
    let mut name = skip_trivia(source, token_end(source, at))
    let mut mutability = "imm"
    if name < len(source) && token_text(source, name) == "mut" {
        mutability = "mut"
        name = skip_trivia(source, token_end(source, name))
    }
    if name >= len(source) || token_kind(source, name) != "identifier" {
        return selfhost_error("E2S12", name, "expected binding name")
    }
    let name_end = token_end(source, name)
    let mut after = skip_trivia(source, name_end)
    let mut annotation = ""
    if after < len(source) && token_text(source, after) == ":" {
        let type_at = skip_trivia(source, token_end(source, after))
        annotation = token_text(source, type_at)
        after = skip_trivia(source, token_end(source, type_at))
        if annotation == "List" {
            after = skip_trivia(source, token_end(source, after))
            after = skip_trivia(source, token_end(source, after))
        }
    }
    if after >= len(source) || token_text(source, after) != "=" {
        return selfhost_error("E2S12", after, "expected `=`")
    }
    let statement = selfhost_counter(counters, 0)
    let value = selfhost_parse_expression(
        source,
        functions,
        env,
        skip_trivia(source, token_end(source, after)),
        0
    )
    if selfhost_failed(value) {
        return value
    }
    let tree = selfhost_records(value)
    let root = selfhost_field_int(value, 1)
    if len(annotation) > 0 && annotation != selfhost_field(value, 3) {
        return selfhost_error(
            "E2S15",
            selfhost_tree_int(tree, root, 3),
            "initializer type mismatch"
        )
    }
    if selfhost_env_count(env) >= 512 {
        return selfhost_error(
            "E2S35",
            name,
            "lexical binding limit is 512"
        )
    }
    let emitted = selfhost_emit_expression(
        source,
        types,
        tree,
        root,
        statement + 1
    )
    let symbol = selfhost_counter(counters, 2)
    let binding = selfhost_counter(counters, 3)
    let scope = decimal_value(pattern_line_field(scope_context, 0, 0))
    let name_text = token_text(source, name)
    let value_type = selfhost_field(value, 3)
    let mut kind = "let"
    if mutability == "mut" {
        kind = "let-mut"
    }
    return selfhost_statement_result(
        selfhost_field_int(value, 0),
        selfhost_counters(
            selfhost_field_int(emitted, 0),
            selfhost_counter(counters, 1),
            symbol + 1,
            binding + 1
        ),
        statement,
        name_text + "|" + value_type + "|" + to_text(binding) + "|" +
        mutability,
        selfhost_bind_records(
            types,
            to_text(symbol) + "|" + to_text(binding),
            scope,
            name_text,
            value_type,
            mutability,
            "local",
            to_text(name) + "|" + to_text(name_end)
        ) + "node|" + to_text(statement) + "|" + kind + "|" +
        to_text(at) + "|" + selfhost_tree_field(tree, root, 4) + "|" +
        to_text(selfhost_scalar_id(types, "Void")) + "|copy|" +
        to_text(binding) + "|" + to_text(statement + 1) + "\n" +
        selfhost_records(emitted)
    )
}

fn selfhost_branch_statement(
    source: Text,
    functions: Text,
    types: Text,
    env: Text,
    declared: Text,
    cursor: Int,
    counters: Text,
    scope_context: Text
) -> Text {
    let at = cursor
    let condition_if = token_text(source, at) == "if"
    let statement = selfhost_counter(counters, 0)
    let condition = selfhost_parse_expression(
        source,
        functions,
        env,
        skip_trivia(source, token_end(source, at)),
        0
    )
    if selfhost_failed(condition) {
        return condition
    }
    let tree = selfhost_records(condition)
    let root = selfhost_field_int(condition, 1)
    if selfhost_field(condition, 3) != "Bool" {
        let mut message = "while condition must be Bool"
        if condition_if {
            message = "if condition must be Bool or an Int comparison"
        }
        return selfhost_error(
            "E2S23",
            selfhost_tree_int(tree, root, 3),
            message
        )
    }
    let emitted = selfhost_emit_expression(
        source,
        types,
        tree,
        root,
        statement + 1
    )
    let body = selfhost_block(
        source,
        functions,
        types,
        env,
        declared,
        selfhost_field_int(condition, 0),
        selfhost_counters(
            selfhost_field_int(emitted, 0),
            selfhost_counter(counters, 1),
            selfhost_counter(counters, 2),
            selfhost_counter(counters, 3)
        ),
        scope_context,
        -1
    )
    if selfhost_failed(body) {
        return body
    }
    let body_scope = selfhost_field_int(body, 5)
    let mut walk = selfhost_field_int(body, 0)
    let mut branch_counters = selfhost_counters(
        selfhost_field_int(body, 1),
        selfhost_field_int(body, 2),
        selfhost_field_int(body, 3),
        selfhost_field_int(body, 4)
    )
    let mut records = selfhost_records(emitted) + selfhost_records(body)
    let mut else_kind = "none"
    let mut else_reference = -1
    if condition_if && walk < len(source) &&
       token_text(source, walk) == "else" {
        let next_at = skip_trivia(source, token_end(source, walk))
        if next_at < len(source) && token_text(source, next_at) == "if" {
            let chained = selfhost_statement(
                source,
                functions,
                types,
                env,
                declared,
                next_at,
                branch_counters,
                scope_context
            )
            if selfhost_failed(chained) {
                return chained
            }
            else_kind = "if"
            else_reference = selfhost_field_int(chained, 5)
            walk = selfhost_field_int(chained, 0)
            branch_counters = selfhost_counters(
                selfhost_field_int(chained, 1),
                selfhost_field_int(chained, 2),
                selfhost_field_int(chained, 3),
                selfhost_field_int(chained, 4)
            )
            records = records + selfhost_records(chained)
        } else {
            let alternative = selfhost_block(
                source,
                functions,
                types,
                env,
                declared,
                next_at,
                branch_counters,
                scope_context,
                -1
            )
            if selfhost_failed(alternative) {
                return alternative
            }
            else_kind = "block"
            else_reference = selfhost_field_int(alternative, 5)
            walk = selfhost_field_int(alternative, 0)
            branch_counters = selfhost_counters(
                selfhost_field_int(alternative, 1),
                selfhost_field_int(alternative, 2),
                selfhost_field_int(alternative, 3),
                selfhost_field_int(alternative, 4)
            )
            records = records + selfhost_records(alternative)
        }
    }
    let mut kind = "while"
    let mut fields = to_text(statement + 1) + "|" + to_text(body_scope)
    if condition_if {
        kind = "if"
        fields = fields + "|" + else_kind + "|" + to_text(else_reference)
    }
    return selfhost_statement_result(
        walk,
        branch_counters,
        statement,
        "",
        "node|" + to_text(statement) + "|" + kind + "|" + to_text(at) +
        "|" + to_text(walk) + "|" +
        to_text(selfhost_scalar_id(types, "Void")) + "|copy|" + fields +
        "\n" + records
    )
}

fn selfhost_for_statement(
    source: Text,
    functions: Text,
    types: Text,
    env: Text,
    declared: Text,
    cursor: Int,
    counters: Text,
    scope_context: Text
) -> Text {
    let at = cursor
    let name = skip_trivia(source, token_end(source, at))
    if name >= len(source) || token_kind(source, name) != "identifier" {
        return selfhost_error("E2S12", name, "expected loop variable")
    }
    let in_at = skip_trivia(source, token_end(source, name))
    if in_at >= len(source) || token_text(source, in_at) != "in" {
        return selfhost_error("E2S12", in_at, "expected `in`")
    }
    let low = selfhost_parse_expression(
        source,
        functions,
        env,
        skip_trivia(source, token_end(source, in_at)),
        0
    )
    if selfhost_failed(low) {
        return low
    }
    let dots = selfhost_field_int(low, 0)
    if dots >= len(source) || token_text(source, dots) != ".." {
        return selfhost_error("E2S12", dots, "expected `..`")
    }
    let high = selfhost_parse_expression(
        source,
        functions,
        env,
        skip_trivia(source, token_end(source, dots)),
        selfhost_field_int(low, 2)
    )
    if selfhost_failed(high) {
        return high
    }
    let low_root = selfhost_field_int(low, 1)
    let high_root = selfhost_field_int(high, 1)
    let mut tree = selfhost_records(low) + selfhost_records(high)
    if selfhost_field(low, 3) != "Int" || selfhost_field(high, 3) != "Int" {
        return selfhost_error(
            "E2S15",
            selfhost_tree_int(tree, low_root, 3),
            "range bounds must be Int"
        )
    }
    let range = selfhost_field_int(high, 2)
    tree = tree + "xnode|" + to_text(range) + "|range|" +
    selfhost_tree_field(tree, low_root, 3) + "|" +
    selfhost_tree_field(tree, high_root, 4) + "|Int|" +
    to_text(low_root) + "|" + to_text(high_root) + "\n"
    let statement = selfhost_counter(counters, 0)
    let emitted = selfhost_emit_expression(
        source,
        types,
        tree,
        range,
        statement + 1
    )
    let loop_binding = selfhost_counter(counters, 3)
    let body = selfhost_block(
        source,
        functions,
        types,
        env,
        declared,
        selfhost_field_int(high, 0),
        selfhost_counters(
            selfhost_field_int(emitted, 0),
            selfhost_counter(counters, 1),
            selfhost_counter(counters, 2),
            selfhost_counter(counters, 3)
        ),
        scope_context,
        name
    )
    if selfhost_failed(body) {
        return body
    }
    let walk = selfhost_field_int(body, 0)
    return selfhost_statement_result(
        walk,
        selfhost_counters(
            selfhost_field_int(body, 1),
            selfhost_field_int(body, 2),
            selfhost_field_int(body, 3),
            selfhost_field_int(body, 4)
        ),
        statement,
        "",
        "node|" + to_text(statement) + "|for-range|" + to_text(at) + "|" +
        to_text(walk) + "|" + to_text(selfhost_scalar_id(types, "Void")) +
        "|copy|" + to_text(loop_binding) + "|" + to_text(statement + 1) +
        "|" + to_text(selfhost_field_int(body, 5)) + "\n" +
        selfhost_records(emitted) + selfhost_records(body)
    )
}

fn selfhost_return_statement(
    source: Text,
    functions: Text,
    types: Text,
    env: Text,
    declared: Text,
    cursor: Int,
    counters: Text
) -> Text {
    let at = cursor
    let keyword_end = token_end(source, at)
    let value_at = skip_trivia(source, keyword_end)
    let statement = selfhost_counter(counters, 0)
    let void_id = to_text(selfhost_scalar_id(types, "Void"))
    if value_at >= len(source) || token_text(source, value_at) == "}" ||
       newline_between(source, keyword_end, value_at) {
        if declared != "Void" {
            return selfhost_error("E2S19", at, "missing return value")
        }
        return selfhost_statement_result(
            value_at,
            selfhost_counters(
                statement + 1,
                selfhost_counter(counters, 1),
                selfhost_counter(counters, 2),
                selfhost_counter(counters, 3)
            ),
            statement,
            "",
            "node|" + to_text(statement) + "|return|" + to_text(at) +
            "|" + to_text(keyword_end) + "|" + void_id + "|copy|none\n"
        )
    }
    let value = selfhost_parse_expression(
        source,
        functions,
        env,
        value_at,
        0
    )
    if selfhost_failed(value) {
        return value
    }
    let tree = selfhost_records(value)
    let root = selfhost_field_int(value, 1)
    if selfhost_field(value, 3) != declared {
        return selfhost_error(
            "E2S15",
            selfhost_tree_int(tree, root, 3),
            "return type mismatch"
        )
    }
    let emitted = selfhost_emit_expression(
        source,
        types,
        tree,
        root,
        statement + 1
    )
    return selfhost_statement_result(
        selfhost_field_int(value, 0),
        selfhost_counters(
            selfhost_field_int(emitted, 0),
            selfhost_counter(counters, 1),
            selfhost_counter(counters, 2),
            selfhost_counter(counters, 3)
        ),
        statement,
        "",
        "node|" + to_text(statement) + "|return|" + to_text(at) + "|" +
        selfhost_tree_field(tree, root, 4) + "|" + void_id + "|copy|" +
        to_text(statement + 1) + "\n" + selfhost_records(emitted)
    )
}

fn selfhost_leading_statement(
    source: Text,
    functions: Text,
    types: Text,
    env: Text,
    cursor: Int,
    counters: Text
) -> Text {
    let at = cursor
    let after = skip_trivia(source, token_end(source, at))
    let statement = selfhost_counter(counters, 0)
    let void_id = to_text(selfhost_scalar_id(types, "Void"))
    if after < len(source) && token_text(source, after) == "=" {
        let resolved = selfhost_resolve(env, token_text(source, at))
        if resolved < 0 {
            return selfhost_error("E2S35", at, "unknown lexical binding")
        }
        if pattern_line_field(env, resolved, 4) != "mut" {
            return selfhost_error(
                "E2S22",
                at,
                "assignment target is immutable"
            )
        }
        let value = selfhost_parse_expression(
            source,
            functions,
            env,
            skip_trivia(source, token_end(source, after)),
            0
        )
        if selfhost_failed(value) {
            return value
        }
        let tree = selfhost_records(value)
        let root = selfhost_field_int(value, 1)
        if selfhost_field(value, 3) != pattern_line_field(env, resolved, 2) {
            return selfhost_error(
                "E2S15",
                selfhost_tree_int(tree, root, 3),
                "assignment type mismatch"
            )
        }
        let emitted = selfhost_emit_expression(
            source,
            types,
            tree,
            root,
            statement + 1
        )
        return selfhost_statement_result(
            selfhost_field_int(value, 0),
            selfhost_counters(
                selfhost_field_int(emitted, 0),
                selfhost_counter(counters, 1),
                selfhost_counter(counters, 2),
                selfhost_counter(counters, 3)
            ),
            statement,
            "",
            "node|" + to_text(statement) + "|assign|" + to_text(at) +
            "|" + selfhost_tree_field(tree, root, 4) + "|" + void_id +
            "|edit|" + pattern_line_field(env, resolved, 3) + "|" +
            to_text(statement + 1) + "\n" + selfhost_records(emitted)
        )
    }
    let value = selfhost_parse_expression(source, functions, env, at, 0)
    if selfhost_failed(value) {
        return value
    }
    let tree = selfhost_records(value)
    let root = selfhost_field_int(value, 1)
    let emitted = selfhost_emit_expression(
        source,
        types,
        tree,
        root,
        statement + 1
    )
    return selfhost_statement_result(
        selfhost_field_int(value, 0),
        selfhost_counters(
            selfhost_field_int(emitted, 0),
            selfhost_counter(counters, 1),
            selfhost_counter(counters, 2),
            selfhost_counter(counters, 3)
        ),
        statement,
        "",
        "node|" + to_text(statement) + "|expr-stmt|" + to_text(at) + "|" +
        selfhost_tree_field(tree, root, 4) + "|" + void_id + "|copy|" +
        to_text(statement + 1) + "\n" + selfhost_records(emitted)
    )
}

fn selfhost_statement(
    source: Text,
    functions: Text,
    types: Text,
    env: Text,
    declared: Text,
    cursor: Int,
    counters: Text,
    scope_context: Text
) -> Text {
    let token = token_text(source, cursor)
    if token == "let" {
        return selfhost_let_statement(
            source,
            functions,
            types,
            env,
            cursor,
            counters,
            scope_context
        )
    }
    if token == "if" || token == "while" {
        return selfhost_branch_statement(
            source,
            functions,
            types,
            env,
            declared,
            cursor,
            counters,
            scope_context
        )
    }
    if token == "for" {
        return selfhost_for_statement(
            source,
            functions,
            types,
            env,
            declared,
            cursor,
            counters,
            scope_context
        )
    }
    if token == "return" {
        return selfhost_return_statement(
            source,
            functions,
            types,
            env,
            declared,
            cursor,
            counters
        )
    }
    if token_kind(source, cursor) == "identifier" {
        return selfhost_leading_statement(
            source,
            functions,
            types,
            env,
            cursor,
            counters
        )
    }
    return selfhost_error("E2S10", cursor, "unsupported Core statement")
}

fn selfhost_block(
    source: Text,
    functions: Text,
    types: Text,
    env: Text,
    declared: Text,
    cursor: Int,
    counters: Text,
    scope_context: Text,
    loop_name: Int
) -> Text {
    if cursor >= len(source) || token_text(source, cursor) != "{" {
        return selfhost_error("E2S18", cursor, "expected `{`")
    }
    let open = cursor
    let close = balanced_end(source, open, "{", "}")
    if close < 0 {
        return selfhost_error("E2S18", open, "unbalanced `{`")
    }
    let depth = decimal_value(pattern_line_field(scope_context, 0, 1))
    if depth >= 32 {
        return selfhost_error(
            "E2S35",
            open,
            "lexical scope depth limit is 32"
        )
    }
    let scope = selfhost_counter(counters, 1)
    let mut records = "scope|" + to_text(scope) + "|" +
    pattern_line_field(scope_context, 0, 0) + "|block|" + to_text(open) +
    "|" + to_text(close) + "\n"
    let mut block_counters = selfhost_counters(
        selfhost_counter(counters, 0),
        scope + 1,
        selfhost_counter(counters, 2),
        selfhost_counter(counters, 3)
    )
    let mut block_env = env
    if loop_name >= 0 {
        if selfhost_env_count(block_env) >= 512 {
            return selfhost_error(
                "E2S35",
                loop_name,
                "lexical binding limit is 512"
            )
        }
        let symbol = selfhost_counter(block_counters, 2)
        let binding = selfhost_counter(block_counters, 3)
        let name_text = token_text(source, loop_name)
        records = records + selfhost_bind_records(
            types,
            to_text(symbol) + "|" + to_text(binding),
            scope,
            name_text,
            "Int",
            "imm",
            "local",
            to_text(loop_name) + "|" +
            to_text(token_end(source, loop_name))
        )
        block_env = block_env + "env|" + name_text + "|Int|" +
        to_text(binding) + "|imm\n"
        block_counters = selfhost_counters(
            selfhost_counter(block_counters, 0),
            selfhost_counter(block_counters, 1),
            symbol + 1,
            binding + 1
        )
    }
    let inner_context = to_text(scope) + "|" + to_text(depth + 1)
    let mut walk = skip_trivia(source, token_end(source, open))
    let mut statement_count = 0
    while walk < len(source) && token_text(source, walk) != "}" {
        if statement_count >= 64 {
            return selfhost_error(
                "E2S35",
                walk,
                "block statement limit is 64"
            )
        }
        let statement = selfhost_statement(
            source,
            functions,
            types,
            block_env,
            declared,
            walk,
            block_counters,
            inner_context
        )
        if selfhost_failed(statement) {
            return statement
        }
        walk = selfhost_field_int(statement, 0)
        block_counters = selfhost_counters(
            selfhost_field_int(statement, 1),
            selfhost_field_int(statement, 2),
            selfhost_field_int(statement, 3),
            selfhost_field_int(statement, 4)
        )
        if len(selfhost_field(statement, 6)) > 0 {
            block_env = block_env + "env|" + selfhost_field(statement, 6) +
            "|" + selfhost_field(statement, 7) + "|" +
            selfhost_field(statement, 8) + "|" +
            selfhost_field(statement, 9) + "\n"
        }
        records = records + selfhost_records(statement)
        statement_count = statement_count + 1
    }
    if walk >= len(source) || token_text(source, walk) != "}" {
        return selfhost_error("E2S18", walk, "expected `}`")
    }
    return to_text(skip_trivia(source, token_end(source, walk))) + "|" +
    block_counters + "|" + to_text(scope) + "\n" + records
}

fn selfhost_first_line(value: Text) -> Text {
    let symbols = chars(value)
    let mut cursor = 0
    while cursor < len(symbols) && symbols[cursor] != "\n" {
        cursor = cursor + 1
    }
    return text_slice(value, 0, cursor)
}

# Collect the record lines carrying one tag, in generation order.
fn selfhost_lines(records: Text, tag: Text) -> Text {
    let symbols = chars(records)
    let mut collected = ""
    let mut line = 0
    while line < len(symbols) {
        let mut line_end = line
        while line_end < len(symbols) && symbols[line_end] != "\n" {
            line_end = line_end + 1
        }
        if line + len(tag) <= line_end &&
           text_slice(records, line, line + len(tag)) == tag {
            collected = collected + text_slice(records, line, line_end) +
            "\n"
        }
        line = line_end + 1
    }
    return collected
}

fn selfhost_node_lines(records: Text) -> Text {
    let symbols = chars(records)
    let mut collected = ""
    let mut line = 0
    while line < len(symbols) {
        let mut line_end = line
        while line_end < len(symbols) && symbols[line_end] != "\n" {
            line_end = line_end + 1
        }
        let mut keep = line + 5 <= line_end &&
        text_slice(records, line, line + 5) == "node|"
        if line + 9 <= line_end &&
           text_slice(records, line, line + 9) == "function|" {
            keep = true
        }
        if keep {
            collected = collected + text_slice(records, line, line_end) +
            "\n"
        }
        line = line_end + 1
    }
    return collected
}

# One function's scope, parameter bindings, and typed body: the function
# scope record, `parameter` symbol/binding pairs, the `function` node
# record, and the body's records. Packs the advanced counters.
fn selfhost_function_hir(
    source: Text,
    functions: Text,
    types: Text,
    index: Int,
    function_start: Int,
    counters: Text
) -> Text {
    let function_close = function_end(source, function_start)
    let parameters = parameter_open(source, function_start)
    let parameters_close = balanced_end(source, parameters, "(", ")")
    let function_scope = selfhost_counter(counters, 1)
    let mut records = "scope|" + to_text(function_scope) +
    "|0|function|" + to_text(parameters) + "|" +
    to_text(function_close) + "\n"
    let line = selfhost_function_line_at(functions, index)
    let mut symbol = selfhost_counter(counters, 2)
    let mut binding = selfhost_counter(counters, 3)
    let mut env = ""
    let mut cursor = skip_trivia(source, token_end(source, parameters))
    let mut parameter_index = 0
    while cursor < parameters_close && token_text(source, cursor) != ")" {
        if selfhost_env_count(env) >= 512 {
            return selfhost_error(
                "E2S35",
                cursor,
                "lexical binding limit is 512"
            )
        }
        let surface = pattern_line_field(
            functions,
            line,
            4 + parameter_index
        )
        let name_text = token_text(source, cursor)
        records = records + selfhost_bind_records(
            types,
            to_text(symbol) + "|" + to_text(binding),
            function_scope,
            name_text,
            surface,
            "imm",
            "parameter",
            to_text(cursor) + "|" + to_text(token_end(source, cursor))
        )
        env = env + "env|" + name_text + "|" + surface + "|" +
        to_text(binding) + "|imm\n"
        symbol = symbol + 1
        binding = binding + 1
        let colon = skip_trivia(source, token_end(source, cursor))
        let type_at = skip_trivia(source, token_end(source, colon))
        cursor = skip_trivia(source, token_end(source, type_at))
        if surface == "List" {
            cursor = skip_trivia(source, token_end(source, cursor))
            cursor = skip_trivia(source, token_end(source, cursor))
        }
        parameter_index = parameter_index + 1
        if cursor < parameters_close && token_text(source, cursor) == "," {
            cursor = skip_trivia(source, token_end(source, cursor))
        }
    }
    let mut body_at = skip_trivia(source, parameters_close)
    while body_at < function_close && token_text(source, body_at) != "{" {
        body_at = skip_trivia(source, token_end(source, body_at))
    }
    let function_node = selfhost_counter(counters, 0)
    let body = selfhost_block(
        source,
        functions,
        types,
        env,
        pattern_line_field(functions, line, 2),
        body_at,
        selfhost_counters(
            function_node + 1,
            function_scope + 1,
            symbol,
            binding
        ),
        to_text(function_scope) + "|2",
        -1
    )
    if selfhost_failed(body) {
        return body
    }
    return selfhost_counters(
        selfhost_field_int(body, 1),
        selfhost_field_int(body, 2),
        selfhost_field_int(body, 3),
        selfhost_field_int(body, 4)
    ) + "\n" + records + "function|" + to_text(function_node) + "|" +
    to_text(index) + "|" + to_text(function_scope) + "|" +
    to_text(function_start) + "|" + to_text(function_close) + "\n" +
    selfhost_records(body)
}

# Walk every declared function in source order, threading the document
# counters: nodes from 0, scopes after the module scope, symbols and
# bindings after the registered functions and builtins.
fn selfhost_functions_hir(
    source: Text,
    functions: Text,
    types: Text
) -> Text {
    let count = selfhost_function_count(functions)
    let mut counters = selfhost_counters(0, 1, count + 17, count)
    let mut records = ""
    let mut function_start = next_function_start(source, 0)
    let mut index = 0
    while index < count {
        let one = selfhost_function_hir(
            source,
            functions,
            types,
            index,
            function_start,
            counters
        )
        if selfhost_failed(one) {
            return one
        }
        counters = selfhost_first_line(one)
        records = records + selfhost_records(one)
        let function_close = function_end(source, function_start)
        if function_close >= 0 {
            function_start = next_function_start(source, function_close)
        } else {
            index = count
        }
        index = index + 1
    }
    return "ok\n" + records
}

# Produce the whole kofun.selfhost-hir/v1 document. The first line of the
# result is `complete` or `rejected`; a rejected result carries the
# diagnostic line to print before the document itself.
fn selfhost_document(source: Text, path: Text, digest: Text) -> Text {
    let header = "schema|kofun.selfhost-hir/v1\n" + "source|" + path +
    "|" + digest + "\n"
    let mut failure = ""
    let mut functions = ""
    let mut registered = ""
    let mut types = ""
    let mut hir = ""
    if next_function_start(source, 0) >= len(source) {
        failure = selfhost_error("E2S04", 0, "source declares no functions")
    }
    if len(failure) == 0 {
        let signatures = selfhost_signatures(source)
        if selfhost_failed(signatures) {
            failure = signatures
        } else {
            functions = selfhost_records(signatures)
        }
    }
    if len(failure) == 0 {
        let registration = selfhost_register(source, functions)
        if selfhost_failed(registration) {
            failure = registration
        } else {
            registered = selfhost_records(registration)
        }
    }
    if len(failure) == 0 {
        types = selfhost_lines(registered, "type|")
        let walked = selfhost_functions_hir(source, functions, types)
        if selfhost_failed(walked) {
            failure = walked
        } else {
            hir = selfhost_records(walked)
        }
    }
    if len(failure) == 0 {
        return "complete\n" + header + "status|complete\n" + types +
        "scope|0|0|module|0|" + to_text(len(source)) + "\n" +
        selfhost_lines(hir, "scope|") +
        selfhost_lines(registered, "symbol|") +
        selfhost_lines(hir, "symbol|") +
        selfhost_lines(registered, "binding|") +
        selfhost_lines(hir, "binding|") +
        selfhost_node_lines(hir)
    }
    let code = pattern_line_field(failure, 0, 1)
    let at = decimal_value(pattern_line_field(failure, 0, 2))
    let message = pattern_line_field(failure, 0, 3)
    let mut printed = "error[" + code + "]: " + message
    if at >= 0 {
        printed = printed + " at byte " + to_text(at)
    }
    let mut clamped = at
    if clamped < 0 {
        clamped = 0
    }
    let mut span_end = clamped
    if clamped < len(source) {
        span_end = token_end(source, clamped)
    }
    let mut document = header + "status|rejected\n" + "diagnostic|" +
    code + "|" + to_text(clamped) + "|" + to_text(span_end) + "|" +
    selfhost_escape(message) + "\n"
    if code == "E2S10" {
        document = document + "unsupported|" + to_text(clamped) + "|" +
        to_text(span_end) + "|statement\n"
    }
    return "rejected\n" + printed + "\n" + document
}

fn selfhost_valid_digest(digest: Text) -> Bool {
    let symbols = chars(digest)
    if len(symbols) != 64 {
        return false
    }
    let mut cursor = 0
    while cursor < 64 {
        if !contains("0123456789abcdef", symbols[cursor]) {
            return false
        }
        cursor = cursor + 1
    }
    return true
}

fn emit_selfhost_hir_file(
    input_path: Text,
    output_path: Text,
    digest: Text
) -> Int {
    if input_path == output_path {
        print("error[E2S35]: selfhost-HIR input and output must be distinct")
        return 2
    }
    if !selfhost_valid_digest(digest) {
        print("error[E2S35]: selfhost-HIR digest must be 64 lowercase hex")
        return 2
    }
    let source = read_text(input_path)
    let tokens = lex(source)
    if starts_with(tokens, "error[") {
        print(tokens)
        return 1
    }
    let result = selfhost_document(source, input_path, digest)
    if starts_with(result, "complete\n") {
        write_text(output_path, selfhost_records(result))
        return 0
    }
    let rejected = selfhost_records(result)
    print(selfhost_first_line(rejected))
    write_text(output_path, pattern_result_records(rejected))
    return 1
}

# selfhost-C11 lowering (#620): kofun.selfhost-hir/v1 -> deterministic
# standalone C11 for the non-looping Text/function profile slice.
#
# The document is the only input: node, symbol, binding, scope, and type
# records drive the lowering; source text is never reparsed. Every
# expression node lowers post-order to one temporary named after its
# node id, so argument evaluation is exactly-once and left-to-right, and
# `&&`/`||` keep short-circuit evaluation through guarded blocks.
# Constructs outside the slice classify as unsupported, never as invalid.
# Results pack C text after an `ok` header line; failures are one
# `error|EXIT|MESSAGE` line.

fn selfhost_c11_error(exit_code: Int, message: Text) -> Text {
    return "error|" + to_text(exit_code) + "|" + message
}

fn selfhost_c11_failed(result: Text) -> Bool {
    return starts_with(result, "error|")
}

fn selfhost_c11_line_end(document: Text, line: Int) -> Int {
    let symbols = chars(document)
    let mut cursor = line
    while cursor < len(symbols) && symbols[cursor] != "\n" {
        cursor = cursor + 1
    }
    return cursor
}

# Line offset of the record `TAG|ID|...`, or -1.
fn selfhost_c11_record(document: Text, tag: Text, id: Int) -> Int {
    let wanted = tag + "|" + to_text(id) + "|"
    let mut line = 0
    let size = len(document)
    while line < size {
        if starts_with(text_slice(document, line, size), wanted) {
            return line
        }
        line = selfhost_c11_line_end(document, line) + 1
    }
    return -1
}

fn selfhost_c11_field_count(document: Text, line: Int) -> Int {
    let symbols = chars(document)
    let mut cursor = line
    let mut count = 1
    while cursor < len(symbols) && symbols[cursor] != "\n" {
        if symbols[cursor] == "|" {
            count = count + 1
        }
        cursor = cursor + 1
    }
    return count
}

# The full key of one type record: the remainder after its second bar.
fn selfhost_c11_type_key(document: Text, type_id: Int) -> Text {
    let line = selfhost_c11_record(document, "type", type_id)
    if line < 0 {
        return ""
    }
    let head = len("type|" + to_text(type_id) + "|")
    return text_slice(
        document,
        line + head,
        selfhost_c11_line_end(document, line)
    )
}

fn selfhost_c11_c_type(key: Text) -> Text {
    if key == "int" {
        return "int64_t"
    }
    if key == "bool" {
        return "bool"
    }
    if key == "text" {
        return "const char *"
    }
    if key == "list-text" {
        return "kofun_text_list"
    }
    return ""
}

fn selfhost_c11_symbol_field(
    document: Text,
    symbol_id: Int,
    field: Int
) -> Text {
    let line = selfhost_c11_record(document, "symbol", symbol_id)
    if line < 0 {
        return ""
    }
    return pattern_line_field(document, line, field)
}

fn selfhost_c11_binding_field(
    document: Text,
    binding_id: Int,
    field: Int
) -> Text {
    let line = selfhost_c11_record(document, "binding", binding_id)
    if line < 0 {
        return ""
    }
    return pattern_line_field(document, line, field)
}

fn selfhost_c11_scope_field(
    document: Text,
    scope_id: Int,
    field: Int
) -> Text {
    let line = selfhost_c11_record(document, "scope", scope_id)
    if line < 0 {
        return ""
    }
    return pattern_line_field(document, line, field)
}

# The value type key of a binding: its symbol's recorded type.
fn selfhost_c11_binding_type(document: Text, binding_id: Int) -> Text {
    let symbol = selfhost_c11_binding_field(document, binding_id, 3)
    if len(symbol) == 0 {
        return ""
    }
    return selfhost_c11_type_key(
        document,
        decimal_value(
            selfhost_c11_symbol_field(document, decimal_value(symbol), 4)
        )
    )
}

# Result type key of a function-typed symbol: field 1 of its fn key.
fn selfhost_c11_result_key(document: Text, symbol_id: Int) -> Text {
    let key = selfhost_c11_type_key(
        document,
        decimal_value(selfhost_c11_symbol_field(document, symbol_id, 4))
    )
    if !starts_with(key, "fn|") {
        return ""
    }
    return selfhost_c11_type_key(
        document,
        decimal_value(pattern_line_field(key, 0, 1))
    )
}

# Whether a builtin symbol's single parameter is List[Text] (the len
# overload outside this slice).
fn selfhost_c11_list_parameter(document: Text, symbol_id: Int) -> Bool {
    let key = selfhost_c11_type_key(
        document,
        decimal_value(selfhost_c11_symbol_field(document, symbol_id, 4))
    )
    let parameter = pattern_line_field(key, 0, 2)
    if len(parameter) == 0 {
        return false
    }
    return selfhost_c11_type_key(document, decimal_value(parameter)) ==
    "list-text"
}

# Map a slice builtin to its runtime helper; empty when the builtin is
# outside the non-looping Text slice.
fn selfhost_c11_builtin_helper(name: Text) -> Text {
    if name == "chars" {
        return "kofun_rt_chars"
    }
    if name == "contains" {
        return "kofun_rt_text_contains"
    }
    if name == "find" {
        return "kofun_rt_find"
    }
    if name == "is_digit" {
        return "kofun_rt_is_digit"
    }
    if name == "is_space" {
        return "kofun_rt_is_space"
    }
    if name == "is_xid_continue" {
        return "kofun_rt_is_xid_continue"
    }
    if name == "len" {
        return "kofun_rt_text_len"
    }
    if name == "replace" {
        return "kofun_rt_replace"
    }
    if name == "starts_with" {
        return "kofun_rt_starts_with"
    }
    if name == "text_slice" {
        return "kofun_rt_text_slice"
    }
    if name == "trim" {
        return "kofun_rt_trim"
    }
    if name == "validate_unicode_source" {
        return "kofun_rt_validate_unicode_source"
    }
    return ""
}

fn selfhost_c11_indent(level: Int) -> Text {
    let mut spaces = ""
    let mut remaining = level
    while remaining > 0 {
        spaces = spaces + "    "
        remaining = remaining - 1
    }
    return spaces
}

fn selfhost_c11_failed_check(fail_return: Text, level: Int) -> Text {
    if len(fail_return) == 0 {
        return selfhost_c11_indent(level) + "if (kofun_failed) return;\n"
    }
    return selfhost_c11_indent(level) + "if (kofun_failed) return " +
    fail_return + ";\n"
}

# Decode the record escaping of a literal-text field, then re-escape the
# bytes as one C string literal.
fn selfhost_c11_string(field: Text) -> Text {
    let symbols = chars(field)
    let mut emitted = "\""
    let mut cursor = 0
    while cursor < len(symbols) {
        let mut symbol = symbols[cursor]
        if symbol == "\\" && cursor + 1 < len(symbols) {
            let following = symbols[cursor + 1]
            if following == "\\" {
                symbol = "\\"
            } else if following == "p" {
                symbol = "|"
            } else if following == "n" {
                symbol = "\n"
            }
            cursor = cursor + 1
        }
        if symbol == "\\" {
            emitted = emitted + "\\\\"
        } else if symbol == "\"" {
            emitted = emitted + "\\\""
        } else if symbol == "\n" {
            emitted = emitted + "\\n"
        } else {
            emitted = emitted + symbol
        }
        cursor = cursor + 1
    }
    return emitted + "\""
}

# Line offset just past the pre-order expression subtree at `line`.
fn selfhost_c11_consume(document: Text, line: Int) -> Int {
    let kind = pattern_line_field(document, line, 2)
    let mut next = selfhost_c11_line_end(document, line) + 1
    if kind == "call" {
        let mut field = 8
        let count = selfhost_c11_field_count(document, line)
        while field < count {
            next = selfhost_c11_consume(document, next)
            field = field + 1
        }
        return next
    }
    if kind == "unary" {
        return selfhost_c11_consume(document, next)
    }
    if kind == "binary" || kind == "index" || kind == "range" {
        next = selfhost_c11_consume(document, next)
        return selfhost_c11_consume(document, next)
    }
    return next
}

# The audited C runtime shim emitted into every generated program;
# byte-identical to the seed. Text helpers keep the trusted stage-1
# semantics; the Unicode builtins consult the Unicode 17 tables via
# kofun_unicode.c; allocations are process-lifetime with an explicit
# panic on exhaustion.
fn selfhost_c11_prelude() -> Text {
    return "#include <ctype.h>\n" +
    "#include <inttypes.h>\n" +
    "#include <stdbool.h>\n" +
    "#include <stdint.h>\n" +
    "#include <stdio.h>\n" +
    "#include <stdlib.h>\n" +
    "#include <string.h>\n" +
    "\n" +
    "#include \"kofun_unicode.c\"\n" +
    "\n" +
    "typedef struct {\n" +
    "    int64_t len;\n" +
    "    const char **items;\n" +
    "} kofun_text_list;\n" +
    "\n" +
    "static bool kofun_failed;\n" +
    "\n" +
    "static void kofun_error(const char *message) {\n" +
    "    if (!kofun_failed) {\n" +
    "        fputs(message, stderr);\n" +
    "        fputc('\\n', stderr);\n" +
    "    }\n" +
    "    kofun_failed = true;\n" +
    "}\n" +
    "\n" +
    "static int64_t kofun_add(int64_t left, int64_t right) {\n" +
    "    int64_t result;\n" +
    "    if (__builtin_add_overflow(left, right, &result)) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `+`\");\n" +
    "        return 0;\n" +
    "    }\n" +
    "    return result;\n" +
    "}\n" +
    "\n" +
    "static int64_t kofun_sub(int64_t left, int64_t right) {\n" +
    "    int64_t result;\n" +
    "    if (__builtin_sub_overflow(left, right, &result)) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `-`\");\n" +
    "        return 0;\n" +
    "    }\n" +
    "    return result;\n" +
    "}\n" +
    "\n" +
    "static int64_t kofun_mul(int64_t left, int64_t right) {\n" +
    "    int64_t result;\n" +
    "    if (__builtin_mul_overflow(left, right, &result)) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `*`\");\n" +
    "        return 0;\n" +
    "    }\n" +
    "    return result;\n" +
    "}\n" +
    "\n" +
    "static int64_t kofun_neg(int64_t value) {\n" +
    "    if (value == INT64_MIN) {\n" +
    "        kofun_error(\n" +
    "            \"error[R010]: integer overflow in unary operator `-`\"\n" +
    "        );\n" +
    "        return 0;\n" +
    "    }\n" +
    "    return -value;\n" +
    "}\n" +
    "\n" +
    "static int64_t kofun_floor_div(int64_t left, int64_t right) {\n" +
    "    if (right == 0) {\n" +
    "        kofun_error(\n" +
    "            \"error[R010]: operator `//` failed: division by zero\"\n" +
    "        );\n" +
    "        return 0;\n" +
    "    }\n" +
    "    if (left == INT64_MIN && right == -1) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `//`\");\n" +
    "        return 0;\n" +
    "    }\n" +
    "    int64_t quotient = left / right;\n" +
    "    int64_t remainder = left % right;\n" +
    "    if (remainder != 0 && ((remainder < 0) != (right < 0))) {\n" +
    "        --quotient;\n" +
    "    }\n" +
    "    return quotient;\n" +
    "}\n" +
    "\n" +
    "static int64_t kofun_floor_mod(int64_t left, int64_t right) {\n" +
    "    if (right == 0) {\n" +
    "        kofun_error(\n" +
    "            \"error[R010]: operator `%` failed: division by zero\"\n" +
    "        );\n" +
    "        return 0;\n" +
    "    }\n" +
    "    if (left == INT64_MIN && right == -1) {\n" +
    "        return 0;\n" +
    "    }\n" +
    "    int64_t remainder = left % right;\n" +
    "    if (remainder != 0 && ((remainder < 0) != (right < 0))) {\n" +
    "        remainder += right;\n" +
    "    }\n" +
    "    return remainder;\n" +
    "}\n" +
    "\n" +
    "void kofun_rt_panic(const char *message) {\n" +
    "    fprintf(stderr, \"Kofun runtime error: %s\\n\", message);\n" +
    "    exit(1);\n" +
    "}\n" +
    "\n" +
    "void *kofun_rt_alloc(size_t size) {\n" +
    "    void *value = malloc(size == 0 ? 1 : size);\n" +
    "    if (value == NULL) {\n" +
    "        kofun_rt_panic(\"out of memory\");\n" +
    "    }\n" +
    "    return value;\n" +
    "}\n" +
    "\n" +
    "char *kofun_rt_copy_n(const char *value, size_t length) {\n" +
    "    char *result = (char *)kofun_rt_alloc(length + 1);\n" +
    "    if (length > 0) {\n" +
    "        memcpy(result, value, length);\n" +
    "    }\n" +
    "    result[length] = '\\0';\n" +
    "    return result;\n" +
    "}\n" +
    "\n" +
    "char *kofun_rt_text_concat(const char *left, const char *right) {\n" +
    "    size_t left_len = strlen(left);\n" +
    "    size_t right_len = strlen(right);\n" +
    "    char *result = (char *)kofun_rt_alloc(left_len + right_len + 1);\n" +
    "    memcpy(result, left, left_len);\n" +
    "    memcpy(result + left_len, right, right_len + 1);\n" +
    "    return result;\n" +
    "}\n" +
    "\n" +
    "bool kofun_rt_text_equal(const char *left, const char *right) {\n" +
    "    return strcmp(left, right) == 0;\n" +
    "}\n" +
    "\n" +
    "int64_t kofun_rt_text_len(const char *value) {\n" +
    "    return (int64_t)strlen(value);\n" +
    "}\n" +
    "\n" +
    "int64_t kofun_rt_text_list_len(kofun_text_list values) {\n" +
    "    return values.len;\n" +
    "}\n" +
    "\n" +
    "kofun_text_list kofun_rt_chars(const char *value) {\n" +
    "    size_t length = strlen(value);\n" +
    "    const char **items = (const char **)kofun_rt_alloc(\n" +
    "        sizeof(char *) * (length == 0 ? 1 : length)\n" +
    "    );\n" +
    "    for (size_t index = 0; index < length; ++index) {\n" +
    "        items[index] = kofun_rt_copy_n(value + index, 1);\n" +
    "    }\n" +
    "    kofun_text_list result;\n" +
    "    result.len = (int64_t)length;\n" +
    "    result.items = items;\n" +
    "    return result;\n" +
    "}\n" +
    "\n" +
    "const char *kofun_rt_text_list_get(kofun_text_list values, int64_t index) {\n" +
    "    if (index < 0 || index >= values.len) {\n" +
    "        kofun_rt_panic(\"List[Text] index out of bounds\");\n" +
    "    }\n" +
    "    return values.items[index];\n" +
    "}\n" +
    "\n" +
    "bool kofun_rt_text_contains(const char *value, const char *needle) {\n" +
    "    return strstr(value, needle) != NULL;\n" +
    "}\n" +
    "\n" +
    "int64_t kofun_rt_find(const char *value, const char *needle) {\n" +
    "    const char *found = strstr(value, needle);\n" +
    "    return found == NULL ? INT64_C(-1) : (int64_t)(found - value);\n" +
    "}\n" +
    "\n" +
    "char *kofun_rt_text_slice(const char *value, int64_t start, int64_t end) {\n" +
    "    int64_t length = (int64_t)strlen(value);\n" +
    "    if (start < 0) start = 0;\n" +
    "    if (end < start) end = start;\n" +
    "    if (start > length) start = length;\n" +
    "    if (end > length) end = length;\n" +
    "    return kofun_rt_copy_n(value + start, (size_t)(end - start));\n" +
    "}\n" +
    "\n" +
    "char *kofun_rt_trim(const char *value) {\n" +
    "    const unsigned char *start = (const unsigned char *)value;\n" +
    "    while (*start != '\\0' && isspace(*start)) {\n" +
    "        ++start;\n" +
    "    }\n" +
    "    const unsigned char *end =\n" +
    "        (const unsigned char *)value + strlen(value);\n" +
    "    while (end > start && isspace(end[-1])) {\n" +
    "        --end;\n" +
    "    }\n" +
    "    return kofun_rt_copy_n((const char *)start, (size_t)(end - start));\n" +
    "}\n" +
    "\n" +
    "char *kofun_rt_replace(\n" +
    "    const char *value,\n" +
    "    const char *old,\n" +
    "    const char *replacement\n" +
    ") {\n" +
    "    size_t old_len = strlen(old);\n" +
    "    if (old_len == 0) {\n" +
    "        return kofun_rt_copy_n(value, strlen(value));\n" +
    "    }\n" +
    "    size_t replacement_len = strlen(replacement);\n" +
    "    size_t count = 0;\n" +
    "    const char *cursor = value;\n" +
    "    while ((cursor = strstr(cursor, old)) != NULL) {\n" +
    "        ++count;\n" +
    "        cursor += old_len;\n" +
    "    }\n" +
    "    size_t value_len = strlen(value);\n" +
    "    size_t result_len;\n" +
    "    if (replacement_len >= old_len) {\n" +
    "        result_len = value_len + count * (replacement_len - old_len);\n" +
    "    } else {\n" +
    "        result_len = value_len - count * (old_len - replacement_len);\n" +
    "    }\n" +
    "    char *result = (char *)kofun_rt_alloc(result_len + 1);\n" +
    "    char *out = result;\n" +
    "    cursor = value;\n" +
    "    const char *match;\n" +
    "    while ((match = strstr(cursor, old)) != NULL) {\n" +
    "        size_t prefix = (size_t)(match - cursor);\n" +
    "        memcpy(out, cursor, prefix);\n" +
    "        out += prefix;\n" +
    "        memcpy(out, replacement, replacement_len);\n" +
    "        out += replacement_len;\n" +
    "        cursor = match + old_len;\n" +
    "    }\n" +
    "    strcpy(out, cursor);\n" +
    "    return result;\n" +
    "}\n" +
    "\n" +
    "bool kofun_rt_starts_with(const char *value, const char *prefix) {\n" +
    "    size_t prefix_len = strlen(prefix);\n" +
    "    return strncmp(value, prefix, prefix_len) == 0;\n" +
    "}\n" +
    "\n" +
    "bool kofun_rt_is_digit(const char *value) {\n" +
    "    return value[0] != '\\0' && value[1] == '\\0' &&\n" +
    "        isdigit((unsigned char)value[0]) != 0;\n" +
    "}\n" +
    "\n" +
    "bool kofun_rt_is_space(const char *value) {\n" +
    "    return value[0] != '\\0' && value[1] == '\\0' &&\n" +
    "        isspace((unsigned char)value[0]) != 0;\n" +
    "}\n" +
    "\n" +
    "bool kofun_rt_is_xid_continue(const char *value) {\n" +
    "    uint32_t codepoint = 0;\n" +
    "    size_t width = 0;\n" +
    "    size_t length = strlen(value);\n" +
    "    if (!kofun_unicode_decode(\n" +
    "            (const uint8_t *)value,\n" +
    "            length,\n" +
    "            0,\n" +
    "            &codepoint,\n" +
    "            &width)) {\n" +
    "        return false;\n" +
    "    }\n" +
    "    return kofun_unicode_is_xid_continue(codepoint);\n" +
    "}\n" +
    "\n" +
    "const char *kofun_rt_validate_unicode_source(const char *value) {\n" +
    "    KofunUnicodeError unicode_error;\n" +
    "    if (kofun_unicode_validate_source(\n" +
    "            (const uint8_t *)value,\n" +
    "            strlen(value),\n" +
    "            &unicode_error)) {\n" +
    "        return \"\";\n" +
    "    }\n" +
    "    char message[1024];\n" +
    "    kofun_unicode_format_error(\n" +
    "        &unicode_error,\n" +
    "        getenv(\"KOFUN_DIAGNOSTIC_LOCALE\"),\n" +
    "        message,\n" +
    "        sizeof(message)\n" +
    "    );\n" +
    "    return kofun_rt_copy_n(message, strlen(message));\n" +
    "}\n" +
    "\n"
}

# Emission context: `RANGE_START|RANGE_END|IS_MAIN|FAIL_RETURN` — the
# function's node-record byte range in the document, whether it is
# `main`, and the value returned when kofun_failed is observed.

fn selfhost_c11_node_line(document: Text, context: Text, node_id: Int) -> Int {
    let range_end = decimal_value(pattern_line_field(context, 0, 1))
    let wanted = "node|" + to_text(node_id) + "|"
    let mut line = decimal_value(pattern_line_field(context, 0, 0))
    while line < range_end {
        if starts_with(text_slice(document, line, range_end), wanted) {
            return line
        }
        line = selfhost_c11_line_end(document, line) + 1
    }
    return -1
}

fn selfhost_c11_expression(
    document: Text,
    context: Text,
    node_id: Int,
    level: Int
) -> Text {
    let line = selfhost_c11_node_line(document, context, node_id)
    if line < 0 {
        return selfhost_c11_error(
            1,
            "error[E2S35]: selfhost-C11 node reference is out of range"
        )
    }
    let kind = pattern_line_field(document, line, 2)
    let type_key = selfhost_c11_type_key(
        document,
        decimal_value(pattern_line_field(document, line, 5))
    )
    let pad = selfhost_c11_indent(level)
    let fail_return = pattern_line_field(context, 0, 3)
    if kind == "literal-int" {
        let digits = pattern_line_field(document, line, 7)
        let symbols = chars(digits)
        let mut cleaned = ""
        let mut cursor = 0
        while cursor < len(symbols) {
            if symbols[cursor] != "_" {
                cleaned = cleaned + symbols[cursor]
            }
            cursor = cursor + 1
        }
        return "ok\n" + pad + "int64_t k_n" + to_text(node_id) +
        " = INT64_C(" + cleaned + ");\n"
    }
    if kind == "literal-bool" {
        return "ok\n" + pad + "bool k_n" + to_text(node_id) + " = " +
        pattern_line_field(document, line, 7) + ";\n"
    }
    if kind == "literal-text" {
        return "ok\n" + pad + "const char *k_n" + to_text(node_id) +
        " = " + selfhost_c11_string(pattern_line_field(document, line, 7)) +
        ";\n"
    }
    if kind == "name" {
        if len(selfhost_c11_c_type(type_key)) == 0 {
            return selfhost_c11_error(
                3,
                "error[E2S10]: unsupported selfhost-C11 type `" +
                type_key + "`"
            )
        }
        return "ok\n" + pad + selfhost_c11_c_type(type_key) + " k_n" +
        to_text(node_id) + " = k_b" +
        pattern_line_field(document, line, 7) + ";\n"
    }
    if kind == "call" {
        let symbol_id = decimal_value(pattern_line_field(document, line, 7))
        let symbol_line = selfhost_c11_record(document, "symbol", symbol_id)
        if symbol_line < 0 {
            return selfhost_c11_error(
                1,
                "error[E2S35]: selfhost-C11 call has no symbol"
            )
        }
        let name = selfhost_c11_symbol_field(document, symbol_id, 3)
        let builtin =
            selfhost_c11_symbol_field(document, symbol_id, 2) == "builtin"
        let mut helper = ""
        if builtin {
            helper = selfhost_c11_builtin_helper(name)
            if name == "len" &&
               selfhost_c11_list_parameter(document, symbol_id) {
                helper = "kofun_rt_text_list_len"
            }
            if len(helper) == 0 {
                return selfhost_c11_error(
                    3,
                    "error[E2S10]: unsupported selfhost-C11 builtin call `" +
                    name + "`"
                )
            }
        }
        let count = selfhost_c11_field_count(document, line)
        let mut emitted = ""
        let mut field = 8
        while field < count {
            let argument = selfhost_c11_expression(
                document,
                context,
                decimal_value(pattern_line_field(document, line, field)),
                level
            )
            if selfhost_c11_failed(argument) {
                return argument
            }
            emitted = emitted + selfhost_records(argument)
            field = field + 1
        }
        let mut open = "kofun_fn_" + name + "("
        if type_key != "void" {
            if builtin {
                open = selfhost_c11_c_type(type_key) + " k_n" +
                to_text(node_id) + " = " + helper + "("
            } else {
                open = selfhost_c11_c_type(type_key) + " k_n" +
                to_text(node_id) + " = kofun_fn_" + name + "("
            }
        }
        let mut arguments = ""
        field = 8
        while field < count {
            if field > 8 {
                arguments = arguments + ", "
            }
            arguments = arguments + "k_n" +
            pattern_line_field(document, line, field)
            field = field + 1
        }
        emitted = emitted + pad + open + arguments + ");\n"
        if !builtin {
            emitted = emitted + selfhost_c11_failed_check(fail_return, level)
        }
        return "ok\n" + emitted
    }
    if kind == "unary" {
        let operator = pattern_line_field(document, line, 7)
        let operand = decimal_value(pattern_line_field(document, line, 8))
        let inner = selfhost_c11_expression(document, context, operand, level)
        if selfhost_c11_failed(inner) {
            return inner
        }
        if operator == "!" {
            return "ok\n" + selfhost_records(inner) + pad + "bool k_n" +
            to_text(node_id) + " = !k_n" + to_text(operand) + ";\n"
        }
        return "ok\n" + selfhost_records(inner) + pad + "int64_t k_n" +
        to_text(node_id) + " = kofun_neg(k_n" + to_text(operand) +
        ");\n" + selfhost_c11_failed_check(fail_return, level)
    }
    if kind == "binary" {
        let operator = pattern_line_field(document, line, 7)
        let left = decimal_value(pattern_line_field(document, line, 8))
        let right = decimal_value(pattern_line_field(document, line, 9))
        let left_line = selfhost_c11_node_line(document, context, left)
        let mut left_key = ""
        if left_line >= 0 {
            left_key = selfhost_c11_type_key(
                document,
                decimal_value(pattern_line_field(document, left_line, 5))
            )
        }
        if operator == "&&" || operator == "\\p\\p" {
            let first = selfhost_c11_expression(document, context, left, level)
            if selfhost_c11_failed(first) {
                return first
            }
            let second = selfhost_c11_expression(
                document,
                context,
                right,
                level + 1
            )
            if selfhost_c11_failed(second) {
                return second
            }
            let mut guard = "if (k_n"
            if operator != "&&" {
                guard = "if (!k_n"
            }
            return "ok\n" + selfhost_records(first) + pad + "bool k_n" +
            to_text(node_id) + " = k_n" + to_text(left) + ";\n" + pad +
            guard + to_text(node_id) + ") {\n" +
            selfhost_records(second) + selfhost_c11_indent(level + 1) +
            "k_n" + to_text(node_id) + " = k_n" + to_text(right) + ";\n" +
            pad + "}\n"
        }
        let first = selfhost_c11_expression(document, context, left, level)
        if selfhost_c11_failed(first) {
            return first
        }
        let second = selfhost_c11_expression(document, context, right, level)
        if selfhost_c11_failed(second) {
            return second
        }
        let emitted = selfhost_records(first) + selfhost_records(second)
        if operator == "+" && left_key == "text" {
            return "ok\n" + emitted + pad + "const char *k_n" +
            to_text(node_id) + " = kofun_rt_text_concat(k_n" +
            to_text(left) + ", k_n" + to_text(right) + ");\n"
        }
        if operator == "==" || operator == "!=" {
            if left_key == "text" {
                let mut negate = ""
                if operator == "!=" {
                    negate = "!"
                }
                return "ok\n" + emitted + pad + "bool k_n" +
                to_text(node_id) + " = " + negate +
                "kofun_rt_text_equal(k_n" + to_text(left) + ", k_n" +
                to_text(right) + ");\n"
            }
            return "ok\n" + emitted + pad + "bool k_n" + to_text(node_id) +
            " = k_n" + to_text(left) + " " + operator + " k_n" +
            to_text(right) + ";\n"
        }
        if operator == "<" || operator == "<=" || operator == ">" ||
           operator == ">=" {
            if left_key == "text" {
                return selfhost_c11_error(
                    3,
                    "error[E2S10]: unsupported selfhost-C11 operator `" +
                    operator + "`"
                )
            }
            return "ok\n" + emitted + pad + "bool k_n" + to_text(node_id) +
            " = k_n" + to_text(left) + " " + operator + " k_n" +
            to_text(right) + ";\n"
        }
        let mut arithmetic = ""
        if operator == "+" {
            arithmetic = "kofun_add"
        } else if operator == "-" {
            arithmetic = "kofun_sub"
        } else if operator == "*" {
            arithmetic = "kofun_mul"
        } else if operator == "//" {
            arithmetic = "kofun_floor_div"
        } else if operator == "%" {
            arithmetic = "kofun_floor_mod"
        }
        if len(arithmetic) == 0 {
            return selfhost_c11_error(
                3,
                "error[E2S10]: unsupported selfhost-C11 operator `" +
                operator + "`"
            )
        }
        return "ok\n" + emitted + pad + "int64_t k_n" + to_text(node_id) +
        " = " + arithmetic + "(k_n" + to_text(left) + ", k_n" +
        to_text(right) + ");\n" +
        selfhost_c11_failed_check(fail_return, level)
    }
    if kind == "index" {
        let base = decimal_value(pattern_line_field(document, line, 7))
        let position = decimal_value(pattern_line_field(document, line, 8))
        let first = selfhost_c11_expression(document, context, base, level)
        if selfhost_c11_failed(first) {
            return first
        }
        let second = selfhost_c11_expression(
            document,
            context,
            position,
            level
        )
        if selfhost_c11_failed(second) {
            return second
        }
        return "ok\n" + selfhost_records(first) +
        selfhost_records(second) + pad + "const char *k_n" +
        to_text(node_id) + " = kofun_rt_text_list_get(k_n" +
        to_text(base) + ", k_n" + to_text(position) + ");\n"
    }
    return selfhost_c11_error(
        3,
        "error[E2S10]: unsupported selfhost-C11 expression `" + kind + "`"
    )
}

# Statement results pack `NEXT|TERMINAL` over the emitted C lines.
fn selfhost_c11_statement(
    document: Text,
    context: Text,
    line: Int,
    level: Int
) -> Text {
    let kind = pattern_line_field(document, line, 2)
    let node_end = selfhost_c11_line_end(document, line) + 1
    let pad = selfhost_c11_indent(level)
    let is_main = pattern_line_field(context, 0, 2) == "1"
    if kind == "let" || kind == "let-mut" {
        let binding = pattern_line_field(document, line, 7)
        let value = decimal_value(pattern_line_field(document, line, 8))
        let emitted = selfhost_c11_expression(document, context, value, level)
        if selfhost_c11_failed(emitted) {
            return emitted
        }
        let binding_key = selfhost_c11_binding_type(
            document,
            decimal_value(binding)
        )
        if len(selfhost_c11_c_type(binding_key)) == 0 {
            return selfhost_c11_error(
                3,
                "error[E2S10]: unsupported selfhost-C11 type `" +
                binding_key + "`"
            )
        }
        return to_text(selfhost_c11_consume(document, node_end)) + "|0\n" +
        selfhost_records(emitted) + pad + selfhost_c11_c_type(binding_key) +
        " k_b" + binding + " = k_n" + to_text(value) + ";\n"
    }
    if kind == "return" {
        if pattern_line_field(document, line, 7) == "none" {
            let mut bare = pad + "return;\n"
            if is_main {
                bare = pad + "return 0;\n"
            }
            return to_text(node_end) + "|1\n" + bare
        }
        let value = decimal_value(pattern_line_field(document, line, 7))
        let emitted = selfhost_c11_expression(document, context, value, level)
        if selfhost_c11_failed(emitted) {
            return emitted
        }
        let mut returned = pad + "return k_n" + to_text(value) + ";\n"
        if is_main {
            returned = pad + "return (int)k_n" + to_text(value) + ";\n"
        }
        return to_text(selfhost_c11_consume(document, node_end)) + "|1\n" +
        selfhost_records(emitted) + returned
    }
    if kind == "expr-stmt" {
        let value = decimal_value(pattern_line_field(document, line, 7))
        let emitted = selfhost_c11_expression(document, context, value, level)
        if selfhost_c11_failed(emitted) {
            return emitted
        }
        let value_line = selfhost_c11_node_line(document, context, value)
        let mut discard = ""
        if selfhost_c11_type_key(
               document,
               decimal_value(pattern_line_field(document, value_line, 5))
           ) != "void" {
            discard = pad + "(void)k_n" + to_text(value) + ";\n"
        }
        return to_text(selfhost_c11_consume(document, node_end)) + "|0\n" +
        selfhost_records(emitted) + discard
    }
    if kind == "if" {
        let condition = decimal_value(pattern_line_field(document, line, 7))
        let then_scope = decimal_value(pattern_line_field(document, line, 8))
        let else_kind = pattern_line_field(document, line, 9)
        let emitted = selfhost_c11_expression(
            document,
            context,
            condition,
            level
        )
        if selfhost_c11_failed(emitted) {
            return emitted
        }
        let body = selfhost_c11_block(
            document,
            context,
            selfhost_c11_consume(document, node_end),
            then_scope,
            level + 1
        )
        if selfhost_c11_failed(body) {
            return body
        }
        let mut walk = decimal_value(pattern_line_field(body, 0, 0))
        let mut branch = selfhost_records(emitted) + pad + "if (k_n" +
        to_text(condition) + ") {\n" + selfhost_records(body)
        if else_kind == "none" {
            return to_text(walk) + "|0\n" + branch + pad + "}\n"
        }
        branch = branch + pad + "} else {\n"
        let mut alternative = ""
        if else_kind == "block" {
            alternative = selfhost_c11_block(
                document,
                context,
                walk,
                decimal_value(pattern_line_field(document, line, 10)),
                level + 1
            )
        } else {
            alternative = selfhost_c11_statement(
                document,
                context,
                walk,
                level + 1
            )
        }
        if selfhost_c11_failed(alternative) {
            return alternative
        }
        walk = decimal_value(pattern_line_field(alternative, 0, 0))
        let terminal =
            pattern_line_field(body, 0, 1) == "1" &&
            pattern_line_field(alternative, 0, 1) == "1"
        let mut flag = "0"
        if terminal {
            flag = "1"
        }
        return to_text(walk) + "|" + flag + "\n" + branch +
        selfhost_records(alternative) + pad + "}\n"
    }
    if kind == "assign" {
        let value = decimal_value(pattern_line_field(document, line, 8))
        let emitted = selfhost_c11_expression(document, context, value, level)
        if selfhost_c11_failed(emitted) {
            return emitted
        }
        return to_text(selfhost_c11_consume(document, node_end)) + "|0\n" +
        selfhost_records(emitted) + pad + "k_b" +
        pattern_line_field(document, line, 7) + " = k_n" + to_text(value) +
        ";\n"
    }
    if kind == "while" {
        let condition = decimal_value(pattern_line_field(document, line, 7))
        let emitted = selfhost_c11_expression(
            document,
            context,
            condition,
            level + 1
        )
        if selfhost_c11_failed(emitted) {
            return emitted
        }
        let body = selfhost_c11_block(
            document,
            context,
            selfhost_c11_consume(document, node_end),
            decimal_value(pattern_line_field(document, line, 8)),
            level + 1
        )
        if selfhost_c11_failed(body) {
            return body
        }
        return pattern_line_field(body, 0, 0) + "|0\n" + pad +
        "for (;;) {\n" + selfhost_records(emitted) +
        selfhost_c11_indent(level + 1) + "if (!k_n" + to_text(condition) +
        ") break;\n" + selfhost_records(body) + pad + "}\n"
    }
    if kind == "for-range" {
        let range_line = selfhost_c11_node_line(
            document,
            context,
            decimal_value(pattern_line_field(document, line, 8))
        )
        if range_line < 0 {
            return selfhost_c11_error(
                1,
                "error[E2S35]: selfhost-C11 node reference is out of range"
            )
        }
        let low = decimal_value(pattern_line_field(document, range_line, 7))
        let high = decimal_value(pattern_line_field(document, range_line, 8))
        let first = selfhost_c11_expression(document, context, low, level)
        if selfhost_c11_failed(first) {
            return first
        }
        let second = selfhost_c11_expression(document, context, high, level)
        if selfhost_c11_failed(second) {
            return second
        }
        let body = selfhost_c11_block(
            document,
            context,
            selfhost_c11_consume(document, node_end),
            decimal_value(pattern_line_field(document, line, 9)),
            level + 1
        )
        if selfhost_c11_failed(body) {
            return body
        }
        let binding = pattern_line_field(document, line, 7)
        return pattern_line_field(body, 0, 0) + "|0\n" +
        selfhost_records(first) + selfhost_records(second) + pad +
        "for (int64_t k_b" + binding + " = k_n" + to_text(low) +
        "; k_b" + binding + " < k_n" + to_text(high) + "; ++k_b" +
        binding + ") {\n" + selfhost_records(body) + pad + "}\n"
    }
    return selfhost_c11_error(
        3,
        "error[E2S10]: unsupported selfhost-C11 statement `" + kind + "`"
    )
}

# Emit the statements whose spans lie inside one block scope.
fn selfhost_c11_block(
    document: Text,
    context: Text,
    line: Int,
    scope_id: Int,
    level: Int
) -> Text {
    let scope_start = selfhost_c11_scope_field(document, scope_id, 4)
    let scope_end = selfhost_c11_scope_field(document, scope_id, 5)
    if len(scope_start) == 0 {
        return selfhost_c11_error(
            1,
            "error[E2S35]: selfhost-C11 scope reference is out of range"
        )
    }
    let range_end = decimal_value(pattern_line_field(context, 0, 1))
    let mut walk = line
    let mut emitted = ""
    let mut terminal = "0"
    let mut walking = true
    while walking && walk < range_end {
        if !starts_with(text_slice(document, walk, range_end), "node|") {
            walking = false
        } else {
            let start = decimal_value(pattern_line_field(document, walk, 3))
            if start < decimal_value(scope_start) ||
               start >= decimal_value(scope_end) {
                walking = false
            } else {
                let statement = selfhost_c11_statement(
                    document,
                    context,
                    walk,
                    level
                )
                if selfhost_c11_failed(statement) {
                    return statement
                }
                walk = decimal_value(pattern_line_field(statement, 0, 0))
                terminal = pattern_line_field(statement, 0, 1)
                emitted = emitted + selfhost_records(statement)
            }
        }
    }
    return to_text(walk) + "|" + terminal + "\n" + emitted
}

# Typed parameter list of one function scope: packs `ARITY` over the
# comma-joined C parameters, or an internal error.
fn selfhost_c11_signature(document: Text, function_scope: Int) -> Text {
    let size = len(document)
    let mut line = 0
    let mut arity = 0
    let mut parameters = ""
    while line < size {
        if starts_with(text_slice(document, line, size), "binding|") &&
           decimal_value(pattern_line_field(document, line, 2)) ==
           function_scope {
            let symbol = decimal_value(pattern_line_field(document, line, 3))
            if selfhost_c11_symbol_field(document, symbol, 2) ==
               "parameter" {
                let key = selfhost_c11_type_key(
                    document,
                    decimal_value(
                        selfhost_c11_symbol_field(document, symbol, 4)
                    )
                )
                if len(selfhost_c11_c_type(key)) == 0 {
                    return selfhost_c11_error(
                        3,
                        "error[E2S10]: unsupported selfhost-C11 type `" +
                        key + "`"
                    )
                }
                if arity > 0 {
                    parameters = parameters + ", "
                }
                let mut spelled = "bool "
                if key == "text" {
                    spelled = "const char *"
                } else if key == "int" {
                    spelled = "int64_t "
                } else if key == "list-text" {
                    spelled = "kofun_text_list "
                }
                parameters = parameters + spelled + "k_b" +
                pattern_line_field(document, line, 1)
                arity = arity + 1
            }
        }
        line = selfhost_c11_line_end(document, line) + 1
    }
    return to_text(arity) + "\n" + parameters
}

# One function record: packs the next record offset over the emitted C
# body (the driver assembles prototypes from the same signature).
fn selfhost_c11_function(
    document: Text,
    record: Int,
    range_end: Int,
    casts: Text
) -> Text {
    let symbol_id = decimal_value(pattern_line_field(document, record, 2))
    let symbol_line = selfhost_c11_record(document, "symbol", symbol_id)
    if symbol_line < 0 {
        return selfhost_c11_error(
            1,
            "error[E2S35]: selfhost-C11 function has no symbol"
        )
    }
    let name = selfhost_c11_symbol_field(document, symbol_id, 3)
    let result_key = selfhost_c11_result_key(document, symbol_id)
    let signature = selfhost_c11_signature(
        document,
        decimal_value(pattern_line_field(document, record, 3))
    )
    if selfhost_c11_failed(signature) {
        return signature
    }
    let arity = decimal_value(pattern_line_field(signature, 0, 0))
    let mut fail_return = ""
    if name == "main" {
        fail_return = "1"
    } else if result_key == "int" {
        fail_return = "INT64_C(0)"
    } else if result_key == "bool" {
        fail_return = "false"
    } else if result_key == "text" {
        fail_return = "\"\""
    } else if result_key != "void" {
        return selfhost_c11_error(
            3,
            "error[E2S10]: unsupported selfhost-C11 type `" + result_key +
            "`"
        )
    }
    let mut opened = ""
    if name == "main" {
        if arity != 0 {
            return selfhost_c11_error(
                1,
                "error[E2S15]: selfhost-C11 `main` takes no parameters"
            )
        }
        opened = "int main(void) {\n" + casts
    } else {
        let mut result_type = "void "
        if result_key == "text" {
            result_type = "const char *"
        } else if result_key == "int" {
            result_type = "int64_t "
        } else if result_key == "bool" {
            result_type = "bool "
        }
        let mut parameters = selfhost_records(signature)
        if arity == 0 {
            parameters = "void"
        }
        opened = "static " + result_type + "kofun_fn_" + name + "(" +
        parameters + ") {\n"
    }
    let mut is_main = "0"
    if name == "main" {
        is_main = "1"
    }
    let context = to_text(selfhost_c11_line_end(document, record) + 1) +
    "|" + to_text(range_end) + "|" + is_main + "|" + fail_return
    let mut walk = selfhost_c11_line_end(document, record) + 1
    let mut body = ""
    let mut terminal = "0"
    while walk < range_end {
        let statement = selfhost_c11_statement(document, context, walk, 1)
        if selfhost_c11_failed(statement) {
            return statement
        }
        walk = decimal_value(pattern_line_field(statement, 0, 0))
        terminal = pattern_line_field(statement, 0, 1)
        body = body + selfhost_records(statement)
    }
    if terminal != "1" && result_key != "void" && name != "main" {
        return selfhost_c11_error(
            1,
            "error[E2S19]: selfhost-C11 function may complete without " +
            "returning a value: `" + name + "`"
        )
    }
    if name == "main" && terminal != "1" {
        body = body + "    return 0;\n"
    }
    return to_text(range_end) + "\n" + opened + body + "}\n\n"
}

# Prototype line for one non-main function.
fn selfhost_c11_prototype(document: Text, record: Int) -> Text {
    let symbol_id = decimal_value(pattern_line_field(document, record, 2))
    let name = selfhost_c11_symbol_field(document, symbol_id, 3)
    let result_key = selfhost_c11_result_key(document, symbol_id)
    let signature = selfhost_c11_signature(
        document,
        decimal_value(pattern_line_field(document, record, 3))
    )
    if selfhost_c11_failed(signature) {
        return signature
    }
    let mut result_type = "void "
    if result_key == "text" {
        result_type = "const char *"
    } else if result_key == "int" {
        result_type = "int64_t "
    } else if result_key == "bool" {
        result_type = "bool "
    }
    let mut parameters = selfhost_records(signature)
    if decimal_value(pattern_line_field(signature, 0, 0)) == 0 {
        parameters = "void"
    }
    return "static " + result_type + "kofun_fn_" + name + "(" +
    parameters + ");\n"
}

# Produce the whole generated C translation unit, or `error|EXIT|MESSAGE`.
fn selfhost_c11_document(document: Text) -> Text {
    if !starts_with(document, "schema|kofun.selfhost-hir/v1\n") {
        return selfhost_c11_error(
            1,
            "error[E2S35]: selfhost-C11 input is not a " +
            "kofun.selfhost-hir/v1 document"
        )
    }
    let source_line = text_find_from(document, "\nsource|", 0)
    if source_line < 0 {
        return selfhost_c11_error(
            1,
            "error[E2S35]: selfhost-C11 document has no source record"
        )
    }
    if !contains(document, "\nstatus|complete\n") {
        return selfhost_c11_error(
            1,
            "error[E2S35]: selfhost-C11 input must be a complete typed " +
            "document"
        )
    }
    let size = len(document)
    let mut casts = "    (void)kofun_failed;\n" +
    "    (void)kofun_error;\n" +
    "    (void)kofun_add;\n" +
    "    (void)kofun_sub;\n" +
    "    (void)kofun_mul;\n" +
    "    (void)kofun_neg;\n" +
    "    (void)kofun_floor_div;\n" +
    "    (void)kofun_floor_mod;\n"
    let mut main_count = 0
    let mut line = 0
    while line < size {
        if starts_with(text_slice(document, line, size), "function|") {
            let symbol =
                decimal_value(pattern_line_field(document, line, 2))
            if selfhost_c11_symbol_field(document, symbol, 3) == "main" {
                main_count = main_count + 1
            } else {
                casts = casts + "    (void)kofun_fn_" +
                selfhost_c11_symbol_field(document, symbol, 3) + ";\n"
            }
        }
        line = selfhost_c11_line_end(document, line) + 1
    }
    if main_count != 1 {
        return selfhost_c11_error(
            1,
            "error[E2S16]: selfhost-C11 program needs exactly one `main`"
        )
    }
    let mut prototypes = ""
    let mut bodies = ""
    line = 0
    while line < size {
        if starts_with(text_slice(document, line, size), "function|") {
            let mut range_end =
                selfhost_c11_line_end(document, line) + 1
            let mut scanning = true
            while scanning && range_end < size {
                if starts_with(
                       text_slice(document, range_end, size),
                       "function|"
                   ) {
                    scanning = false
                } else {
                    range_end =
                        selfhost_c11_line_end(document, range_end) + 1
                }
            }
            let symbol =
                decimal_value(pattern_line_field(document, line, 2))
            if selfhost_c11_symbol_field(document, symbol, 3) != "main" {
                let prototype = selfhost_c11_prototype(document, line)
                if selfhost_c11_failed(prototype) {
                    return prototype
                }
                prototypes = prototypes + prototype
            }
            let emitted = selfhost_c11_function(
                document,
                line,
                range_end,
                casts
            )
            if selfhost_c11_failed(emitted) {
                return emitted
            }
            bodies = bodies + selfhost_records(emitted)
            line = range_end
        } else {
            line = selfhost_c11_line_end(document, line) + 1
        }
    }
    let mut emitted =
    "/* Generated by kofun-stage2 --lower-selfhost-c11. */\n" +
    "/* Source: " + pattern_line_field(document, source_line + 1, 1) +
    " " + pattern_line_field(document, source_line + 1, 2) + " */\n\n" +
    selfhost_c11_prelude()
    if len(prototypes) > 0 {
        emitted = emitted + prototypes + "\n"
    }
    return "ok\n" + emitted + bodies
}

fn lower_selfhost_c11_file(input_path: Text, output_path: Text) -> Int {
    if input_path == output_path {
        print("error[E2S35]: selfhost-C11 input and output must be distinct")
        return 2
    }
    let document = read_text(input_path)
    let lowered = selfhost_c11_document(document)
    if selfhost_c11_failed(lowered) {
        print(pattern_line_field(lowered, 0, 2))
        return decimal_value(pattern_line_field(lowered, 0, 1))
    }
    write_text(output_path, selfhost_records(lowered))
    return 0
}

fn main() -> Int {
    let arguments = args()
    if len(arguments) == 5 && arguments[0] == "--compile-outcome" {
        return compile_file(
            arguments[1],
            arguments[2],
            arguments[3],
            arguments[4]
        )
    }
    if len(arguments) == 2 && arguments[0] == "--check-ownership" {
        if !check_ownership_file(arguments[1]) {
            return 1
        }
        return 0
    }
    if len(arguments) == 3 && arguments[0] == "--parse-patterns" {
        if !parse_patterns_file(arguments[1], arguments[2]) {
            return 1
        }
        return 0
    }
    if len(arguments) == 3 && arguments[0] == "--emit-scope-hir" {
        if !emit_scope_hir_file(arguments[1], arguments[2]) {
            return 1
        }
        return 0
    }
    if len(arguments) == 4 && arguments[0] == "--emit-selfhost-hir" {
        return emit_selfhost_hir_file(
            arguments[1],
            arguments[2],
            arguments[3]
        )
    }
    if len(arguments) == 3 && arguments[0] == "--lower-selfhost-c11" {
        return lower_selfhost_c11_file(arguments[1], arguments[2])
    }
    if len(arguments) != 4 {
        print(
            "usage: kofun-stage2 INPUT.kofun OUTPUT.kofun OUTPUT.ir OUTPUT.tokens\n" +
            "       kofun-stage2 --compile-outcome INPUT.kofun OUTPUT.c OUTPUT.ir OUTPUT.tokens\n" +
            "       kofun-stage2 --check-ownership INPUT.kofun\n" +
            "       kofun-stage2 --parse-patterns INPUT.kofun OUTPUT.patterns\n" +
            "       kofun-stage2 --emit-scope-hir INPUT.kofun OUTPUT.scope-hir\n" +
            "       kofun-stage2 --emit-selfhost-hir INPUT.kofun OUTPUT.hir SOURCE-SHA256\n" +
            "       kofun-stage2 --lower-selfhost-c11 INPUT.hir OUTPUT.c"
        )
        return 2
    }
    if compile_file(
        arguments[0],
        arguments[1],
        arguments[2],
        arguments[3]
    ) != 0 {
        return 1
    }
    return 0
}
