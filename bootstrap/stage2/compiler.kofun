# Kofun Stage 2 semantic-front-end checkpoint.
#
# This compiler is intentionally written in the typed bootstrap subset already
# used by Stage 1: Int, Bool, Text, List[Text], control flow, direct calls, and
# file/text builtins.  Its first fixed-point projection is conservative:
# tokenize and parse a Kofun compilation unit, emit a stable textual IR, then
# reproduce the accepted Kofun source byte-for-byte. A statement/expression
# parser also lowers the integer Core to deterministic, checked C11.
#
# The exact source projection remains useful before this compiler can lower its
# own full source: any change made by the front end would make the second
# projection differ.

fn identifier_start(symbol: Text) -> Bool {
    return symbol == "_" ||
    contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ", symbol)
}

fn identifier_continue(symbol: Text) -> Bool {
    return identifier_start(symbol) || is_digit(symbol)
}

fn skip_trivia(source: Text, start: Int) -> Int {
    let symbols = chars(source)
    let mut cursor = start
    while cursor < len(symbols) {
        if is_space(symbols[cursor]) {
            cursor = cursor + 1
        } else if symbols[cursor] == "#" {
            while cursor < len(symbols) && symbols[cursor] != "\n" {
                cursor = cursor + 1
            }
        } else {
            return cursor
        }
    }
    return cursor
}

fn string_end(source: Text, start: Int) -> Int {
    let symbols = chars(source)
    let mut cursor = start + 1
    let mut escaped = false
    while cursor < len(symbols) {
        let symbol = symbols[cursor]
        if escaped {
            escaped = false
        } else if symbol == "\\" {
            escaped = true
        } else if symbol == "\"" {
            return cursor + 1
        } else if symbol == "\n" {
            return -1
        }
        cursor = cursor + 1
    }
    return -1
}

fn pair_token(token: Text) -> Bool {
    return token == "->" || token == "==" || token == "!=" ||
    token == "<=" || token == ">=" || token == "&&" ||
    token == "||" || token == "//" || token == ".." ||
    token == "**" || token == "??" || token == "|>" ||
    token == "=>"
}

fn token_end(source: Text, start: Int) -> Int {
    let symbols = chars(source)
    if start >= len(symbols) {
        return start
    }

    let first = symbols[start]
    if first == "\"" {
        return string_end(source, start)
    }

    let mut cursor = start + 1
    if identifier_start(first) {
        while cursor < len(symbols) && identifier_continue(symbols[cursor]) {
            cursor = cursor + 1
        }
        return cursor
    }

    if is_digit(first) {
        while cursor < len(symbols) &&
              (is_digit(symbols[cursor]) || symbols[cursor] == "_") {
            cursor = cursor + 1
        }
        return cursor
    }

    if cursor < len(symbols) {
        let pair = text_slice(source, start, cursor + 1)
        if pair_token(pair) {
            return cursor + 1
        }
    }
    return cursor
}

fn token_text(source: Text, start: Int) -> Text {
    let end = token_end(source, start)
    if end < 0 {
        return ""
    }
    return text_slice(source, start, end)
}

fn keyword(token: Text) -> Bool {
    return token == "fn" || token == "let" || token == "mut" ||
    token == "return" || token == "if" || token == "else" ||
    token == "while" || token == "for" || token == "in" ||
    token == "break" || token == "continue" || token == "true" ||
    token == "false" || token == "match" || token == "type"
}

fn token_kind(source: Text, start: Int) -> Text {
    let token = token_text(source, start)
    if len(token) == 0 {
        return "invalid"
    }
    let symbols = chars(token)
    if symbols[0] == "\"" {
        return "string"
    }
    if identifier_start(symbols[0]) {
        if keyword(token) {
            return "keyword"
        }
        return "identifier"
    }
    if is_digit(symbols[0]) {
        return "integer"
    }
    return "punctuation"
}

fn line_at(source: Text, target: Int) -> Int {
    let symbols = chars(source)
    let mut line = 1
    let mut cursor = 0
    while cursor < target && cursor < len(symbols) {
        if symbols[cursor] == "\n" {
            line = line + 1
        }
        cursor = cursor + 1
    }
    return line
}

fn lex(source: Text) -> Text {
    let mut tape = "kofun-token-tape/v1\n"
    let mut cursor = skip_trivia(source, 0)
    while cursor < len(source) {
        let end = token_end(source, cursor)
        if end <= cursor {
            return "error[E2S01]: unterminated string at byte " +
            to_text(cursor)
        }
        tape = tape + token_kind(source, cursor) + "|" +
        to_text(cursor) + "|" + to_text(end) + "|" +
        to_text(line_at(source, cursor)) + "\n"
        cursor = skip_trivia(source, end)
    }
    return tape
}

# General Pattern syntax is preserved independently from executable match
# semantics. Results use a one-line state header followed by post-order node
# records so the bootstrap subset does not need tuples or mutable globals.

fn pattern_depth_limit() -> Int {
    return 32
}

fn pattern_node_limit() -> Int {
    return 256
}

fn pattern_line_field(value: Text, line_start: Int, wanted: Int) -> Text {
    let symbols = chars(value)
    let mut cursor = line_start
    let mut field = 0
    let mut field_start = line_start
    while cursor < len(symbols) && symbols[cursor] != "\n" {
        if symbols[cursor] == "|" {
            if field == wanted {
                return text_slice(value, field_start, cursor)
            }
            field = field + 1
            field_start = cursor + 1
        }
        cursor = cursor + 1
    }
    if field == wanted {
        return text_slice(value, field_start, cursor)
    }
    return ""
}

fn pattern_result_field(result: Text, wanted: Int) -> Text {
    return pattern_line_field(result, 0, wanted)
}

fn pattern_result_records(result: Text) -> Text {
    let symbols = chars(result)
    let mut cursor = 0
    while cursor < len(symbols) && symbols[cursor] != "\n" {
        cursor = cursor + 1
    }
    if cursor >= len(symbols) {
        return ""
    }
    return text_slice(result, cursor + 1, len(result))
}

fn pattern_result(
    end: Int,
    root: Int,
    next_id: Int,
    nodes: Int,
    errors: Int,
    fatal: Bool,
    kind: Text,
    limit_id: Int,
    records: Text
) -> Text {
    let mut fatal_text = "0"
    if fatal {
        fatal_text = "1"
    }
    return to_text(end) + "|" + to_text(root) + "|" +
    to_text(next_id) + "|" + to_text(nodes) + "|" +
    to_text(errors) + "|" + fatal_text + "|" + kind + "|" +
    to_text(limit_id) + "\n" + records
}

fn pattern_result_int(result: Text, field: Int) -> Int {
    return decimal_value(pattern_result_field(result, field))
}

fn pattern_error_result(
    start: Int,
    end: Int,
    reason: Text,
    next_id: Int,
    nodes: Int,
    errors: Int,
    limit_id: Int,
    fatal: Bool
) -> Text {
    if nodes >= pattern_node_limit() {
        return pattern_result(
            end, -1, next_id, nodes, errors, true, "ErrorPattern",
            limit_id, ""
        )
    }
    let id = next_id
    let records = "node|" + to_text(id) + "|ErrorPattern|" +
    to_text(start) + "|" + to_text(end) + "|" + reason + "\n" +
    "pattern-diagnostic|E2S58|" + reason + "|" +
    to_text(start) + "|" + to_text(end) + "\n"
    return pattern_result(
        end, id, next_id + 1, nodes + 1, errors + 1, fatal,
        "ErrorPattern", limit_id, records
    )
}

fn pattern_limit_result(
    source: Text,
    start: Int,
    next_id: Int,
    nodes: Int,
    errors: Int,
    limit_id: Int
) -> Text {
    let end = token_end(source, start)
    if limit_id >= 0 {
        return pattern_result(
            end, limit_id, next_id, nodes, errors, true,
            "ErrorPattern", limit_id, ""
        )
    }
    let id = next_id
    let records = "node|" + to_text(id) + "|ErrorPattern|" +
    to_text(start) + "|" + to_text(end) + "|node-limit\n" +
    "pattern-diagnostic|E2S58|node-limit|" + to_text(start) +
    "|" + to_text(end) + "\n"
    return pattern_result(
        end, id, next_id + 1, nodes, errors + 1, true,
        "ErrorPattern", id, records
    )
}

fn pattern_stop_token(source: Text, start: Int) -> Bool {
    let token = token_text(source, start)
    return start >= len(source) || token == "=>" || token == "," ||
    token == ")" || token == "}" || token == "if"
}

fn pattern_recovery_end(source: Text, start: Int) -> Int {
    let mut cursor = skip_trivia(source, start)
    let mut parens = 0
    let mut brackets = 0
    while cursor < len(source) {
        let token = token_text(source, cursor)
        if token == "=>" {
            return cursor
        }
        if token == "{" && parens == 0 && brackets == 0 {
            return cursor
        }
        if token == "}" && parens == 0 && brackets == 0 {
            return cursor
        }
        if token == "," && parens == 0 && brackets == 0 {
            return cursor
        }
        if token == "(" {
            parens = parens + 1
        } else if token == ")" {
            if parens == 0 {
                return cursor
            }
            parens = parens - 1
        } else if token == "[" {
            brackets = brackets + 1
        } else if token == "]" {
            if brackets == 0 {
                return cursor
            }
            brackets = brackets - 1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return cursor
}

fn parse_pattern_or_result(
    source: Text,
    start: Int,
    depth: Int,
    next_id: Int,
    nodes: Int,
    errors: Int,
    limit_id: Int
) -> Text {
    let cursor = skip_trivia(source, start)
    let token = token_text(source, cursor)
    if token == "|" || token == "||" {
        let mut reason = "leading-or"
        if token == "||" {
            reason = "doubled-or"
        }
        return pattern_error_result(
            cursor, token_end(source, cursor), reason, next_id, nodes,
            errors, limit_id, false
        )
    }

    let first = parse_pattern_atomic_result(
        source, cursor, depth, next_id, nodes, errors, limit_id
    )
    if pattern_result_field(first, 5) == "1" {
        return first
    }
    let mut separator = skip_trivia(
        source,
        pattern_result_int(first, 0)
    )
    if token_text(source, separator) == "||" {
        return pattern_error_result(
            cursor, token_end(source, separator), "doubled-or",
            next_id, nodes, errors, limit_id, false
        )
    }
    if token_text(source, separator) != "|" {
        if token_text(source, separator) == ".." {
            let recovered = pattern_recovery_end(
                source,
                token_end(source, separator)
            )
            return pattern_error_result(
                cursor, recovered, "unsupported-range-pattern",
                next_id, nodes, errors, limit_id, false
            )
        }
        return first
    }

    let mut records = pattern_result_records(first)
    let mut children = pattern_result_field(first, 1)
    let mut current_next = pattern_result_int(first, 2)
    let mut current_nodes = pattern_result_int(first, 3)
    let mut current_errors = pattern_result_int(first, 4)
    let mut current_limit = pattern_result_int(first, 7)
    let mut alternatives = 1
    let mut end = pattern_result_int(first, 0)
    while separator < len(source) && token_text(source, separator) == "|" {
        records = records + "separator|OrPattern|" + to_text(cursor) +
        "|" + to_text(alternatives - 1) + "|" + to_text(separator) +
        "|" + to_text(token_end(source, separator)) + "\n"
        let next = skip_trivia(source, token_end(source, separator))
        if token_text(source, next) == "|" ||
           token_text(source, next) == "||" {
            return pattern_error_result(
                cursor, token_end(source, next), "doubled-or",
                next_id, nodes, errors, limit_id, false
            )
        }
        if pattern_stop_token(source, next) {
            return pattern_error_result(
                cursor, token_end(source, separator), "trailing-or",
                next_id, nodes, errors, limit_id, false
            )
        }
        let alternative = parse_pattern_atomic_result(
            source, next, depth, current_next, current_nodes,
            current_errors, current_limit
        )
        if pattern_result_field(alternative, 5) == "1" {
            return alternative
        }
        records = records + pattern_result_records(alternative)
        children = children + "," + pattern_result_field(alternative, 1)
        current_next = pattern_result_int(alternative, 2)
        current_nodes = pattern_result_int(alternative, 3)
        current_errors = pattern_result_int(alternative, 4)
        current_limit = pattern_result_int(alternative, 7)
        alternatives = alternatives + 1
        end = pattern_result_int(alternative, 0)
        separator = skip_trivia(source, end)
    }
    if token_text(source, separator) == "||" {
        return pattern_error_result(
            cursor, token_end(source, separator), "doubled-or",
            next_id, nodes, errors, limit_id, false
        )
    }
    if token_text(source, separator) == ".." {
        let recovered = pattern_recovery_end(
            source,
            token_end(source, separator)
        )
        return pattern_error_result(
            cursor, recovered, "unsupported-range-pattern",
            next_id, nodes, errors, limit_id, false
        )
    }
    if current_nodes >= pattern_node_limit() {
        return pattern_limit_result(
            source, cursor, current_next, current_nodes,
            current_errors, current_limit
        )
    }
    let id = current_next
    records = records + "node|" + to_text(id) + "|OrPattern|" +
    to_text(cursor) + "|" + to_text(end) + "|" +
    to_text(alternatives) + "|" + children + "\n"
    return pattern_result(
        end, id, current_next + 1, current_nodes + 1,
        current_errors, false, "OrPattern", current_limit, records
    )
}

fn parse_pattern_atomic_result(
    source: Text,
    start: Int,
    depth: Int,
    next_id: Int,
    nodes: Int,
    errors: Int,
    limit_id: Int
) -> Text {
    let cursor = skip_trivia(source, start)
    if nodes >= pattern_node_limit() {
        return pattern_limit_result(
            source, cursor, next_id, nodes, errors, limit_id
        )
    }
    if depth > pattern_depth_limit() {
        return pattern_error_result(
            cursor, pattern_recovery_end(source, cursor), "depth-limit",
            next_id, nodes, errors, limit_id, false
        )
    }
    let token = token_text(source, cursor)
    if cursor >= len(source) || pattern_stop_token(source, cursor) ||
       token == "|" {
        return pattern_error_result(
            cursor, token_end(source, cursor), "missing-pattern",
            next_id, nodes, errors, limit_id, false
        )
    }
    let token_finish = token_end(source, cursor)
    if token == "{" {
        let close = balanced_end(source, cursor, "{", "}")
        let mut end = close
        if close < 0 {
            end = pattern_recovery_end(source, cursor)
        }
        return pattern_error_result(
            cursor, end, "unsupported-record-pattern", next_id, nodes,
            errors, limit_id, false
        )
    }
    if token == "[" || token == ".." {
        let mut reason = "unsupported-pattern-token"
        if token == ".." {
            reason = "unsupported-rest-pattern"
        }
        return pattern_error_result(
            cursor, pattern_recovery_end(source, token_finish), reason,
            next_id, nodes, errors, limit_id, false
        )
    }

    if token == "(" {
        let inner = parse_pattern_or_result(
            source, skip_trivia(source, token_finish), depth + 1,
            next_id, nodes, errors, limit_id
        )
        if pattern_result_field(inner, 5) == "1" {
            return inner
        }
        let close = skip_trivia(source, pattern_result_int(inner, 0))
        if token_text(source, close) != ")" {
            return pattern_error_result(
                cursor, pattern_recovery_end(source, close),
                "missing-closing-parenthesis", next_id, nodes,
                errors, limit_id, false
            )
        }
        let current_nodes = pattern_result_int(inner, 3)
        let current_next = pattern_result_int(inner, 2)
        let current_errors = pattern_result_int(inner, 4)
        let current_limit = pattern_result_int(inner, 7)
        if current_nodes >= pattern_node_limit() {
            return pattern_limit_result(
                source, cursor, current_next, current_nodes,
                current_errors, current_limit
            )
        }
        let end = token_end(source, close)
        let id = current_next
        let records = pattern_result_records(inner) + "node|" +
        to_text(id) + "|ParenthesizedPattern|" + to_text(cursor) +
        "|" + to_text(end) + "|" + to_text(cursor) + "|" +
        to_text(token_finish) + "|" + to_text(close) + "|" +
        to_text(end) + "|" + pattern_result_field(inner, 1) + "\n"
        return pattern_result(
            end, id, current_next + 1, current_nodes + 1,
            current_errors, false, "ParenthesizedPattern",
            current_limit, records
        )
    }

    if token == "_" {
        let records = "node|" + to_text(next_id) +
        "|WildcardPattern|" + to_text(cursor) + "|" +
        to_text(token_finish) + "\n"
        return pattern_result(
            token_finish, next_id, next_id + 1, nodes + 1, errors,
            false, "WildcardPattern", limit_id, records
        )
    }
    if token == "true" || token == "false" || token == "null" ||
       token_kind(source, cursor) == "integer" {
        let mut literal_kind = "Bool"
        if token == "null" {
            literal_kind = "Null"
        } else if token_kind(source, cursor) == "integer" {
            literal_kind = "Int"
        }
        let records = "node|" + to_text(next_id) +
        "|LiteralPattern|" + to_text(cursor) + "|" +
        to_text(token_finish) + "|" + literal_kind + "|" + token + "|" +
        to_text(cursor) + "|" + to_text(token_finish) + "\n"
        return pattern_result(
            token_finish, next_id, next_id + 1, nodes + 1, errors,
            false, "LiteralPattern", limit_id, records
        )
    }
    if token_kind(source, cursor) != "identifier" {
        return pattern_error_result(
            cursor, pattern_recovery_end(source, token_finish),
            "unsupported-pattern-token", next_id, nodes, errors,
            limit_id, false
        )
    }

    let after_name = skip_trivia(source, token_finish)
    if token_text(source, after_name) == "{" {
        let close = balanced_end(source, after_name, "{", "}")
        let mut end = close
        if close < 0 {
            end = pattern_recovery_end(source, after_name)
        }
        return pattern_error_result(
            cursor, end, "unsupported-record-pattern", next_id, nodes,
            errors, limit_id, false
        )
    }
    if token_text(source, after_name) != "(" {
        let records = "node|" + to_text(next_id) + "|NamePattern|" +
        to_text(cursor) + "|" + to_text(token_finish) + "|" + token +
        "|" + to_text(cursor) + "|" + to_text(token_finish) + "\n"
        return pattern_result(
            token_finish, next_id, next_id + 1, nodes + 1, errors,
            false, "NamePattern", limit_id, records
        )
    }

    let open = after_name
    let mut payload = skip_trivia(source, token_end(source, open))
    if token_text(source, payload) == ")" {
        return pattern_error_result(
            cursor, token_end(source, payload), "empty-constructor-payload",
            next_id, nodes, errors, limit_id, false
        )
    }
    let mut records = ""
    let mut children = ""
    let mut payload_count = 0
    let mut close = -1
    let mut current_next = next_id
    let mut current_nodes = nodes
    let mut current_errors = errors
    let mut current_limit = limit_id
    while payload < len(source) && close < 0 {
        let child = parse_pattern_or_result(
            source, payload, depth + 1, current_next, current_nodes,
            current_errors, current_limit
        )
        if pattern_result_field(child, 5) == "1" {
            return child
        }
        records = records + pattern_result_records(child)
        if payload_count > 0 {
            children = children + ","
        }
        children = children + pattern_result_field(child, 1)
        current_next = pattern_result_int(child, 2)
        current_nodes = pattern_result_int(child, 3)
        current_errors = pattern_result_int(child, 4)
        current_limit = pattern_result_int(child, 7)
        payload_count = payload_count + 1
        let separator = skip_trivia(
            source,
            pattern_result_int(child, 0)
        )
        if token_text(source, separator) == "," {
            records = records + "delimiter|ConstructorPattern|" +
            to_text(cursor) + "|payload-comma|" +
            to_text(payload_count - 1) + "|" + to_text(separator) +
            "|" + to_text(token_end(source, separator)) + "\n"
            payload = skip_trivia(source, token_end(source, separator))
            if token_text(source, payload) == ")" {
                close = payload
            }
        } else if token_text(source, separator) == ")" {
            close = separator
        } else {
            let mut recovered = pattern_recovery_end(source, separator)
            if token_text(source, recovered) == ")" {
                recovered = token_end(source, recovered)
            }
            let mut reason = "missing-comma"
            if pattern_stop_token(source, separator) {
                reason = "missing-closing-parenthesis"
            }
            return pattern_error_result(
                cursor, recovered, reason, next_id, nodes,
                errors, limit_id, false
            )
        }
    }
    if close < 0 {
        return pattern_error_result(
            cursor, pattern_recovery_end(source, payload),
            "missing-closing-parenthesis", next_id, nodes, errors,
            limit_id, false
        )
    }
    if current_nodes >= pattern_node_limit() {
        return pattern_limit_result(
            source, cursor, current_next, current_nodes,
            current_errors, current_limit
        )
    }
    let end = token_end(source, close)
    let id = current_next
    records = records + "node|" + to_text(id) +
    "|ConstructorPattern|" + to_text(cursor) + "|" + to_text(end) +
    "|" + token + "|" + to_text(cursor) + "|" +
    to_text(token_finish) + "|" + to_text(open) + "|" +
    to_text(token_end(source, open)) + "|" + to_text(close) + "|" +
    to_text(end) + "|" + to_text(payload_count) + "|" + children + "\n"
    return pattern_result(
        end, id, current_next + 1, current_nodes + 1,
        current_errors, false, "ConstructorPattern", current_limit,
        records
    )
}

fn pattern_match_open(source: Text, match_start: Int) -> Int {
    let mut cursor = skip_trivia(source, token_end(source, match_start))
    let mut parens = 0
    let mut brackets = 0
    while cursor < len(source) {
        let token = token_text(source, cursor)
        if token == "(" {
            parens = parens + 1
        } else if token == ")" {
            if parens > 0 {
                parens = parens - 1
            }
        } else if token == "[" {
            brackets = brackets + 1
        } else if token == "]" {
            if brackets > 0 {
                brackets = brackets - 1
            }
        } else if token == "{" && parens == 0 && brackets == 0 {
            return cursor
        } else if token == "}" && parens == 0 && brackets == 0 {
            return -1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return -1
}

fn pattern_arm_arrow(source: Text, start: Int, match_close: Int) -> Int {
    let mut cursor = skip_trivia(source, start)
    let mut parens = 0
    let mut brackets = 0
    while cursor < match_close {
        let token = token_text(source, cursor)
        if token == "=>" {
            return cursor
        }
        if token == "," && parens == 0 && brackets == 0 {
            return -1
        }
        if token == "(" {
            parens = parens + 1
        } else if token == ")" {
            if parens > 0 {
                parens = parens - 1
            }
        } else if token == "[" {
            brackets = brackets + 1
        } else if token == "]" {
            if brackets > 0 {
                brackets = brackets - 1
            }
        } else if token == "{" && parens == 0 && brackets == 0 {
            return -1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return -1
}

fn parse_pattern_trees(source: Text) -> Text {
    let mut tree = "kofun-pattern-tree/v1\n" +
    "limits|depth|32|nodes-per-compilation|256\n"
    let mut cursor = skip_trivia(source, 0)
    let mut match_id = 0
    let mut next_id = 0
    let mut nodes = 0
    let mut errors = 0
    let mut limit_id = -1
    let mut budget_exhausted = false
    while cursor < len(source) && !budget_exhausted {
        if token_text(source, cursor) == "match" {
            let open = pattern_match_open(source, cursor)
            let mut match_end = -1
            if open >= 0 {
                match_end = balanced_end(source, open, "{", "}")
            }
            if open >= 0 && match_end >= 0 {
                let close = match_end - 1
                let mut arms = ""
                let mut arm_cursor = skip_trivia(
                    source,
                    token_end(source, open)
                )
                let mut arm_id = 0
                while arm_cursor < close &&
                      token_text(source, arm_cursor) != "}" {
                    let checkpoint_next = next_id
                    let checkpoint_nodes = nodes
                    let checkpoint_errors = errors
                    let checkpoint_limit = limit_id
                    let mut pattern = parse_pattern_or_result(
                        source, arm_cursor, 1, next_id, nodes,
                        errors, limit_id
                    )
                    let after_pattern = skip_trivia(
                        source,
                        pattern_result_int(pattern, 0)
                    )
                    if pattern_result_field(pattern, 5) != "1" &&
                       pattern_result_field(pattern, 6) != "ErrorPattern" &&
                       token_text(source, after_pattern) != "=>" &&
                       token_text(source, after_pattern) != "if" {
                        let recovered = pattern_recovery_end(
                            source,
                            after_pattern
                        )
                        pattern = pattern_error_result(
                            arm_cursor,
                            recovered,
                            "unexpected-token-after-pattern",
                            checkpoint_next,
                            checkpoint_nodes,
                            checkpoint_errors,
                            checkpoint_limit,
                            false
                        )
                    }
                    next_id = pattern_result_int(pattern, 2)
                    nodes = pattern_result_int(pattern, 3)
                    errors = pattern_result_int(pattern, 4)
                    limit_id = pattern_result_int(pattern, 7)
                    arms = arms + pattern_result_records(pattern)
                    let arrow = pattern_arm_arrow(
                        source,
                        pattern_result_int(pattern, 0),
                        close
                    )
                    let mut arrow_end = -1
                    if arrow >= 0 {
                        arrow_end = token_end(source, arrow)
                    }
                    arms = arms + "arm|" + to_text(match_id) + "|" +
                    to_text(arm_id) + "|" + pattern_result_field(pattern, 1) +
                    "|" + to_text(arm_cursor) + "|" +
                    pattern_result_field(pattern, 0) + "|" +
                    to_text(arrow) + "|" + to_text(arrow_end) + "\n"
                    arm_id = arm_id + 1
                    if pattern_result_field(pattern, 5) == "1" &&
                       pattern_result_int(pattern, 7) >= 0 {
                        budget_exhausted = true
                        arm_cursor = close
                    } else if arrow < 0 {
                        let recovery = skip_trivia(
                            source,
                            pattern_result_int(pattern, 0)
                        )
                        if recovery < close &&
                           token_text(source, recovery) == "," {
                            arm_cursor = skip_trivia(
                                source,
                                token_end(source, recovery)
                            )
                        } else {
                            arm_cursor = close
                        }
                    } else {
                        let body = skip_trivia(
                            source,
                            token_end(source, arrow)
                        )
                        if body >= close || token_text(source, body) != "{" {
                            arm_cursor = pattern_recovery_end(source, body)
                        } else {
                            let body_end = balanced_end(
                                source,
                                body,
                                "{",
                                "}"
                            )
                            if body_end < 0 {
                                arm_cursor = close
                            } else {
                                arm_cursor = skip_trivia(source, body_end)
                            }
                        }
                        if arm_cursor < close &&
                           token_text(source, arm_cursor) == "," {
                            arm_cursor = skip_trivia(
                                source,
                                token_end(source, arm_cursor)
                            )
                        }
                    }
                }
                tree = tree + "match|" + to_text(match_id) + "|" +
                to_text(cursor) + "|" + to_text(open) + "|" +
                to_text(token_end(source, open)) + "|" + to_text(close) +
                "|" + to_text(token_end(source, close)) + "|" +
                to_text(arm_id) + "\n" + arms
                match_id = match_id + 1
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return tree + "match-count|" + to_text(match_id) + "\n"
}

fn pattern_find_from(value: Text, wanted: Text, start: Int) -> Int {
    if len(wanted) == 0 {
        return start
    }
    let mut cursor = start
    while cursor + len(wanted) <= len(value) {
        if text_slice(value, cursor, cursor + len(wanted)) == wanted {
            return cursor
        }
        cursor = cursor + 1
    }
    return -1
}

fn pattern_first_error(tree: Text) -> Text {
    let mut search = 0
    let mut best_record = -1
    let mut best_start = -1
    while search < len(tree) {
        let record = pattern_find_from(
            tree,
            "pattern-diagnostic|",
            search
        )
        if record < 0 {
            search = len(tree)
        } else {
            let start = decimal_value(pattern_line_field(tree, record, 3))
            if best_start < 0 || start < best_start {
                best_record = record
                best_start = start
            }
            search = record + 1
        }
    }
    if best_record < 0 {
        return ""
    }
    return "error[E2S58]: invalid pattern (" +
    pattern_line_field(tree, best_record, 2) +
    ") at bytes " + pattern_line_field(tree, best_record, 3) + ".." +
    pattern_line_field(tree, best_record, 4)
}

fn pattern_summary(source: Text, start: Int) -> Text {
    let parsed = parse_pattern_or_result(source, start, 1, 0, 0, 0, -1)
    return pattern_result_field(parsed, 6) + "|" +
    pattern_result_field(parsed, 0)
}

fn pattern_summary_kind(summary: Text) -> Text {
    return pattern_line_field(summary, 0, 0)
}

fn pattern_summary_end(summary: Text) -> Int {
    return decimal_value(pattern_line_field(summary, 0, 1))
}

fn validate_executable_patterns(source: Text) -> Text {
    let mut cursor = skip_trivia(source, 0)
    while cursor < len(source) {
        if token_text(source, cursor) == "match" {
            let open = pattern_match_open(source, cursor)
            let mut match_end = -1
            if open >= 0 {
                match_end = balanced_end(source, open, "{", "}")
            }
            if open >= 0 && match_end >= 0 {
                let close = match_end - 1
                let mut arm = skip_trivia(source, token_end(source, open))
                while arm < close && token_text(source, arm) != "}" {
                    let summary = pattern_summary(source, arm)
                    let kind = pattern_summary_kind(summary)
                    let executable = kind == "WildcardPattern" ||
                    kind == "NamePattern" ||
                    (kind == "LiteralPattern" &&
                     (token_text(source, arm) == "true" ||
                      token_text(source, arm) == "false"))
                    if !executable {
                        return "error[E2S24]: general pattern syntax is parsed " +
                        "but not executable in Stage 2 Core at byte " +
                        to_text(arm)
                    }
                    let arrow = pattern_arm_arrow(
                        source,
                        pattern_summary_end(summary),
                        close
                    )
                    if arrow < 0 {
                        arm = close
                    } else {
                        let body = skip_trivia(
                            source,
                            token_end(source, arrow)
                        )
                        if body >= close || token_text(source, body) != "{" {
                            arm = close
                        } else {
                            let body_end = balanced_end(
                                source,
                                body,
                                "{",
                                "}"
                            )
                            if body_end < 0 {
                                arm = close
                            } else {
                                arm = skip_trivia(source, body_end)
                                if arm < close &&
                                   token_text(source, arm) == "," {
                                    arm = skip_trivia(
                                        source,
                                        token_end(source, arm)
                                    )
                                }
                            }
                        }
                    }
                }
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return "ok"
}

fn balanced_end(source: Text, start: Int, open: Text, close: Text) -> Int {
    let mut cursor = start
    let mut depth = 0
    while cursor < len(source) {
        cursor = skip_trivia(source, cursor)
        if cursor >= len(source) {
            return -1
        }
        let token = token_text(source, cursor)
        let end = token_end(source, cursor)
        if len(token) == 0 || end <= cursor {
            return -1
        }
        if token == open {
            depth = depth + 1
        } else if token == close {
            depth = depth - 1
            if depth == 0 {
                return end
            }
        }
        cursor = end
    }
    return -1
}

fn basic_visibility_modifier(source: Text, start: Int) -> Bool {
    let token = token_text(source, start)
    return token == "pub" || token == "internal" || token == "private"
}

fn visibility_word(source: Text, start: Int) -> Bool {
    let token = token_text(source, start)
    return basic_visibility_modifier(source, start) ||
    token == "public" || token == "protected"
}

fn visibility_prefix_candidate(source: Text, start: Int) -> Bool {
    if visibility_word(source, start) {
        return true
    }
    if token_kind(source, start) != "identifier" {
        return false
    }
    let next = skip_trivia(source, token_end(source, start))
    return token_text(source, next) == "fn"
}

fn function_declaration_start(source: Text, start: Int) -> Int {
    if token_text(source, start) == "fn" {
        return start
    }
    if !basic_visibility_modifier(source, start) {
        return -1
    }
    let after_modifier = skip_trivia(source, token_end(source, start))
    if after_modifier < len(source) &&
       token_text(source, after_modifier) == "fn" {
        return after_modifier
    }
    return -1
}

fn visibility_level(source: Text, start: Int) -> Text {
    if token_text(source, start) == "pub" {
        return "public"
    }
    if token_text(source, start) == "internal" {
        return "internal"
    }
    return "private"
}

fn visibility_prefix_error(source: Text, start: Int) -> Text {
    let modifier = token_text(source, start)
    if modifier == "public" || modifier == "protected" {
        return "error[E2S34]: unsupported visibility modifier `" +
        modifier + "`; use `pub`, `internal`, or `private` at bytes " +
        to_text(start) + ".." + to_text(token_end(source, start))
    }
    if !basic_visibility_modifier(source, start) {
        let next = skip_trivia(source, token_end(source, start))
        if token_kind(source, start) == "identifier" &&
           next < len(source) && token_text(source, next) == "fn" {
            return "error[E2S33]: unknown visibility modifier `" +
            modifier + "`; expected `pub`, `internal`, or `private` at bytes " +
            to_text(start) + ".." + to_text(token_end(source, start))
        }
        return ""
    }

    let next = skip_trivia(source, token_end(source, start))
    if next < len(source) && token_text(source, next) == "fn" {
        return ""
    }
    if next < len(source) && basic_visibility_modifier(source, next) {
        let second = token_text(source, next)
        let mut kind = "conflicting"
        if modifier == second {
            kind = "repeated"
        }
        return "error[E2S33]: " + kind + " visibility modifiers `" +
        modifier + "` and `" + second + "` at bytes " +
        to_text(start) + ".." + to_text(token_end(source, next))
    }
    if modifier == "pub" && next < len(source) &&
       token_text(source, next) == "(" {
        let mut form_end = balanced_end(source, next, "(", ")")
        if form_end < 0 {
            form_end = token_end(source, next)
        }
        let form_name = skip_trivia(source, token_end(source, next))
        let name = token_text(source, form_name)
        let mut form_kind = "restricted"
        if name == "crate" || name == "super" || name == "in" {
            form_kind = "Rust-style"
        }
        return "error[E2S34]: " + form_kind +
        " `pub(...)` visibility is not supported in this frontend slice at bytes " +
        to_text(start) + ".." + to_text(form_end)
    }
    return "error[E2S33]: visibility modifier `" + modifier +
    "` must be followed by a top-level `fn` declaration at bytes " +
    to_text(start) + ".." + to_text(token_end(source, start))
}

fn local_visibility_error(
    source: Text,
    function_start: Int,
    function_close: Int
) -> Text {
    let open = parameter_open(source, function_start)
    if open < 0 {
        return ""
    }
    let mut cursor = balanced_end(source, open, "(", ")")
    while cursor >= 0 && cursor < function_close &&
          token_text(source, cursor) != "{" {
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    if cursor < 0 || cursor >= function_close {
        return ""
    }
    cursor = skip_trivia(source, token_end(source, cursor))
    while cursor < function_close {
        let token = token_text(source, cursor)
        let basic = basic_visibility_modifier(source, cursor)
        let alias = token == "public" || token == "protected"
        if basic || alias {
            let next = skip_trivia(source, token_end(source, cursor))
            let next_token = token_text(source, next)
            let declaration_like = next < function_close &&
            (next_token == "fn" || next_token == "let" ||
             next_token == "var" || next_token == "type" ||
             basic_visibility_modifier(source, next))
            if declaration_like {
                let mut code = "E2S33"
                if alias {
                    code = "E2S34"
                }
                return "error[" + code + "]: visibility modifier `" +
                token + "` is not supported in local scope at bytes " +
                to_text(cursor) + ".." + to_text(token_end(source, cursor))
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return ""
}

fn function_name(source: Text, start: Int) -> Text {
    let after_fn = skip_trivia(source, token_end(source, start))
    if after_fn >= len(source) || token_kind(source, after_fn) != "identifier" {
        return ""
    }
    return token_text(source, after_fn)
}

fn parameter_open(source: Text, start: Int) -> Int {
    let after_fn = skip_trivia(source, token_end(source, start))
    let after_name = skip_trivia(source, token_end(source, after_fn))
    if after_name >= len(source) || token_text(source, after_name) != "(" {
        return -1
    }
    return after_name
}

fn parameter_count(source: Text, start: Int) -> Int {
    let open = parameter_open(source, start)
    if open < 0 {
        return -1
    }
    let close = balanced_end(source, open, "(", ")")
    if close < 0 {
        return -1
    }

    let mut cursor = skip_trivia(source, token_end(source, open))
    if cursor >= close || token_text(source, cursor) == ")" {
        return 0
    }

    let mut count = 1
    let mut paren_depth = 0
    let mut bracket_depth = 0
    while cursor < close {
        let token = token_text(source, cursor)
        if token == "(" {
            paren_depth = paren_depth + 1
        } else if token == ")" {
            if paren_depth == 0 {
                return count
            }
            paren_depth = paren_depth - 1
        } else if token == "[" {
            bracket_depth = bracket_depth + 1
        } else if token == "]" {
            bracket_depth = bracket_depth - 1
        } else if token == "," && paren_depth == 0 && bracket_depth == 0 {
            count = count + 1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return count
}

fn function_end(source: Text, start: Int) -> Int {
    if token_text(source, start) != "fn" || len(function_name(source, start)) == 0 {
        return -1
    }

    let open = parameter_open(source, start)
    if open < 0 {
        return -1
    }
    let parameters_end = balanced_end(source, open, "(", ")")
    if parameters_end < 0 {
        return -1
    }

    let mut cursor = skip_trivia(source, parameters_end)
    if cursor < len(source) && token_text(source, cursor) == "->" {
        cursor = skip_trivia(source, token_end(source, cursor))
        let mut type_tokens = 0
        while cursor < len(source) && token_text(source, cursor) != "{" {
            if token_text(source, cursor) == "=" {
                return -1
            }
            type_tokens = type_tokens + 1
            cursor = skip_trivia(source, token_end(source, cursor))
        }
        if type_tokens == 0 {
            return -1
        }
    }

    if cursor >= len(source) || token_text(source, cursor) != "{" {
        return -1
    }
    return balanced_end(source, cursor, "{", "}")
}

fn type_name(source: Text, start: Int) -> Text {
    let name = skip_trivia(source, token_end(source, start))
    if name >= len(source) || token_kind(source, name) != "identifier" {
        return ""
    }
    return token_text(source, name)
}

fn type_declaration_end(source: Text, start: Int) -> Int {
    if token_text(source, start) != "type" || len(type_name(source, start)) == 0 {
        return -1
    }
    let name = skip_trivia(source, token_end(source, start))
    let equals = skip_trivia(source, token_end(source, name))
    if equals >= len(source) || token_text(source, equals) != "=" {
        return -1
    }
    let mut pipe = skip_trivia(source, token_end(source, equals))
    let mut constructors = 0
    let mut last_end = -1
    while pipe < len(source) && token_text(source, pipe) == "|" {
        let constructor = skip_trivia(source, token_end(source, pipe))
        if constructor >= len(source) ||
           token_kind(source, constructor) != "identifier" {
            return -1
        }
        constructors = constructors + 1
        if constructors > 64 {
            return -2
        }
        last_end = token_end(source, constructor)
        pipe = skip_trivia(source, last_end)
        if pipe < len(source) && token_text(source, pipe) == "(" {
            let payload_end = balanced_end(source, pipe, "(", ")")
            if payload_end < 0 {
                return -1
            }
            last_end = payload_end
            pipe = skip_trivia(source, payload_end)
        }
    }
    if constructors == 0 {
        return -1
    }
    if pipe < len(source) && token_text(source, pipe) != "fn" &&
       token_text(source, pipe) != "type" &&
       !visibility_prefix_candidate(source, pipe) {
        return -1
    }
    return last_end
}

fn top_level_end(source: Text, start: Int) -> Int {
    if token_text(source, start) == "type" {
        return type_declaration_end(source, start)
    }
    let function_start = function_declaration_start(source, start)
    if function_start < 0 {
        return -1
    }
    return function_end(source, function_start)
}

fn after_optional_module_header(source: Text, start: Int) -> Int {
    let mut cursor = skip_trivia(source, start)
    if token_text(source, cursor) != "module" {
        return cursor
    }
    cursor = skip_trivia(source, token_end(source, cursor))
    while cursor < len(source) && token_text(source, cursor) != "type" &&
          token_text(source, cursor) != "fn" &&
          !visibility_prefix_candidate(source, cursor) {
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return cursor
}

fn next_function_start(source: Text, start: Int) -> Int {
    let mut cursor = after_optional_module_header(source, start)
    while cursor < len(source) && token_text(source, cursor) == "type" {
        let end = type_declaration_end(source, cursor)
        if end <= cursor {
            return len(source)
        }
        cursor = skip_trivia(source, end)
    }
    let function_start = function_declaration_start(source, cursor)
    if function_start < 0 {
        return cursor
    }
    return function_start
}

fn enum_declaration_start(source: Text, wanted: Text) -> Int {
    let mut cursor = after_optional_module_header(source, 0)
    while cursor < len(source) {
        if token_text(source, cursor) == "type" &&
           type_name(source, cursor) == wanted {
            return cursor
        }
        let end = top_level_end(source, cursor)
        if end <= cursor {
            return -1
        }
        cursor = skip_trivia(source, end)
    }
    return -1
}

fn enum_constructor_count(source: Text, enum_type: Text) -> Int {
    let declaration = enum_declaration_start(source, enum_type)
    if declaration < 0 {
        return -1
    }
    let name = skip_trivia(source, token_end(source, declaration))
    let equals = skip_trivia(source, token_end(source, name))
    let mut pipe = skip_trivia(source, token_end(source, equals))
    let end = type_declaration_end(source, declaration)
    let mut count = 0
    while pipe < end && token_text(source, pipe) == "|" {
        let constructor = skip_trivia(source, token_end(source, pipe))
        count = count + 1
        pipe = skip_trivia(source, token_end(source, constructor))
    }
    return count
}

fn enum_constructor_index(
    source: Text,
    enum_type: Text,
    wanted: Text
) -> Int {
    let declaration = enum_declaration_start(source, enum_type)
    if declaration < 0 {
        return -1
    }
    let name = skip_trivia(source, token_end(source, declaration))
    let equals = skip_trivia(source, token_end(source, name))
    let mut pipe = skip_trivia(source, token_end(source, equals))
    let end = type_declaration_end(source, declaration)
    let mut tag = 0
    while pipe < end && token_text(source, pipe) == "|" {
        let constructor = skip_trivia(source, token_end(source, pipe))
        if token_text(source, constructor) == wanted {
            return tag
        }
        tag = tag + 1
        pipe = skip_trivia(source, token_end(source, constructor))
    }
    return -1
}

fn enum_constructor_owner(source: Text, wanted: Text) -> Text {
    let mut cursor = skip_trivia(source, 0)
    while cursor < len(source) {
        if token_text(source, cursor) == "type" {
            let enum_type = type_name(source, cursor)
            if enum_constructor_index(source, enum_type, wanted) >= 0 {
                return enum_type
            }
        }
        let end = top_level_end(source, cursor)
        if end <= cursor {
            return ""
        }
        cursor = skip_trivia(source, end)
    }
    return ""
}

fn enum_declaration_names(source: Text, constructors: Bool) -> Text {
    let mut names = "|"
    let mut cursor = skip_trivia(source, 0)
    while cursor < len(source) {
        if token_text(source, cursor) == "type" {
            if constructors {
                let type_cursor = skip_trivia(
                    source,
                    token_end(source, cursor)
                )
                let equals = skip_trivia(
                    source,
                    token_end(source, type_cursor)
                )
                let mut pipe = skip_trivia(
                    source,
                    token_end(source, equals)
                )
                let end = type_declaration_end(source, cursor)
                while pipe < end && token_text(source, pipe) == "|" {
                    let constructor = skip_trivia(
                        source,
                        token_end(source, pipe)
                    )
                    names = names + token_text(source, constructor) + "|"
                    pipe = skip_trivia(
                        source,
                        token_end(source, constructor)
                    )
                }
            } else {
                names = names + type_name(source, cursor) + "|"
            }
        }
        let end = top_level_end(source, cursor)
        if end <= cursor {
            return names
        }
        cursor = skip_trivia(source, end)
    }
    return names
}

fn enum_constructors_covered(
    source: Text,
    enum_type: Text,
    covered: Text
) -> Bool {
    let declaration = enum_declaration_start(source, enum_type)
    if declaration < 0 {
        return false
    }
    let name = skip_trivia(source, token_end(source, declaration))
    let equals = skip_trivia(source, token_end(source, name))
    let mut pipe = skip_trivia(source, token_end(source, equals))
    let end = type_declaration_end(source, declaration)
    while pipe < end && token_text(source, pipe) == "|" {
        let constructor = skip_trivia(source, token_end(source, pipe))
        let constructor_name = token_text(source, constructor)
        if !contains(covered, "|" + constructor_name + "|") {
            return false
        }
        pipe = skip_trivia(source, token_end(source, constructor))
    }
    return true
}

fn enum_missing_constructors(
    source: Text,
    enum_type: Text,
    covered: Text
) -> Text {
    let declaration = enum_declaration_start(source, enum_type)
    let name = skip_trivia(source, token_end(source, declaration))
    let equals = skip_trivia(source, token_end(source, name))
    let mut pipe = skip_trivia(source, token_end(source, equals))
    let end = type_declaration_end(source, declaration)
    let mut missing = ""
    while pipe < end && token_text(source, pipe) == "|" {
        let constructor = skip_trivia(source, token_end(source, pipe))
        let constructor_name = token_text(source, constructor)
        if !contains(covered, "|" + constructor_name + "|") {
            if len(missing) > 0 {
                missing = missing + ", "
            }
            missing = missing + "`" + constructor_name + "`"
        }
        pipe = skip_trivia(source, token_end(source, constructor))
    }
    return missing
}

fn reserved_type_name(name: Text) -> Bool {
    return name == "Int" || name == "Bool" || name == "Float" ||
    name == "Unit" || name == "Text" || name == "List" || name == "_"
}

fn parse_program(source: Text) -> Text {
    let mut ir = "kofun-stage2-ir/v1\nsource-bytes|" +
    to_text(len(source)) + "\n"
    let mut cursor = skip_trivia(source, 0)
    let mut functions = 0
    let mut types = 0
    let mut declared_types = "|"
    let mut declared_constructors = "|"
    while cursor < len(source) {
        let visibility_error = visibility_prefix_error(source, cursor)
        if len(visibility_error) > 0 {
            return visibility_error
        }
        if token_text(source, cursor) == "type" {
            let name = type_name(source, cursor)
            let end = type_declaration_end(source, cursor)
            if end == -2 {
                return "error[E2S31]: concrete enum constructor limit is 64 at byte " +
                to_text(cursor)
            }
            if len(name) == 0 || end < 0 {
                return "error[E2S31]: malformed concrete enum declaration at byte " +
                to_text(cursor)
            }
            if reserved_type_name(name) {
                return "error[E2S31]: concrete enum cannot shadow built-in type `" +
                name + "` at byte " + to_text(cursor)
            }
            types = types + 1
            if types > 32 {
                return "error[E2S31]: concrete enum limit is 32 types at byte " +
                to_text(cursor)
            }
            if contains(declared_types, "|" + name + "|") {
                return "error[E2S31]: duplicate concrete enum type `" + name +
                "` at byte " + to_text(cursor)
            }
            if contains(declared_constructors, "|" + name + "|") {
                return "error[E2S31]: concrete enum type `" + name +
                "` conflicts with a constructor at byte " + to_text(cursor)
            }
            declared_types = declared_types + name + "|"
            let count = enum_constructor_count(source, name)
            if count < 1 {
                return "error[E2S31]: concrete enum must declare a constructor at byte " +
                to_text(cursor)
            }
            if count > 64 {
                return "error[E2S31]: concrete enum constructor limit is 64 at byte " +
                to_text(cursor)
            }
            ir = ir + "type|" + name + "|" + to_text(count) + "|" +
            to_text(cursor) + "|" + to_text(end) + "\n"
            let name_cursor = skip_trivia(source, token_end(source, cursor))
            let equals = skip_trivia(source, token_end(source, name_cursor))
            let mut pipe = skip_trivia(source, token_end(source, equals))
            let mut tag = 0
            while pipe < end && token_text(source, pipe) == "|" {
                let constructor = skip_trivia(source, token_end(source, pipe))
                let constructor_name = token_text(source, constructor)
                if constructor_name == "_" {
                    return "error[E2S31]: `_` is reserved for enum catch-all patterns at byte " +
                    to_text(constructor)
                }
                if contains(
                    declared_constructors,
                    "|" + constructor_name + "|"
                ) {
                    return "error[E2S31]: duplicate concrete enum constructor `" +
                    constructor_name + "` at byte " + to_text(constructor)
                }
                if contains(declared_types, "|" + constructor_name + "|") {
                    return "error[E2S31]: concrete enum constructor `" +
                    constructor_name + "` conflicts with an enum type at byte " +
                    to_text(constructor)
                }
                declared_constructors = declared_constructors +
                constructor_name + "|"
                ir = ir + "constructor|" + constructor_name + "|" +
                name + "|" + to_text(tag) + "|" +
                to_text(constructor) + "|" +
                to_text(token_end(source, constructor)) + "\n"
                tag = tag + 1
                pipe = skip_trivia(source, token_end(source, constructor))
            }
            cursor = skip_trivia(source, end)
        } else if function_declaration_start(source, cursor) < 0 {
            return "error[E2S02]: expected top-level `fn` or `type` at byte " +
            to_text(cursor)
        } else {
            let declaration_start = cursor
            let function_start = function_declaration_start(
                source,
                declaration_start
            )
            let name = function_name(source, function_start)
            let arity = parameter_count(source, function_start)
            let end = function_end(source, function_start)
            if len(name) == 0 || arity < 0 || end < 0 {
                return "error[E2S03]: malformed function at byte " +
                to_text(function_start)
            }
            let local_error = local_visibility_error(
                source,
                function_start,
                end
            )
            if len(local_error) > 0 {
                return local_error
            }
            let explicit_visibility = declaration_start != function_start
            let mut origin = "implicit"
            let mut modifier_start = -1
            let mut modifier_end = -1
            if explicit_visibility {
                origin = "explicit"
                modifier_start = declaration_start
                modifier_end = token_end(source, declaration_start)
            }
            ir = ir + "function|" + name + "|" + to_text(arity) + "|" +
            to_text(function_start) + "|" + to_text(end) + "|" +
            visibility_level(source, declaration_start) + "|" + origin + "|" +
            to_text(modifier_start) + "|" + to_text(modifier_end) + "|" +
            to_text(declaration_start) + "|" + to_text(end) +
            "|file:0|symbol:" + to_text(functions) + "\n"
            functions = functions + 1
            cursor = skip_trivia(source, end)
        }
    }
    if functions == 0 {
        return "error[E2S04]: compilation unit has no functions"
    }
    ir = ir + "function-count|" + to_text(functions) + "\n"
    let patterns = parse_pattern_trees(source)
    let pattern_error = pattern_first_error(patterns)
    if len(pattern_error) > 0 {
        return pattern_error
    }
    return ir + patterns
}

fn copy_type(type_name: Text) -> Bool {
    return type_name == "Int" || type_name == "Float" ||
    type_name == "Bool" || type_name == "Unit"
}

fn return_move_at(
    source: Text,
    body_open: Int,
    body_end: Int,
    element_name: Text
) -> Int {
    let mut cursor = skip_trivia(source, token_end(source, body_open))
    while cursor < body_end {
        if token_text(source, cursor) == "return" {
            let return_line = line_at(source, cursor)
            let mut value_cursor = skip_trivia(
                source,
                token_end(source, cursor)
            )
            while value_cursor < body_end &&
                  line_at(source, value_cursor) == return_line {
                if token_text(source, value_cursor) == element_name {
                    return value_cursor
                }
                value_cursor = skip_trivia(
                    source,
                    token_end(source, value_cursor)
                )
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return -1
}

fn borrowed_collection_check(source: Text) -> Text {
    let mut function_cursor = next_function_start(source, 0)
    let mut recognized_loops = 0
    while function_cursor < len(source) {
        let parameters_open = parameter_open(source, function_cursor)
        if parameters_open < 0 {
            return "error[E2S03]: malformed function"
        }
        let parameters_end = balanced_end(
            source,
            parameters_open,
            "(",
            ")"
        )
        if parameters_end < 0 {
            return "error[E2S03]: malformed parameters"
        }

        let mut borrowed_name = ""
        let mut element_type = ""
        let mut borrowed_lists = 0
        let mut parameter_cursor = skip_trivia(
            source,
            token_end(source, parameters_open)
        )
        while parameter_cursor < parameters_end &&
              token_text(source, parameter_cursor) != ")" {
            if token_text(source, parameter_cursor) == "read" {
                let name_cursor = skip_trivia(
                    source,
                    token_end(source, parameter_cursor)
                )
                let colon_cursor = skip_trivia(
                    source,
                    token_end(source, name_cursor)
                )
                let list_cursor = skip_trivia(
                    source,
                    token_end(source, colon_cursor)
                )
                let bracket_cursor = skip_trivia(
                    source,
                    token_end(source, list_cursor)
                )
                let element_cursor = skip_trivia(
                    source,
                    token_end(source, bracket_cursor)
                )
                if token_kind(source, name_cursor) == "identifier" &&
                   token_text(source, colon_cursor) == ":" &&
                   token_text(source, list_cursor) == "List" &&
                   token_text(source, bracket_cursor) == "[" &&
                   token_kind(source, element_cursor) == "identifier" {
                    borrowed_lists = borrowed_lists + 1
                    if borrowed_lists > 1 {
                        return "error[E2S21]: ownership slice supports one borrowed List parameter per function"
                    }
                    borrowed_name = token_text(source, name_cursor)
                    element_type = token_text(source, element_cursor)
                }
            }
            parameter_cursor = skip_trivia(
                source,
                token_end(source, parameter_cursor)
            )
        }

        let function_end_cursor = function_end(source, function_cursor)
        let mut body_open = skip_trivia(source, parameters_end)
        while body_open < function_end_cursor &&
              token_text(source, body_open) != "{" {
            body_open = skip_trivia(source, token_end(source, body_open))
        }
        if function_end_cursor < 0 || body_open >= function_end_cursor {
            return "error[E2S03]: malformed function body"
        }

        let mut cursor = skip_trivia(source, token_end(source, body_open))
        while cursor < function_end_cursor {
            if token_text(source, cursor) == "for" {
                let element_cursor = skip_trivia(
                    source,
                    token_end(source, cursor)
                )
                let in_cursor = skip_trivia(
                    source,
                    token_end(source, element_cursor)
                )
                let collection_cursor = skip_trivia(
                    source,
                    token_end(source, in_cursor)
                )
                let loop_open = skip_trivia(
                    source,
                    token_end(source, collection_cursor)
                )
                if token_kind(source, element_cursor) == "identifier" &&
                   token_text(source, in_cursor) == "in" &&
                   token_kind(source, collection_cursor) == "identifier" &&
                   token_text(source, loop_open) == "{" {
                    let loop_end = balanced_end(source, loop_open, "{", "}")
                    if loop_end < 0 {
                        return "error[E2S03]: malformed for body"
                    }
                    if len(borrowed_name) > 0 &&
                       token_text(source, collection_cursor) == borrowed_name {
                        recognized_loops = recognized_loops + 1
                        let element_name = token_text(source, element_cursor)
                        let move_at = return_move_at(
                            source,
                            loop_open,
                            loop_end,
                            element_name
                        )
                        if move_at >= 0 && !copy_type(element_type) {
                            return "error[E007]: cannot move non-Copy element `" +
                            element_name + ": " + element_type +
                            "` out of borrowed collection `" + borrowed_name +
                            "` at line " + to_text(line_at(source, move_at)) +
                            "; return a Copy scalar or clone the element"
                        }
                    }
                }
            }
            cursor = skip_trivia(source, token_end(source, cursor))
        }
        function_cursor = next_function_start(source, function_end_cursor)
    }
    if recognized_loops == 0 {
        return "error[E2S20]: Stage 2 ownership slice requires `for element in read_list`"
    }
    return "ok"
}

fn primary_end(source: Text, start: Int) -> Int {
    let cursor = skip_trivia(source, start)
    if cursor >= len(source) {
        return -1
    }
    let kind = token_kind(source, cursor)
    if kind == "integer" {
        return token_end(source, cursor)
    }
    if kind == "identifier" {
        let open = skip_trivia(source, token_end(source, cursor))
        if open >= len(source) || token_text(source, open) != "(" {
            return token_end(source, cursor)
        }
        let mut argument = skip_trivia(source, token_end(source, open))
        if argument < len(source) && token_text(source, argument) == ")" {
            return token_end(source, argument)
        }
        while argument < len(source) {
            let argument_end = expression_end(source, argument)
            if argument_end < 0 {
                return -1
            }
            let separator = skip_trivia(source, argument_end)
            if separator < len(source) &&
               token_text(source, separator) == ")" {
                return token_end(source, separator)
            }
            if separator >= len(source) ||
               token_text(source, separator) != "," {
                return -1
            }
            argument = skip_trivia(source, token_end(source, separator))
        }
        return -1
    }
    if token_text(source, cursor) == "(" {
        let value_start = skip_trivia(source, token_end(source, cursor))
        let value_end = expression_end(source, value_start)
        if value_end < 0 {
            return -1
        }
        let close = skip_trivia(source, value_end)
        if close >= len(source) || token_text(source, close) != ")" {
            return -1
        }
        return token_end(source, close)
    }
    return -1
}

fn unary_end(source: Text, start: Int) -> Int {
    let cursor = skip_trivia(source, start)
    let token = token_text(source, cursor)
    if token == "+" || token == "-" {
        return unary_end(source, skip_trivia(source, token_end(source, cursor)))
    }
    return primary_end(source, cursor)
}

fn product_end(source: Text, start: Int) -> Int {
    let mut cursor = unary_end(source, start)
    if cursor < 0 {
        return -1
    }
    let mut operator_start = skip_trivia(source, cursor)
    while operator_start < len(source) &&
          (token_text(source, operator_start) == "*" ||
           token_text(source, operator_start) == "//" ||
           token_text(source, operator_start) == "%") {
        let right_start = skip_trivia(
            source,
            token_end(source, operator_start)
        )
        cursor = unary_end(source, right_start)
        if cursor < 0 {
            return -1
        }
        operator_start = skip_trivia(source, cursor)
    }
    return cursor
}

fn expression_end(source: Text, start: Int) -> Int {
    let mut cursor = product_end(source, start)
    if cursor < 0 {
        return -1
    }
    let mut operator_start = skip_trivia(source, cursor)
    while operator_start < len(source) &&
          (token_text(source, operator_start) == "+" ||
           token_text(source, operator_start) == "-") {
        let right_start = skip_trivia(
            source,
            token_end(source, operator_start)
        )
        cursor = product_end(source, right_start)
        if cursor < 0 {
            return -1
        }
        operator_start = skip_trivia(source, cursor)
    }
    return cursor
}

fn emit_primary(source: Text, hir: Text, start: Int, end: Int) -> Text {
    let cursor = skip_trivia(source, start)
    let kind = token_kind(source, cursor)
    if kind == "integer" {
        return "INT64_C(" +
        replace(text_slice(source, cursor, end), "_", "") + ")"
    }
    if kind == "identifier" {
        let name = token_text(source, cursor)
        let open = skip_trivia(source, token_end(source, cursor))
        if open >= end || token_text(source, open) != "(" {
            return "k_b" + hir_use_binding_id(hir, cursor)
        }
        let mut emitted = "kofun_fn_" + name + "("
        let mut argument = skip_trivia(source, token_end(source, open))
        let mut arguments = 0
        while argument < end && token_text(source, argument) != ")" {
            let argument_end = expression_end(source, argument)
            if arguments > 0 {
                emitted = emitted + ", "
            }
            emitted = emitted +
            emit_expression(source, hir, argument, argument_end)
            arguments = arguments + 1
            let separator = skip_trivia(source, argument_end)
            if separator < end && token_text(source, separator) == "," {
                argument = skip_trivia(source, token_end(source, separator))
            } else {
                argument = separator
            }
        }
        return emitted + ")"
    }
    if token_text(source, cursor) == "(" {
        let value_start = skip_trivia(source, token_end(source, cursor))
        let close = skip_trivia(source, expression_end(source, value_start))
        return "(" + emit_expression(source, hir, value_start, close) + ")"
    }
    return ""
}

fn emit_unary(source: Text, hir: Text, start: Int, end: Int) -> Text {
    let cursor = skip_trivia(source, start)
    let token = token_text(source, cursor)
    if token == "+" {
        let value_start = skip_trivia(source, token_end(source, cursor))
        return emit_unary(source, hir, value_start, end)
    }
    if token == "-" {
        let value_start = skip_trivia(source, token_end(source, cursor))
        return "kofun_neg(" + emit_unary(source, hir, value_start, end) + ")"
    }
    return emit_primary(source, hir, cursor, end)
}

fn emit_product(source: Text, hir: Text, start: Int, end: Int) -> Text {
    let mut cursor = unary_end(source, start)
    let mut emitted = emit_unary(source, hir, start, cursor)
    let mut operator_start = skip_trivia(source, cursor)
    while operator_start < end {
        let operator = token_text(source, operator_start)
        let right_start = skip_trivia(
            source,
            token_end(source, operator_start)
        )
        let right_end = unary_end(source, right_start)
        let right = emit_unary(source, hir, right_start, right_end)
        if operator == "*" {
            emitted = "kofun_mul(" + emitted + ", " + right + ")"
        } else if operator == "//" {
            emitted = "kofun_floor_div(" + emitted + ", " + right + ")"
        } else if operator == "%" {
            emitted = "kofun_floor_mod(" + emitted + ", " + right + ")"
        }
        cursor = right_end
        operator_start = skip_trivia(source, cursor)
    }
    return emitted
}

fn emit_expression(source: Text, hir: Text, start: Int, end: Int) -> Text {
    let mut cursor = product_end(source, start)
    let mut emitted = emit_product(source, hir, start, cursor)
    let mut operator_start = skip_trivia(source, cursor)
    while operator_start < end {
        let operator = token_text(source, operator_start)
        let right_start = skip_trivia(
            source,
            token_end(source, operator_start)
        )
        let right_end = product_end(source, right_start)
        let right = emit_product(source, hir, right_start, right_end)
        if operator == "+" {
            emitted = "kofun_add(" + emitted + ", " + right + ")"
        } else if operator == "-" {
            emitted = "kofun_sub(" + emitted + ", " + right + ")"
        }
        cursor = right_end
        operator_start = skip_trivia(source, cursor)
    }
    return emitted
}

fn function_arity(source: Text, wanted: Text) -> Int {
    let mut cursor = next_function_start(source, 0)
    let mut found = -1
    while cursor < len(source) {
        if function_name(source, cursor) == wanted {
            if found >= 0 {
                return -2
            }
            found = parameter_count(source, cursor)
        }
        cursor = next_function_start(source, function_end(source, cursor))
    }
    return found
}

fn call_arity(source: Text, open: Int) -> Int {
    let mut cursor = skip_trivia(source, token_end(source, open))
    if cursor < len(source) && token_text(source, cursor) == ")" {
        return 0
    }
    let mut arity = 0
    while cursor < len(source) {
        let argument_end = expression_end(source, cursor)
        if argument_end < 0 {
            return -1
        }
        arity = arity + 1
        let separator = skip_trivia(source, argument_end)
        if separator < len(source) && token_text(source, separator) == ")" {
            return arity
        }
        if separator >= len(source) || token_text(source, separator) != "," {
            return -1
        }
        cursor = skip_trivia(source, token_end(source, separator))
    }
    return -1
}

fn validate_core_calls(source: Text) -> Text {
    let mut cursor = next_function_start(source, 0)
    let mut previous = ""
    while cursor < len(source) {
        if token_kind(source, cursor) == "identifier" {
            let name = token_text(source, cursor)
            let open = skip_trivia(source, token_end(source, cursor))
            if previous != "fn" && name != "print" &&
               open < len(source) && token_text(source, open) == "(" {
                let expected = function_arity(source, name)
                if expected == -2 {
                    return "error[E2S16]: duplicate Core function `" + name +
                    "` at byte " + to_text(cursor)
                }
                if expected < 0 {
                    return "error[E2S16]: unknown Core function `" + name +
                    "` at byte " + to_text(cursor)
                }
                let actual = call_arity(source, open)
                if actual != expected {
                    return "error[E2S17]: Core function `" + name +
                    "` expects " + to_text(expected) + " arguments, got " +
                    to_text(actual) + " at byte " + to_text(cursor)
                }
            }
        }
        previous = token_text(source, cursor)
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return "ok"
}

fn core_parameters(
    source: Text,
    hir: Text,
    function_start: Int
) -> Text {
    let parameters = parameter_open(source, function_start)
    if parameters < 0 {
        return "error[E2S15]: malformed Core parameter list"
    }
    let parameters_end = balanced_end(source, parameters, "(", ")")
    if parameters_end < 0 {
        return "error[E2S15]: malformed Core parameter list"
    }
    let mut cursor = skip_trivia(source, token_end(source, parameters))
    let mut emitted = ""
    let mut count = 0
    while cursor < parameters_end && token_text(source, cursor) != ")" {
        if token_kind(source, cursor) != "identifier" {
            return "error[E2S15]: expected Core parameter name at byte " +
            to_text(cursor)
        }
        let name = token_text(source, cursor)
        let colon = skip_trivia(source, token_end(source, cursor))
        let type_cursor = skip_trivia(source, token_end(source, colon))
        if colon >= parameters_end || token_text(source, colon) != ":" ||
           type_cursor >= parameters_end ||
           token_text(source, type_cursor) != "Int" {
            return "error[E2S15]: Core parameters must have type Int at byte " +
            to_text(cursor)
        }
        if count > 0 {
            emitted = emitted + ", "
        }
        emitted = emitted + "int64_t k_b" +
        hir_definition_id_at(hir, cursor)
        count = count + 1
        let separator = skip_trivia(source, token_end(source, type_cursor))
        if separator < parameters_end &&
           token_text(source, separator) == "," {
            cursor = skip_trivia(source, token_end(source, separator))
        } else {
            cursor = separator
        }
    }
    return emitted
}

fn comparison_operator(token: Text) -> Bool {
    return token == "==" || token == "!=" || token == "<" ||
    token == "<=" || token == ">" || token == ">="
}

fn condition_end(source: Text, start: Int) -> Int {
    let cursor = skip_trivia(source, start)
    let first = token_text(source, cursor)
    if first == "true" || first == "false" {
        return token_end(source, cursor)
    }
    let left_end = expression_end(source, cursor)
    if left_end < 0 {
        return -1
    }
    let operator_start = skip_trivia(source, left_end)
    if operator_start >= len(source) ||
       !comparison_operator(token_text(source, operator_start)) {
        return -1
    }
    let right_start = skip_trivia(
        source,
        token_end(source, operator_start)
    )
    return expression_end(source, right_start)
}

fn emit_condition_into(
    source: Text,
    hir: Text,
    start: Int,
    end: Int,
    target: Text,
    failure_result: Text,
    indent: Text
) -> Text {
    let cursor = skip_trivia(source, start)
    let first = token_text(source, cursor)
    if first == "true" || first == "false" {
        return indent + "bool " + target + " = " + first + ";\n"
    }
    let left_end = expression_end(source, cursor)
    let operator_start = skip_trivia(source, left_end)
    let right_start = skip_trivia(
        source,
        token_end(source, operator_start)
    )
    return indent + "int64_t kofun_condition_left = " +
    emit_expression(source, hir, cursor, left_end) + ";\n" +
    indent + "if (kofun_failed) return " + failure_result + ";\n" +
    indent + "int64_t kofun_condition_right = " +
    emit_expression(source, hir, right_start, end) + ";\n" +
    indent + "if (kofun_failed) return " + failure_result + ";\n" +
    indent + "bool " + target + " = kofun_condition_left " +
    token_text(source, operator_start) +
    " kofun_condition_right;\n"
}

fn value_if_branch_end(source: Text, start: Int) -> Int {
    return value_end(source, start)
}

fn value_if_end(source: Text, start: Int) -> Int {
    let condition_start = skip_trivia(source, token_end(source, start))
    let condition_close = condition_end(source, condition_start)
    let then_open = skip_trivia(source, condition_close)
    let then_start = skip_trivia(source, token_end(source, then_open))
    let then_end = value_if_branch_end(source, then_start)
    let then_close = skip_trivia(source, then_end)
    let else_keyword = skip_trivia(source, token_end(source, then_close))
    let else_open = skip_trivia(source, token_end(source, else_keyword))
    let else_start = skip_trivia(source, token_end(source, else_open))
    let else_end = value_if_branch_end(source, else_start)
    let else_close = skip_trivia(source, else_end)
    return token_end(source, else_close)
}

fn value_match_end(source: Text, start: Int) -> Int {
    let cursor = skip_trivia(source, start)
    let value_start = skip_trivia(source, token_end(source, cursor))
    let value_close = condition_end(source, value_start)
    if value_close < 0 {
        return -1
    }
    let arms_open = skip_trivia(source, value_close)
    if arms_open >= len(source) || token_text(source, arms_open) != "{" {
        return -1
    }
    return balanced_end(source, arms_open, "{", "}")
}

fn value_end(source: Text, start: Int) -> Int {
    let cursor = skip_trivia(source, start)
    let first = token_text(source, cursor)
    if first == "if" {
        return value_if_end(source, cursor)
    }
    if first == "match" {
        return value_match_end(source, cursor)
    }
    return expression_end(source, cursor)
}

fn validate_value_if(source: Text, start: Int) -> Text {
    let cursor = skip_trivia(source, start)
    if cursor >= len(source) || token_text(source, cursor) != "if" {
        return "error[E2S28]: expected value-position `if` at byte " +
        to_text(cursor)
    }
    let condition_start = skip_trivia(source, token_end(source, cursor))
    let condition_close = condition_end(source, condition_start)
    if condition_close < 0 {
        return "error[E2S23]: if condition must be Bool or an Int comparison at byte " +
        to_text(condition_start)
    }
    let then_open = skip_trivia(source, condition_close)
    if then_open >= len(source) || token_text(source, then_open) != "{" {
        return "error[E2S18]: expected `{` after if condition at byte " +
        to_text(then_open)
    }
    let then_start = skip_trivia(source, token_end(source, then_open))
    let mut then_end = -1
    if token_text(source, then_start) == "if" {
        let nested_result = validate_value_if(source, then_start)
        if starts_with(nested_result, "error[") {
            return nested_result
        }
        then_end = value_if_end(source, then_start)
    } else if token_text(source, then_start) == "match" {
        let nested_result = validate_value_match(source, then_start)
        if starts_with(nested_result, "error[") {
            return nested_result
        }
        then_end = value_match_end(source, then_start)
    } else {
        if token_text(source, then_start) == "print" {
            return "error[E2S28]: value-position if branch must produce Int, not Void at byte " +
            to_text(then_start)
        }
        then_end = expression_end(source, then_start)
        if then_end < 0 {
            return "error[E2S28]: value-position if branch must produce Int at byte " +
            to_text(then_start)
        }
    }
    let then_close = skip_trivia(source, then_end)
    if then_close >= len(source) || token_text(source, then_close) != "}" {
        return "error[E2S28]: value-position if branch must contain one final Int expression at byte " +
        to_text(then_close)
    }
    let else_keyword = skip_trivia(source, token_end(source, then_close))
    if else_keyword >= len(source) ||
       token_text(source, else_keyword) != "else" {
        return "error[E2S27]: value-position if requires `else` at byte " +
        to_text(else_keyword)
    }
    let else_open = skip_trivia(source, token_end(source, else_keyword))
    if else_open >= len(source) || token_text(source, else_open) != "{" {
        return "error[E2S18]: expected `{` after `else` at byte " +
        to_text(else_open)
    }
    let else_start = skip_trivia(source, token_end(source, else_open))
    let mut else_end = -1
    if token_text(source, else_start) == "if" {
        let nested_result = validate_value_if(source, else_start)
        if starts_with(nested_result, "error[") {
            return nested_result
        }
        else_end = value_if_end(source, else_start)
    } else if token_text(source, else_start) == "match" {
        let nested_result = validate_value_match(source, else_start)
        if starts_with(nested_result, "error[") {
            return nested_result
        }
        else_end = value_match_end(source, else_start)
    } else {
        if token_text(source, else_start) == "print" {
            return "error[E2S28]: value-position if branch must produce Int, not Void at byte " +
            to_text(else_start)
        }
        else_end = expression_end(source, else_start)
        if else_end < 0 {
            return "error[E2S28]: value-position if branch must produce Int at byte " +
            to_text(else_start)
        }
    }
    let else_close = skip_trivia(source, else_end)
    if else_close >= len(source) || token_text(source, else_close) != "}" {
        return "error[E2S28]: value-position if branch must contain one final Int expression at byte " +
        to_text(else_close)
    }
    return "ok"
}

fn validate_value_match(source: Text, start: Int) -> Text {
    let cursor = skip_trivia(source, start)
    if cursor >= len(source) || token_text(source, cursor) != "match" {
        return "error[E2S30]: expected value-position `match` at byte " +
        to_text(cursor)
    }
    let value_start = skip_trivia(source, token_end(source, cursor))
    let value_close = condition_end(source, value_start)
    if value_close < 0 {
        return "error[E2S24]: bounded match scrutinee must be Bool at byte " +
        to_text(value_start)
    }
    let arms_open = skip_trivia(source, value_close)
    if arms_open >= len(source) || token_text(source, arms_open) != "{" {
        return "error[E2S24]: expected `{` after match scrutinee at byte " +
        to_text(arms_open)
    }
    let mut arm_cursor = skip_trivia(source, token_end(source, arms_open))
    let mut covered_true = false
    let mut covered_false = false
    let mut seen_catchall = false
    while arm_cursor < len(source) && token_text(source, arm_cursor) != "}" {
        let pattern_start = arm_cursor
        let pattern_info = pattern_summary(source, pattern_start)
        let pattern_kind = pattern_summary_kind(pattern_info)
        let pattern = token_text(source, pattern_start)
        let pattern_true = pattern_kind == "LiteralPattern" &&
        pattern == "true"
        let pattern_false = pattern_kind == "LiteralPattern" &&
        pattern == "false"
        let pattern_catchall = pattern_kind == "WildcardPattern"
        if seen_catchall {
            return "error[E2S26]: pattern after catch-all is unreachable at byte " +
            to_text(pattern_start)
        }
        if pattern_true && covered_true {
            return "error[E2S26]: duplicate `true` pattern is unreachable at byte " +
            to_text(pattern_start)
        }
        if pattern_false && covered_false {
            return "error[E2S26]: duplicate `false` pattern is unreachable at byte " +
            to_text(pattern_start)
        }
        if pattern_catchall && covered_true && covered_false {
            return "error[E2S26]: catch-all pattern is unreachable at byte " +
            to_text(pattern_start)
        }
        if !pattern_true && !pattern_false && !pattern_catchall {
            return "error[E2S24]: bounded Bool pattern must be `true`, `false`, or `_` at byte " +
            to_text(pattern_start)
        }
        let after_pattern = skip_trivia(
            source,
            pattern_summary_end(pattern_info)
        )
        let mut guarded = false
        let mut arrow = after_pattern
        if arrow < len(source) && token_text(source, arrow) == "if" {
            guarded = true
            let guard_start = skip_trivia(source, token_end(source, arrow))
            let guard_end = condition_end(source, guard_start)
            if guard_end < 0 {
                return "error[E2S29]: match guard must be Bool or an Int comparison at byte " +
                to_text(guard_start)
            }
            arrow = skip_trivia(source, guard_end)
        }
        if arrow >= len(source) || token_text(source, arrow) != "=>" {
            return "error[E2S24]: expected `=>` after Bool pattern at byte " +
            to_text(arrow)
        }
        let arm_open = skip_trivia(source, token_end(source, arrow))
        if arm_open >= len(source) || token_text(source, arm_open) != "{" {
            return "error[E2S24]: bounded Bool match arm must use a block at byte " +
            to_text(arm_open)
        }
        let arm_start = skip_trivia(source, token_end(source, arm_open))
        let mut arm_end = -1
        if token_text(source, arm_start) == "if" {
            let arm_result = validate_value_if(source, arm_start)
            if starts_with(arm_result, "error[") {
                return arm_result
            }
            arm_end = value_if_end(source, arm_start)
        } else if token_text(source, arm_start) == "match" {
            let arm_result = validate_value_match(source, arm_start)
            if starts_with(arm_result, "error[") {
                return arm_result
            }
            arm_end = value_match_end(source, arm_start)
        } else {
            if token_text(source, arm_start) == "print" {
                return "error[E2S30]: value-position match arm must produce Int, not Void at byte " +
                to_text(arm_start)
            }
            arm_end = expression_end(source, arm_start)
            if arm_end < 0 {
                return "error[E2S30]: value-position match arm must produce Int at byte " +
                to_text(arm_start)
            }
        }
        let arm_close = skip_trivia(source, arm_end)
        if arm_close >= len(source) || token_text(source, arm_close) != "}" {
            return "error[E2S30]: value-position match arm must contain one final Int expression at byte " +
            to_text(arm_close)
        }
        if !guarded {
            if pattern_true {
                covered_true = true
            } else if pattern_false {
                covered_false = true
            } else {
                covered_true = true
                covered_false = true
                seen_catchall = true
            }
        }
        arm_cursor = skip_trivia(source, token_end(source, arm_close))
        if arm_cursor < len(source) && token_text(source, arm_cursor) == "," {
            arm_cursor = skip_trivia(source, token_end(source, arm_cursor))
        } else if arm_cursor >= len(source) ||
                  token_text(source, arm_cursor) != "}" {
            return "error[E2S24]: expected `,` between match arms at byte " +
            to_text(arm_cursor)
        }
    }
    if arm_cursor >= len(source) || token_text(source, arm_cursor) != "}" {
        return "error[E2S24]: missing `}` after match arms at byte " +
        to_text(arms_open)
    }
    if !covered_true && !covered_false {
        return "error[E2S25]: non-exhaustive Bool match; missing patterns `true`, `false` at byte " +
        to_text(cursor)
    }
    if !covered_true {
        return "error[E2S25]: non-exhaustive Bool match; missing pattern `true` at byte " +
        to_text(cursor)
    }
    if !covered_false {
        return "error[E2S25]: non-exhaustive Bool match; missing pattern `false` at byte " +
        to_text(cursor)
    }
    return "ok"
}

fn value_control(token: Text) -> Bool {
    return token == "if" || token == "match"
}

fn validate_value_control(source: Text, start: Int) -> Text {
    let cursor = skip_trivia(source, start)
    if token_text(source, cursor) == "if" {
        return validate_value_if(source, cursor)
    }
    return validate_value_match(source, cursor)
}

fn emit_value_into(
    source: Text,
    hir: Text,
    start: Int,
    end: Int,
    target: Text,
    failure_result: Text
) -> Text {
    let cursor = skip_trivia(source, start)
    if token_text(source, cursor) == "match" {
        return emit_value_match_into(
            source,
            hir,
            cursor,
            end,
            target,
            failure_result
        )
    }
    if token_text(source, cursor) != "if" {
        return "    " + target + " = " +
        emit_expression(source, hir, cursor, end) + ";\n" +
        "    if (kofun_failed) return " + failure_result + ";\n"
    }
    let condition_start = skip_trivia(source, token_end(source, cursor))
    let condition_close = condition_end(source, condition_start)
    let then_open = skip_trivia(source, condition_close)
    let then_start = skip_trivia(source, token_end(source, then_open))
    let then_end = value_if_branch_end(source, then_start)
    let then_close = skip_trivia(source, then_end)
    let else_keyword = skip_trivia(source, token_end(source, then_close))
    let else_open = skip_trivia(source, token_end(source, else_keyword))
    let else_start = skip_trivia(source, token_end(source, else_open))
    let else_end = value_if_branch_end(source, else_start)
    return "    {\n" +
    emit_condition_into(
        source,
        hir,
        condition_start,
        condition_close,
        "kofun_value_condition",
        failure_result,
        "        "
    ) +
    "        if (kofun_value_condition) {\n" +
    emit_value_into(
        source,
        hir,
        then_start,
        then_end,
        target,
        failure_result
    ) +
    "        } else {\n" +
    emit_value_into(
        source,
        hir,
        else_start,
        else_end,
        target,
        failure_result
    ) +
    "        }\n" +
    "    }\n"
}

fn emit_value_match_into(
    source: Text,
    hir: Text,
    start: Int,
    end: Int,
    target: Text,
    failure_result: Text
) -> Text {
    let cursor = skip_trivia(source, start)
    let value_start = skip_trivia(source, token_end(source, cursor))
    let value_close = condition_end(source, value_start)
    let arms_open = skip_trivia(source, value_close)
    let mut arm_cursor = skip_trivia(source, token_end(source, arms_open))
    let mut dispatch = ""
    while arm_cursor < end && token_text(source, arm_cursor) != "}" {
        let pattern_info = pattern_summary(source, arm_cursor)
        let pattern_kind = pattern_summary_kind(pattern_info)
        let pattern = token_text(source, arm_cursor)
        let pattern_true = pattern_kind == "LiteralPattern" &&
        pattern == "true"
        let pattern_false = pattern_kind == "LiteralPattern" &&
        pattern == "false"
        let mut arrow = skip_trivia(
            source,
            pattern_summary_end(pattern_info)
        )
        let mut guarded = false
        let mut guard_start = -1
        let mut guard_end = -1
        if arrow < end && token_text(source, arrow) == "if" {
            guarded = true
            guard_start = skip_trivia(source, token_end(source, arrow))
            guard_end = condition_end(source, guard_start)
            arrow = skip_trivia(source, guard_end)
        }
        let arm_open = skip_trivia(source, token_end(source, arrow))
        let arm_start = skip_trivia(source, token_end(source, arm_open))
        let arm_end = value_end(source, arm_start)
        let arm_close = skip_trivia(source, arm_end)
        let mut pattern_condition = "true"
        if pattern_true {
            pattern_condition = "kofun_match_value"
        } else if pattern_false {
            pattern_condition = "!kofun_match_value"
        }
        let arm_body = emit_value_into(
            source,
            hir,
            arm_start,
            arm_end,
            target,
            failure_result
        )
        if guarded {
            dispatch = dispatch +
            "        if (!kofun_match_selected && " +
            pattern_condition + ") {\n" +
            emit_condition_into(
                source,
                hir,
                guard_start,
                guard_end,
                "kofun_match_guard",
                failure_result,
                "            "
            ) +
            "            if (kofun_match_guard) {\n" +
            arm_body +
            "                kofun_match_selected = true;\n" +
            "            }\n" +
            "        }\n"
        } else {
            dispatch = dispatch +
            "        if (!kofun_match_selected && " +
            pattern_condition + ") {\n" +
            arm_body +
            "            kofun_match_selected = true;\n" +
            "        }\n"
        }
        arm_cursor = skip_trivia(source, token_end(source, arm_close))
        if arm_cursor < end && token_text(source, arm_cursor) == "," {
            arm_cursor = skip_trivia(source, token_end(source, arm_cursor))
        }
    }
    return "    {\n" +
    emit_condition_into(
        source,
        hir,
        value_start,
        value_close,
        "kofun_match_value",
        failure_result,
        "        "
    ) +
    "        (void)kofun_match_value;\n" +
    "        bool kofun_match_selected = false;\n" +
    dispatch +
    "    }\n"
}

fn core_body_open(
    source: Text,
    hir: Text,
    function_start: Int,
    is_main: Bool
) -> Int {
    let parameters = parameter_open(source, function_start)
    if parameters < 0 {
        return -1
    }
    let parameters_end = balanced_end(source, parameters, "(", ")")
    if parameters_end < 0 ||
       starts_with(core_parameters(source, hir, function_start), "error[") {
        return -1
    }
    let mut cursor = skip_trivia(source, parameters_end)
    if cursor < len(source) && token_text(source, cursor) == "->" {
        cursor = skip_trivia(source, token_end(source, cursor))
        if cursor >= len(source) || token_text(source, cursor) != "Int" {
            return -1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    } else if !is_main {
        return -1
    }
    if cursor >= len(source) || token_text(source, cursor) != "{" {
        return -1
    }
    return cursor
}

fn parent_block_open(
    source: Text,
    function_open: Int,
    child_open: Int
) -> Int {
    let mut cursor = function_open
    let mut parent = -1
    while cursor < child_open {
        if token_text(source, cursor) == "{" {
            let candidate_end = balanced_end(source, cursor, "{", "}")
            if candidate_end > child_open {
                parent = cursor
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return parent
}

fn scope_kind_for_open(
    source: Text,
    function_open: Int,
    wanted_open: Int
) -> Text {
    let mut cursor = function_open
    let mut previous = ""
    while cursor < wanted_open {
        if token_text(source, cursor) == "if" {
            let condition_start = skip_trivia(
                source,
                token_end(source, cursor)
            )
            let condition_close = condition_end(source, condition_start)
            if condition_close >= 0 &&
               skip_trivia(source, condition_close) == wanted_open {
                return "if-then"
            }
        }
        previous = token_text(source, cursor)
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    if previous == "else" {
        return "if-else"
    }
    if previous == "=>" {
        return "match-arm"
    }
    return "block"
}

fn enum_declaration_syntax_token(
    source: Text,
    function_open: Int,
    target: Int
) -> Bool {
    let mut cursor = skip_trivia(source, token_end(source, function_open))
    while cursor <= target {
        if token_text(source, cursor) == "let" {
            let mut name = skip_trivia(source, token_end(source, cursor))
            if token_text(source, name) == "mut" {
                name = skip_trivia(source, token_end(source, name))
            }
            if name == target {
                return true
            }
            let colon = skip_trivia(source, token_end(source, name))
            if token_text(source, colon) == ":" {
                let type_cursor = skip_trivia(
                    source,
                    token_end(source, colon)
                )
                if type_cursor == target {
                    return true
                }
                let equals = skip_trivia(
                    source,
                    token_end(source, type_cursor)
                )
                let initializer = skip_trivia(
                    source,
                    token_end(source, equals)
                )
                if initializer == target &&
                   token_text(source, equals) == "=" {
                    let enum_type = token_text(source, type_cursor)
                    if enum_constructor_count(source, enum_type) >= 0 {
                        return true
                    }
                }
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return false
}

fn enum_initializer_constructor_token(
    source: Text,
    function_open: Int,
    target: Int
) -> Bool {
    let mut cursor = skip_trivia(source, token_end(source, function_open))
    while cursor <= target {
        if token_text(source, cursor) == "let" {
            let mut name = skip_trivia(source, token_end(source, cursor))
            if token_text(source, name) == "mut" {
                name = skip_trivia(source, token_end(source, name))
            }
            let colon = skip_trivia(source, token_end(source, name))
            if token_text(source, colon) == ":" {
                let type_cursor = skip_trivia(
                    source,
                    token_end(source, colon)
                )
                let equals = skip_trivia(
                    source,
                    token_end(source, type_cursor)
                )
                let initializer = skip_trivia(
                    source,
                    token_end(source, equals)
                )
                if initializer == target && token_text(source, equals) == "=" {
                    let enum_type = token_text(source, type_cursor)
                    let constructor = token_text(source, initializer)
                    return enum_constructor_count(source, enum_type) >= 0 &&
                    len(enum_constructor_owner(source, constructor)) > 0
                }
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return false
}

fn enum_match_pattern_token(
    source: Text,
    function_open: Int,
    target: Int
) -> Bool {
    let mut cursor = skip_trivia(source, token_end(source, function_open))
    while cursor < target {
        if token_text(source, cursor) == "match" {
            let arms_open = pattern_match_open(source, cursor)
            if arms_open >= 0 && arms_open < target &&
               token_text(source, arms_open) == "{" {
                let match_end = balanced_end(source, arms_open, "{", "}")
                let match_close = match_end - 1
                let mut arm_cursor = skip_trivia(
                    source,
                    token_end(source, arms_open)
                )
                while match_end >= 0 && arm_cursor <= target &&
                      arm_cursor < match_close &&
                      token_text(source, arm_cursor) != "}" {
                    let pattern = pattern_summary(source, arm_cursor)
                    let pattern_end = pattern_summary_end(pattern)
                    if target >= arm_cursor && target < pattern_end {
                        return true
                    }
                    let arrow = pattern_arm_arrow(
                        source,
                        pattern_end,
                        match_close
                    )
                    if arm_cursor <= target &&
                       arrow >= 0 &&
                       token_text(source, arrow) == "=>" {
                        let arm_open = skip_trivia(
                            source,
                            token_end(source, arrow)
                        )
                        let arm_end = balanced_end(
                            source,
                            arm_open,
                            "{",
                            "}"
                        )
                        if arm_end < 0 {
                            arm_cursor = target + 1
                        } else if arm_end <= target {
                            arm_cursor = skip_trivia(source, arm_end)
                            if token_text(source, arm_cursor) == "," {
                                arm_cursor = skip_trivia(
                                    source,
                                    token_end(source, arm_cursor)
                                )
                            }
                        } else {
                            arm_cursor = target + 1
                        }
                    } else {
                        arm_cursor = target + 1
                    }
                }
            }
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return false
}

fn text_find_from(value: Text, wanted: Text, start: Int) -> Int {
    if len(wanted) == 0 {
        return start
    }
    let mut cursor = start
    while cursor + len(wanted) <= len(value) {
        if text_slice(value, cursor, cursor + len(wanted)) == wanted {
            return cursor
        }
        cursor = cursor + 1
    }
    return -1
}

fn decimal_value(value: Text) -> Int {
    let symbols = chars(value)
    let mut cursor = 0
    let mut sign = 1
    if len(symbols) > 0 && symbols[0] == "-" {
        sign = -1
        cursor = 1
    }
    let mut result = 0
    while cursor < len(symbols) {
        if !is_digit(symbols[cursor]) {
            return -1
        }
        result = result * 10 +
        text_find_from("0123456789", symbols[cursor], 0)
        cursor = cursor + 1
    }
    return result * sign
}

fn hir_record_start(
    hir: Text,
    kind: Text,
    start: Int
) -> Int {
    let found = text_find_from(hir, "\n" + kind + "|", start)
    if found < 0 {
        return -1
    }
    return found + 1
}

fn hir_field(hir: Text, line_start: Int, wanted: Int) -> Text {
    let symbols = chars(hir)
    let mut cursor = line_start
    let mut field = 0
    let mut field_start = line_start
    while cursor < len(symbols) {
        if symbols[cursor] == "|" || symbols[cursor] == "\n" {
            if field == wanted {
                return text_slice(hir, field_start, cursor)
            }
            if symbols[cursor] == "\n" {
                return ""
            }
            field = field + 1
            field_start = cursor + 1
        }
        cursor = cursor + 1
    }
    if field == wanted {
        return text_slice(hir, field_start, cursor)
    }
    return ""
}

fn hir_scope_id_for_open(hir: Text, open: Int) -> Text {
    let mut line = hir_record_start(hir, "scope", 0)
    while line >= 0 {
        if decimal_value(hir_field(hir, line, 4)) == open {
            return hir_field(hir, line, 1)
        }
        line = hir_record_start(hir, "scope", line + 1)
    }
    return ""
}

fn hir_scope_field(hir: Text, scope_id: Text, field: Int) -> Text {
    let mut line = hir_record_start(hir, "scope", 0)
    while line >= 0 {
        if hir_field(hir, line, 1) == scope_id {
            return hir_field(hir, line, field)
        }
        line = hir_record_start(hir, "scope", line + 1)
    }
    return ""
}

fn hir_binding_field(hir: Text, binding_id: Text, field: Int) -> Text {
    let mut line = hir_record_start(hir, "binding", 0)
    while line >= 0 {
        if hir_field(hir, line, 1) == binding_id {
            return hir_field(hir, line, field)
        }
        line = hir_record_start(hir, "binding", line + 1)
    }
    return ""
}

fn hir_same_scope_declaration(
    hir: Text,
    scope_id: Text,
    name: Text
) -> Text {
    let mut line = hir_record_start(hir, "binding", 0)
    while line >= 0 {
        if hir_field(hir, line, 2) == scope_id &&
           hir_field(hir, line, 3) == name {
            return hir_field(hir, line, 8)
        }
        line = hir_record_start(hir, "binding", line + 1)
    }
    return ""
}

fn hir_definition_id_at(hir: Text, declaration_start: Int) -> Text {
    let mut line = hir_record_start(hir, "binding", 0)
    while line >= 0 {
        if decimal_value(hir_field(hir, line, 8)) == declaration_start {
            return hir_field(hir, line, 1)
        }
        line = hir_record_start(hir, "binding", line + 1)
    }
    return ""
}

fn hir_use_binding_id(hir: Text, use_start: Int) -> Text {
    let mut line = hir_record_start(hir, "use", 0)
    while line >= 0 {
        if decimal_value(hir_field(hir, line, 1)) == use_start {
            return hir_field(hir, line, 4)
        }
        line = hir_record_start(hir, "use", line + 1)
    }
    return ""
}

fn hir_resolve_binding(
    hir: Text,
    current_scope: Text,
    use_start: Int,
    name: Text
) -> Text {
    let mut scope_id = current_scope
    while len(scope_id) > 0 && scope_id != "-1" {
        let mut resolved = ""
        let mut line = hir_record_start(hir, "binding", 0)
        while line >= 0 {
            if hir_field(hir, line, 2) == scope_id &&
               hir_field(hir, line, 3) == name &&
               decimal_value(hir_field(hir, line, 10)) <= use_start {
                resolved = hir_field(hir, line, 1)
            }
            line = hir_record_start(hir, "binding", line + 1)
        }
        if len(resolved) > 0 {
            return resolved
        }
        scope_id = hir_scope_field(hir, scope_id, 2)
    }
    return ""
}

fn hir_pending_declaration(
    hir: Text,
    current_scope: Text,
    use_start: Int,
    name: Text
) -> Text {
    let mut scope_id = current_scope
    while len(scope_id) > 0 && scope_id != "-1" {
        let mut line = hir_record_start(hir, "binding", 0)
        while line >= 0 {
            let declaration = decimal_value(hir_field(hir, line, 8))
            let visible = decimal_value(hir_field(hir, line, 10))
            if hir_field(hir, line, 2) == scope_id &&
               hir_field(hir, line, 3) == name &&
               declaration < use_start && use_start < visible {
                return to_text(declaration)
            }
            line = hir_record_start(hir, "binding", line + 1)
        }
        scope_id = hir_scope_field(hir, scope_id, 2)
    }
    return ""
}

fn hir_scope_root(hir: Text, start_scope: Text) -> Text {
    let mut scope_id = start_scope
    let mut parent = hir_scope_field(hir, scope_id, 2)
    while len(parent) > 0 && parent != "-1" {
        scope_id = parent
        parent = hir_scope_field(hir, scope_id, 2)
    }
    return scope_id
}

fn hir_any_declaration(
    hir: Text,
    current_scope: Text,
    use_start: Int,
    name: Text
) -> Text {
    let current_root = hir_scope_root(hir, current_scope)
    let mut line = hir_record_start(hir, "binding", 0)
    while line >= 0 {
        let binding_scope = hir_field(hir, line, 2)
        let declaration = decimal_value(hir_field(hir, line, 8))
        if hir_field(hir, line, 3) == name &&
           declaration < use_start &&
           hir_scope_root(hir, binding_scope) == current_root {
            return to_text(declaration)
        }
        line = hir_record_start(hir, "binding", line + 1)
    }
    return ""
}

fn scope_depth_for_open(
    source: Text,
    function_open: Int,
    wanted_open: Int
) -> Int {
    let mut cursor = function_open
    let mut depth = 0
    while cursor <= wanted_open {
        if token_text(source, cursor) == "{" {
            depth = depth + 1
            if cursor == wanted_open {
                return depth
            }
        } else if token_text(source, cursor) == "}" {
            depth = depth - 1
        }
        cursor = skip_trivia(source, token_end(source, cursor))
    }
    return -1
}

fn build_scope_hir_mode(
    source: Text,
    preserve_pattern_candidates: Bool
) -> Text {
    let mut hir = "kofun-scope-hir/v1\n"
    let mut next_scope_id = 0
    let mut next_binding_id = 0
    let mut function_start = next_function_start(source, 0)
    while function_start < len(source) {
        let function_close = function_end(source, function_start)
        let parameters = parameter_open(source, function_start)
        let parameters_close = balanced_end(source, parameters, "(", ")")
        let mut function_open = skip_trivia(source, parameters_close)
        while function_open < function_close &&
              token_text(source, function_open) != "{" {
            function_open = skip_trivia(
                source,
                token_end(source, function_open)
            )
        }
        let parameter_scope = next_scope_id
        next_scope_id = next_scope_id + 1
        let body_scope = next_scope_id
        next_scope_id = next_scope_id + 1
        let mut scope_count = 2
        hir = hir + "hir-function|" + to_text(function_start) + "|" +
        to_text(parameter_scope) + "|" + to_text(body_scope) + "\n" +
        "scope|" + to_text(parameter_scope) + "|-1|parameters|" +
        to_text(parameters) + "|" + to_text(parameters_close) + "|0\n" +
        "scope|" + to_text(body_scope) + "|" +
        to_text(parameter_scope) + "|function-body|" +
        to_text(function_open) + "|" + to_text(function_close) + "|1\n"

        let mut cursor = skip_trivia(
            source,
            token_end(source, function_open)
        )
        while cursor < function_close {
            if token_text(source, cursor) == "{" {
                let depth = scope_depth_for_open(
                    source,
                    function_open,
                    cursor
                )
                if depth > 32 {
                    return "error[E2S35]: lexical scope depth limit is 32 at byte " +
                    to_text(cursor)
                }
                scope_count = scope_count + 1
                if scope_count > 256 {
                    return "error[E2S35]: lexical scope limit is 256 per function at byte " +
                    to_text(cursor)
                }
                let parent_open = parent_block_open(
                    source,
                    function_open,
                    cursor
                )
                let parent_scope = hir_scope_id_for_open(hir, parent_open)
                let close = balanced_end(source, cursor, "{", "}")
                let scope_kind = scope_kind_for_open(
                    source,
                    function_open,
                    cursor
                )
                hir = hir + "scope|" + to_text(next_scope_id) + "|" +
                parent_scope + "|" + scope_kind + "|" +
                to_text(cursor) + "|" +
                to_text(close) + "|" + to_text(depth) + "\n"
                next_scope_id = next_scope_id + 1
            }
            cursor = skip_trivia(source, token_end(source, cursor))
        }

        let mut binding_count = 0
        let mut parameter_cursor = skip_trivia(
            source,
            token_end(source, parameters)
        )
        while parameter_cursor < parameters_close &&
              token_text(source, parameter_cursor) != ")" {
            let name = parameter_cursor
            let colon = skip_trivia(source, token_end(source, name))
            let type_cursor = skip_trivia(source, token_end(source, colon))
            let first_declaration = hir_same_scope_declaration(
                hir,
                to_text(parameter_scope),
                token_text(source, name)
            )
            if len(first_declaration) > 0 {
                return "error[E2S47]: duplicate binding `" +
                token_text(source, name) +
                "` in lexical scope at byte " + to_text(name) +
                "; first declaration at byte " + first_declaration
            }
            binding_count = binding_count + 1
            if binding_count > 256 {
                return "error[E2S35]: lexical binding limit is 256 per function at byte " +
                to_text(name)
            }
            hir = hir + "binding|" + to_text(next_binding_id) + "|" +
            to_text(parameter_scope) + "|" + token_text(source, name) +
            "|immutable|" + token_text(source, type_cursor) +
            "|copy|initialized|" + to_text(name) + "|" +
            to_text(token_end(source, name)) + "|" +
            to_text(token_end(source, name)) + "\n"
            next_binding_id = next_binding_id + 1
            let separator = skip_trivia(
                source,
                token_end(source, type_cursor)
            )
            if separator < parameters_close &&
               token_text(source, separator) == "," {
                parameter_cursor = skip_trivia(
                    source,
                    token_end(source, separator)
                )
            } else {
                parameter_cursor = separator
            }
        }

        cursor = skip_trivia(source, token_end(source, function_open))
        while cursor < function_close {
            if token_text(source, cursor) == "let" {
                let mut name = skip_trivia(source, token_end(source, cursor))
                let mut mutability = "immutable"
                if token_text(source, name) == "mut" {
                    mutability = "mutable"
                    name = skip_trivia(source, token_end(source, name))
                }
                let mut after_name = skip_trivia(
                    source,
                    token_end(source, name)
                )
                let mut binding_type = "Int"
                if token_text(source, after_name) == ":" {
                    let type_cursor = skip_trivia(
                        source,
                        token_end(source, after_name)
                    )
                    binding_type = token_text(source, type_cursor)
                    after_name = skip_trivia(
                        source,
                        token_end(source, type_cursor)
                    )
                }
                let initializer = skip_trivia(
                    source,
                    token_end(source, after_name)
                )
                let mut visible_start = value_end(source, initializer)
                if visible_start < 0 {
                    visible_start = token_end(source, initializer)
                }
                let scope_open = parent_block_open(
                    source,
                    function_open,
                    name
                )
                let scope_id = hir_scope_id_for_open(hir, scope_open)
                let first_declaration = hir_same_scope_declaration(
                    hir,
                    scope_id,
                    token_text(source, name)
                )
                if len(first_declaration) > 0 {
                    return "error[E2S47]: duplicate binding `" +
                    token_text(source, name) +
                    "` in lexical scope at byte " + to_text(name) +
                    "; first declaration at byte " + first_declaration
                }
                binding_count = binding_count + 1
                if binding_count > 256 {
                    return "error[E2S35]: lexical binding limit is 256 per function at byte " +
                    to_text(name)
                }
                let mut ownership = "copy"
                if binding_type == "Text" || binding_type == "List" {
                    ownership = "gc"
                }
                hir = hir + "binding|" + to_text(next_binding_id) + "|" +
                scope_id + "|" + token_text(source, name) + "|" +
                mutability + "|" + binding_type + "|" + ownership +
                "|initialized|" + to_text(name) + "|" +
                to_text(token_end(source, name)) + "|" +
                to_text(visible_start) + "\n"
                next_binding_id = next_binding_id + 1
            }
            cursor = skip_trivia(source, token_end(source, cursor))
        }

        let mut use_count = 0
        let mut unresolved_assignment = false
        cursor = skip_trivia(source, token_end(source, function_open))
        while cursor < function_close {
            if token_kind(source, cursor) == "identifier" {
                let name = token_text(source, cursor)
                let declaration_token = enum_declaration_syntax_token(
                    source,
                    function_open,
                    cursor
                )
                let initializer_token = enum_initializer_constructor_token(
                    source,
                    function_open,
                    cursor
                )
                let pattern_token = enum_match_pattern_token(
                    source,
                    function_open,
                    cursor
                )
                if !declaration_token && !initializer_token &&
                   !pattern_token && name != "print" && name != "_" {
                    let scope_open = parent_block_open(
                        source,
                        function_open,
                        cursor
                    )
                    let scope_id = hir_scope_id_for_open(hir, scope_open)
                    let binding_id = hir_resolve_binding(
                        hir,
                        scope_id,
                        cursor,
                        name
                    )
                    let after = skip_trivia(
                        source,
                        token_end(source, cursor)
                    )
                    let mut role = "read"
                    if token_text(source, after) == "=" {
                        role = "assign"
                    }
                    if len(binding_id) > 0 {
                        use_count = use_count + 1
                        if use_count > 256 {
                            return "error[E2S35]: lexical use limit is 256 per function at byte " +
                            to_text(cursor)
                        }
                        hir = hir + "use|" + to_text(cursor) + "|" +
                        to_text(token_end(source, cursor)) + "|" +
                        scope_id + "|" + binding_id + "|" + role + "\n"
                    } else if role == "assign" {
                        use_count = use_count + 1
                        if use_count > 256 {
                            return "error[E2S35]: lexical use limit is 256 per function at byte " +
                            to_text(cursor)
                        }
                        hir = hir + "use|" + to_text(cursor) + "|" +
                        to_text(token_end(source, cursor)) + "|" +
                        scope_id + "|-1|assign\n"
                        unresolved_assignment = true
                    } else if preserve_pattern_candidates &&
                              token_text(source, after) != "(" {
                        use_count = use_count + 1
                        if use_count > 256 {
                            return "error[E2S35]: lexical use limit is 256 per function at byte " +
                            to_text(cursor)
                        }
                        hir = hir + "candidate-use|" + to_text(cursor) + "|" +
                        to_text(token_end(source, cursor)) + "|" +
                        scope_id + "|" + name + "|" + role + "\n"
                    } else if token_text(source, after) != "(" &&
                              !unresolved_assignment {
                        let pending = hir_pending_declaration(
                            hir,
                            scope_id,
                            cursor,
                            name
                        )
                        if len(pending) > 0 {
                            return "error[E2S35]: binding `" + name +
                            "` is not initialized at byte " + to_text(cursor) +
                            "; declaration at byte " + pending
                        }
                        let escaped = hir_any_declaration(
                            hir,
                            scope_id,
                            cursor,
                            name
                        )
                        if len(escaped) > 0 {
                            return "error[E2S35]: binding `" + name +
                            "` is outside its lexical scope at byte " +
                            to_text(cursor) + "; declaration at byte " + escaped
                        }
                        if len(enum_constructor_owner(source, name)) == 0 {
                            return "error[E2S35]: unknown lexical binding `" +
                            name + "` at byte " + to_text(cursor)
                        }
                    }
                }
            }
            cursor = skip_trivia(source, token_end(source, cursor))
        }
        function_start = next_function_start(source, function_close)
    }
    return hir
}

fn build_scope_hir(source: Text) -> Text {
    return build_scope_hir_mode(source, false)
}

fn validate_enum_uses(source: Text, hir: Text) -> Text {
    let constructor_names = enum_declaration_names(source, true)
    if len(constructor_names) <= 1 {
        return "ok"
    }
    let mut function_start = next_function_start(source, 0)
    while function_start < len(source) {
        let function_close = function_end(source, function_start)
        let parameters = parameter_open(source, function_start)
        let parameters_close = balanced_end(source, parameters, "(", ")")
        let mut function_open = skip_trivia(source, parameters_close)
        while function_open < function_close &&
              token_text(source, function_open) != "{" {
            function_open = skip_trivia(
                source,
                token_end(source, function_open)
            )
        }
        let mut related_identifiers = 0
        let mut cursor = skip_trivia(source, token_end(source, function_open))
        let mut previous = ""
        while cursor < function_close {
            if token_kind(source, cursor) == "identifier" {
                let name = token_text(source, cursor)
                let pattern_token = enum_match_pattern_token(
                    source,
                    function_open,
                    cursor
                )
                let initializer_token = enum_initializer_constructor_token(
                    source,
                    function_open,
                    cursor
                )
                let declaration_token = enum_declaration_syntax_token(
                    source,
                    function_open,
                    cursor
                )
                let binding_id = hir_use_binding_id(hir, cursor)
                let binding_type = hir_binding_field(hir, binding_id, 5)
                let binding_enum = len(binding_type) > 0 &&
                enum_constructor_count(source, binding_type) >= 0
                let constructor_named = contains(
                    constructor_names,
                    "|" + name + "|"
                )
                let related = pattern_token || initializer_token ||
                binding_enum ||
                (constructor_named && len(binding_id) == 0 &&
                 !declaration_token)
                if related {
                    related_identifiers = related_identifiers + 1
                    if related_identifiers > 256 {
                        return "error[E2S32]: enum-related identifier use limit is 256 per function at byte " +
                        to_text(cursor)
                    }
                    if !pattern_token && !initializer_token &&
                       !declaration_token {
                        if binding_enum {
                            let after = skip_trivia(
                                source,
                                token_end(source, cursor)
                            )
                            let match_scrutinee = previous == "match" &&
                            token_text(source, after) == "{"
                            if !match_scrutinee {
                                return "error[E2S32]: concrete enum binding `" +
                                name +
                                "` is match-only in this Core slice at byte " +
                                to_text(cursor)
                            }
                        } else if constructor_named &&
                                  len(binding_id) == 0 {
                            let after = skip_trivia(
                                source,
                                token_end(source, cursor)
                            )
                            let resolved_function_call =
                            token_text(source, after) == "(" &&
                            function_arity(source, name) >= 0
                            if !resolved_function_call {
                                let constructor_owner = enum_constructor_owner(
                                    source,
                                    name
                                )
                                if len(constructor_owner) > 0 {
                                    return "error[E2S32]: concrete enum constructor `" +
                                    name +
                                    "` is only valid in an explicitly typed enum initializer or match pattern at byte " +
                                    to_text(cursor)
                                }
                            }
                        }
                    }
                }
            }
            previous = token_text(source, cursor)
            cursor = skip_trivia(source, token_end(source, cursor))
        }
        function_start = next_function_start(source, function_close)
    }
    return "ok"
}

fn enum_match_end(source: Text, start: Int) -> Int {
    let value_start = skip_trivia(source, token_end(source, start))
    let arms_open = skip_trivia(source, token_end(source, value_start))
    if arms_open >= len(source) || token_text(source, arms_open) != "{" {
        return -1
    }
    return balanced_end(source, arms_open, "{", "}")
}

fn lower_enum_match(
    source: Text,
    hir: Text,
    match_start: Int,
    enum_type: Text,
    is_main: Bool,
    function_open: Int
) -> Text {
    let value_start = skip_trivia(source, token_end(source, match_start))
    let value_name = token_text(source, value_start)
    let arms_open = skip_trivia(source, token_end(source, value_start))
    if arms_open >= len(source) || token_text(source, arms_open) != "{" {
        return "error[E2S24]: expected `{` after enum match scrutinee at byte " +
        to_text(arms_open)
    }
    let mut arm_cursor = skip_trivia(source, token_end(source, arms_open))
    let mut covered = "|"
    let mut seen_catchall = false
    let mut dispatch = ""
    let mut failure_result = "0"
    if is_main {
        failure_result = "1"
    }
    while arm_cursor < len(source) && token_text(source, arm_cursor) != "}" {
        let pattern_start = arm_cursor
        let pattern_info = pattern_summary(source, pattern_start)
        let pattern_kind = pattern_summary_kind(pattern_info)
        let pattern = token_text(source, pattern_start)
        let catchall = pattern_kind == "WildcardPattern"
        if seen_catchall {
            return "error[E2S26]: pattern after catch-all is unreachable at byte " +
            to_text(pattern_start)
        }
        let mut tag = -1
        if catchall {
            if enum_constructors_covered(source, enum_type, covered) {
                return "error[E2S26]: catch-all pattern is unreachable at byte " +
                to_text(pattern_start)
            }
        } else {
            if pattern_kind != "NamePattern" {
                return "error[E2S32]: enum pattern must name a constructor or `_` at byte " +
                to_text(pattern_start)
            }
            tag = enum_constructor_index(source, enum_type, pattern)
            if tag < 0 {
                return "error[E2S32]: constructor `" + pattern +
                "` does not belong to enum `" + enum_type + "` at byte " +
                to_text(pattern_start)
            }
            if contains(covered, "|" + pattern + "|") {
                return "error[E2S26]: duplicate enum constructor pattern `" +
                pattern + "` is unreachable at byte " +
                to_text(pattern_start)
            }
        }
        let after_pattern = skip_trivia(
            source,
            pattern_summary_end(pattern_info)
        )
        let mut guarded = false
        let mut guard_start = -1
        let mut guard_end = -1
        let mut arrow = after_pattern
        if arrow < len(source) && token_text(source, arrow) == "if" {
            guarded = true
            guard_start = skip_trivia(source, token_end(source, arrow))
            guard_end = condition_end(source, guard_start)
            if guard_end < 0 {
                return "error[E2S29]: match guard must be Bool or an Int comparison at byte " +
                to_text(guard_start)
            }
            arrow = skip_trivia(source, guard_end)
        }
        if arrow >= len(source) || token_text(source, arrow) != "=>" {
            return "error[E2S24]: expected `=>` after enum pattern at byte " +
            to_text(arrow)
        }
        let arm_open = skip_trivia(source, token_end(source, arrow))
        if arm_open >= len(source) || token_text(source, arm_open) != "{" {
            return "error[E2S24]: bounded enum match arm must use a block at byte " +
            to_text(arm_open)
        }
        let arm_close = balanced_end(source, arm_open, "{", "}")
        if arm_close < 0 {
            return "error[E2S24]: missing `}` after enum match arm at byte " +
            to_text(arm_open)
        }
        let arm_body = lower_body(
            source,
            hir,
            arm_open,
            is_main,
            false,
            function_open
        )
        if starts_with(arm_body, "error[") {
            return arm_body
        }
        let mut pattern_condition = "true"
        if !catchall {
            pattern_condition = "kofun_match_value == INT64_C(" +
            to_text(tag) + ")"
        }
        if guarded {
            dispatch = dispatch +
            "        if (!kofun_match_selected && " +
            pattern_condition + ") {\n" +
            emit_condition_into(
                source,
                hir,
                guard_start,
                guard_end,
                "kofun_match_guard",
                failure_result,
                "            "
            ) +
            "            if (kofun_match_guard) {\n" +
            arm_body +
            "                kofun_match_selected = true;\n" +
            "            }\n" +
            "        }\n"
        } else {
            dispatch = dispatch +
            "        if (!kofun_match_selected && " +
            pattern_condition + ") {\n" +
            arm_body +
            "            kofun_match_selected = true;\n" +
            "        }\n"
            if catchall {
                seen_catchall = true
            } else {
                covered = covered + pattern + "|"
            }
        }
        arm_cursor = skip_trivia(source, arm_close)
        if arm_cursor < len(source) && token_text(source, arm_cursor) == "," {
            arm_cursor = skip_trivia(source, token_end(source, arm_cursor))
        } else if arm_cursor >= len(source) ||
                  token_text(source, arm_cursor) != "}" {
            return "error[E2S24]: expected `,` between enum match arms at byte " +
            to_text(arm_cursor)
        }
    }
    if arm_cursor >= len(source) || token_text(source, arm_cursor) != "}" {
        return "error[E2S24]: missing `}` after enum match arms at byte " +
        to_text(arms_open)
    }
    if !seen_catchall &&
       !enum_constructors_covered(source, enum_type, covered) {
        return "error[E2S25]: non-exhaustive enum `" + enum_type +
        "` match; missing constructors " +
        enum_missing_constructors(source, enum_type, covered) +
        " at byte " + to_text(match_start)
    }
    return "    {\n" +
    "        int64_t kofun_match_value = k_b" +
    hir_use_binding_id(hir, value_start) + ";\n" +
    "        (void)kofun_match_value;\n" +
    "        bool kofun_match_selected = false;\n" +
    dispatch +
    "    }\n"
}

fn lower_body(
    source: Text,
    hir: Text,
    open: Int,
    is_main: Bool,
    append_default: Bool,
    function_open: Int
) -> Text {
    let mut emitted = ""
    let mut cursor = skip_trivia(source, token_end(source, open))
    let mut returned = false
    let mut failure_result = "0"
    if is_main {
        failure_result = "1"
    }
    while cursor < len(source) && token_text(source, cursor) != "}" {
        if returned {
            return "error[E2S14]: statement follows `return` at byte " +
            to_text(cursor)
        }
        let statement = token_text(source, cursor)
        if statement == "let" {
            cursor = skip_trivia(source, token_end(source, cursor))
            let mut mutable = false
            if cursor < len(source) && token_text(source, cursor) == "mut" {
                mutable = true
                cursor = skip_trivia(source, token_end(source, cursor))
            }
            if cursor >= len(source) ||
               token_kind(source, cursor) != "identifier" {
                return "error[E2S11]: expected binding name at byte " +
                to_text(cursor)
            }
            let name = token_text(source, cursor)
            let binding_id = hir_definition_id_at(hir, cursor)
            let storage = "k_b" + binding_id
            cursor = skip_trivia(source, token_end(source, cursor))
            let mut binding_type = "Int"
            if cursor < len(source) && token_text(source, cursor) == ":" {
                cursor = skip_trivia(source, token_end(source, cursor))
                if cursor >= len(source) ||
                   token_kind(source, cursor) != "identifier" {
                    return "error[E2S11]: expected Core binding type at byte " +
                    to_text(cursor)
                }
                binding_type = token_text(source, cursor)
                if binding_type != "Int" &&
                   enum_constructor_count(source, binding_type) < 0 {
                    return "error[E2S32]: unknown concrete enum type `" +
                    binding_type + "` at byte " + to_text(cursor)
                }
                cursor = skip_trivia(source, token_end(source, cursor))
            }
            if cursor >= len(source) || token_text(source, cursor) != "=" {
                return "error[E2S11]: expected `=` at byte " + to_text(cursor)
            }
            let value_start = skip_trivia(source, token_end(source, cursor))
            if binding_type != "Int" {
                if mutable {
                    return "error[E2S32]: concrete enum bindings are immutable in this Core slice at byte " +
                    to_text(value_start)
                }
                if token_kind(source, value_start) != "identifier" {
                    return "error[E2S32]: concrete enum initializer must name a constructor at byte " +
                    to_text(value_start)
                }
                let constructor = token_text(source, value_start)
                let tag = enum_constructor_index(
                    source,
                    binding_type,
                    constructor
                )
                if tag < 0 {
                    return "error[E2S32]: constructor `" + constructor +
                    "` does not belong to enum `" + binding_type +
                    "` at byte " + to_text(value_start)
                }
                emitted = emitted + "    int64_t " + storage +
                " = INT64_C(" + to_text(tag) + ");\n"
                cursor = skip_trivia(source, token_end(source, value_start))
            } else if value_control(token_text(source, value_start)) {
                let value_check = validate_value_control(source, value_start)
                if starts_with(value_check, "error[") {
                    return value_check
                }
                let value_end = value_end(source, value_start)
                emitted = emitted + "    int64_t " + storage +
                " = INT64_C(0);\n" +
                emit_value_into(
                    source,
                    hir,
                    value_start,
                    value_end,
                    storage,
                    failure_result
                )
                cursor = skip_trivia(source, value_end)
            } else {
                let value_end = expression_end(source, value_start)
                if value_end < 0 {
                    return "error[E2S12]: invalid Int expression at byte " +
                    to_text(value_start)
                }
                emitted = emitted + "    int64_t " + storage + " = " +
                emit_expression(source, hir, value_start, value_end) + ";\n" +
                "    if (kofun_failed) return " + failure_result + ";\n"
                cursor = skip_trivia(source, value_end)
            }
        } else if statement == "print" {
            let call_open = skip_trivia(source, token_end(source, cursor))
            if call_open >= len(source) ||
               token_text(source, call_open) != "(" {
                return "error[E2S13]: expected `print(` at byte " +
                to_text(cursor)
            }
            let value_start = skip_trivia(source, token_end(source, call_open))
            if value_control(token_text(source, value_start)) {
                let value_check = validate_value_control(source, value_start)
                if starts_with(value_check, "error[") {
                    return value_check
                }
                let value_end = value_end(source, value_start)
                let call_close = skip_trivia(source, value_end)
                if call_close >= len(source) ||
                   token_text(source, call_close) != ")" {
                    return "error[E2S13]: expected `)` at byte " +
                    to_text(call_close)
                }
                emitted = emitted +
                "    {\n" +
                "        int64_t kofun_value = INT64_C(0);\n" +
                emit_value_into(
                    source,
                    hir,
                    value_start,
                    value_end,
                    "kofun_value",
                    failure_result
                ) +
                "        printf(\"%\" PRId64 \"\\n\", kofun_value);\n" +
                "    }\n"
                cursor = skip_trivia(source, token_end(source, call_close))
            } else {
                let value_end = expression_end(source, value_start)
                if value_end < 0 {
                    return "error[E2S12]: invalid Int expression at byte " +
                    to_text(value_start)
                }
                let call_close = skip_trivia(source, value_end)
                if call_close >= len(source) ||
                   token_text(source, call_close) != ")" {
                    return "error[E2S13]: expected `)` at byte " +
                    to_text(call_close)
                }
                emitted = emitted +
                "    {\n" +
                "        int64_t kofun_value = " +
                emit_expression(source, hir, value_start, value_end) + ";\n" +
                "        if (kofun_failed) return " + failure_result + ";\n" +
                "        printf(\"%\" PRId64 \"\\n\", kofun_value);\n" +
                "    }\n"
                cursor = skip_trivia(source, token_end(source, call_close))
            }
        } else if statement == "if" {
            let condition_start = skip_trivia(
                source,
                token_end(source, cursor)
            )
            let condition_close = condition_end(source, condition_start)
            if condition_close < 0 {
                return "error[E2S23]: if condition must be Bool or an Int comparison at byte " +
                to_text(condition_start)
            }
            let branch_open = skip_trivia(source, condition_close)
            if branch_open >= len(source) ||
               token_text(source, branch_open) != "{" {
                return "error[E2S18]: expected `{` after if condition at byte " +
                to_text(branch_open)
            }
            let branch_close = balanced_end(source, branch_open, "{", "}")
            if branch_close < 0 {
                return "error[E2S18]: missing `}` after if branch at byte " +
                to_text(branch_open)
            }
            let branch_body = lower_body(
                source,
                hir,
                branch_open,
                is_main,
                false,
                function_open
            )
            if starts_with(branch_body, "error[") {
                return branch_body
            }
            emitted = emitted +
            "    {\n" +
            emit_condition_into(
                source,
                hir,
                condition_start,
                condition_close,
                "kofun_condition",
                failure_result,
                "        "
            ) +
            "        if (kofun_condition) {\n" +
            branch_body +
            "        }"
            cursor = skip_trivia(source, branch_close)
            if cursor < len(source) && token_text(source, cursor) == "else" {
                let else_open = skip_trivia(
                    source,
                    token_end(source, cursor)
                )
                if else_open >= len(source) ||
                   token_text(source, else_open) != "{" {
                    return "error[E2S18]: expected `{` after `else` at byte " +
                    to_text(else_open)
                }
                let else_close = balanced_end(source, else_open, "{", "}")
                if else_close < 0 {
                    return "error[E2S18]: missing `}` after else branch at byte " +
                    to_text(else_open)
                }
                let else_body = lower_body(
                    source,
                    hir,
                    else_open,
                    is_main,
                    false,
                    function_open
                )
                if starts_with(else_body, "error[") {
                    return else_body
                }
                emitted = emitted + " else {\n" + else_body + "        }"
                cursor = skip_trivia(source, else_close)
            }
            emitted = emitted + "\n    }\n"
        } else if statement == "match" {
            let match_start = cursor
            let value_start = skip_trivia(
                source,
                token_end(source, cursor)
            )
            let direct_end = skip_trivia(
                source,
                token_end(source, value_start)
            )
            if token_kind(source, value_start) == "identifier" &&
               direct_end < len(source) &&
               token_text(source, direct_end) == "{" {
                let value_name = token_text(source, value_start)
                let enum_binding = hir_use_binding_id(hir, value_start)
                let enum_type = hir_binding_field(hir, enum_binding, 5)
                if len(enum_type) == 0 || enum_type == "Int" ||
                   enum_constructor_count(source, enum_type) < 0 {
                    return "error[E2S32]: enum match scrutinee `" +
                    value_name +
                    "` must be a preceding explicitly typed enum binding at byte " +
                    to_text(value_start)
                }
                let match_body = lower_enum_match(
                    source,
                    hir,
                    match_start,
                    enum_type,
                    is_main,
                    function_open
                )
                if starts_with(match_body, "error[") {
                    return match_body
                }
                emitted = emitted + match_body
                let match_end = enum_match_end(source, match_start)
                cursor = skip_trivia(source, match_end)
            } else {
            let value_end = condition_end(source, value_start)
            if value_end < 0 {
                return "error[E2S24]: bounded match scrutinee must be Bool at byte " +
                to_text(value_start)
            }
            let arms_open = skip_trivia(source, value_end)
            if arms_open >= len(source) ||
               token_text(source, arms_open) != "{" {
                return "error[E2S24]: expected `{` after match scrutinee at byte " +
                to_text(arms_open)
            }
            let mut arm_cursor = skip_trivia(
                source,
                token_end(source, arms_open)
            )
            let mut covered_true = false
            let mut covered_false = false
            let mut seen_catchall = false
            let mut dispatch = ""
            while arm_cursor < len(source) &&
                  token_text(source, arm_cursor) != "}" {
                let pattern_start = arm_cursor
                let pattern_info = pattern_summary(source, pattern_start)
                let pattern_kind = pattern_summary_kind(pattern_info)
                let pattern = token_text(source, pattern_start)
                let pattern_true = pattern_kind == "LiteralPattern" &&
                pattern == "true"
                let pattern_false = pattern_kind == "LiteralPattern" &&
                pattern == "false"
                let pattern_catchall = pattern_kind == "WildcardPattern"
                if seen_catchall {
                    return "error[E2S26]: pattern after catch-all is unreachable at byte " +
                    to_text(pattern_start)
                }
                if pattern_true && covered_true {
                    return "error[E2S26]: duplicate `true` pattern is unreachable at byte " +
                    to_text(pattern_start)
                }
                if pattern_false && covered_false {
                    return "error[E2S26]: duplicate `false` pattern is unreachable at byte " +
                    to_text(pattern_start)
                }
                if pattern_catchall && covered_true && covered_false {
                    return "error[E2S26]: catch-all pattern is unreachable at byte " +
                    to_text(pattern_start)
                }
                if !pattern_true && !pattern_false && !pattern_catchall {
                    return "error[E2S24]: bounded Bool pattern must be `true`, `false`, or `_` at byte " +
                    to_text(pattern_start)
                }
                let after_pattern = skip_trivia(
                    source,
                    pattern_summary_end(pattern_info)
                )
                let mut guarded = false
                let mut guard_start = -1
                let mut guard_end = -1
                let mut arrow = after_pattern
                if arrow < len(source) &&
                   token_text(source, arrow) == "if" {
                    guarded = true
                    guard_start = skip_trivia(
                        source,
                        token_end(source, arrow)
                    )
                    guard_end = condition_end(source, guard_start)
                    if guard_end < 0 {
                        return "error[E2S29]: match guard must be Bool or an Int comparison at byte " +
                        to_text(guard_start)
                    }
                    arrow = skip_trivia(source, guard_end)
                }
                if arrow >= len(source) ||
                   token_text(source, arrow) != "=>" {
                    return "error[E2S24]: expected `=>` after Bool pattern at byte " +
                    to_text(arrow)
                }
                let arm_open = skip_trivia(
                    source,
                    token_end(source, arrow)
                )
                if arm_open >= len(source) ||
                   token_text(source, arm_open) != "{" {
                    return "error[E2S24]: bounded Bool match arm must use a block at byte " +
                    to_text(arm_open)
                }
                let arm_close = balanced_end(source, arm_open, "{", "}")
                if arm_close < 0 {
                    return "error[E2S24]: missing `}` after match arm at byte " +
                    to_text(arm_open)
                }
                let arm_body = lower_body(
                    source,
                    hir,
                    arm_open,
                    is_main,
                    false,
                    function_open
                )
                if starts_with(arm_body, "error[") {
                    return arm_body
                }

                let mut pattern_condition = "true"
                if pattern_true {
                    pattern_condition = "kofun_match_value"
                } else if pattern_false {
                    pattern_condition = "!kofun_match_value"
                }
                if guarded {
                    dispatch = dispatch +
                    "        if (!kofun_match_selected && " +
                    pattern_condition + ") {\n" +
                    emit_condition_into(
                        source,
                        hir,
                        guard_start,
                        guard_end,
                        "kofun_match_guard",
                        failure_result,
                        "            "
                    ) +
                    "            if (kofun_match_guard) {\n" +
                    arm_body +
                    "                kofun_match_selected = true;\n" +
                    "            }\n" +
                    "        }\n"
                } else {
                    dispatch = dispatch +
                    "        if (!kofun_match_selected && " +
                    pattern_condition + ") {\n" +
                    arm_body +
                    "            kofun_match_selected = true;\n" +
                    "        }\n"
                    if pattern_true {
                        covered_true = true
                    } else if pattern_false {
                        covered_false = true
                    } else {
                        covered_true = true
                        covered_false = true
                        seen_catchall = true
                    }
                }
                arm_cursor = skip_trivia(source, arm_close)
                if arm_cursor < len(source) &&
                   token_text(source, arm_cursor) == "," {
                    arm_cursor = skip_trivia(
                        source,
                        token_end(source, arm_cursor)
                    )
                } else if arm_cursor >= len(source) ||
                          token_text(source, arm_cursor) != "}" {
                    return "error[E2S24]: expected `,` between match arms at byte " +
                    to_text(arm_cursor)
                }
            }
            if arm_cursor >= len(source) ||
               token_text(source, arm_cursor) != "}" {
                return "error[E2S24]: missing `}` after match arms at byte " +
                to_text(arms_open)
            }
            if !covered_true && !covered_false {
                return "error[E2S25]: non-exhaustive Bool match; missing patterns `true`, `false` at byte " +
                to_text(match_start)
            }
            if !covered_true {
                return "error[E2S25]: non-exhaustive Bool match; missing pattern `true` at byte " +
                to_text(match_start)
            }
            if !covered_false {
                return "error[E2S25]: non-exhaustive Bool match; missing pattern `false` at byte " +
                to_text(match_start)
            }
            emitted = emitted +
            "    {\n" +
            emit_condition_into(
                source,
                hir,
                value_start,
                value_end,
                "kofun_match_value",
                failure_result,
                "        "
            ) +
            "        (void)kofun_match_value;\n" +
            "        bool kofun_match_selected = false;\n" +
            dispatch +
            "    }\n"
            cursor = skip_trivia(source, token_end(source, arm_cursor))
            }
        } else if statement == "return" {
            let value_start = skip_trivia(source, token_end(source, cursor))
            if value_start < len(source) &&
               token_text(source, value_start) == "}" {
                emitted = emitted + "    return 0;\n"
                cursor = value_start
            } else if value_control(token_text(source, value_start)) {
                let value_check = validate_value_control(source, value_start)
                if starts_with(value_check, "error[") {
                    return value_check
                }
                let value_end = value_end(source, value_start)
                emitted = emitted +
                "    {\n" +
                "        int64_t kofun_result = INT64_C(0);\n" +
                emit_value_into(
                    source,
                    hir,
                    value_start,
                    value_end,
                    "kofun_result",
                    failure_result
                )
                if is_main {
                    emitted = emitted +
                    "        return (int)kofun_result;\n"
                } else {
                    emitted = emitted + "        return kofun_result;\n"
                }
                emitted = emitted + "    }\n"
                cursor = skip_trivia(source, value_end)
            } else {
                let value_end = expression_end(source, value_start)
                if value_end < 0 {
                    return "error[E2S12]: invalid return expression at byte " +
                    to_text(value_start)
                }
                emitted = emitted +
                "    {\n" +
                "        int64_t kofun_result = " +
                emit_expression(source, hir, value_start, value_end) + ";\n" +
                "        if (kofun_failed) return " + failure_result + ";\n"
                if is_main {
                    emitted = emitted +
                    "        return (int)kofun_result;\n"
                } else {
                    emitted = emitted + "        return kofun_result;\n"
                }
                emitted = emitted +
                "    }\n"
                cursor = skip_trivia(source, value_end)
            }
            returned = true
        } else if token_kind(source, cursor) == "identifier" {
            let assignment_start = cursor
            let name = token_text(source, cursor)
            let equals = skip_trivia(source, token_end(source, cursor))
            if equals < len(source) && token_text(source, equals) == "=" {
                let binding_id = hir_use_binding_id(hir, assignment_start)
                if binding_id == "-1" || len(binding_id) == 0 {
                    return "error[E2S22]: unknown assignment target `" + name +
                    "` at byte " + to_text(assignment_start) +
                    "; declare it before assignment"
                }
                let mutability = hir_binding_field(hir, binding_id, 4)
                if mutability != "mutable" {
                    return "error[E2S22]: cannot assign to immutable binding `" +
                    name + "` at byte " + to_text(assignment_start) +
                    "; declare it with `let mut`"
                }
                let value_start = skip_trivia(source, token_end(source, equals))
                if value_control(token_text(source, value_start)) {
                    let value_check = validate_value_control(source, value_start)
                    if starts_with(value_check, "error[") {
                        return value_check
                    }
                    let value_end = value_end(source, value_start)
                    emitted = emitted +
                    "    {\n" +
                    "        int64_t kofun_replacement = INT64_C(0);\n" +
                    emit_value_into(
                        source,
                        hir,
                        value_start,
                        value_end,
                        "kofun_replacement",
                        failure_result
                    ) +
                    "        k_b" + binding_id + " = kofun_replacement;\n" +
                    "    }\n"
                    cursor = skip_trivia(source, value_end)
                } else {
                    let value_end = expression_end(source, value_start)
                    if value_end < 0 {
                        return "error[E2S12]: invalid Int expression at byte " +
                        to_text(value_start)
                    }
                    emitted = emitted +
                    "    {\n" +
                    "        int64_t kofun_replacement = " +
                    emit_expression(source, hir, value_start, value_end) + ";\n" +
                    "        if (kofun_failed) return " + failure_result + ";\n" +
                    "        k_b" + binding_id + " = kofun_replacement;\n" +
                    "    }\n"
                    cursor = skip_trivia(source, value_end)
                }
            } else {
                let value_end = expression_end(source, cursor)
                if value_end < 0 {
                    return "error[E2S12]: invalid expression statement at byte " +
                    to_text(cursor)
                }
                emitted = emitted + "    (void)" +
                emit_expression(source, hir, cursor, value_end) + ";\n" +
                "    if (kofun_failed) return " + failure_result + ";\n"
                cursor = skip_trivia(source, value_end)
            }
        } else {
            return "error[E2S10]: unsupported Core statement at byte " +
            to_text(cursor)
        }
    }
    if cursor >= len(source) || token_text(source, cursor) != "}" {
        return "error[E2S03]: missing function close"
    }
    if !returned && append_default {
        if !is_main {
            return "error[E2S19]: Core function may complete without returning Int at byte " +
            to_text(open)
        }
        emitted = emitted + "    return 0;\n"
    }
    return emitted
}

fn lower_c(source: Text, hir: Text) -> Text {
    let enum_use_check = validate_enum_uses(source, hir)
    if starts_with(enum_use_check, "error[") {
        return enum_use_check
    }
    let call_check = validate_core_calls(source)
    if starts_with(call_check, "error[") {
        return call_check
    }
    let mut prototypes = ""
    let mut bodies = ""
    let mut cursor = next_function_start(source, 0)
    let mut main_count = 0
    while cursor < len(source) {
        let name = function_name(source, cursor)
        if function_arity(source, name) == -2 {
            return "error[E2S16]: duplicate Core function `" + name +
            "` at byte " + to_text(cursor)
        }
        let is_main = name == "main"
        let arity = parameter_count(source, cursor)
        let parameters = core_parameters(source, hir, cursor)
        if starts_with(parameters, "error[") {
            return parameters
        }
        let mut c_parameters = parameters
        if len(c_parameters) == 0 {
            c_parameters = "void"
        }
        if is_main {
            main_count = main_count + 1
            if arity != 0 {
                return "error[E2S15]: Core main must have zero parameters"
            }
        } else {
            prototypes = prototypes + "static int64_t kofun_fn_" + name +
            "(" + c_parameters + ");\n"
        }
        let open = core_body_open(source, hir, cursor, is_main)
        if open < 0 {
            return "error[E2S15]: Core function `" + name +
            "` requires Int parameters and an Int return"
        }
        let body = lower_body(source, hir, open, is_main, true, open)
        if starts_with(body, "error[") {
            return body
        }
        if is_main {
            bodies = bodies + "int main(void) {\n" +
            "    (void)kofun_failed;\n" +
            "    (void)kofun_add;\n" +
            "    (void)kofun_sub;\n" +
            "    (void)kofun_mul;\n" +
            "    (void)kofun_neg;\n" +
            "    (void)kofun_floor_div;\n" +
            "    (void)kofun_floor_mod;\n" +
            body + "}\n"
        } else {
            bodies = bodies + "static int64_t kofun_fn_" + name +
            "(" + c_parameters + ") {\n" + body + "}\n"
        }
        cursor = next_function_start(source, function_end(source, cursor))
    }
    if main_count != 1 {
        return "error[E2S15]: C11 Core requires exactly one `fn main()`"
    }
    return "/* Generated by the Kofun-written Stage 2 Core lowerer. */\n" +
    "#include <inttypes.h>\n" +
    "#include <stdbool.h>\n" +
    "#include <stdint.h>\n" +
    "#include <stdio.h>\n\n" +
    "static bool kofun_failed;\n" +
    "static inline void kofun_error(const char *message) {\n" +
    "    if (!kofun_failed) { fputs(message, stderr); fputc('\\n', stderr); }\n" +
    "    kofun_failed = true;\n" +
    "}\n" +
    "static inline int64_t kofun_add(int64_t a, int64_t b) {\n" +
    "    int64_t r; if (__builtin_add_overflow(a, b, &r)) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `+`\"); return 0;\n" +
    "    } return r;\n" +
    "}\n" +
    "static inline int64_t kofun_sub(int64_t a, int64_t b) {\n" +
    "    int64_t r; if (__builtin_sub_overflow(a, b, &r)) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `-`\"); return 0;\n" +
    "    } return r;\n" +
    "}\n" +
    "static inline int64_t kofun_mul(int64_t a, int64_t b) {\n" +
    "    int64_t r; if (__builtin_mul_overflow(a, b, &r)) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `*`\"); return 0;\n" +
    "    } return r;\n" +
    "}\n" +
    "static inline int64_t kofun_neg(int64_t value) {\n" +
    "    if (value == INT64_MIN) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in unary operator `-`\"); return 0;\n" +
    "    } return -value;\n" +
    "}\n" +
    "static inline int64_t kofun_floor_div(int64_t a, int64_t b) {\n" +
    "    if (b == 0) {\n" +
    "        kofun_error(\"error[R010]: operator `//` failed: division by zero\"); return 0;\n" +
    "    }\n" +
    "    if (a == INT64_MIN && b == -1) {\n" +
    "        kofun_error(\"error[R010]: integer overflow in operator `//`\"); return 0;\n" +
    "    }\n" +
    "    int64_t q = a / b; int64_t r = a % b;\n" +
    "    if (r != 0 && ((r < 0) != (b < 0))) { --q; }\n" +
    "    return q;\n" +
    "}\n" +
    "static inline int64_t kofun_floor_mod(int64_t a, int64_t b) {\n" +
    "    if (b == 0) {\n" +
    "        kofun_error(\"error[R010]: operator `%` failed: division by zero\"); return 0;\n" +
    "    }\n" +
    "    if (a == INT64_MIN && b == -1) return 0;\n" +
    "    int64_t r = a % b;\n" +
    "    if (r != 0 && ((r < 0) != (b < 0))) { r += b; }\n" +
    "    return r;\n" +
    "}\n\n" + prototypes + "\n" + bodies
}

fn emit_kofun(source: Text, ir: Text) -> Text {
    if starts_with(ir, "error[") {
        return ""
    }
    return source
}

fn unsupported_lowering_error(diagnostic: Text) -> Bool {
    return starts_with(
        diagnostic,
        "error[E2S10]: unsupported Core statement"
    ) || starts_with(
        diagnostic,
        "error[E2S24]: general pattern syntax is parsed "
    )
}

fn compile_file(
    input_path: Text,
    output_path: Text,
    ir_path: Text,
    tokens_path: Text
) -> Int {
    let source = read_text(input_path)
    let tokens = lex(source)
    if starts_with(tokens, "error[") {
        print(tokens)
        return 1
    }
    let ir = parse_program(source)
    if starts_with(ir, "error[") {
        print(ir)
        return 1
    }
    write_text(tokens_path, tokens)
    write_text(ir_path, ir)
    if ends_with(output_path, ".c") {
        let pattern_check = validate_executable_patterns(source)
        if starts_with(pattern_check, "error[") {
            print(pattern_check)
            if unsupported_lowering_error(pattern_check) {
                return 3
            }
            return 1
        }
        let hir = build_scope_hir(source)
        if starts_with(hir, "error[") {
            print(hir)
            let ownership = borrowed_collection_check(source)
            if ownership == "ok" {
                return 3
            }
            return 1
        }
        let c_source = lower_c(source, hir)
        if starts_with(c_source, "error[") {
            print(c_source)
            if unsupported_lowering_error(c_source) {
                return 3
            }
            return 1
        }
        write_text(ir_path, ir + hir)
        write_text(output_path, c_source)
    } else {
        write_text(output_path, emit_kofun(source, ir))
    }
    print(output_path)
    return 0
}

fn parse_patterns_file(input_path: Text, output_path: Text) -> Bool {
    let source = read_text(input_path)
    let tokens = lex(source)
    if starts_with(tokens, "error[") {
        print(tokens)
        return false
    }
    let tree = parse_pattern_trees(source)
    write_text(output_path, tree)
    let pattern_error = pattern_first_error(tree)
    if len(pattern_error) > 0 {
        print(pattern_error)
        return false
    }
    return true
}

fn emit_scope_hir_file(input_path: Text, output_path: Text) -> Bool {
    if input_path == output_path {
        print("error[E2S35]: scope-HIR input and output must be distinct")
        return false
    }
    let source = read_text(input_path)
    let tokens = lex(source)
    if starts_with(tokens, "error[") {
        print(tokens)
        return false
    }
    let tree = parse_pattern_trees(source)
    let pattern_error = pattern_first_error(tree)
    if len(pattern_error) > 0 {
        print(pattern_error)
        return false
    }
    let hir = build_scope_hir_mode(source, true)
    if starts_with(hir, "error[") {
        print(hir)
        return false
    }
    write_text(output_path, hir)
    return true
}

fn check_ownership_file(input_path: Text) -> Bool {
    let source = read_text(input_path)
    let tokens = lex(source)
    if starts_with(tokens, "error[") {
        print(tokens)
        return false
    }
    let ir = parse_program(source)
    if starts_with(ir, "error[") {
        print(ir)
        return false
    }
    let result = borrowed_collection_check(source)
    if starts_with(result, "error[") {
        print(result)
        return false
    }
    return true
}

fn main() -> Int {
    let arguments = args()
    if len(arguments) == 5 && arguments[0] == "--compile-outcome" {
        return compile_file(
            arguments[1],
            arguments[2],
            arguments[3],
            arguments[4]
        )
    }
    if len(arguments) == 2 && arguments[0] == "--check-ownership" {
        if !check_ownership_file(arguments[1]) {
            return 1
        }
        return 0
    }
    if len(arguments) == 3 && arguments[0] == "--parse-patterns" {
        if !parse_patterns_file(arguments[1], arguments[2]) {
            return 1
        }
        return 0
    }
    if len(arguments) == 3 && arguments[0] == "--emit-scope-hir" {
        if !emit_scope_hir_file(arguments[1], arguments[2]) {
            return 1
        }
        return 0
    }
    if len(arguments) != 4 {
        print(
            "usage: kofun-stage2 INPUT.kofun OUTPUT.kofun OUTPUT.ir OUTPUT.tokens\n" +
            "       kofun-stage2 --compile-outcome INPUT.kofun OUTPUT.c OUTPUT.ir OUTPUT.tokens\n" +
            "       kofun-stage2 --check-ownership INPUT.kofun\n" +
            "       kofun-stage2 --parse-patterns INPUT.kofun OUTPUT.patterns\n" +
            "       kofun-stage2 --emit-scope-hir INPUT.kofun OUTPUT.scope-hir"
        )
        return 2
    }
    if compile_file(
        arguments[0],
        arguments[1],
        arguments[2],
        arguments[3]
    ) != 0 {
        return 1
    }
    return 0
}
